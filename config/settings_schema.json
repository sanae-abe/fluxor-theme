[
  {
    "name": "theme_info",
    "theme_name": "Fluxor v2",
    "theme_version": "1.0.0",
    "theme_author": "Fluxor",
    "theme_documentation_url": "https://fluxor.jp/",
    "theme_support_url": "https://fluxor.jp/"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#fafaf9"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#1c1917"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent (brand)",
        "default": "#0f766e"
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo width (px)",
        "min": 60,
        "max": 300,
        "step": 10,
        "default": 120
      }
    ]
  },
  {
    "name": "セールスケジュール",
    "settings": [
      {
        "type": "checkbox",
        "id": "sale_enabled",
        "label": "スケジュールセールを有効にする",
        "default": false
      },
      {
        "type": "text",
        "id": "sale_start",
        "label": "開始日時（日本時間）",
        "info": "例: 2024-04-01 00:00（YYYY-MM-DD HH:MM 形式）"
      },
      {
        "type": "text",
        "id": "sale_end",
        "label": "終了日時（日本時間）",
        "info": "例: 2024-04-30 23:59（YYYY-MM-DD HH:MM 形式）"
      },
      {
        "type": "range",
        "id": "sale_discount_percent",
        "label": "ディスカウント率",
        "min": 1,
        "max": 90,
        "step": 1,
        "default": 20,
        "unit": "%"
      },
      {
        "type": "select",
        "id": "sale_target",
        "label": "対象商品",
        "options": [
          { "value": "all", "label": "全商品" },
          { "value": "tag", "label": "特定タグ" },
          { "value": "collection", "label": "特定コレクション" }
        ],
        "default": "all"
      },
      {
        "type": "text",
        "id": "sale_target_tags",
        "label": "対象タグ",
        "info": "カンマ区切りで複数指定（例: sale-item,new-arrival）。対象を「特定タグ」にした場合のみ有効。"
      },
      {
        "type": "text",
        "id": "sale_target_collections",
        "label": "対象コレクション（ハンドル）",
        "info": "カンマ区切りで複数指定（例: skincare,hair-care）。対象を「特定コレクション」にした場合のみ有効。"
      },
      {
        "type": "header",
        "content": "除外設定"
      },
      {
        "type": "text",
        "id": "sale_exclude_handles",
        "label": "除外商品（ハンドル）",
        "info": "カンマ区切りで複数指定（例: product-a,limited-item）"
      },
      {
        "type": "text",
        "id": "sale_exclude_tags",
        "label": "除外タグ",
        "info": "カンマ区切りで複数指定（例: sale-excluded,no-discount）"
      },
      {
        "type": "header",
        "content": "バナー"
      },
      {
        "type": "checkbox",
        "id": "sale_banner_show",
        "label": "セールバナーを表示する",
        "default": true
      },
      {
        "type": "text",
        "id": "sale_banner_text",
        "label": "バナーテキスト",
        "default": "セール開催中！"
      }
    ]
  },
  {
    "name": "個人輸入代行・免責事項",
    "settings": [
      {
        "type": "textarea",
        "id": "import_notice_declaration",
        "label": "①本サービスについて（個人輸入代行の宣言）"
      },
      {
        "type": "textarea",
        "id": "import_notice_liability",
        "label": "②免責事項（薬機法・自己責任）"
      },
      {
        "type": "textarea",
        "id": "import_notice_resale",
        "label": "③転売禁止"
      },
      {
        "type": "textarea",
        "id": "import_notice_customs",
        "label": "④関税・輸入数量制限"
      },
      {
        "type": "textarea",
        "id": "import_notice_returns",
        "label": "⑤キャンセル・返品・交換"
      },
      {
        "type": "header",
        "content": "フッター表示用"
      },
      {
        "type": "textarea",
        "id": "import_notice_footer",
        "label": "フッター用注意事項（要約版）"
      },
      {
        "type": "textarea",
        "id": "disclaimer",
        "label": "各用語の定義（薬機法等）"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "url",
        "id": "social_instagram_link",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "social_twitter_link",
        "label": "X (Twitter) URL"
      },
      {
        "type": "url",
        "id": "social_tiktok_link",
        "label": "TikTok URL"
      }
    ]
  }
]
