<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- unless page_title contains shop.name %} — {{ shop.name }}{%- endunless -%}
    </title>

    {{ content_for_header }}

    {%- comment %} Google Fonts: Outfit + Noto Sans JP {%- endcomment %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500&family=Outfit:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    >

    {%- comment %} Theme CSS (Tailwind) {%- endcomment %}
    {{ 'app.css' | asset_url | stylesheet_tag }}

    {%- comment %} 管理画面カラー設定を CSS 変数に注入（app.css のデフォルト値を上書き） {%- endcomment %}
    {%- style -%}
      :root {
        --color-background: {{ settings.color_background }};
        --color-text:       {{ settings.color_text }};
        --color-accent:     {{ settings.color_accent }};
      }
    {%- endstyle -%}

    <style>
      body {
        font-family: 'Outfit', 'Noto Sans JP', sans-serif;
        -webkit-font-smoothing: antialiased;
      }
    </style>

    {%- comment %} セールスケジュール設定をグローバル JS 変数として公開 {%- endcomment %}
    <script>
      window.fluxorSale = {
        enabled:    {{ settings.sale_enabled | json }},
        start:      {{ settings.sale_start | default: '' | json }},
        end:        {{ settings.sale_end | default: '' | json }},
        discount:   {{ settings.sale_discount_percent | default: 20 | json }},
        bannerShow: {{ settings.sale_banner_show | json }},
        bannerText: {{ settings.sale_banner_text | default: 'セール開催中！' | json }}
      };
    </script>
  </head>

  <body class="bg-stone-50 text-stone-900">
    <a class="sr-only focus:not-sr-only" href="#MainContent">
      {{ 'general.accessibility.skip_to_content' | t }}
    </a>

    {%- section 'announcement-bar' -%}
    {%- section 'header' -%}
    {%- section 'cart-drawer' -%}

    <main id="MainContent" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- section 'footer' -%}

    {%- comment %} Alpine.js {%- endcomment %}
    <script src="{{ 'app.js' | asset_url }}" defer></script>
  </body>
</html>
