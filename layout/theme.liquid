<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    <title>
      {{ page_title | escape }}
      {%- unless page_title contains shop.name %} — {{ shop.name | escape }}{%- endunless -%}
    </title>

    <link rel="canonical" href="{{ canonical_url }}">

    {%- if template contains 'customers' -%}
      <meta name="robots" content="noindex,nofollow">
    {%- endif -%}

    {%- comment %} OGP & Twitter Card {%- endcomment -%}
    {%- liquid
      assign og_title = page_title
      unless og_title contains shop.name
        assign og_title = og_title | append: ' — ' | append: shop.name
      endunless
      assign og_description = page_description | default: shop.description
      if template.name == 'product'
        assign og_type  = 'product'
        assign og_image = product.featured_image
      elsif template.name == 'article'
        assign og_type  = 'article'
        assign og_image = article.image
      elsif template.name == 'collection'
        assign og_type  = 'website'
        assign og_image = collection.image
      else
        assign og_type  = 'website'
        assign og_image = nil
      endif
    -%}
    <meta property="og:site_name" content="{{ shop.name | escape }}">
    <meta property="og:type"      content="{{ og_type }}">
    <meta property="og:title"     content="{{ og_title | escape }}">
    {%- if og_description != blank -%}
      <meta property="og:description" content="{{ og_description | escape }}">
    {%- endif -%}
    <meta property="og:url" content="{{ canonical_url }}">
    {%- if og_image != blank -%}
      <meta property="og:image"       content="{{ og_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
    {%- endif -%}

    <meta name="twitter:card"  content="summary_large_image">
    <meta name="twitter:title" content="{{ og_title | escape }}">
    {%- if og_description != blank -%}
      <meta name="twitter:description" content="{{ og_description | escape }}">
    {%- endif -%}
    {%- if og_image != blank -%}
      <meta name="twitter:image" content="{{ og_image | image_url: width: 1200 }}">
    {%- endif -%}

    {{ content_for_header }}

    {%- comment %} Favicon {%- endcomment -%}
    <link rel="icon" type="image/svg+xml" href="{{ 'favicon.svg' | asset_url }}">
    <link rel="icon" type="image/png" sizes="96x96" href="{{ 'favicon-96x96.png' | asset_url }}">
    <link rel="shortcut icon" href="{{ 'favicon.ico' | asset_url }}">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ 'apple-touch-icon.png' | asset_url }}">
    <link rel="manifest" href="{{ 'site.webmanifest' | asset_url }}">

    {%- comment %} Google Fonts: 非同期ロードで描画ブロックを防ぐ {%- endcomment %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Zen+Old+Mincho:wght@500&&family=Noto+Sans+JP:wght@400;500;600&family=Outfit:wght@400;500;600&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    >
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Zen+Old+Mincho:wght@500&&family=Noto+Sans+JP:wght@400;500;600&family=Outfit:wght@400;500;600&display=swap"
        rel="stylesheet"
      >
    </noscript>

    {%- comment %} Theme CSS (Tailwind) {%- endcomment %}
    {{ 'app.css' | asset_url | stylesheet_tag }}

    {%- comment %} 管理画面カラー設定を CSS 変数に注入（app.css のデフォルト値を上書き） {%- endcomment %}
    {%- style -%}
      :root {
        --color-background: {{ settings.color_background }};
        --color-text:       {{ settings.color_text }};
        --color-accent:     {{ settings.color_accent }};
      }
    {%- endstyle -%}

    {%- comment %} セールスケジュール設定をグローバル JS 変数として公開 {%- endcomment %}
    <script>
      window.fluxorSale = {
        enabled:    {{ settings.sale_enabled | json }},
        start:      {{ settings.sale_start | default: '' | json }},
        end:        {{ settings.sale_end | default: '' | json }},
        discount:   {{ settings.sale_discount_percent | default: 20 | json }},
        bannerShow: {{ settings.sale_banner_show | json }},
        bannerText: {{ settings.sale_banner_text | default: 'セール開催中！' | json }}
      };
    </script>
  </head>

  <body class="bg-stone-50 text-stone-900">
    <a class="sr-only focus:not-sr-only skip-link" href="#MainContent">
      {{ 'general.accessibility.skip_to_content' | t }}
    </a>

    {%- section 'announcement-bar' -%}
    {%- section 'header' -%}
    {%- section 'cart-drawer' -%}

    {%- unless template.name == 'index' -%}
      {%- assign main_class = 'pt-14 md:pt-20' -%}
    {%- endunless -%}
    <main id="MainContent" tabindex="-1" class="{{ main_class }}">
      {{ content_for_layout }}
    </main>

    {%- section 'footer' -%}

    {%- comment %} Alpine.js {%- endcomment %}
    <script src="{{ 'app.js' | asset_url }}" defer></script>
  </body>
</html>
