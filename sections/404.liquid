<section class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4 md:px-10 py-10 md:py-[60px] overflow-hidden">
  <p class="text-8xl text-stone-200 mb-6 select-none" aria-hidden="true">404</p>
  <h1 class="text-2xl mb-4">{{ section.settings.heading }}</h1>
  <p class="text-sm text-stone-400 mb-10">{{ section.settings.subheading }}</p>
  {%- render 'button',
    label: section.settings.button_label,
    url: routes.root_url,
    variant: 'outline',
    icon_right: 'arrow-right',
  -%}
</section>

{%- schema %}
{
  "name": "404",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "ページが見つかりません"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "サブテキスト",
      "default": "お探しのページは存在しないか、移動した可能性があります。"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "ボタンラベル",
      "default": "トップへ戻る"
    }
  ],
  "presets": [
    {
      "name": "404"
    }
  ]
}
{%- endschema %}
