{{ 'about-method-fluxor.css' | asset_url | stylesheet_tag }}

<div class="about-method-fluxor color-{{ section.settings.color_scheme }} gradient">
  <div class="about-method-fluxor__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="about-method-fluxor__heading">
        {{- section.settings.heading | escape -}}
      </h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="about-method-fluxor__description">
        {{- section.settings.description | escape -}}
      </p>
    {%- endif -%}

    <div class="about-method-fluxor__grid">
      {%- for block in section.blocks -%}
        <div class="about-method-fluxor__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div class="about-method-fluxor__icon">
              <img
                src="{{ block.settings.icon | image_url: width: 64 }}"
                alt="{{ block.settings.title | escape }}"
                width="32"
                height="32"
                loading="lazy"
              />
            </div>
          {%- endif -%}

          {%- if block.settings.title != blank -%}
            <h3 class="about-method-fluxor__title">
              {{- block.settings.title | escape -}}
            </h3>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p class="about-method-fluxor__text">
              {{- block.settings.description | escape -}}
            </p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About Method - Fluxor",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "私たちの調査方法"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "説明文",
      "default": "専門家ではないからこそ、一般消費者目線で疑問を調べ尽くします。"
    }
  ],
  "blocks": [
    {
      "type": "method",
      "name": "調査方法",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "アイコン画像"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "論文検索"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "説明",
          "default": "PubMed、皮膚科学会誌を調査"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Method - Fluxor",
      "blocks": [
        {
          "type": "method",
          "settings": {
            "title": "論文検索",
            "description": "PubMed、皮膚科学会誌を調査"
          }
        },
        {
          "type": "method",
          "settings": {
            "title": "成分分析",
            "description": "INCI表示と濃度を確認"
          }
        },
        {
          "type": "method",
          "settings": {
            "title": "製造元調査",
            "description": "OEM先、品質管理体制を調査"
          }
        },
        {
          "type": "method",
          "settings": {
            "title": "口コミ分析",
            "description": "実際のユーザー評価を収集"
          }
        }
      ]
    }
  ]
}
{% endschema %}