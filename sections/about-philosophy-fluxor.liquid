{{ 'about-philosophy-fluxor.css' | asset_url | stylesheet_tag }}

<div class="about-philosophy-fluxor color-{{ section.settings.color_scheme }} gradient">
  <div class="about-philosophy-fluxor__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="about-philosophy-fluxor__heading">
        {{- section.settings.heading | escape -}}
      </h2>
    {%- endif -%}

    {%- if section.settings.tagline != blank -%}
      <p class="about-philosophy-fluxor__tagline">
        {{- section.settings.tagline | escape -}}
      </p>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="about-philosophy-fluxor__description">
        {{- section.settings.description | escape | newline_to_br -}}
      </p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "About Philosophy - Fluxor",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "なぜFluxorなのか"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "タグライン",
      "default": "「流行より、エビデンス。」"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "説明文",
      "default": "私たちは販売数やマーケティングではなく、科学的根拠と実際の使用感に基づいて商品を選んでいます。時間をかけて調査し、納得したもののみを紹介します。"
    }
  ],
  "presets": [
    {
      "name": "About Philosophy - Fluxor"
    }
  ]
}
{% endschema %}