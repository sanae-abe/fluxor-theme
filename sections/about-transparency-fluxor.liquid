{{ 'about-transparency-fluxor.css' | asset_url | stylesheet_tag }}

<div class="about-transparency-fluxor color-{{ section.settings.color_scheme }} gradient">
  <div class="about-transparency-fluxor__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="about-transparency-fluxor__heading">
        {{- section.settings.heading | escape -}}
      </h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="about-transparency-fluxor__description">
        {{- section.settings.description | escape -}}
      </p>
    {%- endif -%}

    <div class="about-transparency-fluxor__grid">
      {%- for block in section.blocks -%}
        <div class="about-transparency-fluxor__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div class="about-transparency-fluxor__icon">
              <img
                src="{{ block.settings.icon | image_url: width: 64 }}"
                alt="{{ block.settings.title | escape }}"
                width="32"
                height="32"
                loading="lazy"
              />
            </div>
          {%- endif -%}

          {%- if block.settings.title != blank -%}
            <h3 class="about-transparency-fluxor__title">
              {{- block.settings.title | escape -}}
            </h3>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p class="about-transparency-fluxor__text">
              {{- block.settings.description | escape -}}
            </p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Transparency - Fluxor",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "透明性へのこだわり"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "説明文",
      "default": "調査過程も、分からないことも、正直にお伝えします。"
    }
  ],
  "blocks": [
    {
      "type": "transparency_point",
      "name": "透明性ポイント",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "アイコン画像"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "誇張しません"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "説明",
          "default": "「奇跡の効果」は謳いません"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Transparency - Fluxor",
      "blocks": [
        {
          "type": "transparency_point",
          "settings": {
            "title": "誇張しません",
            "description": "「奇跡の効果」は謳いません"
          }
        },
        {
          "type": "transparency_point",
          "settings": {
            "title": "隠しません",
            "description": "製造元、成分濃度を可能な限り公開"
          }
        },
        {
          "type": "transparency_point",
          "settings": {
            "title": "推測しません",
            "description": "確認できないことは「分からない」と言います"
          }
        }
      ]
    }
  ]
}
{% endschema %}