{%- comment %} About — 透明性セクション {%- endcomment -%}

<section class="w-full px-4 md:px-10 py-10 md:py-[60px]">
  <div class="w-full max-w-3xl mx-auto flex flex-col gap-8">

    <div class="flex flex-col gap-6 md:gap-8 items-center">
      {%- if section.settings.heading != blank -%}
        <h2 class="text-2xl md:text-3xl font-medium text-stone-900 text-center">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
      {%- if section.settings.paragraph != blank -%}
        <p class="text-sm md:text-base text-stone-900 text-center">
          {{ section.settings.paragraph }}
        </p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="flex flex-col gap-6">
        {%- for block in section.blocks -%}
          <div class="bg-stone-100 p-6 flex flex-col md:flex-row gap-4 md:gap-6 items-center text-center md:text-left" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <div class="shrink-0">
                {%- render 'icon',
                  icon: block.settings.icon,
                  class: 'w-10 h-10 text-stone-900',
                  stroke_width: 1
                -%}
              </div>
            {%- endif -%}
            <div class="flex flex-col gap-2">
              {%- if block.settings.title != blank -%}
                <p class="text-base font-medium text-stone-900">
                  {{ block.settings.title }}
                </p>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="text-sm leading-relaxed text-stone-900">
                  {{ block.settings.description }}
                </p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{%- schema %}
{
  "name": "About — 透明性",
  "blocks": [
    {
      "type": "item",
      "name": "透明性アイテム",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "アイコン名",
          "info": "利用可能: check, shield, info, sparkle, gem, leaf など"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "説明文"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "透明性へのこだわり"
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "サブテキスト",
      "default": "調査したこと、確かめたこと、そして分からなかったことも、ありのままにお伝えします。"
    }
  ],
  "presets": [
    {
      "name": "About — 透明性",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "check",
            "title": "正直な言葉で",
            "description": "効果を誇張せず、実際の使用感や特徴を率直にお伝えします。"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "shield",
            "title": "知りうる限りオープンに",
            "description": "ブランド情報や成分について、把握できる範囲で透明性を持ってご紹介します"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "info",
            "title": "分からないことは、分からないと",
            "description": "確認できないことは、臆せずそのままお伝えします。"
          }
        }
      ]
    }
  ]
}
{%- endschema -%}
