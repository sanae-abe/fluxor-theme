{%- assign is_dark = false -%}
{%- if section.settings.color_scheme == 'bg-stone-950' or section.settings.background_image != blank -%}
  {%- assign is_dark = true -%}
{%- endif -%}

{%- if is_dark -%}
  {%- assign text_color = 'text-stone-50' -%}
  {%- assign btn_color = 'light' -%}
  {%- assign particle_color = '#a8a29e' -%}
{%- else -%}
  {%- assign text_color = 'text-stone-900' -%}
  {%- assign btn_color = 'dark' -%}
  {%- assign particle_color = '#79716b' -%}
{%- endif -%}

{%- assign heading_class = 'about-heading font-medium leading-tight palt tracking-wider ' | append: text_color -%}
{%- if section.settings.tagline != blank -%}
  {%- assign heading_size = 'text-3xl md:text-5xl' -%}
{%- else -%}
  {%- assign heading_size = 'text-3xl md:text-4xl' -%}
{%- endif -%}

<section class="relative {{ section.settings.color_scheme }} px-4 md:px-10 py-10 md:py-20 overflow-hidden border-b border-stone-200">

  {%- if section.settings.background_image != blank -%}
    <div class="absolute inset-0">
      <img
        src="{{ section.settings.background_image | image_url: width: 2400, format: 'webp' }}"
        alt=""
        class="w-full h-full object-cover"
        loading="lazy"
        width="2400"
        height="1600"
        aria-hidden="true"
      >
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
  {%- endif -%}

  {%- if section.settings.enable_particles -%}
    <div
      id="about-ptcl-{{ section.id }}"
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
    ></div>

    <script>
      (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const containerId = 'about-ptcl-{{ section.id }}';
        const color = '{{ particle_color }}';

        function initParticles() {
          tsParticles.load(containerId, {
            fullScreen: { enable: false },
            fpsLimit: 60,
            particles: {
              color: { value: color },
              links: {
                color: color,
                distance: 160,
                enable: true,
                opacity: 0.2,
                width: 1
              },
              move: {
                enable: true,
                outModes: { default: 'bounce' },
                random: true,
                speed: 1,
                straight: false
              },
              number: {
                density: { enable: true, area: 800 },
                value: 100
              },
              opacity: { value: { min: 0.3, max: 0.7 } },
              shape: { type: 'circle' },
              size: { value: { min: 1, max: 3 } }
            },
            detectRetina: true
          });
        }

        function load() {
          if (window.tsParticles) {
            initParticles();
          } else {
            const s = document.createElement('script');
            s.src = 'https://cdn.jsdelivr.net/npm/tsparticles-slim@2.12.0/tsparticles.slim.bundle.min.js';
            s.onload = initParticles;
            document.head.appendChild(s);
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', load);
        } else {
          load();
        }
      })();
    </script>
  {%- endif -%}

  <div class="relative max-w-screen-xl mx-auto flex items-center justify-center">
    <div class="w-full flex flex-col items-center gap-6 md:gap-10 text-center">

      <div class="flex flex-col gap-6 w-full">
        {%- if section.settings.heading != blank -%}
          <h2 class="{{ heading_size }} {{ heading_class }}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if section.settings.tagline != blank -%}
          <p class="text-lg md:text-3xl {{ heading_class }}">
            {{ section.settings.tagline }}
          </p>
        {%- endif -%}
      </div>

      {%- if section.settings.paragraph != blank -%}
        <div class="text-sm md:text-base leading-relaxed {{ text_color }} opacity-80 [&_p]:mb-0">
          {{ section.settings.paragraph }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
        {%- render 'button',
          label: section.settings.button_label,
          url: section.settings.button_url,
          variant: 'outline',
          color: btn_color,
          icon_right: 'arrow-right',
          class: 'w-full md:w-auto'
        -%}
      {%- endif -%}

    </div>
  </div>

</section>

{%- schema %}
{
  "name": "About",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "カラースキーム",
      "options": [
        { "value": "bg-stone-50", "label": "ライト（デフォルト）" },
        { "value": "bg-stone-100", "label": "ライトグレー" },
        { "value": "bg-stone-200", "label": "グレー" },
        { "value": "bg-stone-950", "label": "ダーク" }
      ],
      "default": "bg-stone-50"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "背景画像"
    },
    {
      "type": "checkbox",
      "id": "enable_particles",
      "label": "パーティクルアニメーションを表示",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し（Heading）",
      "default": "Curated with Conviction"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "タグライン",
      "default": "信頼できるものだけを。"
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "本文（Paragraph）",
      "default": "<p>成分表を読み込み、ブランドの背景を調べ、実際に自分たちで使って確かめる。<br>その積み重ねから生まれた、Fluxorのスキンケアセレクション。</p>"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "ボタンのリンク先"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "ボタンテキスト",
      "default": "Fluxorについて"
    }
  ],
  "presets": [
    {
      "name": "About"
    }
  ]
}
{%- endschema -%}
