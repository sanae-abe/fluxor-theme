{%- comment %} ダーク判定：bg-stone-950 または背景画像あり {%- endcomment -%}
{%- assign is_dark = false -%}
{%- if section.settings.color_scheme == 'bg-stone-950' or section.settings.background_image != blank -%}
  {%- assign is_dark = true -%}
{%- endif -%}

{%- if is_dark -%}
  {%- assign text_color     = 'text-stone-50' -%}
  {%- assign btn_color      = 'light' -%}
  {%- assign particle_color = '#a8a29e' -%}
{%- else -%}
  {%- assign text_color     = 'text-stone-900' -%}
  {%- assign btn_color      = 'dark' -%}
  {%- assign particle_color = '#79716b' -%}
{%- endif -%}

{%- assign heading_base = 'about-heading leading-tight palt tracking-wider ' | append: text_color -%}
{%- assign heading_size = 'text-3xl md:text-4xl' -%}
{%- if section.settings.tagline != blank -%}
  {%- assign heading_size = 'text-3xl md:text-5xl' -%}
{%- endif -%}

<section class="relative {{ section.settings.color_scheme }} px-4 md:px-10 py-10 md:py-20 overflow-hidden border-b border-stone-200">

  {%- comment %} 背景画像 + オーバーレイ {%- endcomment %}
  {%- if section.settings.background_image != blank -%}
    <div class="absolute inset-0">
      <img
        src="{{ section.settings.background_image | image_url: width: 2400, format: 'webp' }}"
        alt=""
        class="w-full h-full object-cover"
        loading="lazy"
        width="2400"
        height="1600"
        aria-hidden="true"
      >
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
  {%- endif -%}

  {%- comment %} パーティクルアニメーション {%- endcomment %}
  {%- if section.settings.enable_particles -%}
    {%- assign ptcl_id = 'about-ptcl-' | append: section.id -%}
    {%- render 'particles', container_id: ptcl_id, color: particle_color -%}
  {%- endif -%}

  <div class="relative max-w-screen-xl mx-auto flex items-center justify-center">
    <div class="w-full flex flex-col items-center gap-6 md:gap-10 text-center">

      <div class="flex flex-col gap-6 w-full">
        {%- if section.settings.heading != blank -%}
          <h2 class="{{ heading_size }} {{ heading_base }}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if section.settings.tagline != blank -%}
          <p class="text-lg md:text-3xl {{ heading_base }}">
            {{ section.settings.tagline }}
          </p>
        {%- endif -%}
      </div>

      {%- if section.settings.paragraph != blank -%}
        <div class="text-sm md:text-base leading-relaxed {{ text_color }} opacity-80 [&_p]:mb-0">
          {{ section.settings.paragraph }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
        {%- render 'button',
          label: section.settings.button_label,
          url: section.settings.button_url,
          variant: 'outline',
          color: btn_color,
          icon_right: 'arrow-right',
          class: 'w-full md:w-auto'
        -%}
      {%- endif -%}

    </div>
  </div>

</section>

{%- schema %}
{
  "name": "About",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "カラースキーム",
      "options": [
        { "value": "bg-stone-50",  "label": "ライト（デフォルト）" },
        { "value": "bg-stone-100", "label": "ライトグレー" },
        { "value": "bg-stone-200", "label": "グレー" },
        { "value": "bg-stone-950", "label": "ダーク" }
      ],
      "default": "bg-stone-50"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "背景画像"
    },
    {
      "type": "checkbox",
      "id": "enable_particles",
      "label": "パーティクルアニメーションを表示",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し（Heading）",
      "default": "Curated with Conviction"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "タグライン",
      "default": "信頼できるものだけを。"
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "本文（Paragraph）",
      "default": "<p>成分表を読み込み、ブランドの背景を調べ、実際に自分たちで使って確かめる。<br>その積み重ねから生まれた、Fluxorのスキンケアセレクション。</p>"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "ボタンのリンク先"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "ボタンテキスト",
      "default": "Fluxorについて"
    }
  ],
  "presets": [
    {
      "name": "About"
    }
  ]
}
{%- endschema -%}
