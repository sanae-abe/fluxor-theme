{%- liquid
  assign carousel_count = 0
  for block in section.blocks
    if block.settings.text != blank
      assign carousel_count = carousel_count | plus: 1
    endif
  endfor
  if settings.sale_enabled and settings.sale_banner_show
    assign carousel_count = carousel_count | plus: 1
  endif
-%}

{%- if carousel_count > 0 -%}
  <div
    id="AnnouncementBar"
    class="bg-stone-950 text-stone-50 overflow-hidden py-2"
    {%- if settings.sale_enabled %} x-data x-show="$store.sale.isActive()"{%- endif %}
  >
    <div class="announcement-marquee flex whitespace-nowrap text-xs md:text-sm tracking-wide">
      {%- comment %} 1セット目 {%- endcomment %}
      {%- for block in section.blocks -%}
        {%- if block.settings.text != blank -%}
          <span class="inline-flex items-center px-10" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
          <span class="opacity-30 select-none" aria-hidden="true">·</span>
        {%- endif -%}
      {%- endfor -%}
      {%- if settings.sale_enabled and settings.sale_banner_show -%}
        <span class="inline-flex items-center gap-2 px-10">
          <span>{{ settings.sale_banner_text }} {{ settings.sale_discount_percent }}% OFF</span>
          {%- render 'sale-countdown' -%}
        </span>
        <span class="opacity-30 select-none" aria-hidden="true">·</span>
      {%- endif -%}

      {%- comment %} 2セット目（シームレスループ用） {%- endcomment %}
      {%- for block in section.blocks -%}
        {%- if block.settings.text != blank -%}
          <span class="inline-flex items-center px-10" aria-hidden="true">{{ block.settings.text }}</span>
          <span class="opacity-30 select-none" aria-hidden="true">·</span>
        {%- endif -%}
      {%- endfor -%}
      {%- if settings.sale_enabled and settings.sale_banner_show -%}
        <span class="inline-flex items-center gap-2 px-10" aria-hidden="true">
          <span>{{ settings.sale_banner_text }} {{ settings.sale_discount_percent }}% OFF</span>
        </span>
        <span class="opacity-30 select-none" aria-hidden="true">·</span>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "text",
      "name": "テキスト",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "テキスト"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        {
          "type": "text",
          "settings": {
            "text": "オープン記念セール開催中🎉4月30日まで全商品20%オフ！（一部商品を除く）"
          }
        }
      ]
    }
  ]
}
{% endschema %}
