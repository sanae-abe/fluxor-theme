{%- liquid
  assign has_content = false
  if section.blocks.size > 0
    assign has_content = true
  endif
  if settings.sale_enabled and settings.sale_banner_show
    assign has_content = true
  endif
-%}

{%- if has_content -%}
  <div
    id="AnnouncementBar"
    class="bg-stone-950 text-stone-50 min-h-9 flex items-center justify-center py-2 px-4 md:px-10"
    {%- if settings.sale_enabled %}x-data x-show="$store.sale.isActive()"{%- endif %}
  >
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-1 text-xs md:text-sm tracking-wide">
      {%- for block in section.blocks -%}
        {%- if block.settings.text != blank -%}
          <p {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
        {%- endif -%}
      {%- endfor -%}
      {%- if settings.sale_enabled and settings.sale_banner_show -%}
        <div class="flex items-center gap-2">
          {{ settings.sale_banner_text }} {{ settings.sale_discount_percent }}% OFF
          {%- render 'sale-countdown' -%}
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "text",
      "name": "テキスト",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "テキスト"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        {
          "type": "text",
          "settings": {
            "text": "オープン記念セール開催中🎉4月30日まで全商品20%オフ！（一部商品を除く）"
          }
        }
      ]
    }
  ]
}
{% endschema %}
