{%- if section.settings.text != blank -%}
  <div
    id="AnnouncementBar"
    class="bg-stone-950 text-stone-50 min-h-9 flex items-center justify-center py-2 px-4 md:px-10"
    {%- if settings.sale_enabled %}x-data x-show="$store.sale.isActive()"{%- endif %}
  >
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-1 text-xs md:text-sm tracking-wide">
      <p>{{ section.settings.text }}</p>
      {%- if settings.sale_enabled and settings.sale_banner_show -%}
        <div class="flex items-center gap-2">
          <span class="opacity-80">{{ settings.sale_banner_text }} {{ settings.sale_discount_percent }}% OFF</span>
          {%- render 'sale-countdown' -%}
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "テキスト",
      "default": "オープン記念セール開催中🎉4月30日まで全商品20%オフ！（一部商品を除く）"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
