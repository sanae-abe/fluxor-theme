{%- liquid
  assign carousel_count = 0
  for block in section.blocks
    if block.settings.text != blank
      assign carousel_count = carousel_count | plus: 1
    endif
  endfor
  if settings.sale_enabled and settings.sale_banner_show
    assign carousel_count = carousel_count | plus: 1
  endif
-%}

{%- if settings.sale_enabled and settings.sale_banner_show or carousel_count > 0 -%}
  <div
    id="AnnouncementBar"
    class="bg-stone-950 text-stone-50 py-2 overflow-hidden"
    x-data="{}"
    x-init="$nextTick(() => { $store.ui.announcementHeight = $el.offsetHeight; new ResizeObserver(() => { $store.ui.announcementHeight = $el.offsetHeight }).observe($el) })"
    x-cloak
    {%- if settings.sale_enabled %} :class="{ 'hidden': !$store.sale.isActive() }"{%- endif %}
  >
    <div class="marquee-track text-xs font-medium tracking-wide">

      {%- comment %} 1回目（実コンテンツ・Shopify属性付き） {%- endcomment -%}
      <span class="marquee-content">
        {%- if settings.sale_enabled and settings.sale_banner_show -%}
          <span class="inline-flex items-center gap-2 px-10">
            {{ settings.sale_banner_text }}
            {%- render 'sale-countdown' -%}
          </span>
          <span class="px-2 opacity-30" aria-hidden="true">·</span>
        {%- endif -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.text != blank -%}
            <span class="px-10" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
            <span class="px-2 opacity-30" aria-hidden="true">·</span>
          {%- endif -%}
        {%- endfor -%}
      </span>

      {%- comment %} 2回目（シームレスループ用・スクリーンリーダー非表示） {%- endcomment -%}
      <span class="marquee-content" aria-hidden="true">
        {%- if settings.sale_enabled and settings.sale_banner_show -%}
          <span class="inline-flex items-center gap-2 px-10">
            {{ settings.sale_banner_text }}
            {%- render 'sale-countdown' -%}
          </span>
          <span class="px-2 opacity-30">·</span>
        {%- endif -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.text != blank -%}
            <span class="px-10">{{ block.settings.text }}</span>
            <span class="px-2 opacity-30">·</span>
          {%- endif -%}
        {%- endfor -%}
      </span>

    </div>
  </div>
{%- endif -%}

{%- schema %}
{
  "name": "Announcement Bar",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "text",
      "name": "テキスト",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "テキスト"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        {
          "type": "text",
          "settings": {
            "text": "海外で人気のスキンケア商品をピックアップ！"
          }
        }
      ]
    }
  ]
}
{%- endschema -%}
