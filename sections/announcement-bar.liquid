{%- liquid
  assign carousel_count = 0
  for block in section.blocks
    if block.settings.text != blank
      assign carousel_count = carousel_count | plus: 1
    endif
  endfor
  if settings.sale_enabled and settings.sale_banner_show
    assign carousel_count = carousel_count | plus: 1
  endif
-%}

{%- if settings.sale_enabled and settings.sale_banner_show or carousel_count > 0 -%}
  <div
    id="AnnouncementBar"
    class="bg-stone-950 text-stone-50 py-2"
    x-data="announcementBar({{ carousel_count }})"
    x-init="$nextTick(() => { $store.ui.announcementHeight = $el.offsetHeight; new ResizeObserver(() => { $store.ui.announcementHeight = $el.offsetHeight }).observe($el) })"
    x-cloak
    {%- if settings.sale_enabled %} :class="{ 'hidden': !$store.sale.isActive() }"{%- endif %}
  >
    <div class="relative flex items-center justify-center min-h-[28px] px-10 md:px-16 text-xs md:text-sm tracking-wide">

      {%- if carousel_count > 1 -%}
        <button
          type="button"
          @click="prev()"
          class="announcement-nav-btn absolute left-2 md:left-4 p-1 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-stone-50 rounded"
          aria-label="前のメッセージ"
        >
          {%- render 'icon', icon: 'chevron-left', class: 'w-4 h-4', stroke_width: 2 -%}
        </button>
      {%- endif -%}

      <div class="text-center">
        {%- assign item_index = 0 -%}
        {%- if settings.sale_enabled and settings.sale_banner_show -%}
          <span
            class="inline-flex items-center gap-2"
            :class="{{ item_index }} === current ? '' : 'hidden'"
          >
            <span>{{ settings.sale_banner_text }}</span>
            {%- render 'sale-countdown' -%}
          </span>
          {%- assign item_index = item_index | plus: 1 -%}
        {%- endif -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.text != blank -%}
            <span
              class="inline-flex items-center"
              :class="{{ item_index }} === current ? '' : 'hidden'"
              {{ block.shopify_attributes }}
            >{{ block.settings.text }}</span>
            {%- assign item_index = item_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if carousel_count > 1 -%}
        <button
          type="button"
          @click="next()"
          class="announcement-nav-btn absolute right-2 md:right-4 p-1 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-stone-50 rounded"
          aria-label="次のメッセージ"
        >
          {%- render 'icon', icon: 'chevron-right', class: 'w-4 h-4', stroke_width: 2 -%}
        </button>
      {%- endif -%}

    </div>
  </div>
{%- endif -%}

{%- schema %}
{
  "name": "Announcement Bar",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "text",
      "name": "テキスト",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "テキスト"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        {
          "type": "text",
          "settings": {
            "text": "海外で人気のスキンケア製品をピックアップ！"
          }
        }
      ]
    }
  ]
}
{%- endschema %}
