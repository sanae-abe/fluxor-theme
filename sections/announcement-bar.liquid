{%- liquid
  assign carousel_count = 0
  for block in section.blocks
    if block.settings.text != blank
      assign carousel_count = carousel_count | plus: 1
    endif
  endfor
  if settings.sale_enabled and settings.sale_banner_show
    assign carousel_count = carousel_count | plus: 1
  endif
-%}

{%- if carousel_count > 0 -%}
  <div
    id="AnnouncementBar"
    class="bg-stone-950 text-stone-50 flex items-center justify-center py-2 px-4 md:px-10"
    x-data="{
      current: 0,
      total: {{ carousel_count }},
      timer: null,
      init() {
        if (this.total > 1) {
          this.startTimer();
        }
      },
      startTimer() {
        this.timer = setInterval(() => { this.next(); }, 4000);
      },
      resetTimer() {
        clearInterval(this.timer);
        this.startTimer();
      },
      prev() {
        this.current = (this.current - 1 + this.total) % this.total;
        this.resetTimer();
      },
      next() {
        this.current = (this.current + 1) % this.total;
      }
    }"
    {%- if settings.sale_enabled %}x-show="$store.sale.isActive()"{%- endif %}
  >
    {%- comment %} 前へ {%- endcomment %}
    <button
      type="button"
      x-show="total > 1"
      @click="prev()"
      class="flex-shrink-0 p-1 opacity-60 hover:opacity-100 transition-opacity"
      aria-label="前へ"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <div class="relative flex-1 min-h-5 text-xs md:text-sm tracking-wide mx-2">
      {%- assign carousel_idx = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.text != blank -%}
          <p
            class="absolute inset-x-0 text-center"
            x-show="current === {{ carousel_idx }}"
            x-transition:enter="transition-opacity duration-500"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition-opacity duration-500"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            {{ block.shopify_attributes }}
          >{{ block.settings.text }}</p>
          {%- assign carousel_idx = carousel_idx | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if settings.sale_enabled and settings.sale_banner_show -%}
        <div
          class="absolute inset-x-0 flex items-center justify-center gap-2"
          x-show="current === {{ carousel_idx }}"
          x-transition:enter="transition-opacity duration-500"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition-opacity duration-500"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
        >
          <span>{{ settings.sale_banner_text }} {{ settings.sale_discount_percent }}% OFF</span>
          {%- render 'sale-countdown' -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment %} 次へ {%- endcomment %}
    <button
      type="button"
      x-show="total > 1"
      @click="next(); resetTimer();"
      class="flex-shrink-0 p-1 opacity-60 hover:opacity-100 transition-opacity"
      aria-label="次へ"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "text",
      "name": "テキスト",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "テキスト"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        {
          "type": "text",
          "settings": {
            "text": "オープン記念セール開催中🎉4月30日まで全商品20%オフ！（一部商品を除く）"
          }
        }
      ]
    }
  ]
}
{% endschema %}
