{%- assign col = collections[section.settings.collection] -%}
{%- assign products_limit = section.settings.products_to_show | default: 3 -%}
{%- assign link_url = section.settings.link_url | default: col.url -%}

<section class="bg-stone-100 px-10 py-[60px]">
  <div class="max-w-screen-xl mx-auto flex flex-col gap-10">

    <!-- ヘッダー -->
    {%- if section.settings.show_view_all -%}
      <div class="flex items-end justify-between gap-6">
        <div class="flex flex-col gap-4">
          {%- if section.settings.heading != blank -%}
            <h2 class="text-[42px] font-semibold leading-tight text-stone-900">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <p class="text-lg leading-tight text-stone-900 opacity-70">
              {{ section.settings.subheading }}
            </p>
          {%- endif -%}
        </div>
        {%- if section.settings.link_label != blank and link_url != blank -%}
          <a
            href="{{ link_url }}"
            class="flex-shrink-0 flex items-center gap-2 text-base leading-6 text-stone-900 hover:opacity-60 transition-opacity duration-200"
          >
            <span>{{ section.settings.link_label }}</span>
            {%- render 'icon', icon: 'arrow-right', class: 'w-6 h-6 flex-shrink-0' -%}
          </a>
        {%- endif -%}
      </div>
    {%- else -%}
      <div class="flex flex-col gap-4 items-center text-center">
        {%- if section.settings.heading != blank -%}
          <h2 class="text-[42px] font-semibold leading-tight text-stone-900">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="text-lg leading-tight text-stone-900 opacity-70">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- 製品グリッド（3カラム） -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {%- if col != blank -%}
        {%- for product in col.products limit: products_limit -%}
          {%- if section.settings.show_rank -%}
            {%- assign card_rank = forloop.index -%}
          {%- else -%}
            {%- assign card_rank = '' -%}
          {%- endif -%}
          {%- render 'card-product-3col', product: product, rank: card_rank -%}
        {%- else -%}
          <p class="col-span-3 text-stone-400">コレクションに商品がありません。</p>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_limit) -%}
          <div class="bg-stone-50 rounded-2xl overflow-hidden">
            <div class="w-full aspect-square bg-stone-200 animate-pulse"></div>
            <div class="p-4 flex flex-col gap-2">
              <div class="h-3 w-1/3 bg-stone-200 rounded animate-pulse"></div>
              <div class="h-5 w-2/3 bg-stone-200 rounded animate-pulse"></div>
              <div class="h-4 w-1/4 bg-stone-200 rounded animate-pulse"></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "ベストセラー",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "ベストセラー"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "サブテキスト",
      "default": "多くのお客様に選ばれている、実力派スキンケア製品"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "表示するコレクション"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "「すべて見る」リンクを表示",
      "default": false
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "「すべて見る」リンク先（省略時はコレクションURL）"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "「すべて見る」テキスト",
      "default": "すべて見る"
    },
    {
      "type": "checkbox",
      "id": "show_rank",
      "label": "ランクバッジを表示",
      "default": true
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "表示件数",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "ベストセラー"
    }
  ]
}
{% endschema %}
