{%- assign col = collections[section.settings.collection] -%}
{%- assign products_limit = section.settings.products_to_show | default: 3 -%}
{%- assign link_url = section.settings.link_url | default: col.url -%}

<section class="bg-stone-100 px-4 md:px-10 py-10 md:py-[60px]">
  <div class="max-w-screen-xl mx-auto flex flex-col gap-6 md:gap-10">

    {%- comment %} ヘッダー {%- endcomment %}
    {%- assign header_align = 'center' -%}
    {%- if section.settings.show_view_all -%}{%- assign header_align = 'left' -%}{%- endif -%}
    {%- render 'section-header',
      heading: section.settings.heading,
      subheading: section.settings.subheading,
      link_url: link_url,
      link_label: section.settings.link_label,
      align: header_align
    -%}

    {%- comment %} 製品グリッド（3カラム） {%- endcomment %}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign product = all_products[block.settings.product] -%}
          {%- if product != blank -%}
            {%- if section.settings.show_rank -%}
              {%- assign card_rank = forloop.index -%}
            {%- else -%}
              {%- assign card_rank = '' -%}
            {%- endif -%}
            {%- render 'card-product-3col', product: product, rank: card_rank -%}
          {%- endif -%}
        {%- endfor -%}
      {%- elsif col != blank -%}
        {%- for product in col.products limit: products_limit -%}
          {%- if section.settings.show_rank -%}
            {%- assign card_rank = forloop.index -%}
          {%- else -%}
            {%- assign card_rank = '' -%}
          {%- endif -%}
          {%- render 'card-product-3col', product: product, rank: card_rank -%}
        {%- else -%}
          <p class="col-span-3 text-stone-400">コレクションに商品がありません。</p>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_limit) -%}
          <div class="bg-stone-50 overflow-hidden">
            <div class="w-full aspect-square bg-stone-200 animate-pulse"></div>
            <div class="p-4 flex flex-col gap-2">
              <div class="h-3 w-1/3 bg-stone-200 rounded animate-pulse"></div>
              <div class="h-5 w-2/3 bg-stone-200 rounded animate-pulse"></div>
              <div class="h-4 w-1/4 bg-stone-200 rounded animate-pulse"></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "ベストセラー",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "ベストセラー"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "サブテキスト",
      "default": "多くのお客様に選ばれている、実力派スキンケア製品"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "表示するコレクション"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "「すべて見る」リンクを表示",
      "default": false
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "「すべて見る」リンク先（省略時はコレクションURL）"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "「すべて見る」テキスト",
      "default": "すべて見る"
    },
    {
      "type": "checkbox",
      "id": "show_rank",
      "label": "ランクバッジを表示",
      "default": true
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "表示件数",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "product_item",
      "name": "商品",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "商品"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "ベストセラー"
    }
  ]
}
{% endschema %}
