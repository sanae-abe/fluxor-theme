{{ 'brand-story-fluxor.css' | asset_url | stylesheet_tag }}

<div
  class="brand-story-fluxor color-{{ section.settings.color_scheme }} gradient{% if section.settings.text_align == 'left' %} brand-story-fluxor--align-left{% endif %}"
>
  <div class="brand-story-fluxor__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="brand-story-fluxor__heading">
        {{- section.settings.heading | escape -}}
      </h2>
    {%- endif -%}

    {%- if section.settings.body != blank -%}
      <p class="brand-story-fluxor__body">
        {{- section.settings.body | escape -}}
      </p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_link | default: '#' }}"
        class="brand-story-fluxor__cta"
      >
        {{- section.settings.button_label | escape -}}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Brand Story - Fluxor",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "テキスト配置",
      "options": [
        { "value": "center", "label": "中央" },
        { "value": "left", "label": "左" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "コンテンツ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "私たちは成分を読む。"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "本文",
      "default": "皮膚科学に基づいた製品だけを、\n世界中からセレクトしています。\n流行より、エビデンス。"
    },
    {
      "type": "header",
      "content": "ボタン（任意）"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "ボタンテキスト"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "ボタンリンク"
    }
  ],
  "presets": [
    {
      "name": "Brand Story - Fluxor"
    }
  ]
}
{% endschema %}
