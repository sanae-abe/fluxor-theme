{%- comment %}
  sections/bundle-page.liquid

  バンドルビルダー専用商品ページセクション
  使用: templates/product.bundle.json

  左カラム: 商品画像ギャラリー（バンドル商品のメディア）
  右カラム: タイトル・価格・固定商品・候補選択・カートボタン
{%- endcomment %}

{%- liquid
  assign fp = section.settings.fixed_product | default: product
  assign has_fixed = fp != blank
  assign fp_variant = fp.selected_or_first_available_variant

  assign has_candidates = false
  for i in (1..8)
    assign key = 'product_' | append: i
    if section.settings[key] != blank
      assign has_candidates = true
      break
    endif
  endfor
-%}

{%- comment %} 候補商品 JSON 配列 {%- endcomment %}
{%- assign json_parts = '' -%}
{%- for i in (1..8) -%}
  {%- assign key = 'product_' | append: i -%}
  {%- assign p = section.settings[key] -%}
  {%- if p != blank -%}
    {%- assign pv = p.selected_or_first_available_variant -%}
    {%- if json_parts != '' -%}{%- assign json_parts = json_parts | append: ',' -%}{%- endif -%}
    {%- capture entry -%}{"id":{{ p.id }},"title":{{ p.title | json }},"price":{{ pv.price }},"variantId":{{ pv.id }},"image":{{ p.featured_image | image_url: width: 400 | json }}}{%- endcapture -%}
    {%- assign json_parts = json_parts | append: entry -%}
  {%- endif -%}
{%- endfor -%}

<script type="application/json" id="bundle-page-data-{{ section.id }}">
{
  "fixed": {
    "id": {{ fp.id | default: 0 }},
    "title": {{ fp.title | default: '' | json }},
    "price": {{ fp_variant.price | default: 0 }},
    "variantId": {{ fp_variant.id | default: 0 }},
    "image": {{ fp.featured_image | image_url: width: 400 | json }}
  },
  "candidates": [{{ json_parts }}],
  "discountType": {{ section.settings.discount_type | default: 'percentage' | json }},
  "discountValue": {{ section.settings.discount_value | default: 10 }}
}
</script>

<script>
  function bundlePage(dataId) {
    const raw = JSON.parse(document.getElementById(dataId).textContent)
    return {
      fixedProduct: raw.fixed,
      candidates: raw.candidates,
      discountType: raw.discountType,
      discountValue: raw.discountValue,
      selected: [],
      adding: false,
      added: false,

      isSelected(product) {
        return this.selected.some(s => s.id === product.id)
      },

      toggleSelect(product) {
        if (this.isSelected(product)) {
          this.selected = this.selected.filter(s => s.id !== product.id)
        } else if (this.selected.length < 2) {
          this.selected = [...this.selected, product]
        }
      },

      get bundleTotal() {
        return this.fixedProduct.price + this.selected.reduce((sum, p) => sum + p.price, 0)
      },

      get discountAmount() {
        if (this.selected.length < 2) return 0
        if (this.discountType === 'percentage') {
          return Math.round(this.bundleTotal * this.discountValue / 100)
        }
        return this.discountValue
      },

      get finalPrice() {
        return this.bundleTotal - this.discountAmount
      },

      formatMoney(price) {
        return new Intl.NumberFormat('ja-JP', {
          style: 'currency',
          currency: 'JPY',
          maximumFractionDigits: 0,
        }).format(price)
      },

      async addBundle() {
        if (this.selected.length < 2 || this.adding) return
        this.adding = true
        try {
          const items = [
            { id: this.fixedProduct.variantId, quantity: 1 },
            { id: this.selected[0].variantId, quantity: 1 },
            { id: this.selected[1].variantId, quantity: 1 },
          ]
          const res = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items }),
          })
          if (!res.ok) throw new Error('Cart add failed')
          await this.$store.cart.fetch()
          this.$store.cart.open = true
          this.added = true
          setTimeout(() => { this.added = false }, 3000)
        } catch (err) {
          console.error('[bundlePage.addBundle]', err)
        } finally {
          this.adding = false
        }
      },
    }
  }
</script>

{%- comment %} パンくずリスト {%- endcomment %}
{%- liquid
  if collection != blank
    assign _bc2_name = collection.title
    assign _bc2_url  = shop.url | append: collection.url
    assign _bc3_name = product.title
    assign _bc3_url  = shop.url | append: product.url
  else
    assign _bc2_name = product.title
    assign _bc2_url  = shop.url | append: product.url
  endif
-%}
<div class="px-4 md:px-10 pt-5 md:pt-10">
  {%- if collection != blank -%}
    {%- render 'breadcrumb',
      item1_label: 'ホーム',
      item1_url: routes.root_url,
      item2_label: collection.title,
      item2_url: collection.url,
      item3_label: product.title,
      max_w: 'max-w-screen-xl'
    -%}
  {%- else -%}
    {%- render 'breadcrumb',
      item1_label: 'ホーム',
      item1_url: routes.root_url,
      item2_label: product.title,
      max_w: 'max-w-screen-xl'
    -%}
  {%- endif -%}
</div>

<div x-data="bundlePage('bundle-page-data-{{ section.id }}')">
<section
  class="bg-stone-50 px-4 md:px-10 pt-5 pb-10 md:pt-5 md:pb-[60px]"
>
  <div class="max-w-screen-xl mx-auto flex flex-col lg:flex-row gap-6 md:gap-10 items-start">

    {%- comment %}--- 左カラム: 画像ギャラリー ---{%- endcomment %}
    <div class="w-full lg:flex-1 flex flex-col gap-4">
      <div class="aspect-square overflow-hidden bg-stone-100 [transform:translateZ(0)]">
        {%- if product.featured_image -%}
          <img
            src="{{ product.featured_image | image_url: width: 800 }}"
            alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            class="w-full h-full object-cover"
            width="800"
            height="800"
          >
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="grid grid-cols-4 gap-3">
          {%- for image in product.images limit: 8 -%}
            <div class="aspect-square overflow-hidden bg-stone-100 [transform:translateZ(0)]">
              <img
                src="{{ image | image_url: width: 300 }}"
                alt="{{ image.alt | escape | default: product.title | escape }}"
                class="w-full h-full object-cover"
                loading="lazy"
                width="300"
                height="300"
              >
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment %}--- 右カラム: バンドル情報 ---{%- endcomment %}
    <div class="w-full lg:flex-1 flex flex-col gap-5 lg:sticky lg:top-20 min-w-0">

      {%- comment %} タイトル {%- endcomment %}
      <div class="flex flex-col gap-2">
        {%- if product.vendor != blank -%}
          <p class="text-sm text-stone-500 leading-tight">{{ product.vendor }}</p>
        {%- endif -%}
        <h1 class="text-2xl md:text-3xl font-medium leading-tight text-stone-900 palt tracking-wider">{{ product.title }}</h1>
        {%- if product.description != blank -%}
          <p class="text-sm text-stone-500 leading-relaxed">{{ product.description | strip_html | truncate: 120 }}</p>
        {%- endif -%}
      </div>

      {%- comment %} 価格（動的） {%- endcomment %}
      <div class="flex items-end gap-2 flex-wrap">
        <span class="text-3xl font-semibold text-stone-900 leading-none" x-text="selected.length === 2 ? formatMoney(finalPrice) : formatMoney(fixedProduct.price + candidates.reduce((s,p) => s, 0))">
          {{- fp_variant.price | money -}}
        </span>
        <span class="text-sm text-stone-900 leading-tight">(税込・送料込)</span>
        <span
          class="text-sm font-medium bundle-discount-text"
          x-show="selected.length === 2 && discountAmount > 0"
          x-cloak
        >
          <span x-show="discountType === 'percentage'" x-text="discountValue + '%オフ'"></span>
          <span x-show="discountType !== 'percentage'" x-text="'¥' + discountValue + '引き'"></span>
        </span>
      </div>

      <hr class="border-stone-200">

      {%- comment %} 固定商品 {%- endcomment %}
      <div>
        <p class="text-xs font-medium text-stone-400 uppercase tracking-wider mb-2">固定商品</p>
        <div class="flex items-center gap-3 p-3 rounded-xl border border-stone-200 bg-white">
          {%- if fp.featured_image -%}
            <img
              src="{{ fp.featured_image | image_url: width: 96 }}"
              alt="{{ fp.featured_image.alt | escape }}"
              width="64" height="64"
              class="w-16 h-16 object-cover rounded-lg flex-shrink-0"
              loading="lazy"
            >
          {%- endif -%}
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-stone-900 line-clamp-2">{{ fp.title | escape }}</p>
            <p class="text-sm text-stone-500 mt-0.5">{{ fp_variant.price | money_without_trailing_zeros }}</p>
          </div>
          <div class="bundle-fixed-check flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center">
            <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
        </div>
      </div>

      {%- comment %} 候補商品選択 {%- endcomment %}
      <div>
        <div class="flex items-center justify-between mb-3">
          <p class="text-xs font-medium text-stone-400 uppercase tracking-wider">好きな2点を選んでください</p>
          <span class="text-xs font-semibold bundle-count" :class="selected.length === 2 ? 'is-complete' : ''">
            <span x-text="selected.length"></span>/2
          </span>
        </div>
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-2 xl:grid-cols-3">
          <template x-for="product in candidates" :key="product.id">
            <button
              type="button"
              class="bundle-candidate relative rounded-xl border p-2.5 text-left"
              :class="{
                'is-selected': isSelected(product),
                'is-disabled': !isSelected(product) && selected.length >= 2
              }"
              :disabled="!isSelected(product) && selected.length >= 2"
              @click="toggleSelect(product)"
            >
              <img
                :src="product.image"
                :alt="product.title"
                width="200" height="200"
                class="w-full aspect-square object-cover rounded-lg mb-2"
              >
              <p class="text-xs font-medium text-stone-900 line-clamp-2 leading-tight mb-1" x-text="product.title"></p>
              <p class="text-xs text-stone-500" x-text="formatMoney(product.price)"></p>
              <div class="bundle-check-dot absolute top-2 right-2 w-5 h-5 rounded-full border-2 flex items-center justify-center">
                <svg x-show="isSelected(product)" class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
            </button>
          </template>
        </div>
      </div>

      {%- comment %} 価格サマリー（2点選択後） {%- endcomment %}
      <div x-show="selected.length === 2" x-cloak class="bg-stone-100 rounded-xl p-4 space-y-1.5 text-sm">
        <div class="flex justify-between text-stone-500">
          <span>通常価格合計</span>
          <span x-text="formatMoney(bundleTotal)"></span>
        </div>
        <template x-if="discountAmount > 0">
          <div class="flex justify-between font-medium bundle-discount-text">
            <span>
              <span x-show="discountType === 'percentage'">セット割引（<span x-text="discountValue"></span>%オフ）</span>
              <span x-show="discountType !== 'percentage'">セット割引</span>
            </span>
            <span>－<span x-text="formatMoney(discountAmount)"></span></span>
          </div>
        </template>
        <div class="flex justify-between font-semibold text-stone-900 text-base pt-1.5 border-t border-stone-200">
          <span>セット価格</span>
          <span x-text="formatMoney(finalPrice)"></span>
        </div>
      </div>

      {%- comment %} カートに追加ボタン {%- endcomment %}
      <div class="flex flex-col gap-3">
        <button
          type="button"
          class="btn-add-to-cart w-full bg-stone-950 border-2 border-stone-950 text-white flex items-center justify-center min-h-[48px] px-4 py-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-900 focus-visible:ring-offset-2"
          :class="(selected.length < 2 || adding) ? 'opacity-50 cursor-not-allowed' : ''"
          :disabled="selected.length < 2 || adding"
          @click="addBundle"
        >
          <span class="text-base font-bold leading-tight" x-show="!adding && !added">
            <span x-show="selected.length < 2">あと<span x-text="2 - selected.length"></span>点選んでください</span>
            <span x-show="selected.length === 2" x-cloak>3点セットをカートに追加</span>
          </span>
          <span class="text-base font-bold leading-tight" x-show="adding" x-cloak>追加中…</span>
          <span class="text-base font-bold leading-tight" x-show="added" x-cloak>✓ カートに追加しました</span>
        </button>

        <p class="flex gap-2 text-sm justify-end">
          {%- render 'icon', icon: 'van', class: 'w-5 h-5 flex-shrink-0 stroke-1.5' -%}
          国際配送のため、通常ご注文から約14〜21営業日でお届けいたします。
        </p>
      </div>

    </div>
  </div>
</section>
</div>

{% schema %}
{
  "name": "バンドルページ",
  "settings": [
    {
      "type": "product",
      "id": "fixed_product",
      "label": "固定商品",
      "info": "空欄の場合、このページの商品が固定商品になります"
    },
    {
      "type": "header",
      "content": "候補商品（最大8商品）"
    },
    { "type": "product", "id": "product_1", "label": "候補商品 1" },
    { "type": "product", "id": "product_2", "label": "候補商品 2" },
    { "type": "product", "id": "product_3", "label": "候補商品 3" },
    { "type": "product", "id": "product_4", "label": "候補商品 4" },
    { "type": "product", "id": "product_5", "label": "候補商品 5" },
    { "type": "product", "id": "product_6", "label": "候補商品 6" },
    { "type": "product", "id": "product_7", "label": "候補商品 7" },
    { "type": "product", "id": "product_8", "label": "候補商品 8" },
    {
      "type": "header",
      "content": "割引設定"
    },
    {
      "type": "select",
      "id": "discount_type",
      "label": "割引タイプ",
      "options": [
        { "value": "percentage", "label": "% 割引" },
        { "value": "fixed", "label": "固定額割引（円）" }
      ],
      "default": "percentage"
    },
    {
      "type": "number",
      "id": "discount_value",
      "label": "割引値",
      "default": 10,
      "info": "%割引なら「10」= 10%オフ。固定額なら「500」= ¥500引き"
    }
  ],
  "presets": [
    {
      "name": "バンドルページ"
    }
  ]
}
{% endschema %}
