{{ 'product-grid-fluxor.css' | asset_url | stylesheet_tag }}
{{ 'section-related-products.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .cart-complementary-products .product-grid-fluxor__grid > li {
    min-width: 0;
  }

  product-recommendations {
    display: block;
  }
{%- endstyle -%}

{%- if cart.item_count > 0 -%}
  {%- assign first_product_id = cart.items.first.product_id -%}
  <div class="color-{{ section.settings.color_scheme }} gradient">
    <product-recommendations
      class="cart-complementary-products page-width section-{{ section.id }}-padding isolate"
      data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.products_to_show }}&intent=complementary"
      data-section-id="{{ section.id }}"
      data-product-id="{{ first_product_id }}"
    >
      {%- if recommendations.performed and recommendations.products_count > 0 -%}
        <h2 class="related-products__heading inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
        <ul class="product-grid-fluxor__grid" role="list">
          {%- for recommendation in recommendations.products -%}
            <li>
              {%- render 'card-product-fluxor',
                card_product: recommendation,
                lazy_load: true,
                show_vendor: section.settings.show_vendor
              -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </product-recommendations>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "おすすめセット商品",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "カート内の商品に合わせてSearch & Discoveryで設定した補完商品を表示します。商品ごとに補完商品を設定してください。"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "あわせてお試しください",
      "label": "見出し"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "見出しサイズ"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "表示商品数"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "カラースキーム",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "ブランド名を表示"
    },
    {
      "type": "header",
      "content": "余白"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "上の余白",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "下の余白",
      "default": 36
    }
  ]
}
{% endschema %}
