{%- comment %} カートドロワー（Alpine.js $store.cart で制御） {%- endcomment %}
<div
  x-data
  x-show="$store.cart.open"
  x-transition:enter="transition-transform duration-300 ease-out"
  x-transition:enter-start="translate-x-full"
  x-transition:enter-end="translate-x-0"
  x-transition:leave="transition-transform duration-200 ease-in"
  x-transition:leave-start="translate-x-0"
  x-transition:leave-end="translate-x-full"
  class="fixed inset-y-0 right-0 z-50 w-full max-w-sm bg-stone-50 shadow-2xl flex flex-col"
  role="dialog"
  aria-modal="true"
  aria-label="カート"
  @keydown.escape.window="$store.cart.open = false"
  style="display: none;"
>
  {%- comment %} ヘッダー {%- endcomment %}
  <div class="flex items-center justify-between px-6 py-5 border-b border-stone-200">
    <h2 class="text-sm tracking-widest uppercase">
      カート
      <span
        :class="$store.cart.itemCount > 0 ? '' : 'hidden'"
        class="text-stone-500"
      >(<span x-text="$store.cart.itemCount"></span>)</span>
    </h2>
    <button
      type="button"
      @click="$store.cart.open = false"
      class="text-stone-500 hover:text-stone-900 transition-colors"
      aria-label="カートを閉じる"
    >
      {%- render 'icon', icon: 'x', class: 'w-5 h-5' -%}
    </button>
  </div>

  {%- comment %} カートが空 {%- endcomment %}
  <div
    :class="$store.cart.items.length > 0 ? 'hidden' : ''"
    class="flex-1 flex flex-col items-center justify-center gap-4 px-6 text-center"
  >
    {%- render 'icon', icon: 'cart', class: 'w-12 h-12 text-stone-300' -%}
    <p class="text-sm text-stone-500">カートに商品がありません</p>
    <a
      href="{{ routes.all_products_collection_url }}"
      @click="$store.cart.open = false"
      class="inline-block border border-stone-900 px-6 py-2.5 text-sm hover:bg-stone-900 hover:text-stone-50 transition-colors duration-200"
    >
      ショッピングを続ける
    </a>
  </div>

  {%- comment %} カートアイテム一覧 {%- endcomment %}
  <div
    :class="$store.cart.items.length > 0 ? '' : 'hidden'"
    class="flex-1 overflow-y-auto px-6 py-4 space-y-6"
  >
    <template x-for="item in $store.cart.items" :key="item.key">
      <div class="flex gap-4">
        <a :href="item.url" @click="$store.cart.open = false" class="flex-shrink-0 w-20 h-20 bg-stone-200 overflow-hidden">
          <img
            :src="item.featured_image ? item.featured_image.url : ''"
            :alt="item.title"
            class="w-full h-full object-cover"
            loading="lazy"
          >
        </a>

        <div class="flex-1 min-w-0">
          <p class="text-xs text-stone-500 mb-0.5" x-text="item.vendor"></p>
          <a :href="item.url" @click="$store.cart.open = false" class="text-sm font-medium leading-snug" x-text="item.product_title"></a>
          <p
            :class="item.variant_title && item.variant_title !== 'Default Title' ? '' : 'hidden'"
            class="text-xs text-stone-500 mt-0.5"
            x-text="item.variant_title"
          ></p>

          <div class="flex items-center justify-between mt-2">
            <p class="text-sm">
              <span x-text="$store.cart.formatPrice(item.final_line_price)"></span>
              <span class="text-xs text-stone-500">（税込）</span>
            </p>
            <button
              type="button"
              @click="$store.cart.remove(item.key)"
              class="text-xs text-stone-500 hover:text-stone-900 underline transition-colors"
            >
              削除
            </button>
          </div>
        </div>
      </div>
    </template>
  </div>

  {%- comment %} フッター {%- endcomment %}
  <div
    :class="$store.cart.items.length > 0 ? '' : 'hidden'"
    class="border-t border-stone-200 px-6 py-5 space-y-4"
  >
    <div class="flex justify-between text-sm">
      <span class="text-stone-500">小計</span>
      <span x-text="$store.cart.formatPrice($store.cart.totalPrice())"></span>
    </div>
    {%- render 'button',
      label: '購入手続きへ',
      url: routes.cart_url,
      full_width: true
    -%}
  </div>
</div>

{%- comment %} オーバーレイ {%- endcomment %}
<div
  x-data
  x-show="$store.cart.open"
  x-transition:enter="transition-opacity duration-300"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition-opacity duration-200"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  class="fixed inset-0 z-40 bg-stone-950/40 backdrop-blur-sm"
  @click="$store.cart.open = false"
  style="display: none;"
></div>

{% schema %}
{
  "name": "Cart Drawer"
}
{% endschema %}
