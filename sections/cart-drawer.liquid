{%- comment %} カートドロワー（Alpine.js $store.cart で制御） {%- endcomment -%}
<div
  x-data="{}"
  x-init="$watch('$store.cart.open', val => { if (val) $nextTick(() => $refs.closeBtn.focus()) })"
  x-show="$store.cart.open"
  x-cloak
  x-trap="$store.cart.open"
  x-transition:enter="transition-transform duration-300 ease-out"
  x-transition:enter-start="translate-x-full"
  x-transition:enter-end="translate-x-0"
  x-transition:leave="transition-transform duration-200 ease-in"
  x-transition:leave-start="translate-x-0"
  x-transition:leave-end="translate-x-full"
  class="fixed inset-y-0 right-0 z-50 w-full max-w-sm bg-stone-50 shadow-2xl flex flex-col"
  role="dialog"
  aria-modal="true"
  aria-label="カート"
  @keydown.escape.window="$store.cart.open = false"
>
  {%- comment %} ヘッダー {%- endcomment -%}
  <div class="flex items-center justify-between px-6 py-5 border-b border-stone-200">
    <h2 class="text-base font-semibold tracking-widest uppercase">
      カート
      <span
        :class="$store.cart.itemCount > 0 ? '' : 'hidden'"
        class="text-stone-500"
      >(<span x-text="$store.cart.itemCount"></span>)</span>
    </h2>
    <button
      x-ref="closeBtn"
      type="button"
      @click="$store.cart.open = false"
      class="text-stone-500 hover:text-stone-900 transition-colors"
      aria-label="カートを閉じる"
    >
      {%- render 'icon', icon: 'x', class: 'w-5 h-5' -%}
    </button>
  </div>

  {%- comment %} エラーバナー {%- endcomment -%}
  <div
    x-show="$store.cart.errored"
    x-cloak
    class="mx-4 mt-3 px-3 py-2.5 bg-red-50 border border-red-200 text-red-700 text-xs flex items-center justify-between gap-2"
    role="alert"
    aria-live="polite"
  >
    <span>エラーが発生しました。もう一度お試しください。</span>
    <button
      type="button"
      @click="$store.cart.errored = false"
      class="text-red-400 hover:text-red-700 flex-shrink-0"
      aria-label="エラーを閉じる"
    >
      {%- render 'icon', icon: 'x', class: 'w-3.5 h-3.5' -%}
    </button>
  </div>

  {%- comment %} カートが空 {%- endcomment -%}
  <div
    :class="$store.cart.items.length > 0 ? 'hidden' : ''"
    class="flex-1 flex flex-col items-center justify-center gap-4 px-6 text-center"
  >
    {%- render 'icon', icon: 'cart', class: 'w-12 h-12 text-stone-300' -%}
    <p class="text-sm text-stone-500">カートに商品がありません</p>
    <a
      href="{{ routes.all_products_collection_url }}"
      @click="$store.cart.open = false"
      class="inline-block border border-stone-900 px-6 py-2.5 text-sm hover:bg-stone-900 hover:text-stone-50 transition-colors duration-200"
    >
      ショッピングを続ける
    </a>
  </div>

  {%- comment %} カートアイテム一覧 {%- endcomment -%}
  <div
    :class="$store.cart.items.length > 0 ? '' : 'hidden'"
    :aria-busy="$store.cart.loading"
    class="flex-1 overflow-y-auto px-6 space-y-6 relative"
  >
    {%- comment %} ローディングオーバーレイ {%- endcomment -%}
    <div
      :class="$store.cart.loading ? '' : 'hidden'"
      class="absolute inset-0 z-10 flex items-center justify-center bg-stone-50/70"
      aria-hidden="true"
    >
      <svg class="w-6 h-6 text-stone-400 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </div>
    <template x-for="item in $store.cart.items" :key="item.key">
      <div class="flex gap-4" :class="$store.cart.loading ? 'opacity-50' : ''">
        <a
          :href="item.url"
          @click="$store.cart.open = false"
          class="flex-shrink-0 w-20 h-20 bg-stone-200 overflow-hidden"
        >
          <img
            :src="$store.cart.imageUrl(item.featured_image?.url, 160)"
            :alt="item.title"
            class="w-full h-full object-cover"
            width="80"
            height="80"
            loading="lazy"
            @error="$el.src = $store.cart.placeholder"
          >
        </a>

        <div class="flex-1 min-w-0">
          <p class="text-xs text-stone-500 mb-0.5" x-text="item.vendor"></p>
          <a
            :href="item.url"
            @click="$store.cart.open = false"
            class="text-sm font-medium leading-snug"
            x-text="item.product_title"
          ></a>
          <p
            :class="item.variant_title && item.variant_title !== 'Default Title' ? '' : 'hidden'"
            class="text-xs text-stone-500 mt-0.5"
            x-text="item.variant_title"
          ></p>

          <div class="flex items-center justify-between mt-2">
            {%- comment %} 数量ステッパー {%- endcomment -%}
            <div class="flex items-center gap-1.5">
              <button
                type="button"
                @click="item.quantity <= 1 ? $store.cart.remove(item.key) : $store.cart.changeQuantity(item.key, item.quantity - 1)"
                :disabled="$store.cart.loading"
                :aria-label="'数量を減らす: ' + item.product_title"
                class="w-6 h-6 flex items-center justify-center border border-stone-300 text-stone-500 hover:border-stone-900 hover:text-stone-900 transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
              >−</button>
              <span class="text-sm w-5 text-center tabular-nums" x-text="item.quantity"></span>
              <button
                type="button"
                @click="$store.cart.changeQuantity(item.key, item.quantity + 1)"
                :disabled="$store.cart.loading"
                :aria-label="'数量を増やす: ' + item.product_title"
                class="w-6 h-6 flex items-center justify-center border border-stone-300 text-stone-500 hover:border-stone-900 hover:text-stone-900 transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
              >+</button>
            </div>

            {%- comment %} 価格・削除 {%- endcomment -%}
            <div class="flex items-center gap-3">
              <p class="text-sm">
                <span x-text="$store.cart.formatPrice(item.final_line_price)"></span>
                <span class="text-xs text-stone-400">（税込）</span>
              </p>
              <button
                type="button"
                @click="$store.cart.remove(item.key)"
                :disabled="$store.cart.loading"
                :aria-label="'削除: ' + item.product_title"
                class="text-stone-400 hover:text-stone-900 transition-colors disabled:cursor-not-allowed"
              >
                {%- render 'icon', icon: 'x', class: 'w-4 h-4' -%}
              </button>
            </div>
          </div>
        </div>
      </div>
    </template>
  </div>

  {%- comment %} フッター {%- endcomment -%}
  <div
    :class="$store.cart.items.length > 0 ? '' : 'hidden'"
    :aria-busy="$store.cart.loading"
    class="border-t border-stone-200 px-6 py-5 space-y-4"
  >
    <div class="flex justify-between text-sm">
      <span class="text-stone-500">小計</span>
      <span class="text-xl" x-text="$store.cart.formatPrice($store.cart.totalPrice())"></span>
    </div>
    {%- render 'button',
      label: 'カートを見る',
      url: routes.cart_url,
      full_width: true
    -%}
  </div>
</div>

{%- comment %} オーバーレイ {%- endcomment -%}
<div
  x-data
  x-show="$store.cart.open"
  x-cloak
  x-transition:enter="transition-opacity duration-300"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition-opacity duration-200"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  class="fixed inset-0 z-40 bg-stone-950/40 backdrop-blur-sm"
  @click="$store.cart.open = false"
  aria-hidden="true"
></div>

{%- schema %}
{
  "name": "Cart Drawer",
  "presets": [
    {
      "name": "Cart Drawer"
    }
  ]
}
{%- endschema -%}
