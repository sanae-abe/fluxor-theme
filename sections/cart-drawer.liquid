<!-- カートドロワー（Alpine.js $store.cart で制御） -->
<div
  x-data
  x-show="$store.cart.open"
  x-transition:enter="transition-transform duration-300 ease-out"
  x-transition:enter-start="translate-x-full"
  x-transition:enter-end="translate-x-0"
  x-transition:leave="transition-transform duration-200 ease-in"
  x-transition:leave-start="translate-x-0"
  x-transition:leave-end="translate-x-full"
  class="fixed inset-y-0 right-0 z-50 w-full max-w-sm bg-stone-50 shadow-2xl flex flex-col"
  role="dialog"
  aria-modal="true"
  aria-label="カート"
  @keydown.escape.window="$store.cart.open = false"
  style="display: none;"
>
  <!-- ヘッダー -->
  <div class="flex items-center justify-between px-6 py-5 border-b border-stone-200">
    <h2 class="text-sm tracking-widest uppercase">
      Cart
      <span x-text="$store.cart.itemCount > 0 ? '(' + $store.cart.itemCount + ')' : ''" class="text-stone-400"></span>
    </h2>
    <button
      type="button"
      @click="$store.cart.open = false"
      class="text-stone-400 hover:text-stone-900 transition-colors"
      aria-label="カートを閉じる"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- カートが空 -->
  <div x-show="$store.cart.items.length === 0" class="flex-1 flex flex-col items-center justify-center gap-4 px-6 text-center">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />
    </svg>
    <p class="text-sm text-stone-400">カートに商品がありません</p>
    <a
      href="{{ routes.all_products_collection_url }}"
      @click="$store.cart.open = false"
      class="inline-block border border-stone-900 px-6 py-2.5 text-sm hover:bg-stone-900 hover:text-stone-50 transition-colors duration-200"
    >
      ショッピングを続ける
    </a>
  </div>

  <!-- カートアイテム一覧 -->
  <div x-show="$store.cart.items.length > 0" class="flex-1 overflow-y-auto px-6 py-4 space-y-6">
    <template x-for="item in $store.cart.items" :key="item.key">
      <div class="flex gap-4">
        <!-- サムネイル -->
        <a :href="item.url" @click="$store.cart.open = false" class="flex-shrink-0 w-20 h-20 bg-stone-200 overflow-hidden">
          <img
            :src="item.featured_image ? item.featured_image.url : ''"
            :alt="item.title"
            class="w-full h-full object-cover"
            loading="lazy"
          >
        </a>

        <!-- 情報 -->
        <div class="flex-1 min-w-0">
          <p class="text-xs text-stone-400 mb-0.5" x-text="item.vendor"></p>
          <a :href="item.url" @click="$store.cart.open = false" class="text-sm font-medium leading-snug" x-text="item.product_title"></a>
          <p x-show="item.variant_title && item.variant_title !== 'Default Title'" class="text-xs text-stone-400 mt-0.5" x-text="item.variant_title"></p>

          <div class="flex items-center justify-between mt-2">
            <p class="text-sm">
              <span x-text="new Intl.NumberFormat('ja-JP', { style: 'currency', currency: 'JPY' }).format(item.final_line_price / 100)"></span>
              <span class="text-xs text-stone-400">（税込）</span>
            </p>
            <button
              type="button"
              @click="$store.cart.remove(item.key)"
              class="text-xs text-stone-400 hover:text-stone-900 underline transition-colors"
            >
              削除
            </button>
          </div>
        </div>
      </div>
    </template>
  </div>

  <!-- フッター -->
  <div x-show="$store.cart.items.length > 0" class="border-t border-stone-200 px-6 py-5 space-y-4">
    <div class="flex justify-between text-sm">
      <span class="text-stone-500">小計</span>
      <span x-text="new Intl.NumberFormat('ja-JP', { style: 'currency', currency: 'JPY' }).format($store.cart.items.reduce((s, i) => s + i.final_line_price, 0) / 100)"></span>
    </div>
    <p class="text-xs text-stone-400 text-center">送料・消費税は購入手続き時に確認できます</p>
    <a
      href="{{ routes.cart_url }}"
      class="block w-full text-center bg-stone-900 text-stone-50 py-3 text-sm tracking-wide hover:bg-stone-800 transition-colors"
    >
      購入手続きへ
    </a>
  </div>
</div>

<!-- オーバーレイ -->
<div
  x-data
  x-show="$store.cart.open"
  x-transition:enter="transition-opacity duration-300"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition-opacity duration-200"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  class="fixed inset-0 z-40 bg-stone-950/40 backdrop-blur-sm"
  @click="$store.cart.open = false"
  style="display: none;"
></div>

{% schema %}
{
  "name": "Cart Drawer"
}
{% endschema %}
