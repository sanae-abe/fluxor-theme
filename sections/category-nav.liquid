<section class="{{ section.settings.background }} px-4 md:px-10 py-10 md:py-[60px]">
  <div class="max-w-screen-xl mx-auto">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-10">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.url | default: '#' }}"
          class="group flex flex-col items-center gap-4"
          {{ block.shopify_attributes }}
        >
          <!-- 丸画像 -->
          <div class="w-full aspect-square rounded-full bg-stone-50 overflow-hidden [transform:translateZ(0)]">
            {%- if block.settings.image -%}
              <img
                src="{{ block.settings.image | image_url: width: 500 }}"
                alt="{{ block.settings.label | escape }}"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                width="500"
                height="500"
              >
            {%- else -%}
              <div class="w-full h-full flex items-center justify-center text-stone-200">
                {%- render 'icon', icon: 'image', class: 'w-12 h-12' -%}
              </div>
            {%- endif -%}
          </div>

          <!-- ラベル -->
          {%- if block.settings.label != blank -%}
            <p class="text-base font-medium {% if section.settings.background == 'bg-stone-950' %}text-stone-50{% else %}text-stone-900{% endif %} text-center leading-6">
              {{ block.settings.label }}
            </p>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "カテゴリナビゲーション",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "背景色",
      "options": [
        { "value": "bg-stone-100", "label": "ライトグレー（デフォルト）" },
        { "value": "bg-stone-50", "label": "ライト" },
        { "value": "bg-stone-200", "label": "グレー" },
        { "value": "bg-stone-950", "label": "ダーク" }
      ],
      "default": "bg-stone-100"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "ナビゲーション項目",
      "settings": [
        {
          "type": "url",
          "id": "url",
          "label": "リンク先"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "画像"
        },
        {
          "type": "text",
          "id": "label",
          "label": "テキスト",
          "default": "カテゴリ名"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "カテゴリナビゲーション",
      "blocks": [
        { "type": "item", "settings": { "label": "クレンジング・洗顔" } },
        { "type": "item", "settings": { "label": "美容液・オイル" } },
        { "type": "item", "settings": { "label": "化粧水" } },
        { "type": "item", "settings": { "label": "乳液・クリーム" } },
        { "type": "item", "settings": { "label": "アイ・リップケア" } }
      ]
    }
  ]
}
{% endschema %}
