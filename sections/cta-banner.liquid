{%- liquid
  assign heading   = section.settings.heading
  assign body      = section.settings.body
  assign btn_label = section.settings.button_label
-%}
{%- if heading != blank -%}
<section class="w-full bg-surface overflow-hidden px-4 md:px-10 py-[60px]">
  <div class="w-full max-w-screen-xl mx-auto flex flex-col gap-6 md:gap-10 items-center text-center">
    <h2 class="cta-heading text-3xl md:text-4xl leading-tight font-semibold tracking-wider text-text">
      {{ heading }}
    </h2>
    {%- if body != blank -%}
      <p class="text-sm md:text-base leading-relaxed text-stone-900/80 max-w-2xl">{{ body }}</p>
    {%- endif -%}
    {%- if btn_label != blank -%}
      {%- assign btn_url = section.settings.button_url | default: '/collections/all' -%}
      {%- render 'button',
        label: btn_label,
        url: btn_url,
        variant: 'outline',
        icon_right: 'arrow-right',
        class: 'w-full md:w-auto'
      -%}
    {%- endif -%}
  </div>
</section>
{%- endif -%}

{%- schema %}
{
  "name": "CTAバナー",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "スキンケア製品をお探しですか？"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "本文",
      "default": "お肌のお悩みや目的に合わせて、最適な成分が配合された製品をご提案します。"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "ボタンラベル",
      "default": "スキンケア製品を探す"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "ボタンURL"
    }
  ],
  "presets": [
    {
      "name": "CTAバナー"
    }
  ]
}
{%- endschema -%}
