{{ 'featured-collection-fluxor.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_count = section.settings.products_to_show
-%}

<div class="featured-collection-fluxor color-{{ section.settings.color_scheme }} gradient">
  <div class="featured-collection-fluxor__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="featured-collection-fluxor__heading">
        {{- section.settings.heading | escape -}}
      </h2>
    {%- endif -%}

    {%- if section.settings.show_view_all and collection != blank -%}
      <a href="{{ collection.url }}" class="featured-collection-fluxor__view-all">
        すべて見る
      </a>
    {%- endif -%}
  </div>

  {%- if collection != blank and collection.products_count > 0 -%}
    <div class="featured-collection-fluxor__grid">
      {%- for product in collection.products limit: products_count -%}
        <a href="{{ product.url }}" class="fluxor-product-card">
          <div class="fluxor-product-card__image-wrapper">
            {%- if product.featured_image != blank -%}
              {{
                product.featured_image
                | image_url: width: 600
                | image_tag: loading: 'lazy', alt: product.title
              }}
            {%- endif -%}
          </div>
          <div class="fluxor-product-card__info">
            {%- if product.vendor != blank -%}
              <p class="fluxor-product-card__vendor">{{ product.vendor | escape }}</p>
            {%- endif -%}
            <p class="fluxor-product-card__title">{{ product.title | escape }}</p>
            <p class="fluxor-product-card__price">{{ product.price | money }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="featured-collection-fluxor__empty">
      テーマカスタマイザーでコレクションを選択してください。
    </p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Collection - Fluxor",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "New Arrivals"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "コレクション"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "表示件数",
      "min": 2,
      "max": 12,
      "step": 2,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "「すべて見る」リンクを表示",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Collection - Fluxor"
    }
  ]
}
{% endschema %}
