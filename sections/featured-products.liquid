{%- assign col = collections[section.settings.collection] -%}
{%- assign link_url = section.settings.link_url | default: col.url -%}

<section class="bg-stone-100 px-10 py-[60px]">
  <div class="max-w-screen-xl mx-auto flex flex-col gap-10">

    <!-- ヘッダー行 -->
    {%- assign header_align = 'center' -%}
    {%- if section.settings.show_view_all -%}{%- assign header_align = 'left' -%}{%- endif -%}
    {%- render 'section-header',
      heading: section.settings.heading,
      subheading: section.settings.subheading,
      link_url: link_url,
      link_label: section.settings.link_label,
      align: header_align
    -%}

    <!-- 製品グリッド -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
      {%- if col != blank -%}
        {%- for product in col.products limit: section.settings.products_to_show -%}
          {% render 'card-product-4col', product: product %}
        {%- else -%}
          <p class="col-span-4 text-stone-400">コレクションに商品がありません。</p>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          <div class="flex flex-col gap-4">
            <div class="w-full aspect-square rounded-2xl bg-stone-200 animate-pulse"></div>
            <div class="flex flex-col gap-2">
              <div class="h-3 w-1/3 bg-stone-200 rounded animate-pulse"></div>
              <div class="h-4 w-2/3 bg-stone-200 rounded animate-pulse"></div>
              <div class="h-4 w-1/4 bg-stone-200 rounded animate-pulse"></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "おすすめ商品",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "注目のアイテム"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "サブテキスト",
      "default": "エディターが厳選した、今注目のスキンケア製品"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "表示するコレクション"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "「すべて見る」リンクを表示",
      "default": true
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "表示件数",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "「すべて見る」リンク先（省略時はコレクションURL）"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "「すべて見る」テキスト",
      "default": "すべて見る"
    }
  ],
  "presets": [
    {
      "name": "おすすめ商品"
    }
  ]
}
{% endschema %}
