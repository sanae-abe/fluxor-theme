{%- assign col = collections[section.settings.collection] -%}
{%- assign link_url = section.settings.link_url | default: col.url -%}

<section class="bg-stone-50 px-10 py-[60px]">
  <div class="max-w-screen-xl mx-auto flex flex-col gap-10">

    <!-- ヘッダー行 -->
    <div class="flex items-end justify-between gap-6">

      <!-- 見出し＋サブ -->
      <div class="flex flex-col gap-2">
        {%- if section.settings.heading != blank -%}
          <h2 class="text-[42px] font-semibold leading-[1.5] text-stone-900">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="text-lg leading-[27px] text-stone-900 opacity-70">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>

      <!-- 「すべて見る」リンク -->
      {%- if section.settings.link_label != blank and link_url != blank -%}
        <a
          href="{{ link_url }}"
          class="flex-shrink-0 flex items-center gap-2 text-base leading-6 text-stone-900 hover:opacity-60 transition-opacity duration-200"
        >
          <span>{{ section.settings.link_label }}</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      {%- endif -%}

    </div>

    <!-- 製品グリッド -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
      {%- if col != blank -%}
        {%- for product in col.products limit: section.settings.products_to_show -%}
          {% render 'card-product', product: product %}
        {%- else -%}
          <p class="col-span-4 text-stone-400">コレクションに商品がありません。</p>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          <div class="flex flex-col gap-4">
            <div class="w-full aspect-square rounded-2xl bg-stone-200 animate-pulse"></div>
            <div class="flex flex-col gap-2">
              <div class="h-3 w-1/3 bg-stone-200 rounded animate-pulse"></div>
              <div class="h-4 w-2/3 bg-stone-200 rounded animate-pulse"></div>
              <div class="h-4 w-1/4 bg-stone-200 rounded animate-pulse"></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "おすすめ商品",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "注目のアイテム"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "サブテキスト",
      "default": "エディターが厳選した、今注目のスキンケア製品"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "表示するコレクション"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "表示件数",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "「すべて見る」リンク先（省略時はコレクションURL）"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "「すべて見る」テキスト",
      "default": "すべて見る"
    }
  ],
  "presets": [
    {
      "name": "おすすめ商品"
    }
  ]
}
{% endschema %}
