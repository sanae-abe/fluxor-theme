<footer class="bg-stone-900 px-10 py-[60px]">
  <div class="max-w-screen-xl mx-auto flex flex-col gap-10">

    <!-- 3カラム：Quick Links / Information / メルマガ＋SNS -->
    <div class="flex gap-10 items-start">

      <!-- Quick Links -->
      {%- if section.settings.menu_1 != blank -%}
        <div class="flex-1 flex flex-col gap-4">
          <p class="text-sm font-medium text-stone-400 uppercase leading-tight">
            {{ section.settings.menu_1_title | default: 'Quick Links' }}
          </p>
          <ul class="flex flex-col gap-4">
            {%- for link in linklists[section.settings.menu_1].links -%}
              <li>
                <a
                  href="{{ link.url }}"
                  class="text-base text-stone-50 uppercase leading-tight hover:underline underline-offset-[8px]"
                >{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <!-- Information -->
      {%- if section.settings.menu_2 != blank -%}
        <div class="flex-1 flex flex-col gap-4">
          <p class="text-sm font-medium text-stone-400 uppercase leading-tight">
            {{ section.settings.menu_2_title | default: 'Information' }}
          </p>
          <ul class="flex flex-col gap-4">
            {%- for link in linklists[section.settings.menu_2].links -%}
              <li>
                <a
                  href="{{ link.url }}"
                  class="text-base text-stone-100 uppercase leading-tight hover:underline underline-offset-[8px]"
                >{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <!-- メルマガ登録 + SNS -->
      <div class="flex-1 flex flex-col gap-8">

        <!-- メルマガ -->
        <div class="flex flex-col gap-4">
          <p class="text-sm font-medium text-stone-400 uppercase leading-tight">メルマガ登録</p>
          <p class="text-sm text-stone-50 leading-tight">
            新しい製品やセールのお知らせをメールで配信しています。
          </p>

          <div x-data="{ agreed: false }">
            {%- form 'customer', id: 'FooterNewsletter' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">

              {%- if form.posted_successfully? -%}
                <p class="text-sm text-stone-50 py-3">ご登録ありがとうございます。</p>
              {%- else -%}

                <!-- メールアドレス入力 + 送信ボタン -->
                <div class="flex items-center border-b border-white gap-3 h-[50px]">
                  <input
                    type="email"
                    name="contact[email]"
                    placeholder="メールアドレスを入力"
                    class="flex-1 bg-transparent text-white placeholder-[rgba(246,244,240,0.5)] text-base outline-none px-4 py-3"
                    required
                    autocomplete="email"
                  >
                  <button
                    type="submit"
                    class="flex-shrink-0 w-11 h-11 flex items-center justify-center text-white transition-opacity duration-200"
                    :class="!agreed ? 'opacity-30 cursor-not-allowed' : 'hover:opacity-60'"
                    :disabled="!agreed"
                    aria-label="メルマガ登録"
                  >
                    {%- render 'icon', icon: 'arrow-right', class: 'w-6 h-6' -%}
                  </button>
                </div>

                <!-- プライバシーポリシー同意 -->
                <label class="flex items-center gap-1.5 mt-4 cursor-pointer">
                  <input
                    type="checkbox"
                    x-model="agreed"
                    class="w-5 h-5 flex-shrink-0 border border-stone-200 bg-stone-50 cursor-pointer"
                  >
                  <span class="text-sm text-white opacity-80 leading-tight">
                    {%- if section.settings.privacy_url != blank -%}
                      <a href="{{ section.settings.privacy_url }}" class="underline hover:opacity-70 transition-opacity duration-200">プライバシーポリシー</a>に同意します
                    {%- else -%}
                      プライバシーポリシーに同意します
                    {%- endif -%}
                  </span>
                </label>

              {%- endif -%}
            {%- endform -%}
          </div>
        </div>

        <!-- SNSアイコン -->
        <div class="flex items-center gap-4">
          {%- if section.settings.social_instagram_url != blank -%}
            <a
              href="{{ section.settings.social_instagram_url }}"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors duration-200"
              aria-label="Instagram"
            >
              {%- render 'icon', icon: 'instagram', class: 'w-5 h-5 text-white' -%}
            </a>
          {%- endif -%}

          {%- if section.settings.social_x_url != blank -%}
            <a
              href="{{ section.settings.social_x_url }}"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors duration-200"
              aria-label="X (Twitter)"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.social_tiktok_url != blank -%}
            <a
              href="{{ section.settings.social_tiktok_url }}"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors duration-200"
              aria-label="TikTok"
            >
              {%- render 'icon', icon: 'tiktok', class: 'w-5 h-5 text-white' -%}
            </a>
          {%- endif -%}
        </div>

      </div>
    </div>

    <!-- 決済アイコン -->
    {%- unless shop.enabled_payment_types == empty -%}
      <div class="flex items-center gap-4 flex-wrap">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'h-6' }}
        {%- endfor -%}
      </div>
    {%- endunless -%}

    <!-- 注意書き -->
    {%- if section.settings.disclaimer != blank -%}
      <p class="text-sm text-white opacity-40 leading-tight">
        {{ section.settings.disclaimer }}
      </p>
    {%- endif -%}

    <!-- ボトムバー（コピーライト） -->
    <div class="border-t border-[rgba(246,244,240,0.1)] pt-10 flex items-center justify-center">
      <p class="text-sm text-white opacity-80 leading-5">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name | upcase }}
      </p>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "ナビゲーション"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Quick Links メニュー",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "menu_1_title",
      "label": "Quick Links タイトル",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Information メニュー"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "Information タイトル",
      "default": "Information"
    },
    {
      "type": "header",
      "content": "メルマガ登録"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "プライバシーポリシーのリンク先"
    },
    {
      "type": "header",
      "content": "SNSリンク"
    },
    {
      "type": "url",
      "id": "social_instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_x_url",
      "label": "X (Twitter) URL"
    },
    {
      "type": "url",
      "id": "social_tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "header",
      "content": "その他"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "注意書き（薬機法等）",
      "default": "※本サイトにおける各用語の定義は以下の通りです。 エイジングケア：年齢に応じた潤いによるお手入れのこと。 ニキビケア：洗浄により肌を清浄にし、ニキビを防ぐこと。 毛穴ケア：潤いを与え、キメを整えることで毛穴を目立たなくすること。 美白：メラニンの生成を抑え、シミ・そばかすを防ぐこと（※医薬部外品の場合）。 浸透：角質層まで。"
    }
  ]
}
{% endschema %}
