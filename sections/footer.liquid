<footer class="bg-stone-950 text-stone-50 pt-16 pb-8 mt-24">
  <div class="max-w-screen-xl mx-auto px-5">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-12">

      <!-- ブランド -->
      <div>
        <p class="text-lg tracking-widest uppercase font-light mb-4">{{ shop.name }}</p>
        {%- if section.settings.description != blank -%}
          <p class="text-sm text-stone-400 leading-relaxed">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>

      <!-- リンク1 -->
      {%- if section.settings.menu_1 != blank -%}
        <div>
          {%- if section.settings.menu_1_title != blank -%}
            <p class="text-xs tracking-widest uppercase text-stone-500 mb-4">{{ section.settings.menu_1_title }}</p>
          {%- endif -%}
          <ul class="space-y-2">
            {%- for link in linklists[section.settings.menu_1].links -%}
              <li>
                <a href="{{ link.url }}" class="text-sm text-stone-400 hover:text-stone-50 transition-colors duration-200">
                  {{ link.title }}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <!-- リンク2 -->
      {%- if section.settings.menu_2 != blank -%}
        <div>
          {%- if section.settings.menu_2_title != blank -%}
            <p class="text-xs tracking-widest uppercase text-stone-500 mb-4">{{ section.settings.menu_2_title }}</p>
          {%- endif -%}
          <ul class="space-y-2">
            {%- for link in linklists[section.settings.menu_2].links -%}
              <li>
                <a href="{{ link.url }}" class="text-sm text-stone-400 hover:text-stone-50 transition-colors duration-200">
                  {{ link.title }}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

    </div>

    <!-- SNSリンク -->
    {%- if settings.social_instagram_link != blank or settings.social_twitter_link != blank -%}
      <div class="flex gap-4 mb-10">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer" class="text-stone-500 hover:text-stone-50 transition-colors" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if settings.social_twitter_link != blank -%}
          <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener noreferrer" class="text-stone-500 hover:text-stone-50 transition-colors" aria-label="X (Twitter)">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- コピーライト -->
    <div class="border-t border-stone-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-stone-600">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <p>Powered by Shopify</p>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "description",
      "label": "Brand description"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Footer menu 1"
    },
    {
      "type": "text",
      "id": "menu_1_title",
      "label": "Menu 1 title",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Footer menu 2"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "Menu 2 title",
      "default": "Info"
    }
  ]
}
{% endschema %}
