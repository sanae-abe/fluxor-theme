<footer class="bg-[#1c1917] px-10 py-[60px]">
  <div class="max-w-screen-xl mx-auto flex flex-col gap-10">

    <!-- 3カラム：Quick Links / Information / メルマガ＋SNS -->
    <div class="flex gap-10 items-start">

      <!-- Quick Links -->
      {%- if section.settings.menu_1 != blank -%}
        <div class="flex-1 flex flex-col gap-4">
          <p class="text-base font-medium text-white uppercase leading-6">
            {{ section.settings.menu_1_title | default: 'Quick Links' }}
          </p>
          <ul class="flex flex-col gap-2">
            {%- for link in linklists[section.settings.menu_1].links -%}
              <li>
                <a
                  href="{{ link.url }}"
                  class="text-sm text-white opacity-80 uppercase leading-[21px] hover:opacity-100 transition-opacity duration-200"
                >{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <!-- Information -->
      {%- if section.settings.menu_2 != blank -%}
        <div class="flex-1 flex flex-col gap-4">
          <p class="text-base font-medium text-white uppercase leading-6">
            {{ section.settings.menu_2_title | default: 'Information' }}
          </p>
          <ul class="flex flex-col gap-2">
            {%- for link in linklists[section.settings.menu_2].links -%}
              <li>
                <a
                  href="{{ link.url }}"
                  class="text-sm text-white opacity-80 uppercase leading-[21px] hover:opacity-100 transition-opacity duration-200"
                >{{ link.title }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <!-- メルマガ登録 + SNS -->
      <div class="flex-1 flex flex-col gap-8">

        <!-- メルマガ -->
        <div class="flex flex-col gap-4">
          <p class="text-base font-medium text-white uppercase leading-6">メルマガ登録</p>
          <p class="text-sm text-white opacity-80 leading-[21px]">
            新しい製品やセールのお知らせをメールで配信しています。
          </p>

          <div x-data="{ agreed: false }">
            {%- form 'customer', id: 'FooterNewsletter' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">

              {%- if form.posted_successfully? -%}
                <p class="text-sm text-white opacity-80 py-3">ご登録ありがとうございます。</p>
              {%- else -%}

                <!-- メールアドレス入力 + 送信ボタン -->
                <div class="flex items-center border-b border-white gap-3 h-[50px]">
                  <input
                    type="email"
                    name="contact[email]"
                    placeholder="メールアドレスを入力"
                    class="flex-1 bg-transparent text-white placeholder-[rgba(246,244,240,0.5)] text-base outline-none px-4 py-3"
                    required
                    autocomplete="email"
                  >
                  <button
                    type="submit"
                    class="flex-shrink-0 w-11 h-11 flex items-center justify-center text-white transition-opacity duration-200"
                    :class="!agreed ? 'opacity-30 cursor-not-allowed' : 'hover:opacity-60'"
                    :disabled="!agreed"
                    aria-label="メルマガ登録"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </button>
                </div>

                <!-- プライバシーポリシー同意 -->
                <label class="flex items-center gap-1.5 mt-4 cursor-pointer">
                  <input
                    type="checkbox"
                    x-model="agreed"
                    class="w-5 h-5 flex-shrink-0 border border-stone-200 bg-white cursor-pointer"
                  >
                  <span class="text-sm text-white opacity-80 leading-[21px]">
                    {%- if section.settings.privacy_url != blank -%}
                      <a href="{{ section.settings.privacy_url }}" class="underline hover:opacity-70 transition-opacity duration-200">プライバシーポリシー</a>に同意します
                    {%- else -%}
                      プライバシーポリシーに同意します
                    {%- endif -%}
                  </span>
                </label>

              {%- endif -%}
            {%- endform -%}
          </div>
        </div>

        <!-- SNSアイコン -->
        <div class="flex items-center gap-4">
          {%- if section.settings.social_instagram_url != blank -%}
            <a
              href="{{ section.settings.social_instagram_url }}"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors duration-200"
              aria-label="Instagram"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.social_x_url != blank -%}
            <a
              href="{{ section.settings.social_x_url }}"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors duration-200"
              aria-label="X (Twitter)"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.social_tiktok_url != blank -%}
            <a
              href="{{ section.settings.social_tiktok_url }}"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors duration-200"
              aria-label="TikTok"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.16 8.16 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/>
              </svg>
            </a>
          {%- endif -%}
        </div>

      </div>
    </div>

    <!-- 決済アイコン -->
    {%- unless shop.enabled_payment_types == empty -%}
      <div class="flex items-center gap-4 flex-wrap">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'h-6' }}
        {%- endfor -%}
      </div>
    {%- endunless -%}

    <!-- 注意書き -->
    {%- if section.settings.disclaimer != blank -%}
      <p class="text-sm text-white opacity-40 leading-[21px]">
        {{ section.settings.disclaimer }}
      </p>
    {%- endif -%}

    <!-- ボトムバー（コピーライト） -->
    <div class="border-t border-[rgba(246,244,240,0.1)] pt-10 flex items-center justify-center">
      <p class="text-sm text-white opacity-80 leading-5">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name | upcase }}
      </p>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "ナビゲーション"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Quick Links メニュー",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "menu_1_title",
      "label": "Quick Links タイトル",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Information メニュー"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "Information タイトル",
      "default": "Information"
    },
    {
      "type": "header",
      "content": "メルマガ登録"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "プライバシーポリシーのリンク先"
    },
    {
      "type": "header",
      "content": "SNSリンク"
    },
    {
      "type": "url",
      "id": "social_instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_x_url",
      "label": "X (Twitter) URL"
    },
    {
      "type": "url",
      "id": "social_tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "header",
      "content": "その他"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "注意書き（薬機法等）",
      "default": "※本サイトにおける各用語の定義は以下の通りです。 エイジングケア：年齢に応じた潤いによるお手入れのこと。 ニキビケア：洗浄により肌を清浄にし、ニキビを防ぐこと。 毛穴ケア：潤いを与え、キメを整えることで毛穴を目立たなくすること。 美白：メラニンの生成を抑え、シミ・そばかすを防ぐこと（※医薬部外品の場合）。 浸透：角質層まで。"
    }
  ]
}
{% endschema %}
