<footer id="site-footer" class="bg-stone-900 px-4 md:px-10 py-10 md:py-[60px]">
  <div class="max-w-screen-xl mx-auto flex flex-col gap-6 md:gap-10">

    {%- comment %} 3カラム：Quick Links / Information / メルマガ＋SNS {%- endcomment %}
    <div class="flex flex-col md:flex-row gap-10 items-start">

      {%- for n in (1..2) -%}
        {%- assign menu_key    = 'menu_' | append: n -%}
        {%- assign title_key   = 'menu_' | append: n | append: '_title' -%}
        {%- assign menu_handle = section.settings[menu_key] -%}
        {%- if menu_handle != blank -%}
          <div class="flex-1 flex flex-col gap-4">
            <p class="text-sm font-medium text-stone-500 uppercase leading-tight">
              {{ section.settings[title_key] | default: 'Links' }}
            </p>
            <ul class="flex flex-col gap-4">
              {%- for link in linklists[menu_handle].links -%}
                <li>
                  <a
                    href="{{ link.url }}"
                    class="text-sm text-stone-200 uppercase leading-tight palt tracking-wider hover:underline underline-offset-[8px]"
                  >{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment %} メルマガ登録 + SNS {%- endcomment %}
      <div class="flex-1 flex flex-col gap-8">

        {%- comment %} メルマガ {%- endcomment %}
        <div class="flex flex-col gap-4">
          <p class="text-sm font-medium text-stone-500 uppercase leading-tight">メルマガ登録</p>
          <p class="text-sm text-stone-200 leading-tight">
            新しい製品やセールのお知らせをメールで配信しています。
          </p>

          <div x-data="{ agreed: false }">
            {%- form 'customer', id: 'FooterNewsletter' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">

              {%- if form.posted_successfully? -%}
                <p class="text-sm text-stone-200 py-3">ご登録ありがとうございます。</p>
              {%- else -%}

                {%- comment %} メールアドレス入力 + 送信ボタン {%- endcomment %}
                <div class="flex items-center border-b border-white gap-3 h-[50px]">
                  <input
                    type="email"
                    name="contact[email]"
                    placeholder="メールアドレスを入力"
                    class="flex-1 bg-transparent text-white placeholder-[rgba(246,244,240,0.5)] text-base outline-none px-4 py-3"
                    required
                    autocomplete="email"
                  >
                  <button
                    type="submit"
                    class="flex-shrink-0 w-11 h-11 flex items-center justify-center text-white transition-opacity duration-200"
                    :class="!agreed ? 'opacity-30 cursor-not-allowed' : 'hover:opacity-60'"
                    :disabled="!agreed"
                    aria-label="メルマガ登録"
                  >
                    {%- render 'icon', icon: 'arrow-right', class: 'w-6 h-6' -%}
                  </button>
                </div>

                {%- comment %} プライバシーポリシー同意 {%- endcomment %}
                {%- render 'checkbox-consent',
                  privacy_url: section.settings.privacy_url,
                  x_model: 'agreed',
                  variant: 'dark'
                -%}

              {%- endif -%}
            {%- endform -%}
          </div>
        </div>

        {%- comment %} SNSアイコン {%- endcomment %}
        <div class="flex items-center gap-4">
          {%- if section.settings.social_instagram_url != blank -%}
            <a
              href="{{ section.settings.social_instagram_url }}"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors duration-200"
              aria-label="Instagram"
            >
              {%- render 'icon', icon: 'instagram', class: 'w-5 h-5 text-white' -%}
            </a>
          {%- endif -%}

          {%- if section.settings.social_x_url != blank -%}
            <a
              href="{{ section.settings.social_x_url }}"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors duration-200"
              aria-label="X (Twitter)"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.social_tiktok_url != blank -%}
            <a
              href="{{ section.settings.social_tiktok_url }}"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors duration-200"
              aria-label="TikTok"
            >
              {%- render 'icon', icon: 'tiktok', class: 'w-5 h-5 text-white' -%}
            </a>
          {%- endif -%}
        </div>

      </div>
    </div>

    {%- comment %} 決済アイコン {%- endcomment %}
    {%- unless shop.enabled_payment_types == empty -%}
      <div class="flex items-center gap-4 flex-wrap">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'h-6' }}
        {%- endfor -%}
      </div>
    {%- endunless -%}

    {%- comment %} 個人輸入・薬機法 注意事項 {%- endcomment %}
    {%- if section.settings.import_notice_footer != blank or section.settings.disclaimer != blank -%}
      <div class="border-t border-[rgba(246,244,240,0.1)] pt-8 flex flex-col gap-8">
        <div class="flex flex-col gap-1">
          <p class="text-xs font-medium text-stone-500 uppercase leading-tight tracking-wider">個人輸入代行に関するご注意</p>
          {%- if section.settings.import_notice_footer != blank -%}
            <p class="text-xs text-stone-500 leading-relaxed">{{ section.settings.import_notice_footer }}</p>
          {%- endif -%}
        </div>
        <div class="flex flex-col gap-1">
          <p class="text-xs font-medium text-stone-500 uppercase leading-tight tracking-wider">本サイトにおける各用語の定義</p>
          {%- if section.settings.disclaimer != blank -%}
            <p class="text-xs text-stone-500 leading-relaxed">{{ section.settings.disclaimer }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment %} ボトムバー（コピーライト） {%- endcomment %}
    <div class="border-t border-[rgba(246,244,240,0.1)] pt-10 flex items-center justify-center">
      <p class="text-sm text-stone-500 leading-5">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name | upcase }}
      </p>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "ナビゲーション"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Quick Links メニュー"
    },
    {
      "type": "text",
      "id": "menu_1_title",
      "label": "Quick Links タイトル",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Information メニュー"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "Information タイトル",
      "default": "Information"
    },
    {
      "type": "header",
      "content": "メルマガ登録"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "プライバシーポリシーのリンク先"
    },
    {
      "type": "header",
      "content": "SNSリンク"
    },
    {
      "type": "url",
      "id": "social_instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_x_url",
      "label": "X (Twitter) URL"
    },
    {
      "type": "url",
      "id": "social_tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "header",
      "content": "個人輸入代行に関する注意事項"
    },
    {
      "type": "textarea",
      "id": "import_notice_footer",
      "label": "個人輸入に関する注意文",
      "default": "当店「Fluxor」は商品の販売者ではなく、お客様ご自身が海外の事業者から商品を直接購入するための手続きと発送手配を代行する「個人輸入代行」サービスを提供しております。海外コスメは日本の薬機法に基づく承認を受けておらず、ご使用はお客様の完全な自己責任となります。個人輸入品の第三者への譲渡・転売は法律により固く禁じられています。商品代金が約16,666円を超える場合、関税・消費税等が別途発生する場合があります（お客様負担）。発注完了後のキャンセル・返品は原則お受けできません。"
    },
    {
      "type": "header",
      "content": "本サイトにおける各用語の定義"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "注意書き（薬機法等）",
      "default": "浸透：角質層まで。エイジングケア：年齢に応じた潤いによるお手入れのこと。ニキビケア：洗浄により肌を清浄にし、ニキビを防ぐこと。毛穴ケア：潤いを与え、キメを整えることで毛穴を目立たなくすること。美白、透明感：うるおいを与え乾燥によるくすみを防ぐこと、またはキメが整うことによる肌印象のこと。配合成分（ペプチド、アゼライン酸等）の表記は、すべて整肌・保湿成分としての目的。"
    }
  ]
}
{% endschema %}
