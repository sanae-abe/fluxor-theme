            <path d="M47.458 23.6608C45.6456 23.6608 44.0296 23.2687 42.6102 22.4843C41.2126 21.6782 40.1098 20.5779 39.3018 19.1836C38.4939 17.7892 38.0898 16.2096 38.0898 14.4448V0.359375H42.5446V14.5756C42.5446 15.5995 42.7521 16.4819 43.167 17.2227C43.6038 17.9634 44.1934 18.5408 44.9358 18.9548C45.7002 19.347 46.5409 19.543 47.458 19.543C48.3971 19.543 49.2269 19.347 49.9475 18.9548C50.6681 18.5408 51.2361 17.9634 51.6506 17.2227C52.0877 16.4819 52.3058 15.6104 52.3058 14.6082V0.359375H56.7933V14.4775C56.7933 16.2423 56.3895 17.8218 55.5813 19.2162C54.7737 20.5888 53.6708 21.6782 52.273 22.4843C50.8974 23.2687 49.2924 23.6608 47.458 23.6608Z" fill="#1C1917"/>
