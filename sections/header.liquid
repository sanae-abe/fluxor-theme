<header
  class="sticky top-0 z-50 bg-stone-50 border-b border-stone-900/10 px-10"
  x-data
>
  <div class="max-w-screen-xl mx-auto flex items-center justify-between h-20">

    <!-- ロゴ -->
    <a href="{{ routes.root_url }}" class="flex-shrink-0" aria-label="{{ shop.name | escape }}">
      {%- if settings.logo -%}
        <img
          src="{{ settings.logo | image_url: width: settings.logo_width | times: 2 }}"
          alt="{{ shop.name | escape }}"
          width="{{ settings.logo_width }}"
          loading="eager"
        >
      {%- else -%}
