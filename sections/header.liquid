{%- assign header_transparent = false -%}
{%- if template.name == 'index' -%}
  {%- assign header_transparent = true -%}
{%- endif -%}
<header
  class="w-full fixed left-0 right-0 z-30 pl-1 pr-1 md:pl-10 md:pr-10 transition-[background-color,border-color,color,backdrop-filter] duration-300 border-b"
  :class="scrolled ? 'bg-stone-100/95 backdrop-blur-sm border-stone-900/10 text-stone-900' : '{% if header_transparent %}bg-transparent border-transparent text-white{% else %}bg-stone-100 border-stone-900/10 text-stone-900{% endif %}'"
  :style="{ top: headerTop + 'px' }"
  x-data="siteHeader"
>
  <div class="max-w-screen-xl mx-auto grid grid-cols-3 items-center h-14 md:h-20">

    {%- comment %} 左カラム：ハンバーガー（モバイル） / ナビゲーション（デスクトップ） {%- endcomment -%}
    <div class="flex items-center">
      <button
        type="button"
        class="lg:hidden flex flex-col gap-1.5 p-3 text-current"
        @click="mobileMenuOpen = !mobileMenuOpen"
        :aria-expanded="mobileMenuOpen"
        :aria-label="mobileMenuOpen ? 'メニューを閉じる' : 'メニューを開く'"
        aria-controls="mobile-menu-drawer"
      >
        <span class="block w-5 h-px bg-current transition-transform duration-200" :class="mobileMenuOpen ? 'rotate-45 translate-y-2' : ''"></span>
        <span class="block w-5 h-px bg-current transition-opacity duration-200" :class="mobileMenuOpen ? 'opacity-0' : ''"></span>
        <span class="block w-5 h-px bg-current transition-transform duration-200" :class="mobileMenuOpen ? '-rotate-45 -translate-y-2' : ''"></span>
      </button>
      <nav class="header-nav hidden lg:flex items-center gap-8" aria-label="Main">
        {%- if section.settings.menu != blank -%}
          {%- for link in linklists[section.settings.menu].links -%}
            <a
              href="{{ link.url }}"
              class="header-nav-link text-md text-current palt tracking-wider"
              {% if link.active %}aria-current="page"{% endif %}
            >
              {{- link.title | upcase -}}
            </a>
          {%- endfor -%}
        {%- endif -%}
      </nav>
    </div>

    {%- comment %} 中央カラム：ロゴ {%- endcomment -%}
    <div class="col-start-2 flex justify-center">
      {%- if template.name == 'index' -%}
        <h1 class="leading-none m-0">
          <a href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">{%- render 'logo' -%}</a>
        </h1>
      {%- else -%}
        <a href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">{%- render 'logo' -%}</a>
      {%- endif -%}
    </div>

    {%- comment %} 右カラム：アイコン群 {%- endcomment -%}
    <div class="col-start-3 flex items-center justify-end md:gap-2">
      <a
        href="{{ routes.search_url }}"
        class="header-icon-btn flex items-center justify-center w-11 h-11 rounded-full text-current"
        aria-label="検索"
      >
        {%- render 'icon', icon: 'search', class: 'w-6 h-6' -%}
      </a>
      <a
        href="{{ routes.account_url }}"
        class="header-icon-btn hidden lg:flex items-center justify-center w-11 h-11 rounded-full text-current"
        aria-label="アカウント"
      >
        {%- render 'icon', icon: 'user', class: 'w-6 h-6' -%}
      </a>
      <button
        type="button"
        class="header-icon-btn relative flex items-center justify-center w-11 h-11 rounded-full text-current"
        @click="$store.cart.toggle()"
        :aria-label="$store.cart.open ? 'カートを閉じる' : 'カートを開く'"
      >
        {%- render 'icon', icon: 'cart', class: 'w-6 h-6' -%}
        <span
          :class="{ 'hidden': $store.cart.itemCount === 0 }"
          x-text="$store.cart.itemCount"
          class="absolute top-0 right-0 bg-stone-900 text-stone-50 text-[10px] leading-none w-4 h-4 rounded-full flex items-center justify-center hidden"
          aria-hidden="true"
        ></span>
        <span
          class="sr-only"
          role="status"
          aria-live="polite"
          aria-atomic="true"
          x-text="$store.cart.itemCount > 0 ? 'カートに' + $store.cart.itemCount + '点の商品があります' : ''"
        ></span>
      </button>
    </div>

  </div>

  {%- comment %} モバイルメニュードロワー {%- endcomment -%}
  <div
    id="mobile-menu-drawer"
    x-show="mobileMenuOpen"
    x-cloak
    x-trap="mobileMenuOpen"
    x-transition:enter="transition-transform duration-300 ease-out"
    x-transition:enter-start="-translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition-transform duration-200 ease-in"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="-translate-x-full"
    class="fixed inset-y-0 left-0 z-50 w-72 max-w-full h-screen bg-stone-100 shadow-2xl flex flex-col md:hidden"
    role="dialog"
    aria-modal="true"
    aria-label="メニュー"
    @keydown.escape.window="mobileMenuOpen = false"
  >
    <div class="flex items-center justify-between px-6 pt-6 pb-4">
      <button
        type="button"
        @click="mobileMenuOpen = false"
        class="header-menu-close text-stone-500"
        aria-label="閉じる"
      >
        {%- render 'icon', icon: 'x', class: 'w-5 h-5' -%}
      </button>
    </div>
    <nav class="flex-1 overflow-y-auto px-6 p-4" aria-label="モバイルナビゲーション">
      {%- if section.settings.menu != blank -%}
        <ul class="flex flex-col gap-4">
          {%- for link in linklists[section.settings.menu].links -%}
            <li>
              <a
                href="{{ link.url }}"
                class="header-nav-link text-lg text-stone-900 leading-loose palt tracking-wider uppercase"
                {% if link.active %}aria-current="page"{% endif %}
                @click="mobileMenuOpen = false"
              >
                {{- link.title | upcase -}}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </nav>
  </div>

  {%- comment %} オーバーレイ {%- endcomment -%}
  <div
    x-show="mobileMenuOpen"
    x-cloak
    x-transition:enter="transition-opacity duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition-opacity duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 z-40 bg-stone-950/40 backdrop-blur-sm md:hidden h-screen"
    @click="mobileMenuOpen = false"
    aria-hidden="true"
  ></div>

</header>

{%- schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{%- endschema -%}
