            <path d="M0 23.334V0.359375H4.4548V23.334H0ZM3.27559 13.9219V9.96755H14.8712V13.9219H3.27559ZM3.27559 4.28108V0.359375H15.428V4.28108H3.27559Z" fill="#1C1917"/>
          </g>
          <defs>
            <clipPath id="clip0_3084_7063">
              <rect width="130" height="24" fill="white"/>
            </clipPath>
          </defs>
        </svg>
      {%- endif -%}
    </a>

    <!-- ナビゲーション（デスクトップ） -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Main">
      {%- if section.settings.menu != blank -%}
        {%- for link in linklists[section.settings.menu].links -%}
          <a
            href="{{ link.url }}"
            class="text-sm text-stone-900 tracking-[1px] hover:underline underline-offset-[8px] decoration-stone-900 transition-all duration-200"
            {% if link.active %}aria-current="page"{% endif %}
          >
            {{ link.title | upcase }}
          </a>
        {%- endfor -%}
      {%- endif -%}
    </nav>

    <!-- 右アイコン群 -->
    <div class="flex items-center">

      <!-- 検索 -->
      <a
        href="{{ routes.search_url }}"
        class="flex items-center justify-center w-11 h-11 rounded-full text-stone-900 hover:bg-stone-900/10 transition-colors duration-200"
        aria-label="検索"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
      </a>

      <!-- アカウント -->
      <a
        href="{{ routes.account_url }}"
        class="flex items-center justify-center w-11 h-11 rounded-full text-stone-900 hover:bg-stone-900/10 transition-colors duration-200"
        aria-label="アカウント"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
        </svg>
      </a>

      <!-- カート -->
      <button
        type="button"
        class="relative flex items-center justify-center w-11 h-11 rounded-full text-stone-900 hover:bg-stone-900/10 transition-colors duration-200"
        @click="$store.cart.toggle()"
        aria-label="カートを開く"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />
        </svg>
        <span
          x-show="$store.cart.itemCount > 0"
          x-text="$store.cart.itemCount"
          class="absolute top-0 right-0 bg-stone-900 text-stone-50 text-[10px] leading-none w-4 h-4 rounded-full flex items-center justify-center"
          aria-hidden="true"
        ></span>
      </button>

      <!-- ハンバーガー（モバイル） -->
      <button
        type="button"
        class="md:hidden flex flex-col gap-1.5 p-3 text-stone-900"
        x-data="{ open: false }"
        @click="open = !open"
        aria-label="メニューを開く"
      >
        <span class="block w-5 h-px bg-current transition-all duration-200" :class="open ? 'rotate-45 translate-y-2' : ''"></span>
        <span class="block w-5 h-px bg-current transition-all duration-200" :class="open ? 'opacity-0' : ''"></span>
        <span class="block w-5 h-px bg-current transition-all duration-200" :class="open ? '-rotate-45 -translate-y-2' : ''"></span>
      </button>

    </div>

  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
