{%- style -%}
  #HeroFluxor-{{ section.id }} {
    --ticker-speed: {{ section.settings.ticker_speed }}s;
  }
{%- endstyle -%}

{{ 'section-hero-fluxor.css' | asset_url | stylesheet_tag }}

<section
  id="HeroFluxor-{{ section.id }}"
  class="hero-fluxor color-{{ section.settings.color_scheme }} gradient"
>
  <div class="hero-fluxor__content">
    {%- if section.settings.heading != blank -%}
      <h1 class="hero-fluxor__heading">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.tagline != blank -%}
      <p class="hero-fluxor__tagline">{{ section.settings.tagline | escape }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_link | default: '#' }}"
        class="hero-fluxor__cta"
      >
        {{- section.settings.button_label | escape -}}
      </a>
    {%- endif -%}
  </div>

  <div class="hero-fluxor__ticker-section" aria-hidden="true">
    {%- comment -%} Row 1: 左→右 {%- endcomment -%}
    <div class="hero-fluxor__ticker-wrapper">
      <div class="hero-fluxor__ticker-track">
        <span class="hero-fluxor__ticker-item">{{ section.settings.ticker_row_1 }}</span>
        <span class="hero-fluxor__ticker-item">{{ section.settings.ticker_row_1 }}</span>
      </div>
    </div>

    {%- comment -%} Row 2: 右→左 {%- endcomment -%}
    <div class="hero-fluxor__ticker-wrapper">
      <div class="hero-fluxor__ticker-track hero-fluxor__ticker-track--reverse">
        <span class="hero-fluxor__ticker-item">{{ section.settings.ticker_row_2 }}</span>
        <span class="hero-fluxor__ticker-item">{{ section.settings.ticker_row_2 }}</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero - Fluxor",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FLUXOR"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "The authority in active skincare."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Ingredient Ticker"
    },
    {
      "type": "text",
      "id": "ticker_row_1",
      "label": "Ticker row 1 (left to right)",
      "default": "Retinol · Niacinamide · Hyaluronic Acid · Vitamin C · Bakuchiol · Azelaic Acid · Squalane · Ferulic Acid · Centella Asiatica · Tranexamic Acid · Salicylic Acid · レチノール · ナイアシンアミド · ヒアルロン酸 ·"
    },
    {
      "type": "text",
      "id": "ticker_row_2",
      "label": "Ticker row 2 (right to left)",
      "default": "Ceramide · AHA · BHA · Glycolic Acid · Lactic Acid · Mandelic Acid · Peptides · Resveratrol · Zinc · セラミド · グリコール酸 · バクチオール · スクワラン · アゼライン酸 · センテラアジアティカ ·"
    },
    {
      "type": "range",
      "id": "ticker_speed",
      "label": "Ticker speed",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "s",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Hero - Fluxor"
    }
  ]
}
{% endschema %}
