{%- style -%}
  #HeroFluxor-{{ section.id }} {
    --overlay-opacity: {{ section.settings.image_overlay_opacity | default: 50 | divided_by: 100.0 }};
  }
{%- endstyle -%}

{{ 'section-hero-fluxor.css' | asset_url | stylesheet_tag }}

<hero-fluxor
  id="HeroFluxor-{{ section.id }}"
  class="hero-fluxor color-{{ section.settings.color_scheme }} gradient"
  data-duration="{{ section.settings.slide_duration | times: 1000 }}"
  tabindex="0"
  aria-label="Featured products slideshow"
>
  <div class="hero-fluxor__slides">
    {%- for block in section.blocks -%}
      <div
        class="hero-fluxor__slide{% if forloop.first %} is-active{% endif %}"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          <div
            class="hero-fluxor__bg"
            aria-hidden="true"
            style="background-image: url('{{ block.settings.image | image_url: width: 2400 }}');"
          ></div>
        {%- endif -%}

        <div class="hero-fluxor__content">
          {%- if block.settings.brand != blank -%}
            <p class="hero-fluxor__brand">{{ block.settings.brand | escape }}</p>
          {%- endif -%}

          {%- if block.settings.product_name != blank -%}
            <h2 class="hero-fluxor__product-name">{{ block.settings.product_name | escape }}</h2>
          {%- endif -%}

          {%- if block.settings.tagline != blank -%}
            <p class="hero-fluxor__tagline">{{ block.settings.tagline | escape }}</p>
          {%- endif -%}

          {%- if block.settings.button_label != blank -%}
            <a
              href="{{ block.settings.button_link | default: '#' }}"
              class="hero-fluxor__cta"
            >
              {{- block.settings.button_label | escape -}}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- else -%}
      <div class="hero-fluxor__slide is-active">
        <div class="hero-fluxor__content">
          <p class="hero-fluxor__brand">Brand Name</p>
          <h2 class="hero-fluxor__product-name">Product Name.</h2>
          <p class="hero-fluxor__tagline">Add slides from the theme editor.</p>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="hero-fluxor__dots" role="tablist" aria-label="Slides">
      {%- for block in section.blocks -%}
        <button
          class="hero-fluxor__dot{% if forloop.first %} is-active{% endif %}"
          role="tab"
          aria-label="{{ forloop.index }} / {{ section.blocks.size }}"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</hero-fluxor>

<script src="{{ 'hero-fluxor.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Hero - Fluxor",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "range",
      "id": "image_overlay_opacity",
      "label": "Image overlay opacity (mobile)",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "slide_duration",
      "label": "Auto-play duration",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        },
        {
          "type": "text",
          "id": "brand",
          "label": "Brand name",
          "default": "BRAND NAME"
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product name",
          "default": "Product Name."
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "Short description of the product."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero - Fluxor",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "brand": "BRAND NAME",
            "product_name": "Product Name.",
            "tagline": "Short description of the product.",
            "button_label": "Shop Now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
