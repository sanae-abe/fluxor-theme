{%- assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0 -%}

<section
  class="relative min-h-[619px] overflow-hidden"
  x-data="{
    current: 0,
    total: {{ section.blocks.size }},
    timer: null,
    speed: {{ section.settings.slide_speed | times: 1000 }},
    init() {
      if (this.total > 1) this.startAuto()
    },
    startAuto() {
      this.timer = setInterval(() => {
        this.current = (this.current + 1) % this.total
      }, this.speed)
    },
    goTo(i) {
      this.current = i
      clearInterval(this.timer)
      if (this.total > 1) this.startAuto()
    }
  }"
>

  <!-- ── 背景画像レイヤー ─────────────────────────────── -->
  {%- for block in section.blocks -%}
    <div
      class="absolute inset-0 transition-opacity duration-700"
      :class="current === {{ forloop.index0 }} ? 'opacity-100' : 'opacity-0'"
      {{ block.shopify_attributes }}
    >
      {%- if block.settings.image -%}
        <img
          src="{{ block.settings.image | image_url: width: 2400 }}"
          alt="{{ block.settings.heading | escape }}"
          class="absolute inset-0 w-full h-full object-cover"
          loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          {% if forloop.first %}fetchpriority="high"{% endif %}
          width="2400"
          height="1600"
        >
      {%- else -%}
        <div class="absolute inset-0 bg-stone-800"></div>
      {%- endif -%}

      <!-- オーバーレイ -->
      <div class="absolute inset-0 bg-black" style="opacity: {{ overlay_opacity }}"></div>
    </div>
  {%- endfor -%}

  <!-- ── コンテンツレイヤー ──────────────────────────── -->
  {%- for block in section.blocks -%}
    <div
      class="absolute inset-0 flex items-center transition-opacity duration-700"
      :class="current === {{ forloop.index0 }} ? 'opacity-100' : 'opacity-0 pointer-events-none'"
    >
      <div class="max-w-screen-xl mx-auto px-10 py-[60px] w-full">
        <div class="max-w-[640px] flex flex-col gap-8">

          <!-- テキストグループ -->
          <div class="flex flex-col gap-5">
            {%- if block.settings.eyebrow != blank -%}
              <p class="text-stone-50 text-base tracking-[1px]">{{ block.settings.eyebrow }}</p>
            {%- endif -%}

            {%- if block.settings.heading != blank -%}
              <h2 class="text-stone-50 text-[72px] font-semibold leading-[1.3]">
                {{ block.settings.heading }}
              </h2>
            {%- endif -%}

            {%- if block.settings.subheading != blank -%}
              <p class="text-stone-50 text-2xl leading-[1.5] opacity-80">
                {{ block.settings.subheading }}
              </p>
            {%- endif -%}
          </div>

          <!-- CTAボタン -->
          {%- if block.settings.cta_label != blank and block.settings.cta_url != blank -%}
            <a
              href="{{ block.settings.cta_url }}"
              class="inline-flex items-center gap-4 self-start border-2 border-stone-50 text-stone-50 px-5 py-[21px] text-xl font-medium min-w-[216px] hover:bg-stone-50 hover:text-stone-900 transition-colors duration-200"
              {% if block.settings.cta_target %}target="_blank" rel="noopener noreferrer"{% endif %}
            >
              <span>{{ block.settings.cta_label }}</span>
              {%- if block.settings.cta_icon -%}
                <img
                  src="{{ block.settings.cta_icon | image_url: width: 48 }}"
                  alt=""
                  class="w-6 h-6 flex-shrink-0"
                  aria-hidden="true"
                >
              {%- else -%}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              {%- endif -%}
            </a>
          {%- endif -%}

        </div>
      </div>
    </div>
  {%- endfor -%}

  <!-- ── スライドインジケーター ──────────────────────── -->
  {%- if section.blocks.size > 1 -%}
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex items-center gap-4 z-10">
      {%- for block in section.blocks -%}
        <button
          type="button"
          @click="goTo({{ forloop.index0 }})"
          class="rounded-full transition-all duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-stone-50 focus-visible:outline-offset-2"
          :class="current === {{ forloop.index0 }}
            ? 'w-4 h-4 bg-stone-50'
            : 'w-2.5 h-2.5 bg-stone-50/30 hover:bg-stone-50/60'"
          aria-label="{{ forloop.index }}枚目のスライドへ"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "オーバーレイの透明度",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "range",
      "id": "slide_speed",
      "label": "スライドの切替速度",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "秒",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "スライド",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "背景画像"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "アイキャッチラベル",
          "default": "FLUXOR"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "メインヘッドライン",
          "default": "Trusted Skincare, Curated."
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "サブヘッドライン",
          "default": "信頼できるものだけを、あなたへ。"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTAボタンのテキスト",
          "default": "コレクションを見る"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "CTAボタンのURL"
        },
        {
          "type": "image_picker",
          "id": "cta_icon",
          "label": "CTAボタンのアイコン画像（省略時は矢印）"
        },
        {
          "type": "checkbox",
          "id": "cta_target",
          "label": "リンクを別ウィンドウで開く",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
