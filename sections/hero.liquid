{%- assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0 -%}

<section
  class="relative hero-cinematic overflow-hidden"
  x-data="{
    current: 0,
    total: {{ section.blocks.size }},
    timer: null,
    speed: {{ section.settings.slide_speed | times: 1000 }},
    paused: false,
    init() {
      if (this.total > 1) {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          this.paused = true;
        } else {
          this.startAuto();
        }
      }
    },
    startAuto() {
      clearInterval(this.timer);
      if (!this.paused) {
        this.timer = setInterval(() => {
          this.current = (this.current + 1) % this.total;
        }, this.speed);
      }
    },
    togglePause() {
      this.paused = !this.paused;
      if (this.paused) {
        clearInterval(this.timer);
      } else {
        this.startAuto();
      }
    },
    goTo(i) {
      this.current = i;
      clearInterval(this.timer);
      if (this.total > 1) this.startAuto();
    }
  }"
>

  {%- comment %} スライド（背景 + コンテンツ） {%- endcomment -%}
  {%- for block in section.blocks -%}
    <div
      class="absolute inset-0 transition-opacity duration-700"
      :class="current === {{ forloop.index0 }} ? 'opacity-100' : 'opacity-0 pointer-events-none'"
      :aria-hidden="current !== {{ forloop.index0 }}"
      {{ block.shopify_attributes }}
    >
      {%- comment %} 背景画像 {%- endcomment -%}
      {%- if block.settings.image -%}
        <img
          src="{{ block.settings.image | image_url: width: 1800, format: 'webp' }}"
          srcset="{{ block.settings.image | image_url: width: 600, format: 'webp' }} 600w,
                  {{ block.settings.image | image_url: width: 900, format: 'webp' }} 900w,
                  {{ block.settings.image | image_url: width: 1200, format: 'webp' }} 1200w,
                  {{ block.settings.image | image_url: width: 1800, format: 'webp' }} 1800w,
                  {{ block.settings.image | image_url: width: 2400, format: 'webp' }} 2400w"
          sizes="100vw"
          alt="{{ block.settings.heading | escape }}"
          class="absolute inset-0 w-full h-full object-cover{% if forloop.first %} hero-image-entrance{% endif %}"
          loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          {% if forloop.first %}fetchpriority="high"{% endif %}
          width="2400"
          height="1600"
        >
      {%- else -%}
        <div class="absolute inset-0 bg-stone-800{% if forloop.first %} hero-image-entrance{% endif %}"></div>
      {%- endif -%}

      {%- comment %} オーバーレイ {%- endcomment -%}
      <div class="absolute inset-0 bg-black" style="opacity: {{ overlay_opacity }}"></div>

      {%- comment %} コンテンツ {%- endcomment -%}
      <div class="absolute inset-0 flex items-end px-4 md:px-10">
        <div class="max-w-screen-xl mx-auto py-10 md:py-20 w-full">
          <div
            class="max-w-[640px] flex flex-col gap-6 items-center md:items-start"
            :class="current === {{ forloop.index0 }} ? 'hero-slide-active' : ''"
          >

            {%- comment %} テキストグループ {%- endcomment -%}
            <div class="flex flex-col gap-5 items-center md:items-start">
              {%- if block.settings.eyebrow != blank -%}
                <p class="hero-text-item hero-text-eyebrow text-stone-50 text-sm md:text-base tracking-wider">{{ block.settings.eyebrow }}</p>
              {%- endif -%}

              {%- if block.settings.heading != blank -%}
                <h2 class="hero-text-item hero-text-heading hero-heading italic text-stone-50 text-4xl md:text-6xl leading-tight tracking-wide text-center md:text-left">
                  {{ block.settings.heading }}
                </h2>
              {%- endif -%}

              {%- if block.settings.subheading != blank -%}
                <p class="hero-text-item hero-text-subheading text-stone-50 text-base md:text-lg leading-tight">
                  {{ block.settings.subheading }}
                </p>
              {%- endif -%}
            </div>

            {%- comment %} CTAボタン {%- endcomment -%}
            {%- if block.settings.cta_label != blank and block.settings.cta_url != blank -%}
              {%- liquid
                assign cta_attr = ''
                if block.settings.cta_target
                  assign cta_attr = 'target="_blank" rel="noopener noreferrer"'
                endif
              -%}
              <div class="hero-text-item hero-text-cta">
                {%- render 'button',
                  label: block.settings.cta_label,
                  url: block.settings.cta_url,
                  variant: 'outline',
                  color: 'light',
                  size: 'md',
                  size_mobile: 'md',
                  icon_right: 'arrow-right',
                  attr: cta_attr
                -%}
              </div>
            {%- endif -%}

          </div>
        </div>
      </div>
    </div>
  {%- endfor -%}

  {%- comment %} スライドインジケーター {%- endcomment -%}
  {%- if section.blocks.size > 1 -%}
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex items-center gap-2 z-10">
      {%- for block in section.blocks -%}
        <button
          type="button"
          @click="goTo({{ forloop.index0 }})"
          class="hero-indicator rounded-full bg-stone-50/30 transition-[width,background-color] duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-stone-50 focus-visible:outline-offset-2"
          :class="current === {{ forloop.index0 }}
            ? 'w-8 h-2.5 bg-stone-50'
            : 'w-2.5 h-2.5'"
          :aria-current="current === {{ forloop.index0 }} ? 'true' : null"
          aria-label="{{ forloop.index }}枚目のスライドへ"
        ></button>
      {%- endfor -%}
      <button
        type="button"
        @click="togglePause()"
        class="ml-2 flex items-center justify-center w-7 h-7 rounded-full bg-stone-50/30 text-stone-50 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-stone-50 focus-visible:outline-offset-2"
        :aria-label="paused ? '自動スライドを再生' : '自動スライドを一時停止'"
        :aria-pressed="paused"
      >
        <template x-if="!paused">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" stroke="none" aria-hidden="true">
            <rect x="6" y="4" width="4" height="16" rx="1"/>
            <rect x="14" y="4" width="4" height="16" rx="1"/>
          </svg>
        </template>
        <template x-if="paused">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" stroke="none" aria-hidden="true">
            <polygon points="5,3 19,12 5,21"/>
          </svg>
        </template>
      </button>
    </div>
  {%- endif -%}

</section>

{%- schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "オーバーレイの透明度",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "range",
      "id": "slide_speed",
      "label": "スライドの切替速度",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "秒",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "スライド",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "背景画像"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "アイキャッチラベル",
          "default": "FLUXOR"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "メインヘッドライン",
          "default": "Trusted Skincare, Curated."
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "サブヘッドライン",
          "default": "信頼できるものだけを、あなたへ。"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTAボタンのテキスト",
          "default": "コレクションを見る"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "CTAボタンのURL"
        },
        {
          "type": "checkbox",
          "id": "cta_target",
          "label": "リンクを別ウィンドウで開く",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ]
}
{%- endschema -%}
