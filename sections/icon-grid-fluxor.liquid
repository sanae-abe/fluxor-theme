{{ 'icon-grid-fluxor.css' | asset_url | stylesheet_tag }}

{%- assign columns = section.settings.columns | default: 3 -%}
{%- assign card_style = section.settings.card_style | default: 'plain' -%}
{%- assign container_width = section.settings.container_width | default: 'wide' -%}

<div
  class="icon-grid-fluxor color-{{ section.settings.color_scheme }} gradient"
  style="
    --icon-grid-columns: {{ columns }};
    --icon-grid-container-max-width: {% if container_width == 'narrow' %}50rem{% else %}75rem{% endif %};
  "
>
  <div class="icon-grid-fluxor__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="icon-grid-fluxor__heading">
        {{- section.settings.heading | escape -}}
      </h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="icon-grid-fluxor__description">
        {{- section.settings.description | escape -}}
      </p>
    {%- endif -%}

    <div class="icon-grid-fluxor__grid{% if card_style == 'bordered' %} icon-grid-fluxor__grid--bordered{% endif %}">
      {%- for block in section.blocks -%}
        <div class="icon-grid-fluxor__item{% if card_style == 'bordered' %} icon-grid-fluxor__item--bordered{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div class="icon-grid-fluxor__icon">
              <img
                src="{{ block.settings.icon | image_url: width: 64 }}"
                alt="{{ block.settings.title | escape }}"
                width="32"
                height="32"
                loading="lazy"
              />
            </div>
          {%- endif -%}

          {%- if block.settings.title != blank -%}
            <h3 class="icon-grid-fluxor__title">
              {{- block.settings.title | escape -}}
            </h3>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p class="icon-grid-fluxor__text">
              {{- block.settings.description | escape | newline_to_br -}}
            </p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Icon Grid - Fluxor",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "見出しを入力"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "説明文",
      "default": "説明文を入力"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "列数",
      "options": [
        { "value": "2", "label": "2列" },
        { "value": "3", "label": "3列" },
        { "value": "4", "label": "4列" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "カードスタイル",
      "options": [
        { "value": "plain", "label": "枠なし" },
        { "value": "bordered", "label": "枠あり" }
      ],
      "default": "plain"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "コンテナ幅",
      "options": [
        { "value": "narrow", "label": "狭め（50rem）" },
        { "value": "wide", "label": "広め（75rem）" }
      ],
      "default": "wide"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "アイテム",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "アイコン画像"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "タイトル"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "説明",
          "default": "説明文を入力"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon Grid - Fluxor",
      "settings": {
        "heading": "見出しを入力",
        "columns": "3",
        "card_style": "plain",
        "container_width": "wide"
      },
      "blocks": [
        { "type": "item", "settings": { "title": "項目1", "description": "説明文" } },
        { "type": "item", "settings": { "title": "項目2", "description": "説明文" } },
        { "type": "item", "settings": { "title": "項目3", "description": "説明文" } }
      ]
    }
  ]
}
{% endschema %}
