{%- assign img_left = true -%}
{%- if section.settings.image_position == 'right' -%}
  {%- assign img_left = false -%}
{%- endif -%}

<section class="{{ section.settings.color_scheme }} pb-10 md:pt-[60px] md:pb-[60px]">

  <div class="flex flex-col {% if img_left %}md:flex-row{% else %}md:flex-row-reverse{% endif %} items-center gap-10">

    {%- comment %} 画像 {%- endcomment %}
    <div class="md:w-1/2 flex-shrink-0">
      {%- if section.settings.image != blank -%}
        <div class="w-full aspect-[640/427] overflow-hidden [transform:translateZ(0)]">
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.image.alt | escape | default: section.settings.heading | escape }}"
            class="w-full h-full object-cover"
            loading="lazy"
            width="800"
            height="534"
          >
        </div>
      {%- else -%}
        <div class="w-full aspect-[640/427] bg-stone-100 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
      {%- endif -%}
    </div>

    {%- comment %} テキスト {%- endcomment %}
    <div class="md:w-1/2 flex flex-col gap-10 px-4 md:px-10 max-w-[640px]">

      {%- comment %} バッジ + 見出し {%- endcomment %}
      <div class="flex flex-col items-start gap-4">
        {%- if section.settings.badge_label != blank -%}
          {% render 'badge',
            label: section.settings.badge_label,
            variant: section.settings.badge_variant,
            size: 'md',
            icon_left: section.settings.badge_icon_left,
            icon_right: section.settings.badge_icon_right
          %}
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="text-2xl md:text-4xl font-semibold leading-tight text-stone-900 palt tracking-wider">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- comment %} 本文（リスト含む） {%- endcomment %}
        {%- if section.settings.paragraph != blank -%}
          <div class="text-base leading-relaxed text-stone-900 [&_p]:mb-0 [&_ul]:list-disc [&_ul]:pl-6 [&_li]:mb-1 [&_li:last-child]:mb-0">
            {{ section.settings.paragraph }}
          </div>
        {%- endif -%}
      </div>

      {%- comment %} ボタン {%- endcomment %}
      {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
        <div class="flex justify-center md:justify-start">
          {%- render 'button',
            label: section.settings.button_label,
            url: section.settings.button_url,
            variant: 'outline',
            color: 'dark',
            icon_left: section.settings.button_icon_left,
            icon_right: section.settings.button_icon_right,
            class: 'self-start'
          -%}
        </div>
      {%- endif -%}

    </div>

  </div>
</section>

