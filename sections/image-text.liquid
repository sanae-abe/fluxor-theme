{%- liquid
  assign s        = section.settings
  assign flex_dir = 'md:flex-row'
  if s.image_position == 'right'
    assign flex_dir = 'md:flex-row-reverse'
  endif
-%}

<section class="{{ s.color_scheme }} pb-10 md:pt-[60px] md:pb-[60px]">

  <div class="flex flex-col {{ flex_dir }} items-center gap-6 md:gap-10">

    <div class="md:w-1/2 flex-shrink-0">
      {%- if s.image != blank -%}
        <div class="w-full aspect-[640/427] overflow-hidden [transform:translateZ(0)]">
          <img
            src="{{ s.image | image_url: width: 800 }}"
            alt="{{ s.image.alt | escape | default: s.heading | escape }}"
            class="w-full h-full object-cover"
            loading="lazy"
            width="800"
            height="534"
          >
        </div>
      {%- else -%}
        <div class="w-full aspect-[640/427] bg-stone-100 flex items-center justify-center">
          {%- render 'icon', icon: 'image', class: 'w-16 h-16 text-stone-300' -%}
        </div>
      {%- endif -%}
    </div>

    <div class="md:w-1/2 flex flex-col gap-10 px-4 md:px-10 max-w-[640px]">

      <div class="flex flex-col items-center md:items-start gap-5">
        {%- if s.badge_label != blank -%}
          {%- render 'badge',
            label: s.badge_label,
            variant: s.badge_variant,
            size: 'md',
            icon_left: s.badge_icon_left,
            icon_right: s.badge_icon_right
          -%}
        {%- endif -%}
        {%- if s.heading != blank -%}
          <h2 class="text-2xl md:text-4xl font-semibold leading-tight text-stone-900 palt tracking-wider">
            {{ s.heading }}
          </h2>
        {%- endif -%}
        {%- if s.paragraph != blank -%}
          <div class="text-base leading-relaxed text-stone-900 [&_p]:mb-0 [&_ul]:list-disc [&_ul]:pl-6 [&_li]:mb-1 [&_li:last-child]:mb-0">
            {{ s.paragraph }}
          </div>
        {%- endif -%}
      </div>

      {%- if s.button_label != blank and s.button_url != blank -%}
        <div class="flex w-full md:justify-start">
          {%- render 'button',
            label: s.button_label,
            url: s.button_url,
            variant: 'outline',
            color: 'dark',
            icon_left: s.button_icon_left,
            icon_right: s.button_icon_right,
            class: 'self-start w-full md:w-auto'
          -%}
        </div>
      {%- endif -%}

    </div>

  </div>
</section>

