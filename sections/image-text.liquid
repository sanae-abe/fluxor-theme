{%- assign img_left = true -%}
{%- if section.settings.image_position == 'right' -%}
  {%- assign img_left = false -%}
{%- endif -%}

<section class="{{ section.settings.color_scheme }} px-10 py-[60px]">
  <div class="max-w-screen-xl mx-auto">

    <div class="flex {% if img_left %}flex-row{% else %}flex-row-reverse{% endif %} items-center gap-10">

      <!-- 画像 -->
      <div class="w-1/2 flex-shrink-0">
        {%- if section.settings.image != blank -%}
          <div class="w-full aspect-[640/427] rounded-2xl overflow-hidden [transform:translateZ(0)]">
            <img
              src="{{ section.settings.image | image_url: width: 800 }}"
              alt="{{ section.settings.image.alt | escape | default: section.settings.heading | escape }}"
              class="w-full h-full object-cover"
              loading="lazy"
              width="800"
              height="534"
            >
          </div>
        {%- else -%}
          <div class="w-full aspect-[640/427] rounded-2xl bg-stone-100 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
        {%- endif -%}
      </div>

      <!-- テキスト -->
      <div class="w-1/2 flex flex-col gap-8">

        <!-- バッジ + 見出し -->
        <div class="flex flex-col gap-4">
          {%- if section.settings.badge_label != blank -%}
            <div class="inline-flex items-center gap-2 px-3 py-[2px] rounded-full bg-[#f0fdfa] self-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#0b4f4a] flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M7 2a1 1 0 00-.707 1.707L7 4.414v3.758a1 1 0 01-.293.707l-4 4C.817 14.769 2.156 18 4.828 18h10.343c2.673 0 4.012-3.231 2.122-5.121l-4-4A1 1 0 0113 8.172V4.414l.707-.707A1 1 0 0013 2H7zm2 6.172V4h2v4.172a3 3 0 00.879 2.12l1.027 1.028a4 4 0 00-2.171.102l-.47.156a4 4 0 01-2.53 0l-.563-.187a1.993 1.993 0 00-.114-.035l1.063-1.063A3 3 0 009 8.172z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm font-medium leading-[21px] text-[#0b4f4a] uppercase">{{ section.settings.badge_label }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="text-[42px] font-semibold leading-[1.5] text-stone-900">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}
        </div>

        <!-- 本文（リスト含む） -->
        {%- if section.settings.paragraph != blank -%}
          <div class="text-base leading-[1.7] text-stone-900 [&_p]:mb-0 [&_ul]:list-disc [&_ul]:pl-6 [&_li]:mb-1 [&_li:last-child]:mb-0">
            {{ section.settings.paragraph }}
          </div>
        {%- endif -%}

        <!-- ボタン -->
        {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
          <a
            href="{{ section.settings.button_url }}"
            class="self-start inline-flex items-center gap-3 border-2 border-stone-900 text-stone-900 px-[18px] py-3 min-h-[60px] min-w-[180px] justify-center hover:bg-stone-900 hover:text-stone-50 transition-colors duration-200"
          >
            <span class="text-lg font-medium">{{ section.settings.button_label }}</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        {%- endif -%}

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ingredient",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "背景色",
      "options": [
        { "value": "bg-white", "label": "ホワイト（デフォルト）" },
        { "value": "bg-stone-50", "label": "ライト" },
        { "value": "bg-stone-100", "label": "ライトグレー" },
        { "value": "bg-stone-200", "label": "グレー" },
        { "value": "bg-stone-950", "label": "ダーク" }
      ],
      "default": "bg-white"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "画像位置",
      "options": [
        { "value": "left", "label": "左" },
        { "value": "right", "label": "右" }
      ],
      "default": "left"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "画像"
    },
    {
      "type": "text",
      "id": "badge_label",
      "label": "バッジテキスト",
      "default": "Ingredient"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "レチノール"
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "本文（箇条書き可）",
      "default": "<p>科学的に研究が進む美容成分の一つ。使い続けることで肌のキメを整え、うるおいとともにハリ感をサポートします。</p>"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "ボタンのリンク先"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "ボタンテキスト",
      "default": "成分について詳しく見る"
    }
  ],
  "presets": [
    {
      "name": "Ingredient"
    }
  ]
}
{% endschema %}
