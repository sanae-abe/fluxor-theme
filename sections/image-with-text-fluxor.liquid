{{ 'image-with-text-fluxor.css' | asset_url | stylesheet_tag }}

<div
  id="ImageWithText-{{ section.id }}"
  class="image-with-text-fluxor color-{{ section.settings.color_scheme }} gradient{% if section.settings.image_position == 'right' %} image-with-text-fluxor--image-right{% endif %}"
>
  <div class="image-with-text-fluxor__container">

    <!-- 右側: 分子構造画像 -->
    <div class="image-with-text-fluxor__image">
      {%- if section.settings.molecule_image != blank -%}
        {{
          section.settings.molecule_image
          | image_url: width: 1280
          | image_tag:
            class: 'image-with-text-fluxor__img',
            loading: 'lazy',
            alt: section.settings.heading
        }}
      {%- endif -%}
    </div>
    <!-- 左側: テキストコンテンツ -->
    <div class="image-with-text-fluxor__content">
      <div class="image-with-text-fluxor__inner">
        {%- if section.settings.subtitle != blank -%}
          <div class="image-with-text-fluxor__subtitle">
            {{- section.settings.subtitle | escape -}}
          </div>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="image-with-text-fluxor__heading image-with-text-fluxor__heading--{{ section.settings.heading_font }}">
            {{- section.settings.heading | escape -}}
          </h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="image-with-text-fluxor__body">
            {{ section.settings.body }}
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="image-with-text-fluxor__cta"
        >
          {{- section.settings.button_label | escape -}}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with Text",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "画像"
    },
    {
      "type": "image_picker",
      "id": "molecule_image",
      "label": "画像"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "画像の位置",
      "options": [
        { "value": "right", "label": "右" },
        { "value": "left", "label": "左" }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "コンテンツ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "私たちは成分を読む。"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "小見出し",
      "default": "Key Ingredient"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "見出しフォント",
      "options": [
        { "value": "brand", "label": "ブランド体（Shippori Mincho / serif）" },
        { "value": "heading", "label": "見出し体（Outfit / sans-serif）" }
      ],
      "default": "brand"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "本文"
    },
    {
      "type": "header",
      "content": "ボタン（任意）"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "ボタンテキスト",
      "default": "ブランドストーリー"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "ボタンリンク"
    }
  ],
  "presets": [
    {
      "name": "Image with Text"
    }
  ]
}
{% endschema %}
