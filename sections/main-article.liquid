{%- comment %} ── Header ────────────────────────────────────────── {%- endcomment -%}
<div class="w-full bg-stone-50 flex flex-col items-center px-4 md:px-10">

  <div class="w-full border-b border-stone-200 flex items-center pb-5 pt-10">
    <a
      href="{{ blog.url }}"
      class="link-back inline-flex items-center gap-1 text-sm text-stone-500"
    >
      {%- render 'icon', icon: 'arrow-left', class: 'link-back__icon w-5 h-5 flex-shrink-0', stroke_width: 1.5 -%}
      <span>記事一覧に戻る</span>
    </a>
  </div>

  <div class="w-full max-w-[768px] flex flex-col gap-10 pt-8 pb-10">
    <h1 class="text-3xl font-semibold leading-snug text-stone-900">{{ article.title }}</h1>
    <div class="flex items-center justify-between w-full gap-4 flex-wrap">
      {%- if article.tags.size > 0 -%}
        <div class="flex gap-3 items-center flex-wrap">
          {%- for tag in article.tags -%}
            {%- render 'badge', label: tag, variant: 'secondary', size: 'sm' -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div></div>
      {%- endif -%}
      <p class="text-sm font-medium text-stone-900 shrink-0">PUBLISHED: {{ article.published_at | date: '%Y/%m/%d' }}</p>
    </div>
  </div>

  {%- if article.image -%}
    <div class="w-full max-w-[768px] overflow-hidden">
      <img
        src="{{ article.image | image_url: width: 1200, format: 'webp' }}"
        srcset="{{ article.image | image_url: width: 1200, format: 'webp' }} 1x, {{ article.image | image_url: width: 2400, format: 'webp' }} 2x"
        alt="{{ article.image.alt | default: article.title | escape }}"
        class="w-full h-auto object-cover"
        loading="eager"
        fetchpriority="high"
        width="1200"
        height="800"
      >
    </div>
  {%- else -%}
    <div class="w-full max-w-[768px] aspect-[3/2] bg-stone-200"></div>
  {%- endif -%}

</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "ホーム", "item": {{ shop.url | json }}},
    {"@type": "ListItem", "position": 2, "name": {{ blog.title | json }}, "item": {{ shop.url | append: blog.url | json }}},
    {"@type": "ListItem", "position": 3, "name": {{ article.title | json }}, "item": {{ shop.url | append: article.url | json }}}
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title | json }},
  "description": {{ article.excerpt | strip_html | json }},
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S+09:00' }}",
  "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S+09:00' }}",
  "url": {{ shop.url | append: article.url | json }},
  "author": {
    "@type": "Organization",
    "name": {{ shop.name | json }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ shop.name | json }}
  }{%- if article.image -%},
  "image": {{ article.image | image_url: width: 1200 | json }}{%- endif -%}
}
</script>

{%- comment %} ── 本文 ──────────────────────────────────────────── {%- endcomment -%}
<div class="w-full flex flex-col items-center px-4 md:px-10 py-20">
  <div class="w-full max-w-[768px] text-base leading-[1.75] text-stone-900 rte">
    {{ article.content }}
  </div>
</div>

{%- comment %} ── ブロックレンダリング ─────────────────────────── {%- endcomment -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'references' -%}
    {%- assign reference_entries = article.metafields.custom.reference_entry.value -%}
    <div class="w-full bg-stone-100 flex flex-col items-center px-4 md:px-10 py-10 md:py-[60px]" {{ block.shopify_attributes }}>
      <div class="w-full max-w-[768px] flex flex-col gap-5">
        {%- if block.settings.heading != blank -%}
          <p class="text-base font-medium text-stone-900">{{ block.settings.heading }}</p>
        {%- endif -%}
        {%- if reference_entries != blank -%}
          <ol class="flex flex-col gap-2 list-none">
            {%- for entry in reference_entries -%}
              <li class="flex gap-3">
                <span class="text-base text-stone-400 shrink-0 pt-0.5 min-w-[1.5rem] tabular-nums">{{ forloop.index }}.</span>
                <div class="flex flex-col gap-1 min-w-0">
                  {%- if entry.url != blank -%}
                    <a href="{{ entry.url }}" target="_blank" rel="noopener noreferrer" class="text-base font-medium text-stone-900 underline decoration-stone-400 underline-offset-2">{{ entry.title }}</a>
                  {%- else -%}
                    <p class="text-base font-medium text-stone-900">{{ entry.title }}</p>
                  {%- endif -%}
                  {%- liquid
                    assign meta_parts = ''
                    if entry.authors != blank
                      assign meta_parts = entry.authors
                    endif
                    if entry.journal != blank
                      if meta_parts != blank
                        assign meta_parts = meta_parts | append: ' / ' | append: entry.journal
                      else
                        assign meta_parts = entry.journal
                      endif
                    endif
                    if entry.details != blank
                      if meta_parts != blank
                        assign meta_parts = meta_parts | append: ', ' | append: entry.details
                      else
                        assign meta_parts = entry.details
                      endif
                    endif
                  -%}
                  {%- if meta_parts != blank -%}
                    <p class="text-sm text-stone-500">{{ meta_parts }}</p>
                  {%- endif -%}
                  {%- if entry.accessed_on != blank -%}
                    <p class="text-sm text-stone-500">[アクセス日：{{ entry.accessed_on }}]</p>
                  {%- endif -%}
                </div>
              </li>
            {%- endfor -%}
          </ol>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'related_articles' -%}
    {%- liquid
      assign related_limit = block.settings.count | default: 4
      assign related_fetch_limit = related_limit | plus: 1
      assign rendered_count = 0
    -%}
    <section class="w-full bg-stone-100 flex flex-col gap-10 items-center overflow-hidden px-4 md:px-10 py-[60px]" {{ block.shopify_attributes }}>
      <div class="w-full max-w-screen-xl flex flex-col gap-10">
        {%- if block.settings.heading != blank -%}
          <h2 class="text-4xl font-semibold tracking-wider text-stone-900 text-center">{{ block.settings.heading }}</h2>
        {%- endif -%}
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-8 md:gap-x-10 md:gap-y-8">
          {%- for related_article in blog.articles limit: related_fetch_limit -%}
            {%- unless related_article.id == article.id -%}
              {%- if rendered_count < related_limit -%}
                {%- render 'card-article', article: related_article -%}
                {%- assign rendered_count = rendered_count | plus: 1 -%}
              {%- endif -%}
            {%- endunless -%}
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}
{%- endfor -%}

{%- schema %}
{
  "name": "Journal 記事",
  "blocks": [
    {
      "type": "references",
      "name": "参考文献",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "見出し",
          "default": "参考文献"
        }
      ]
    },
    {
      "type": "related_articles",
      "name": "関連記事",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "見出し",
          "default": "関連記事"
        },
        {
          "type": "range",
          "id": "count",
          "label": "表示件数",
          "min": 2,
          "max": 8,
          "step": 1,
          "default": 4
        }
      ]
    }
  ],
  "settings": [],
  "presets": [
    {
      "name": "Journal 記事"
    }
  ]
}
{%- endschema -%}
