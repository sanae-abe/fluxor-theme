{%- comment %}
  Journal 記事 (main-article.liquid)

  対応メタフィールド (名前空間: custom):
    category_tags   {list.single_line_text_field}   カテゴリタグ一覧
{%- endcomment -%}

{%- liquid
  assign category_tags = article.metafields.custom.category_tags.value
-%}

{%- comment %} ── Header ────────────────────────────────────────── {%- endcomment -%}
<div class="w-full bg-stone-50 flex flex-col items-center px-4 md:px-10">

  <div class="w-full border-b border-stone-200 flex items-center pb-5 pt-10">
    <a
      href="{{ blog.url }}"
      class="link-back inline-flex items-center gap-1 text-sm text-stone-500"
    >
      {%- render 'icon', icon: 'arrow-left', class: 'link-back__icon w-5 h-5 flex-shrink-0', stroke_width: 1.5 -%}
      <span>記事一覧に戻る</span>
    </a>
  </div>

  <div class="w-full max-w-[768px] flex flex-col gap-10 pt-8 pb-10">
    <h1 class="text-3xl font-semibold leading-snug text-stone-900">{{ article.title }}</h1>


    <div class="flex items-center justify-between w-full gap-4 flex-wrap">
      <div class="flex gap-3 items-center flex-wrap">
        {%- for tag in category_tags limit: 4 -%}
          {%- render 'badge', label: tag, variant: 'secondary', size: 'sm' -%}
        {%- endfor -%}
        {%- if article.tags != blank -%}
          <span class="text-stone-300 select-none">|</span>
          {%- for tag in article.tags limit: 4 -%}
            {%- render 'badge', label: tag, variant: 'secondary', size: 'sm' -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
      <p class="text-sm font-medium text-stone-900 shrink-0">PUBLISHED: {{ article.published_at | date: '%Y/%m/%d' }}</p>
    </div>
  </div>

  {%- if article.image -%}
    <div class="w-full max-w-[768px] overflow-hidden">
      <img
        src="{{ article.image | image_url: width: 1200, format: 'webp' }}"
        srcset="{{ article.image | image_url: width: 1200, format: 'webp' }} 1x, {{ article.image | image_url: width: 2400, format: 'webp' }} 2x"
        alt="{{ article.image.alt | default: article.title | escape }}"
        class="w-full h-auto object-cover"
        loading="eager"
        fetchpriority="high"
        width="1200"
        height="800"
      >
    </div>
  {%- else -%}
    <div class="w-full max-w-[768px] aspect-[3/2] bg-stone-200"></div>
  {%- endif -%}

</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "ホーム", "item": {{ shop.url | json }}},
    {"@type": "ListItem", "position": 2, "name": {{ blog.title | json }}, "item": {{ shop.url | append: blog.url | json }}},
    {"@type": "ListItem", "position": 3, "name": {{ article.title | json }}, "item": {{ shop.url | append: article.url | json }}}
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title | json }},
  "description": {{ article.excerpt | strip_html | json }},
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S+09:00' }}",
  "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S+09:00' }}",
  "url": {{ shop.url | append: article.url | json }},
  "author": {
    "@type": "Organization",
    "name": {{ shop.name | json }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ shop.name | json }}
  }{%- if article.image -%},
  "image": {{ article.image | image_url: width: 1200 | json }}{%- endif -%}
}
</script>

{%- comment %} ── 本文 ──────────────────────────────────────────── {%- endcomment -%}
<div class="w-full flex flex-col items-center px-4 md:px-10 py-20">
  <div class="w-full max-w-[768px] text-base leading-[1.75] text-stone-900 rte">
    {{ article.content }}
  </div>
</div>

{%- comment %} ── ブロックレンダリング ─────────────────────────── {%- endcomment -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'references' -%}
    {%- assign reference_entries = article.metafields.custom.reference_entry.value -%}
    {%- if reference_entries != blank -%}
    <div class="w-full bg-stone-100 flex flex-col items-center px-4 md:px-10 py-10 md:py-[60px]" {{ block.shopify_attributes }}>
      <div class="w-full max-w-[768px] flex flex-col gap-5">
        {%- if block.settings.heading != blank -%}
          <p class="text-base font-medium text-stone-900">{{ block.settings.heading }}</p>
        {%- endif -%}
          <ol class="flex flex-col gap-2 list-none">
            {%- for entry in reference_entries -%}
              <li class="flex gap-3">
                <span class="text-base text-stone-400 shrink-0 pt-0.5 min-w-[1.5rem] tabular-nums">{{ forloop.index }}.</span>
                <div class="flex flex-col gap-1 min-w-0">
                  {%- if entry.url != blank -%}
                    <a href="{{ entry.url }}" target="_blank" rel="noopener noreferrer" class="text-base font-medium text-stone-900 underline decoration-stone-400 underline-offset-2">{{ entry.title }}</a>
                  {%- else -%}
                    <p class="text-base font-medium text-stone-900">{{ entry.title }}</p>
                  {%- endif -%}
                  {%- liquid
                    assign meta_parts = ''
                    if entry.authors != blank
                      assign meta_parts = entry.authors
                    endif
                    if entry.journal != blank
                      if meta_parts != blank
                        assign meta_parts = meta_parts | append: ' / ' | append: entry.journal
                      else
                        assign meta_parts = entry.journal
                      endif
                    endif
                    if entry.details != blank
                      if meta_parts != blank
                        assign meta_parts = meta_parts | append: ', ' | append: entry.details
                      else
                        assign meta_parts = entry.details
                      endif
                    endif
                  -%}
                  {%- if meta_parts != blank -%}
                    <p class="text-sm text-stone-500">{{ meta_parts }}</p>
                  {%- endif -%}
                  {%- if entry.accessed_on != blank -%}
                    <p class="text-sm text-stone-500">[アクセス日：{{ entry.accessed_on }}]</p>
                  {%- endif -%}
                </div>
              </li>
            {%- endfor -%}
          </ol>
      </div>
    </div>
    {%- endif -%}

  {%- elsif block.type == 'product_grid' -%}
    {%- liquid
      assign fc_max = 4
      assign fc_ids = ','
      assign fc_count = 0
      assign fc_ref_products = article.metafields.custom.product_reference.value
      assign fc_skin_concerns = article.metafields.custom.skin_concerns.value
      assign fc_collection = collections[block.settings.collection]
    -%}
    {%- capture product_cards -%}
      {%- comment %} Priority 1: product_reference {%- endcomment -%}
      {%- if fc_ref_products != blank -%}
        {%- for product in fc_ref_products -%}
          {%- if fc_count < fc_max -%}
            {%- assign id_with_sep = product.id | prepend: ',' | append: ',' -%}
            {%- unless fc_ids contains id_with_sep -%}
              {%- render 'card-product-4col', product: product -%}
              {%- assign fc_ids = fc_ids | append: product.id | append: ',' -%}
              {%- assign fc_count = fc_count | plus: 1 -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- comment %} Priority 2: skin_concerns が同じ商品（featured collection 内） {%- endcomment -%}
      {%- if fc_count < fc_max and fc_collection != blank and fc_skin_concerns != blank -%}
        {%- for product in fc_collection.products -%}
          {%- if fc_count < fc_max -%}
            {%- assign id_with_sep = product.id | prepend: ',' | append: ',' -%}
            {%- unless fc_ids contains id_with_sep -%}
              {%- assign product_concerns = product.metafields.custom.skin_concerns.value -%}
              {%- assign has_match = false -%}
              {%- if product_concerns != blank -%}
                {%- for concern in fc_skin_concerns -%}
                  {%- if product_concerns contains concern -%}
                    {%- assign has_match = true -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {%- if has_match -%}
                {%- render 'card-product-4col', product: product -%}
                {%- assign fc_ids = fc_ids | append: product.id | append: ',' -%}
                {%- assign fc_count = fc_count | plus: 1 -%}
              {%- endif -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- comment %} Priority 3: featured collection の残り商品 {%- endcomment -%}
      {%- if fc_count < fc_max and fc_collection != blank -%}
        {%- for product in fc_collection.products -%}
          {%- if fc_count < fc_max -%}
            {%- assign id_with_sep = product.id | prepend: ',' | append: ',' -%}
            {%- unless fc_ids contains id_with_sep -%}
              {%- render 'card-product-4col', product: product -%}
              {%- assign fc_ids = fc_ids | append: product.id | append: ',' -%}
              {%- assign fc_count = fc_count | plus: 1 -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endcapture -%}
    {%- if fc_count > 0 -%}
      <section class="w-full bg-stone-100 flex flex-col gap-10 items-center overflow-hidden px-4 md:px-10 py-[60px]" {{ block.shopify_attributes }}>
        <div class="w-full max-w-screen-xl flex flex-col gap-10">
          {%- if block.settings.heading != blank -%}
            <h2 class="text-4xl font-semibold tracking-wider text-stone-900 text-center">{{ block.settings.heading }}</h2>
          {%- endif -%}
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-6 md:gap-6">
            {{ product_cards }}
          </div>
        </div>
      </section>
    {%- endif -%}

  {%- elsif block.type == 'related_ingredients' -%}
    {%- liquid
      assign ri_limit = block.settings.count | default: 4
      assign ri_fetch = 50
      assign ri_count = 0
      assign ri_seen = ','
      assign ri_blog = blogs[block.settings.blog]
      assign current_category_tags = article.metafields.custom.category_tags.value
    -%}
    {%- capture ri_cards -%}
      {%- comment %} Priority 1: category_tags が一致する成分記事 {%- endcomment -%}
      {%- if ri_blog != blank and current_category_tags != blank -%}
        {%- for candidate in ri_blog.articles limit: ri_fetch -%}
          {%- if ri_count < ri_limit -%}
            {%- assign id_sep = candidate.id | prepend: ',' | append: ',' -%}
            {%- unless ri_seen contains id_sep -%}
              {%- assign candidate_tags = candidate.metafields.custom.category_tags.value -%}
              {%- assign has_match = false -%}
              {%- if candidate_tags != blank -%}
                {%- for tag in current_category_tags -%}
                  {%- if candidate_tags contains tag -%}
                    {%- assign has_match = true -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {%- if has_match -%}
                {%- render 'card-ingredient', article: candidate -%}
                {%- assign ri_seen = ri_seen | append: candidate.id | append: ',' -%}
                {%- assign ri_count = ri_count | plus: 1 -%}
              {%- endif -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- comment %} Fallback: 残り枠をその他成分記事で補充 {%- endcomment -%}
      {%- if ri_count < ri_limit and ri_blog != blank -%}
        {%- for candidate in ri_blog.articles limit: ri_fetch -%}
          {%- if ri_count < ri_limit -%}
            {%- assign id_sep = candidate.id | prepend: ',' | append: ',' -%}
            {%- unless ri_seen contains id_sep -%}
              {%- render 'card-ingredient', article: candidate -%}
              {%- assign ri_seen = ri_seen | append: candidate.id | append: ',' -%}
              {%- assign ri_count = ri_count | plus: 1 -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endcapture -%}
    {%- if ri_count > 0 -%}
      <section class="w-full bg-stone-100 flex flex-col gap-10 items-center overflow-hidden px-4 md:px-10 py-[60px]" {{ block.shopify_attributes }}>
        <div class="w-full max-w-screen-xl flex flex-col gap-10">
          {%- if block.settings.heading != blank -%}
            <h2 class="text-4xl font-semibold tracking-wider text-stone-900 text-center">{{ block.settings.heading }}</h2>
          {%- endif -%}
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-8 md:gap-x-10 md:gap-y-8">
            {{ ri_cards }}
          </div>
        </div>
      </section>
    {%- endif -%}

  {%- elsif block.type == 'related_articles' -%}
    {%- liquid
      assign related_limit = block.settings.count | default: 4
      assign fetch_limit = 50
      assign rendered_count = 0
      assign seen_ids = ','
      assign current_category_tags = article.metafields.custom.category_tags.value
      assign current_skin_concerns = article.metafields.custom.skin_concerns.value
    -%}
    {%- capture related_cards -%}
      {%- comment %} Priority 1: category_tags が一致する記事 {%- endcomment -%}
      {%- for candidate in blog.articles limit: fetch_limit -%}
        {%- unless candidate.id == article.id -%}
          {%- if rendered_count < related_limit -%}
            {%- liquid
              assign candidate_tags = candidate.metafields.custom.category_tags.value
              assign has_match = false
              if current_category_tags != blank and candidate_tags != blank
                for tag in current_category_tags
                  if candidate_tags contains tag
                    assign has_match = true
                  endif
                endfor
              endif
            -%}
            {%- if has_match -%}
              {%- assign id_sep = candidate.id | prepend: ',' | append: ',' -%}
              {%- unless seen_ids contains id_sep -%}
                {%- render 'card-article', article: candidate -%}
                {%- assign seen_ids = seen_ids | append: candidate.id | append: ',' -%}
                {%- assign rendered_count = rendered_count | plus: 1 -%}
              {%- endunless -%}
            {%- endif -%}
          {%- endif -%}
        {%- endunless -%}
      {%- endfor -%}
      {%- comment %} Priority 2: skin_concerns が一致する記事（残り枠を補充） {%- endcomment -%}
      {%- if rendered_count < related_limit -%}
        {%- for candidate in blog.articles limit: fetch_limit -%}
          {%- unless candidate.id == article.id -%}
            {%- if rendered_count < related_limit -%}
              {%- assign id_sep = candidate.id | prepend: ',' | append: ',' -%}
              {%- unless seen_ids contains id_sep -%}
                {%- liquid
                  assign candidate_concerns = candidate.metafields.custom.skin_concerns.value
                  assign has_match = false
                  if current_skin_concerns != blank and candidate_concerns != blank
                    for concern in current_skin_concerns
                      if candidate_concerns contains concern
                        assign has_match = true
                      endif
                    endfor
                  endif
                -%}
                {%- if has_match -%}
                  {%- render 'card-article', article: candidate -%}
                  {%- assign seen_ids = seen_ids | append: candidate.id | append: ',' -%}
                  {%- assign rendered_count = rendered_count | plus: 1 -%}
                {%- endif -%}
              {%- endunless -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
      {%- comment %} Priority 3 & 4: 新着・その他記事（残り枠を補充） {%- endcomment -%}
      {%- if rendered_count < related_limit -%}
        {%- for candidate in blog.articles limit: fetch_limit -%}
          {%- unless candidate.id == article.id -%}
            {%- if rendered_count < related_limit -%}
              {%- assign id_sep = candidate.id | prepend: ',' | append: ',' -%}
              {%- unless seen_ids contains id_sep -%}
                {%- render 'card-article', article: candidate -%}
                {%- assign seen_ids = seen_ids | append: candidate.id | append: ',' -%}
                {%- assign rendered_count = rendered_count | plus: 1 -%}
              {%- endunless -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endcapture -%}
    {%- if rendered_count > 0 -%}
      <section class="w-full bg-stone-100 flex flex-col gap-10 items-center overflow-hidden px-4 md:px-10 py-[60px]" {{ block.shopify_attributes }}>
        <div class="w-full max-w-screen-xl flex flex-col gap-10">
          {%- if block.settings.heading != blank -%}
            <h2 class="text-4xl font-semibold tracking-wider text-stone-900 text-center">{{ block.settings.heading }}</h2>
          {%- endif -%}
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-8 md:gap-x-10 md:gap-y-8">
            {{ related_cards }}
          </div>
        </div>
      </section>
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- schema %}
{
  "name": "Journal 記事",
  "blocks": [
    {
      "type": "references",
      "name": "参考文献",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "見出し",
          "default": "参考文献"
        }
      ]
    },
    {
      "type": "product_grid",
      "name": "おすすめ商品",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "見出し",
          "default": "おすすめ商品"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "コレクション"
        }
      ]
    },
    {
      "type": "related_articles",
      "name": "関連JOURNAL記事",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "見出し",
          "default": "関連JOURNAL記事"
        },
        {
          "type": "range",
          "id": "count",
          "label": "表示件数",
          "min": 2,
          "max": 8,
          "step": 1,
          "default": 4
        }
      ]
    },
    {
      "type": "related_ingredients",
      "name": "関連INGREDIENTS記事",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "見出し",
          "default": "関連INGREDIENTS記事"
        },
        {
          "type": "blog",
          "id": "blog",
          "label": "成分ブログ"
        },
        {
          "type": "range",
          "id": "count",
          "label": "表示件数",
          "min": 2,
          "max": 8,
          "step": 1,
          "default": 4
        }
      ]
    }
  ],
  "settings": [],
  "presets": [
    {
      "name": "Journal 記事"
    }
  ]
}
{%- endschema -%}
