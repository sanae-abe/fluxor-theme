{{ 'section-blog-journal-fluxor.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="journal-glossary color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="journal-glossary__inner page-width">

    <div class="journal-glossary__header">
      <h1 class="journal-glossary__title">{{ section.settings.title | default: blog.title }}</h1>
      {%- if section.settings.description != blank -%}
        <p class="journal-glossary__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- paginate blog.articles by section.settings.articles_per_page -%}
      {%- if blog.articles.size == 0 -%}
        <p class="journal-glossary__empty">記事がまだありません。</p>
      {%- else -%}
        <ul class="journal-glossary__grid" role="list">
          {%- for article in blog.articles -%}
            <li class="journal-card-wrapper">
              <a href="{{ article.url }}" class="journal-card">
                <div class="journal-card__media">
                  {%- if article.image -%}
                    <img
                      src="{{ article.image | image_url: width: 800 }}"
                      srcset="
                        {{ article.image | image_url: width: 400 }} 400w,
                        {{ article.image | image_url: width: 800 }} 800w
                      "
                      sizes="(min-width: 1024px) 33vw, (min-width: 750px) 50vw, 100vw"
                      alt="{{ article.image.alt | escape }}"
                      class="journal-card__img"
                      loading="{{ forloop.index | plus: 0 | at_most: 2 | map: 'eager' | default: 'lazy' }}"
                      width="{{ article.image.width }}"
                      height="{{ article.image.height }}"
                    >
                  {%- else -%}
                    <div class="journal-card__img-placeholder">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                        <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
                      </svg>
                    </div>
                  {%- endif -%}
                </div>

                <div class="journal-card__body">
                  {%- if article.tags.size > 0 -%}
                    <p class="journal-card__tag">{{ article.tags | first }}</p>
                  {%- endif -%}
                  <h2 class="journal-card__title">{{ article.title | escape }}</h2>
                  {%- if section.settings.show_date -%}
                    <p class="journal-card__date">
                      <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                        {{- article.published_at | date: '%Y.%m.%d' -}}
                      </time>
                    </p>
                  {%- endif -%}
                  {%- if article.excerpt != blank -%}
                    <p class="journal-card__excerpt">{{ article.excerpt | strip_html | truncate: 100 }}</p>
                  {%- endif -%}
                </div>
              </a>
            </li>
          {%- endfor -%}
        </ul>

        {%- if paginate.pages > 1 -%}
          {%- render 'pagination', paginate: paginate, anchor: '' -%}
        {%- endif -%}
      {%- endif -%}
    {%- endpaginate -%}

  </div>
</div>

{% schema %}
{
  "name": "Journal",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Journal"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 6,
      "max": 24,
      "step": 3,
      "default": 9,
      "label": "Articles per page"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1 (Light Warm)" },
        { "value": "scheme-2", "label": "Scheme 2 (Secondary Light)" },
        { "value": "scheme-3", "label": "Scheme 3 (Dark)" },
        { "value": "scheme-4", "label": "Scheme 4 (Header/Footer)" },
        { "value": "scheme-5", "label": "Scheme 5 (Botanical)" }
      ],
      "default": "scheme-1",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ]
}
{% endschema %}
