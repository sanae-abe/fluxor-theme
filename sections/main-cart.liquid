<section class="max-w-screen-xl mx-auto py-12">
  <h1 class="text-2xl md:text-4xl font-semibold mb-10">カート</h1>

  {%- if cart.item_count > 0 -%}
    {%- form 'cart', cart -%}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        {%- comment %} カートアイテム {%- endcomment %}
        <div class="lg:col-span-2 space-y-8">
          {%- for item in cart.items -%}
            <div class="flex gap-5 pb-8 border-b border-stone-200">
              <a href="{{ item.url }}" class="flex-shrink-0 w-24 h-24 bg-stone-200 overflow-hidden">
                <img
                  src="{{ item.image | image_url: width: 240 }}"
                  alt="{{ item.title | escape }}"
                  class="w-full h-full object-cover"
                  loading="lazy"
                  width="240"
                  height="240"
                >
              </a>

              <div class="flex-1 min-w-0">
                <p class="text-xs text-stone-400 mb-0.5">{{ item.vendor }}</p>
                <a href="{{ item.url }}" class="text-sm font-medium leading-snug">{{ item.product.title }}</a>
                {%- unless item.variant.title == 'Default Title' -%}
                  <p class="text-xs text-stone-400 mt-0.5">{{ item.variant.title }}</p>
                {%- endunless -%}

                <div class="flex items-center justify-between mt-4">
                  <div class="flex border border-stone-200 h-9 w-28">
                    <a
                      href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | minus: 1 }}"
                      class="w-9 flex items-center justify-center text-stone-400 hover:text-stone-900 transition-colors text-lg"
                    >−</a>
                    <span class="flex-1 flex items-center justify-center text-sm border-x border-stone-200">{{ item.quantity }}</span>
                    <a
                      href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity={{ item.quantity | plus: 1 }}"
                      class="w-9 flex items-center justify-center text-stone-400 hover:text-stone-900 transition-colors text-lg"
                    >+</a>
                  </div>

                  <div class="text-right">
                    <p class="text-sm">{{ item.final_line_price | money }}</p>
                    <p class="text-xs text-stone-400">（税込）</p>
                  </div>
                </div>

                <a
                  href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity=0"
                  class="inline-block mt-3 text-xs text-stone-400 hover:text-stone-900 underline transition-colors"
                >削除</a>
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- comment %} 合計・チェックアウト {%- endcomment %}
        <div class="lg:col-span-1">
          <div class="bg-stone-100 p-6 space-y-4 sticky top-24">
            <h2 class="text-sm tracking-widest uppercase">注文内容</h2>

            <div class="space-y-2 text-sm">
              {%- for item in cart.items -%}
                <div class="flex justify-between text-stone-500">
                  <span>{{ item.product.title | truncate: 24 }} ×{{ item.quantity }}</span>
                  <span>{{ item.final_line_price | money }}</span>
                </div>
              {%- endfor -%}
            </div>

            <div class="border-t border-stone-200 pt-4 flex justify-between font-medium">
              <span class="text-sm">小計</span>
              <span class="text-sm">{{ cart.total_price | money }}<span class="text-xs font-normal text-stone-400 ml-1">（税込）</span></span>
            </div>

            <p class="text-xs text-stone-400">¥5,500（税込）以上で送料無料</p>

            {%- render 'button',
              label: '購入手続きへ',
              type: 'submit',
              attr: 'name="checkout"',
              size: 'lg',
              full_width: true
            -%}

            <a
              href="{{ routes.all_products_collection_url }}"
              class="block text-center text-xs text-stone-400 hover:text-stone-900 underline transition-colors"
            >
              ショッピングを続ける
            </a>
          </div>
        </div>

      </div>
    {%- endform -%}
  {%- else -%}
    <div class="flex flex-col items-center justify-center py-32 gap-6 text-center">
      <p class="text-sm text-stone-400">カートに商品がありません</p>
      {%- render 'button',
        label: '商品を見る',
        url: routes.all_products_collection_url,
        variant: 'outline',
        size: 'lg'
      -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Cart"
}
{% endschema %}
