{%- paginate collection.products by section.settings.products_per_page -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "ホーム", "item": {{ shop.url | json }}},
    {"@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ shop.url | append: collection.url | json }}}
  ]
}
</script>

<div class="px-4 md:px-10 pt-6 pb-10 md:pt-10 md:pb-[60px]">
  <section
    class="max-w-screen-xl mx-auto"
    x-data="{ filtersOpen: false }"
  >
    {%- comment %} コレクションヘッダー {%- endcomment -%}
    <div class="mb-6">
      <h1 class="text-2xl md:text-4xl font-semibold">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p class="mt-6 text-sm text-stone-500 max-w-xl leading-relaxed">{{ collection.description }}</p>
      {%- endif -%}
    </div>

    {%- comment %} アクティブフィルター数の計算 {%- endcomment -%}
    {%- assign active_filter_count = 0 -%}
    {%- for filter in collection.filters -%}
      {%- assign active_filter_count = active_filter_count | plus: filter.active_values.size -%}
      {%- if filter.type == 'price_range' -%}
        {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
          {%- assign active_filter_count = active_filter_count | plus: 1 -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}

    {%- comment %} ツールバー {%- endcomment -%}
    <div class="flex items-center gap-4 mb-6 pb-4 border-b border-stone-200">
      {%- if collection.filters.size > 0 -%}
        {%- comment %} 絞り込みボタン（モバイル） {%- endcomment -%}
        <button
          type="button"
          @click="filtersOpen = true"
          class="flex items-center gap-2 text-sm font-medium md:hidden"
        >
          {%- render 'icon', icon: 'list-filter', class: 'w-4 h-4' -%}
          絞り込み
          {%- if active_filter_count > 0 -%}
            <span class="bg-stone-900 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center leading-none">{{ active_filter_count }}</span>
          {%- endif -%}
        </button>
      {%- endif -%}

      {%- comment %} 件数表示 {%- endcomment -%}
      <p class="text-sm text-stone-600{% if collection.filters.size > 0 %} hidden md:block{% endif %}">{{ paginate.items }}点の製品</p>

      {%- comment %} ソート {%- endcomment -%}
      <div class="ml-auto flex items-center gap-2"> 
        <label for="SortBy" class="text-sm text-stone-600 whitespace-nowrap hidden sm:block">並び順:</label>        {%- capture _sort_options -%}
          {%- for option in collection.sort_options -%}
            {%- case option.value -%}
              {%- when 'manual' -%}{%- assign _sort_label = 'おすすめ順' -%}
              {%- when 'best-selling' -%}{%- assign _sort_label = '売れ筋順' -%}
              {%- when 'title-ascending' -%}{%- assign _sort_label = 'タイトル: A〜Z' -%}
              {%- when 'title-descending' -%}{%- assign _sort_label = 'タイトル: Z〜A' -%}
              {%- when 'price-ascending' -%}{%- assign _sort_label = '価格: 安い順' -%}
              {%- when 'price-descending' -%}{%- assign _sort_label = '価格: 高い順' -%}
              {%- when 'created-ascending' -%}{%- assign _sort_label = '古い順' -%}
              {%- when 'created-descending' -%}{%- assign _sort_label = '新しい順' -%}
              {%- else -%}{%- assign _sort_label = option.name -%}
            {%- endcase -%}
            <option value="{{ option.value }}"{% if option.value == collection.sort_by %} selected{% endif %}>{{ _sort_label }}</option>
          {%- endfor -%}
        {%- endcapture -%}
        {%- capture _sort_onchange -%}onchange="const u = new URL(window.location.href); u.searchParams.set('sort_by', this.value); window.location.href = u.toString();"{%- endcapture -%}
        {%- render 'form-select', id: 'SortBy', options_html: _sort_options, attr: _sort_onchange -%}
      </div>
    </div>

    {%- comment %} アクティブフィルター chips {%- endcomment -%}
    {%- if active_filter_count > 0 -%}
      <div class="flex flex-wrap gap-2 mb-6">
        {%- for filter in collection.filters -%}
          {%- if filter.type == 'price_range' -%}
            {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
              <a href="{{ filter.url_to_remove }}" class="flex items-center gap-1.5 border border-stone-200 rounded-full px-3 py-1 text-xs hover:border-stone-900 transition-colors">
                価格:
                {%- if filter.min_value.value != blank -%}¥{{ filter.min_value.value | money_without_currency | replace: ',', '' }}{%- else -%}¥0{%- endif -%}
                〜
                {%- if filter.max_value.value != blank -%}¥{{ filter.max_value.value | money_without_currency | replace: ',', '' }}{%- endif -%}
                {%- render 'icon', icon: 'x', class: 'w-3 h-3 flex-shrink-0', stroke_width: 2 -%}
              </a>
            {%- endif -%}
          {%- else -%}
            {%- for value in filter.active_values -%}
              <a href="{{ value.url_to_remove }}" class="flex items-center gap-1.5 border border-stone-300 rounded-full px-3 py-1 text-xs hover:border-stone-900 transition-colors">
                {{ value.label }}
                {%- render 'icon', icon: 'x', class: 'w-3 h-3 flex-shrink-0', stroke_width: 2 -%}
              </a>
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
        <a href="{{ collection.url }}" class="text-xs text-stone-500 underline self-center hover:text-stone-900 transition-colors ml-1">すべてクリア</a>
      </div>
    {%- endif -%}

    <div class="flex gap-8">
      {%- comment %} デスクトップサイドバー {%- endcomment -%}
      {%- if collection.filters.size > 0 -%}
        <aside class="hidden md:block w-[calc(25%-2rem)] flex-shrink-0">
          {%- render 'filter-sidebar', filters: collection.filters, sort_by: collection.sort_by -%}
        </aside>
      {%- endif -%}

      {%- comment %} 商品グリッド {%- endcomment -%}
      <div
        class="flex-1 min-w-0"
        x-data="{
          nextUrl: '{{ paginate.next.url | escape }}',
          loading: false,
          done: '{{ paginate.next.url | escape }}' === '',
          init() {
            if (!window.matchMedia('(max-width: 767px)').matches) return;
            if (this.done) return;
            const obs = new IntersectionObserver(entries => {
              if (entries[0].isIntersecting) this.loadMore();
            }, { rootMargin: '400px' });
            obs.observe(this.$refs.sentinel);
          },
          async loadMore() {
            if (this.loading || this.done || !this.nextUrl) return;
            this.loading = true;
            try {
              const res = await fetch(this.nextUrl);
              const html = await res.text();
              const doc = new DOMParser().parseFromString(html, 'text/html');
              const grid = doc.querySelector('[data-product-grid]');
              if (grid) [...grid.children].forEach(el => this.$refs.grid.appendChild(el));
              const marker = doc.getElementById('js-next-url');
              this.nextUrl = marker ? marker.dataset.url : null;
              this.done = !this.nextUrl;
            } catch(e) {
              this.done = true;
            }
            this.loading = false;
          }
        }"
      >
        {%- if collection.products.size > 0 -%}

          {%- comment %} 次ページURLマーカー（JSが取得するため） {%- endcomment -%}
          {%- if paginate.next -%}
            <span id="js-next-url" data-url="{{ paginate.next.url | escape }}" hidden></span>
          {%- endif -%}

          <div
            x-ref="grid"
            data-product-grid
            class="product-grid-masonry md:gap-8 {%- if collection.filters.size > 0 %} md:grid-cols-2 lg:grid-cols-3{%- else %} md:grid-cols-3 lg:grid-cols-4{%- endif %}"
          >
            {%- for product in collection.products -%}
              {%- render 'card-product-4col', product: product -%}
            {%- endfor -%}
          </div>

          {%- comment %} モバイル: 監視用センチネル + ローディング {%- endcomment -%}
          <div x-ref="sentinel" class="md:hidden h-px" aria-hidden="true"></div>
          <div :class="loading ? '' : 'hidden'" class="md:hidden flex justify-center py-8 hidden">
            <span class="text-sm text-stone-400">読み込み中…</span>
          </div>

          {%- comment %} デスクトップ: ページネーション {%- endcomment -%}
          {%- if paginate.pages > 1 -%}
            <nav class="hidden md:flex justify-center gap-2 mt-16" aria-label="ページネーション">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="border border-stone-200 px-4 py-2 text-sm hover:border-stone-900 transition-colors">前へ</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="border border-stone-200 px-4 py-2 text-sm hover:border-stone-900 transition-colors">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}
                  <span class="border border-stone-900 bg-stone-900 text-stone-50 px-4 py-2 text-sm">{{ part.title }}</span>
                {%- else -%}
                  <span class="px-4 py-2 text-sm text-stone-300">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="border border-stone-200 px-4 py-2 text-sm hover:border-stone-900 transition-colors">次へ</a>
              {%- endif -%}
            </nav>
          {%- endif -%}

        {%- else -%}
          <p class="text-sm text-stone-400 py-20 text-center">条件に一致する商品がありません。</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment %} モバイルフィルタードロワー {%- endcomment -%}
    {%- if collection.filters.size > 0 -%}
      {%- comment %} パネル {%- endcomment -%}
      <div
        x-show="filtersOpen"
        x-transition:enter="transition-transform duration-300 ease-out"
        x-transition:enter-start="-translate-x-full"
        x-transition:enter-end="translate-x-0"
        x-transition:leave="transition-transform duration-200 ease-in"
        x-transition:leave-start="translate-x-0"
        x-transition:leave-end="-translate-x-full"
        class="fixed inset-y-0 left-0 z-50 w-80 max-w-full bg-stone-50 shadow-2xl flex flex-col md:hidden"
        role="dialog"
        aria-modal="true"
        aria-label="絞り込み"
        @keydown.escape.window="filtersOpen = false"
        style="display: none;"
      >
        <div class="flex items-center justify-between px-6 py-5 border-b border-stone-200">
          <h2 class="text-sm tracking-widest uppercase">絞り込み</h2>
          <button
            type="button"
            @click="filtersOpen = false"
            class="text-stone-500 hover:text-stone-900 transition-colors"
            aria-label="閉じる"
          >
            {%- render 'icon', icon: 'x', class: 'w-5 h-5' -%}
          </button>
        </div>
        <div class="flex-1 overflow-y-auto p-5">
          {%- render 'filter-sidebar', filters: collection.filters, sort_by: collection.sort_by -%}
        </div>
      </div>
      {%- comment %} オーバーレイ {%- endcomment -%}
      <div
        x-show="filtersOpen"
        x-transition:enter="transition-opacity duration-300"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition-opacity duration-200"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="fixed inset-0 z-40 bg-stone-950/40 backdrop-blur-sm md:hidden"
        @click="filtersOpen = false"
        aria-hidden="true"
        style="display: none;"
      ></div>
    {%- endif -%}
  </section>
</div>

{%- endpaginate -%}

{%- schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "1ページあたりの商品数",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Collection"
    }
  ]
}
{%- endschema %}
