{%- paginate collection.products by section.settings.products_per_page -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "ホーム", "item": {{ shop.url | json }}},
    {"@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ shop.url | append: collection.url | json }}}
  ]
}
</script>

<div class="px-4 md:px-10 pb-10 md:pb-[60px]">
  <section
    class="max-w-screen-xl mx-auto"
    x-data="{ filtersOpen: false }"
    aria-label="商品一覧"
  >
    {%- comment %} コレクションヘッダー {%- endcomment -%}
    <div class="py-5 md:py-10 flex flex-col gap-4 justify-center">
      <h1 class="text-2xl md:text-4xl md:leading-tight font-semibold md:tracking-wider uppercase">
        {%- if collection.handle == 'all' -%}Shop All{%- else -%}{{ collection.title }}{%- endif -%}
      </h1>
    </div>
    <hr class="border-stone-200">

    {%- comment %} アクティブフィルター数の計算 {%- endcomment -%}
    {%- assign active_filter_count = 0 -%}
    {%- for filter in collection.filters -%}
      {%- assign active_filter_count = active_filter_count | plus: filter.active_values.size -%}
      {%- if filter.type == 'price_range' -%}
        {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
          {%- assign active_filter_count = active_filter_count | plus: 1 -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}

    {%- comment %} ツールバー {%- endcomment -%}
    <div class="flex items-start md:items-center justify-between pt-10 pb-6">
      {%- comment %} 左側: 件数 + クリア（デスクトップ）/ 絞り込みボタン（モバイル） {%- endcomment -%}
      <div class="flex flex-col md:flex-row items-start md:items-center gap-4">
        {%- if collection.filters.size > 0 -%}
          {%- comment %} 絞り込みボタン（モバイル） {%- endcomment -%}
          <button
            type="button"
            @click="filtersOpen = true"
            class="flex items-center gap-2 text-sm font-medium md:hidden"
          >
            {%- render 'icon', icon: 'list-filter', class: 'w-4 h-4' -%}
            絞り込み
            {%- if active_filter_count > 0 -%}
              <span class="bg-stone-900 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center leading-none">{{ active_filter_count }}</span>
            {%- endif -%}
          </button>
        {%- endif -%}
        {%- comment %} 件数 + クリア {%- endcomment -%}
        <div class="flex items-center gap-4{%- if collection.filters.size > 0 %} md:w-72{%- endif %}">
          <p class="text-sm text-stone-500 md:uppercase md:tracking-wider">{{ paginate.items }}点の商品</p>
          {%- if active_filter_count > 0 -%}
            <a href="{{ collection.url }}" class="text-sm text-stone-500 underline md:uppercase md:tracking-wider">すべてクリア</a>
          {%- endif -%}
        </div>
      </div>

      {%- comment %} ソート {%- endcomment -%}
      <div class="flex items-center">
        {%- capture _sort_options -%}
          {%- for option in collection.sort_options -%}
            {%- case option.value -%}
              {%- when 'manual' -%}{%- assign _sort_label = 'おすすめ順' -%}
              {%- when 'best-selling' -%}{%- assign _sort_label = '売れ筋順' -%}
              {%- when 'title-ascending' -%}{%- assign _sort_label = 'タイトル: A〜Z' -%}
              {%- when 'title-descending' -%}{%- assign _sort_label = 'タイトル: Z〜A' -%}
              {%- when 'price-ascending' -%}{%- assign _sort_label = '価格: 安い順' -%}
              {%- when 'price-descending' -%}{%- assign _sort_label = '価格: 高い順' -%}
              {%- when 'created-ascending' -%}{%- assign _sort_label = '古い順' -%}
              {%- when 'created-descending' -%}{%- assign _sort_label = '新しい順' -%}
              {%- else -%}{%- assign _sort_label = option.name -%}
            {%- endcase -%}
            <option value="{{ option.value }}"{% if option.value == collection.sort_by %} selected{% endif %}>{{ _sort_label }}</option>
          {%- endfor -%}
        {%- endcapture -%}
        {%- capture _sort_onchange -%}onchange="const u = new URL(window.location.href); u.searchParams.set('sort_by', this.value); window.location.href = u.toString();"{%- endcapture -%}
        <label for="SortBy" class="sr-only">並び替え</label>
        {%- render 'form-select', id: 'SortBy', options_html: _sort_options, attr: _sort_onchange -%}
      </div>
    </div>

    <div class="flex gap-16">
      {%- comment %} デスクトップサイドバー {%- endcomment -%}
      {%- if collection.filters.size > 0 -%}
        <aside class="hidden md:block w-[calc(25%-2rem)] flex-shrink-0 sticky top-32 self-start">
          {%- render 'filter-sidebar', filters: collection.filters, sort_by: collection.sort_by -%}
        </aside>
      {%- endif -%}

      {%- comment %} 商品グリッド {%- endcomment -%}
      <div
        class="flex-1 min-w-0"
        x-data="productGrid('{{ paginate.next.url | escape }}')"
      >
        {%- if collection.products.size > 0 -%}

          {%- comment %} 次ページURLマーカー（JSが取得するため） {%- endcomment -%}
          {%- if paginate.next -%}
            <span id="js-next-url" data-url="{{ paginate.next.url | escape }}" hidden></span>
          {%- endif -%}

          <div
            x-ref="grid"
            data-product-grid
            class="product-grid-masonry md:gap-8 {%- if collection.filters.size > 0 %} md:grid-cols-2 lg:grid-cols-3{%- else %} md:grid-cols-3 lg:grid-cols-4{%- endif %}"
          >
            {%- for product in collection.products -%}
              {%- render 'card-product-4col', product: product -%}
            {%- endfor -%}
          </div>

          {%- comment %} モバイル: 監視用センチネル + ローディング {%- endcomment -%}
          <div x-ref="sentinel" class="md:hidden h-px" aria-hidden="true"></div>
          <div :class="loading ? '' : 'hidden'" class="md:hidden flex justify-center py-8 hidden" aria-live="polite">
            <span class="text-sm text-stone-400">読み込み中…</span>
          </div>
          <div :class="errored ? '' : 'hidden'" class="md:hidden flex justify-center py-8 hidden" aria-live="assertive">
            <span class="text-sm text-stone-500">読み込みに失敗しました。</span>
          </div>

          {%- comment %} デスクトップ: ページネーション {%- endcomment -%}
          {%- if paginate.pages > 1 -%}
            <nav class="hidden md:flex justify-center gap-2 mt-16" aria-label="ページネーション">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="border border-stone-200 px-4 py-2 text-sm hover:border-stone-900 transition-colors">前へ</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="border border-stone-200 px-4 py-2 text-sm hover:border-stone-900 transition-colors">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}
                  <span aria-current="page" class="border border-stone-900 bg-stone-900 text-stone-50 px-4 py-2 text-sm">{{ part.title }}</span>
                {%- else -%}
                  <span class="px-4 py-2 text-sm text-stone-300">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="border border-stone-200 px-4 py-2 text-sm hover:border-stone-900 transition-colors">次へ</a>
              {%- endif -%}
            </nav>
          {%- endif -%}

        {%- else -%}
          <p class="text-sm text-stone-400 py-20 text-center">条件に一致する商品がありません。</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment %} モバイルフィルタードロワー {%- endcomment -%}
    {%- if collection.filters.size > 0 -%}
      {%- capture drawer_content -%}
        {%- render 'filter-sidebar', filters: collection.filters, sort_by: collection.sort_by -%}
      {%- endcapture -%}
      {%- if active_filter_count > 0 -%}
        {%- render 'mobile-filter-drawer', open_expr: 'filtersOpen', close_expr: 'filtersOpen = false', content: drawer_content, clear_url: collection.url -%}
      {%- else -%}
        {%- render 'mobile-filter-drawer', open_expr: 'filtersOpen', close_expr: 'filtersOpen = false', content: drawer_content -%}
      {%- endif -%}
    {%- endif -%}
  </section>
</div>

{%- endpaginate -%}

{%- schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "1ページあたりの商品数",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Collection"
    }
  ]
}
{%- endschema -%}
