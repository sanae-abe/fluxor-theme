{%- comment %} ページヒーロー {%- endcomment -%}
<section class="w-full px-4 md:px-10 py-10 md:py-16 border-b border-stone-200">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl md:text-4xl font-medium text-text text-center">
      {{- section.settings.heading | default: 'お問い合わせ' -}}
    </h1>
  </div>
</section>

{%- comment %} お問い合わせフォーム {%- endcomment -%}
<section class="max-w-2xl mx-auto px-5 py-10 md:py-[60px]">
  {%- form 'contact', id: 'ContactForm' -%}
    {%- if form.posted_successfully? -%}
      <p class="text-sm text-teal-700 p-4 border border-teal-700/30 bg-teal-50">
        お問い合わせを受け付けました。ありがとうございます。
      </p>
    {%- else -%}
      {%- if form.errors -%}
        <div class="text-sm text-rose-700 mb-6 p-4 border border-rose-700/30 bg-rose-50">
          {%- for field in form.errors -%}
            <p>{{ form.errors.translated_fields[field] }}: {{ form.errors.messages[field] }}</p>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="space-y-6">
        <div>
          {%- render 'form-input',
            type: 'text',
            id: 'ContactForm-name',
            name: 'contact[name]',
            label: 'お名前',
            value: form.name,
            required: true
          -%}
        </div>

        <div>
          {%- render 'form-input',
            type: 'email',
            id: 'ContactForm-email',
            name: 'contact[email]',
            label: 'メールアドレス',
            value: form.email,
            required: true
          -%}
        </div>

        <div>
          {%- render 'form-input',
            type: 'textarea',
            id: 'ContactForm-message',
            name: 'contact[body]',
            label: 'メッセージ',
            value: form.body,
            required: true
          -%}
        </div>

        {%- assign privacy_url = shop.privacy_policy.url | default: '/policies/privacy-policy' -%}
        {%- render 'checkbox-consent',
          id: 'ContactForm-privacy',
          privacy_url: privacy_url,
          required: true
        -%}

        {%- render 'button',
          label: '送信する',
          type: 'submit',
          size: 'md',
          full_width: true
        -%}
      </div>
    {%- endif -%}
  {%- endform -%}
</section>

{%- schema %}
{
  "name": "Contact",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "お問い合わせ"
    }
  ],
  "presets": [{ "name": "Contact" }]
}
{%- endschema %}
