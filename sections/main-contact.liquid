<section class="max-w-xl mx-auto px-5 py-16">
  <h1 class="text-4xl font-semibold mb-10">お問い合わせ</h1>

  {%- form 'contact', id: 'ContactForm' -%}
    {%- if form.posted_successfully? -%}
      <p class="text-sm text-teal-900 mb-8 p-4 border border-teal-900/30 bg-teal-50">
        お問い合わせを受け付けました。ありがとうございます。
      </p>
    {%- endif -%}

    <div class="space-y-6">
      <div>
        <label for="ContactForm-name" class="block text-xs tracking-widest uppercase text-stone-500 mb-2">お名前</label>
        <input
          type="text"
          id="ContactForm-name"
          name="contact[name]"
          value="{{ form.name }}"
          class="w-full border-b border-stone-200 bg-transparent py-2.5 text-sm focus:outline-none focus:border-stone-900 transition-colors"
          required
        >
      </div>

      <div>
        <label for="ContactForm-email" class="block text-xs tracking-widest uppercase text-stone-500 mb-2">メールアドレス</label>
        <input
          type="email"
          id="ContactForm-email"
          name="contact[email]"
          value="{{ form.email }}"
          class="w-full border-b border-stone-200 bg-transparent py-2.5 text-sm focus:outline-none focus:border-stone-900 transition-colors"
          required
        >
      </div>

      <div>
        <label for="ContactForm-message" class="block text-xs tracking-widest uppercase text-stone-500 mb-2">メッセージ</label>
        <textarea
          id="ContactForm-message"
          name="contact[body]"
          rows="6"
          class="w-full border-b border-stone-200 bg-transparent py-2.5 text-sm focus:outline-none focus:border-stone-900 transition-colors resize-none"
          required
        >{{ form.body }}</textarea>
      </div>

      <div class="flex items-start gap-3">
        <input
          type="checkbox"
          id="ContactForm-privacy"
          required
          class="mt-0.5 w-4 h-4 accent-stone-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-stone-900"
        >
        <label for="ContactForm-privacy" class="text-sm text-stone-600 leading-relaxed">
          <a href="{{ shop.privacy_policy.url | default: '/policies/privacy-policy' }}" class="underline hover:text-stone-900 transition-colors" target="_blank" rel="noopener noreferrer">プライバシーポリシー</a>に同意します
        </label>
      </div>

      {%- render 'button',
        label: '送信する',
        type: 'submit',
        size: 'lg',
        full_width: true
      -%}
    </div>
  {%- endform -%}
</section>

{% schema %}
{
  "name": "Contact"
}
{% endschema %}
