<section class="max-w-2xl mx-auto px-5 py-16">
  <h1 class="text-2xl md:text-4xl font-semibold mb-10">お問い合わせ</h1>

  {%- form 'contact', id: 'ContactForm' -%}
    {%- if form.posted_successfully? -%}
      <p class="text-sm text-teal-700 p-4 border border-teal-700/30 bg-teal-50">
        お問い合わせを受け付けました。ありがとうございます。
      </p>
    {%- else -%}
      {%- if form.errors -%}
        <div class="text-sm text-rose-700 mb-6 p-4 border border-rose-700/30 bg-rose-50">
          {%- for field in form.errors -%}
            <p>{{ form.errors.messages[field] }}</p>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="space-y-6">
        <div>
          {%- render 'form-input',
            type: 'text',
            id: 'ContactForm-name',
            name: 'contact[name]',
            label: 'お名前',
            value: form.name,
            required: true
          -%}
        </div>

        <div>
          {%- render 'form-input',
            type: 'email',
            id: 'ContactForm-email',
            name: 'contact[email]',
            label: 'メールアドレス',
            value: form.email,
            required: true
          -%}
        </div>

        <div>
          {%- render 'form-input',
            type: 'textarea',
            id: 'ContactForm-message',
            name: 'contact[body]',
            label: 'メッセージ',
            value: form.body,
            required: true
          -%}
        </div>

        {%- assign _privacy_url = shop.privacy_policy.url | default: '/policies/privacy-policy' -%}
        {%- render 'checkbox-consent',
          id: 'ContactForm-privacy',
          privacy_url: _privacy_url,
          required: true
        -%}

        {%- render 'button',
          label: '送信する',
          type: 'submit',
          size: 'md',
          full_width: true
        -%}
      </div>
    {%- endif -%}
  {%- endform -%}
</section>

{% schema %}
{
  "name": "Contact",
  "presets": [{ "name": "Contact" }]
}
{% endschema %}
