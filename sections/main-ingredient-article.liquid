{%- comment %}
  Ingredients 記事 (main-ingredient-article.liquid)

  対応メタフィールド (名前空間: custom):
    inci_name               {single_line_text_field}
    category_tags           {list.single_line_text_field}
    skin_concerns           {list.single_line_text_field}
    pregnancy_note          {multi_line_text_field}
    compatible_ingredients  {list.metaobject_reference} → ingredient_combination { name, reason }
    caution_combinations    {list.metaobject_reference} → ingredient_combination { name, reason }
    usage_tips              {list.metaobject_reference} → content_item { title, description }
    roles                   {list.metaobject_reference} → role_item { title, description, icon }
    reference_entry         {list.metaobject_reference} → reference_entry { title, authors, journal, details, url, accessed_on }
    product_reference       {list.product_reference}
{%- endcomment -%}

{%- liquid
  assign category_tags = article.metafields.custom.category_tags.value
  assign name_en = article.metafields.custom.inci_name
  assign pregnancy_note = article.metafields.custom.pregnancy_note
  assign compatible_ingredients = article.metafields.custom.compatible_ingredients.value
  assign caution_combinations = article.metafields.custom.caution_combinations.value
  assign usage_tips = article.metafields.custom.usage_tips.value
  assign roles = article.metafields.custom.roles.value
  assign skin_concerns = article.metafields.custom.skin_concerns.value
  assign reference_entries = article.metafields.custom.reference_entry.value
  assign ingredient_products = article.metafields.custom.product_reference.value
-%}

{%- comment %} ── Header ────────────────────────────────────────── {%- endcomment -%}
<div class="w-full flex flex-col items-center px-4 md:px-10 bg-stone-50">

  <div class="w-full border-b border-stone-400 flex items-center pb-5 pt-5 md:pt-10">
    <a
      href="{{ blog.url }}"
      class="link-back inline-flex items-center gap-1 text-xs md:text-sm text-stone-500"
    >
      {%- render 'icon', icon: 'arrow-left', class: 'link-back__icon w-5 h-5 flex-shrink-0', stroke_width: 1.5 -%}
      <span>記事一覧に戻る</span>
    </a>
  </div>

  <div class="w-full max-w-screen-xl flex flex-col gap-6 md:gap-10 pt-6 md:pt-8 pb-6 md:pb-10">
    <div class="flex flex-col gap-4">
      {%- if name_en != blank -%}
        <p class="text-4xl md:text-5xl font-semibold tracking-wider text-stone-900 leading-tight">
          {{ name_en }}
        </p>
      {%- endif -%}
      <h1 class="text-lg font-medium text-stone-500 tracking-widest">{{ article.title }}</h1>
    </div>
    <div class="flex items-center justify-between w-full gap-4 flex-wrap">
      <div class="flex gap-3 items-center flex-wrap">
        {%- for tag in category_tags limit: 4 -%}
          {%- render 'badge', label: tag, variant: 'secondary', size: 'sm' -%}
        {%- endfor -%}
        {%- if skin_concerns != blank -%}
          <span class="text-stone-300 select-none">|</span>
          {%- for tag in skin_concerns limit: 4 -%}
            {%- render 'badge', label: tag, variant: 'secondary', size: 'sm' -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
      <p class="flex items-center gap-4 text-sm font-medium text-stone-900 shrink-0 uppercase"><span>Updated: {{ article.updated_at | date: "%Y/%m/%d" }}</span><span>Published: {{ article.published_at | date: "%Y/%m/%d" }}</span></p>
    </div>
  </div>

  {%- if article.image -%}
    <div class="w-full h-[250px] md:h-[410px] relative overflow-hidden">
      <img
        src="{{ article.image | image_url: width: 1200, format: 'webp' }}"
        srcset="{{ article.image | image_url: width: 1200, format: 'webp' }} 1x, {{ article.image | image_url: width: 2400, format: 'webp' }} 2x"
        alt="{{ article.image.alt | default: article.title | escape }}"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        width="1200"
        height="800"
      >
    </div>
  {%- else -%}
    <div class="w-full h-[250px] md:h-[410px] bg-stone-200"></div>
  {%- endif -%}

</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "ホーム", "item": {{ shop.url | json }}},
    {"@type": "ListItem", "position": 2, "name": {{ blog.title | json }}, "item": {{ shop.url | append: blog.url | json }}},
    {"@type": "ListItem", "position": 3, "name": {{ article.title | json }}, "item": {{ shop.url | append: article.url | json }}}
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title | json }},
  "description": {{ article.excerpt | strip_html | json }},
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S+09:00' }}",
  "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S+09:00' }}",
  "url": {{ shop.url | append: article.url | json }},
  "author": {
    "@type": "Organization",
    "name": {{ shop.name | json }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ shop.name | json }}
  }{%- if article.image -%},
  "image": {{ article.image | image_url: width: 1200 | json }}{%- endif -%}
}
</script>

{%- comment %} ── ブロックレンダリング ───────────────────────────── {%- endcomment -%}
{%- liquid
  assign last_non_ref_index = nil
  assign disclaimer_shown = false
  for block in section.blocks
    unless block.type == 'references'
      assign last_non_ref_index = forloop.index0
    endunless
  endfor
  assign block_outer = 'w-full flex flex-col items-center px-4 md:px-10 py-10'
  assign block_inner = 'w-full max-w-3xl flex flex-col gap-8'
  assign h2_class = 'text-2xl font-semibold leading-tight text-stone-900 tracking-wider'
-%}
{%- for block in section.blocks -%}
  {%- liquid
    assign extra_class = ''
    if forloop.first
      assign extra_class = 'pt-20'
    endif
    if forloop.index0 == last_non_ref_index
      assign extra_class = extra_class | append: ' pb-20' | strip
    endif
  -%}

  {%- if block.type == 'article_content' -%}
    <div class="{{ block_outer }} {{ extra_class }}" {{ block.shopify_attributes }}>
      <div class="{{ block_inner }}">
        {%- if block.settings.heading != blank -%}
          <h2 class="{{ h2_class }}">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if article.content != blank -%}
          <div class="text-base leading-relaxed text-stone-900 space-y-4 rte">{{ article.content }}</div>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'text_section' -%}
    <div class="{{ block_outer }} {{ extra_class }}" {{ block.shopify_attributes }}>
      <div class="{{ block_inner }}">
        {%- if block.settings.heading != blank -%}
          <h2 class="{{ h2_class }}">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if block.settings.content != blank -%}
          <div class="text-base leading-relaxed text-stone-900 space-y-4">{{ block.settings.content }}</div>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'roles' -%}
    <div class="{{ block_outer }} {{ extra_class }}" {{ block.shopify_attributes }}>
      <div class="{{ block_inner }}">
        {%- if block.settings.heading != blank -%}
          <h2 class="{{ h2_class }}">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if roles != blank -%}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8">
            {%- for role in roles -%}
              {%- if role.title != blank -%}
                <div class="bg-stone-100 p-6 flex flex-col gap-4 items-center md:items-start">
                  {%- if role.icon != blank -%}
                    {%- render 'icon', icon: role.icon, class: 'w-10 h-10', stroke_width: 1 -%}
                  {%- endif -%}
                  <h3 class="text-base font-medium text-stone-900">{{ role.title }}</h3>
                  {%- if role.description != blank -%}
                    <p class="text-sm leading-relaxed text-stone-900">{{ role.description | newline_to_br }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'disclaimer' -%}
    {%- assign disclaimer_shown = true -%}
    <div class="{{ block_outer }} {{ extra_class }}" {{ block.shopify_attributes }}>
      <div class="w-full max-w-3xl">
        <div class="bg-stone-100 p-4 flex gap-2 items-start">
          <div class="shrink-0 pt-1">
            {%- render 'icon', icon: 'info', class: 'w-4 h-4 text-stone-900' -%}
          </div>
          <div class="flex-1 text-sm leading-relaxed text-stone-900">{{ block.settings.text }}</div>
        </div>
      </div>
    </div>

  {%- elsif block.type == 'compatible_ingredients' or block.type == 'caution_combinations' -%}
    {%- liquid
      assign combo_items = compatible_ingredients
      if block.type == 'caution_combinations'
        assign combo_items = caution_combinations
      endif
    -%}
    <div class="{{ block_outer }} {{ extra_class }}" {{ block.shopify_attributes }}>
      <div class="{{ block_inner }}">
        {%- if block.settings.heading != blank -%}
          <h2 class="{{ h2_class }}">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if combo_items != blank -%}
          <div class="flex flex-col divide-y divide-stone-200">
            {%- for item in combo_items -%}
              {%- if item.name != blank -%}
                {%- liquid
                  assign item_padding = 'py-5'
                  if forloop.first
                    assign item_padding = 'pt-0 pb-5'
                  elsif forloop.last
                    assign item_padding = 'pt-5 pb-0'
                  endif
                -%}
                <div class="flex flex-col gap-2 {{ item_padding }}">
                  <div class="flex items-center gap-2">
                    {%- if block.type == 'caution_combinations' -%}
                      {%- render 'icon', icon: 'triangle-alert', width: 16, height: 16, stroke_width: 2, class: 'flex-shrink-0' -%}
                    {%- else -%}
                      {%- render 'icon', icon: 'check', width: 16, height: 16, stroke_width: 2, class: 'flex-shrink-0' -%}
                    {%- endif -%}
                    <p class="text-base font-medium text-stone-900">{{ item.name }}</p>
                  </div>
                  {%- if item.reason != blank -%}
                    <p class="text-base leading-relaxed text-stone-600">{{ item.reason | newline_to_br }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'pregnancy_note' -%}
    <div class="{{ block_outer }} {{ extra_class }}" {{ block.shopify_attributes }}>
      <div class="{{ block_inner }}">
        {%- if block.settings.heading != blank -%}
          <h2 class="{{ h2_class }}">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if pregnancy_note != blank -%}
          <p class="text-base leading-relaxed text-stone-900">{{ pregnancy_note | newline_to_br }}</p>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'usage_tips' -%}
    <div class="{{ block_outer }} {{ extra_class }}" {{ block.shopify_attributes }}>
      <div class="{{ block_inner }}">
        {%- if block.settings.heading != blank -%}
          <h2 class="{{ h2_class }}">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if usage_tips != blank -%}
          <ol class="flex flex-col gap-6 list-none">
            {%- for tip in usage_tips -%}
              {%- if tip.title != blank -%}
                <li class="flex gap-2">
                  <span class="text-base font-medium text-stone-900 shrink-0 pt-0.5 min-w-[1.25rem] tabular-nums">{{ forloop.index }}.</span>
                  <div class="flex flex-col gap-1">
                    <p class="text-base font-medium text-stone-900">{{ tip.title }}</p>
                    {%- if tip.description != blank -%}
                      <p class="text-base leading-relaxed text-stone-600">{{ tip.description | newline_to_br }}</p>
                    {%- endif -%}
                  </div>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ol>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'references' -%}
    {%- if reference_entries != blank -%}
    <div class="w-full bg-stone-100 flex flex-col items-center px-4 md:px-10 py-10 md:py-[60px]" {{ block.shopify_attributes }}>
      <div class="w-full max-w-3xl flex flex-col gap-5">
        {%- if block.settings.heading != blank -%}
          <h2 class="text-base font-medium text-stone-900">{{ block.settings.heading }}</h2>
        {%- endif -%}
          <ol class="flex flex-col gap-2 list-none">
            {%- for entry in reference_entries -%}
              <li class="flex gap-3">
                <span class="text-base text-stone-400 shrink-0 pt-0.5 min-w-[1.5rem] tabular-nums">{{ forloop.index }}.</span>
                <div class="flex flex-col gap-1 min-w-0">
                  {%- if entry.url != blank -%}
                    <a href="{{ entry.url }}" target="_blank" rel="noopener noreferrer" class="text-base font-medium text-stone-900 underline decoration-stone-400 underline-offset-2">{{ entry.title }}</a>
                  {%- else -%}
                    <p class="text-base font-medium text-stone-900">{{ entry.title }}</p>
                  {%- endif -%}
                  {%- liquid
                    assign meta_parts = ''
                    if entry.authors != blank
                      assign meta_parts = entry.authors
                    endif
                    if entry.journal != blank
                      if meta_parts != blank
                        assign meta_parts = meta_parts | append: ' / ' | append: entry.journal
                      else
                        assign meta_parts = entry.journal
                      endif
                    endif
                    if entry.details != blank
                      if meta_parts != blank
                        assign meta_parts = meta_parts | append: ', ' | append: entry.details
                      else
                        assign meta_parts = entry.details
                      endif
                    endif
                  -%}
                  {%- if meta_parts != blank -%}
                    <p class="text-sm text-stone-500">{{ meta_parts }}</p>
                  {%- endif -%}
                  {%- if entry.accessed_on != blank -%}
                    <p class="text-sm text-stone-500">[アクセス日：{{ entry.accessed_on }}]</p>
                  {%- endif -%}
                </div>
              </li>
            {%- endfor -%}
          </ol>
      </div>
    </div>
    {%- endif -%}

  {%- elsif block.type == 'related_journal_articles' -%}
    {%- liquid
      assign rj_limit = block.settings.count | default: 4
      assign rj_fetch = 50
      assign rj_count = 0
      assign rj_seen = ','
      assign rj_blog = blogs[block.settings.blog]
    -%}
    {%- capture rj_cards -%}
      {%- comment %} Priority 1: category_tags が一致するJournal記事 {%- endcomment -%}
      {%- if rj_blog != blank and category_tags != blank -%}
        {%- for candidate in rj_blog.articles limit: rj_fetch -%}
          {%- if rj_count < rj_limit -%}
            {%- assign id_sep = candidate.id | prepend: ',' | append: ',' -%}
            {%- unless rj_seen contains id_sep -%}
              {%- assign candidate_tags = candidate.metafields.custom.category_tags.value -%}
              {%- assign has_match = false -%}
              {%- if candidate_tags != blank -%}
                {%- for tag in category_tags -%}
                  {%- if candidate_tags contains tag -%}
                    {%- assign has_match = true -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {%- if has_match -%}
                {%- render 'card-article', article: candidate -%}
                {%- assign rj_seen = rj_seen | append: candidate.id | append: ',' -%}
                {%- assign rj_count = rj_count | plus: 1 -%}
              {%- endif -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- comment %} Priority 2: skin_concerns が一致するJournal記事（残り枠補充） {%- endcomment -%}
      {%- if rj_count < rj_limit and rj_blog != blank and skin_concerns != blank -%}
        {%- for candidate in rj_blog.articles limit: rj_fetch -%}
          {%- if rj_count < rj_limit -%}
            {%- assign id_sep = candidate.id | prepend: ',' | append: ',' -%}
            {%- unless rj_seen contains id_sep -%}
              {%- assign candidate_concerns = candidate.metafields.custom.skin_concerns.value -%}
              {%- assign has_match = false -%}
              {%- if candidate_concerns != blank -%}
                {%- for concern in skin_concerns -%}
                  {%- if candidate_concerns contains concern -%}
                    {%- assign has_match = true -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {%- if has_match -%}
                {%- render 'card-article', article: candidate -%}
                {%- assign rj_seen = rj_seen | append: candidate.id | append: ',' -%}
                {%- assign rj_count = rj_count | plus: 1 -%}
              {%- endif -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- comment %} Fallback: 残り枠をその他Journal記事で補充 {%- endcomment -%}
      {%- if rj_count < rj_limit and rj_blog != blank -%}
        {%- for candidate in rj_blog.articles limit: rj_fetch -%}
          {%- if rj_count < rj_limit -%}
            {%- assign id_sep = candidate.id | prepend: ',' | append: ',' -%}
            {%- unless rj_seen contains id_sep -%}
              {%- render 'card-article', article: candidate -%}
              {%- assign rj_seen = rj_seen | append: candidate.id | append: ',' -%}
              {%- assign rj_count = rj_count | plus: 1 -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endcapture -%}
    {%- if rj_count > 0 -%}
      <section class="w-full bg-stone-100 flex flex-col gap-10 items-center overflow-hidden px-4 md:px-10 py-10 md:py-[60px] {{ extra_class }}" {{ block.shopify_attributes }}>
        <div class="w-full max-w-screen-xl flex flex-col gap-10">
          {%- if block.settings.heading != blank -%}
            <h2 class="text-2xl md:text-4xl font-semibold tracking-wider text-stone-900 text-center">{{ block.settings.heading }}</h2>
          {%- endif -%}
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-8 md:gap-x-10 md:gap-y-8">
            {{ rj_cards }}
          </div>
        </div>
      </section>
    {%- endif -%}

  {%- elsif block.type == 'product_grid' -%}
    {%- liquid
      assign fc_max = 4
      assign fc_ids = ','
      assign fc_count = 0
      assign fc_collection = collections[block.settings.collection]
    -%}
    {%- capture product_cards -%}
      {%- comment %} Priority 1: product_reference {%- endcomment -%}
      {%- if ingredient_products != blank -%}
        {%- for product in ingredient_products -%}
          {%- if fc_count < fc_max -%}
            {%- assign id_with_sep = product.id | prepend: ',' | append: ',' -%}
            {%- unless fc_ids contains id_with_sep -%}
              {%- render 'card-product-4col', product: product -%}
              {%- assign fc_ids = fc_ids | append: product.id | append: ',' -%}
              {%- assign fc_count = fc_count | plus: 1 -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- comment %} Priority 2: skin_concerns が同じ商品（featured collection 内） {%- endcomment -%}
      {%- if fc_count < fc_max and fc_collection != blank and skin_concerns != blank -%}
        {%- for product in fc_collection.products -%}
          {%- if fc_count < fc_max -%}
            {%- assign id_with_sep = product.id | prepend: ',' | append: ',' -%}
            {%- unless fc_ids contains id_with_sep -%}
              {%- assign product_concerns = product.metafields.custom.skin_concerns.value -%}
              {%- assign has_match = false -%}
              {%- if product_concerns != blank -%}
                {%- for concern in skin_concerns -%}
                  {%- if product_concerns contains concern -%}
                    {%- assign has_match = true -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              {%- if has_match -%}
                {%- render 'card-product-4col', product: product -%}
                {%- assign fc_ids = fc_ids | append: product.id | append: ',' -%}
                {%- assign fc_count = fc_count | plus: 1 -%}
              {%- endif -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- comment %} Priority 3: featured collection の残り商品 {%- endcomment -%}
      {%- if fc_count < fc_max and fc_collection != blank -%}
        {%- for product in fc_collection.products -%}
          {%- if fc_count < fc_max -%}
            {%- assign id_with_sep = product.id | prepend: ',' | append: ',' -%}
            {%- unless fc_ids contains id_with_sep -%}
              {%- render 'card-product-4col', product: product -%}
              {%- assign fc_ids = fc_ids | append: product.id | append: ',' -%}
              {%- assign fc_count = fc_count | plus: 1 -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endcapture -%}
    {%- if fc_count > 0 -%}
      <section class="w-full bg-stone-100 flex flex-col gap-10 items-center overflow-hidden px-4 md:px-10 py-10 md:py-[60px] {{ extra_class }}" {{ block.shopify_attributes }}>
        <div class="w-full max-w-screen-xl flex flex-col gap-2 items-center text-center">
          {%- if block.settings.heading != blank -%}
            <h2 class="text-4xl font-semibold tracking-wider text-stone-900">{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.subheading != blank -%}
            <p class="text-lg text-stone-900/70">{{ block.settings.subheading }}</p>
          {%- endif -%}
        </div>
        <div class="w-full max-w-screen-xl grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-6 md:gap-6">
          {{ product_cards }}
        </div>
      </section>
    {%- endif -%}

  {%- elsif block.type == 'related_articles' -%}
    {%- liquid
      assign related_limit = block.settings.count | default: 4
      assign fetch_limit = 50
      assign rendered_count = 0
      assign seen_ids = ','
    -%}
    {%- capture related_cards -%}
      {%- comment %} Priority 1: category_tags が一致する記事 {%- endcomment -%}
      {%- for candidate in blog.articles limit: fetch_limit -%}
        {%- unless candidate.id == article.id -%}
          {%- if rendered_count < related_limit -%}
            {%- assign id_sep = candidate.id | prepend: ',' | append: ',' -%}
            {%- unless seen_ids contains id_sep -%}
              {%- liquid
                assign candidate_tags = candidate.metafields.custom.category_tags.value
                assign has_match = false
                if category_tags != blank and candidate_tags != blank
                  for tag in category_tags
                    if candidate_tags contains tag
                      assign has_match = true
                    endif
                  endfor
                endif
              -%}
              {%- if has_match -%}
                {%- render 'card-ingredient', article: candidate -%}
                {%- assign seen_ids = seen_ids | append: candidate.id | append: ',' -%}
                {%- assign rendered_count = rendered_count | plus: 1 -%}
              {%- endif -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endunless -%}
      {%- endfor -%}
      {%- comment %} Priority 2: skin_concerns が一致する記事（残り枠を補充） {%- endcomment -%}
      {%- if rendered_count < related_limit -%}
        {%- for candidate in blog.articles limit: fetch_limit -%}
          {%- unless candidate.id == article.id -%}
            {%- if rendered_count < related_limit -%}
              {%- assign id_sep = candidate.id | prepend: ',' | append: ',' -%}
              {%- unless seen_ids contains id_sep -%}
                {%- liquid
                  assign candidate_concerns = candidate.metafields.custom.skin_concerns.value
                  assign has_match = false
                  if skin_concerns != blank and candidate_concerns != blank
                    for concern in skin_concerns
                      if candidate_concerns contains concern
                        assign has_match = true
                      endif
                    endfor
                  endif
                -%}
                {%- if has_match -%}
                  {%- render 'card-ingredient', article: candidate -%}
                  {%- assign seen_ids = seen_ids | append: candidate.id | append: ',' -%}
                  {%- assign rendered_count = rendered_count | plus: 1 -%}
                {%- endif -%}
              {%- endunless -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
      {%- comment %} Priority 3 & 4: 新着・その他記事（残り枠を補充） {%- endcomment -%}
      {%- if rendered_count < related_limit -%}
        {%- for candidate in blog.articles limit: fetch_limit -%}
          {%- unless candidate.id == article.id -%}
            {%- if rendered_count < related_limit -%}
              {%- assign id_sep = candidate.id | prepend: ',' | append: ',' -%}
              {%- unless seen_ids contains id_sep -%}
                {%- render 'card-ingredient', article: candidate -%}
                {%- assign seen_ids = seen_ids | append: candidate.id | append: ',' -%}
                {%- assign rendered_count = rendered_count | plus: 1 -%}
              {%- endunless -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endcapture -%}
    {%- if rendered_count > 0 -%}
      <section class="w-full bg-stone-100 flex flex-col gap-10 items-center overflow-hidden px-4 md:px-10 py-10 md:py-[60px] {{ extra_class }}" {{ block.shopify_attributes }}>
        <div class="w-full max-w-screen-xl flex flex-col gap-10">
          {%- if block.settings.heading != blank -%}
            <h2 class="text-2xl md:text-4xl font-semibold tracking-wider text-stone-900 text-center">{{ block.settings.heading }}</h2>
          {%- endif -%}
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-8 md:gap-x-10 md:gap-y-8">
            {{ related_cards }}
          </div>
        </div>
      </section>
    {%- endif -%}

  {%- endif -%}
{%- endfor -%}

{%- comment %} 薬機法対応：disclaimerブロックが管理画面で削除された場合のフォールバック免責表記 {%- endcomment -%}
{%- unless disclaimer_shown -%}
  <div class="{{ block_outer }}">
    <div class="w-full max-w-3xl">
      <div class="bg-stone-100 p-4 flex gap-2 items-start">
        <div class="shrink-0 pt-1">
          {%- render 'icon', icon: 'info', class: 'w-4 h-4 text-stone-900' -%}
        </div>
        <div class="flex-1 text-sm leading-relaxed text-stone-900">本ページは成分の一般的な情報提供を目的としており、特定の効能・効果を保証するものではありません。肌悩みについては皮膚科専門医へご相談ください。</div>
      </div>
    </div>
  </div>
{%- endunless -%}

