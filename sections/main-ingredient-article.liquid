{%- comment %}
  成分ガイド記事 (main-ingredient-article.liquid)

  対応メタフィールド (名前空間: custom):
    inci_name               {single_line_text_field}
    category_tags           {list.single_line_text_field}
    pregnancy_note          {single_line_text_field}
    compatible_ingredients  {list.metaobject_reference} → ingredient_combination { name, reason }
    caution_combinations    {list.metaobject_reference} → ingredient_combination { name, reason }
    usage_tips              {list.metaobject_reference} → content_item { title, description }
    roles                   {list.metaobject_reference} → role_item { title, description, icon }
    reference_entry         {list.metaobject_reference} → reference_entry { title, authors, journal, details }
{%- endcomment %}

{%- assign category_tags = article.metafields.custom.category_tags.value -%}
{%- assign name_en = article.metafields.custom.inci_name -%}
{%- assign pregnancy_note = article.metafields.custom.pregnancy_note -%}
{%- assign compatible_ingredients = article.metafields.custom.compatible_ingredients.value -%}
{%- assign caution_combinations = article.metafields.custom.caution_combinations.value -%}
{%- assign usage_tips = article.metafields.custom.usage_tips.value -%}
{%- assign roles = article.metafields.custom.roles.value -%}
{%- assign reference_entries = article.metafields.custom.reference_entry.value -%}
{%- assign ingredient_products = article.metafields.custom.product_reference.value -%}

{%- comment %} ── Header ────────────────────────────────────────── {%- endcomment -%}
<div class="w-full flex flex-col items-center px-4 md:px-10 bg-stone-50">

  <div class="w-full border-b border-stone-400 flex items-center pb-5 pt-10">
    <a
      href="{{ blog.url }}"
      class="link-back inline-flex items-center gap-1 text-sm text-stone-500"
    >
      {%- render 'icon', icon: 'arrow-left', class: 'link-back__icon w-5 h-5 flex-shrink-0', stroke_width: 1.5 -%}
      <span>成分ガイドに戻る</span>
    </a>
  </div>

  <div class="w-full max-w-screen-xl flex flex-col gap-10 py-8 pb-10">
    <div class="flex flex-col gap-4">
      {%- if name_en != blank -%}
        <h1 class="text-4xl md:text-5xl font-semibold tracking-wider text-stone-900 leading-tight">
          {{ name_en }}
        </h1>
      {%- endif -%}
      <p class="text-lg font-medium text-stone-900">{{ article.title }}</p>
    </div>
    <div class="flex items-center justify-between w-full gap-4 flex-wrap">
      <div class="flex gap-3 items-center flex-wrap">
        {%- for tag in category_tags limit: 4 -%}          {%- render 'badge', label: tag, variant: 'secondary', size: 'sm' -%}
        {%- endfor -%}
      </div>
      <p class="text-sm font-medium text-stone-900 shrink-0">UPDATE: {{ article.updated_at | date: "%Y/%m/%d" }}</p>
    </div>
  </div>

  {%- if article.image -%}
    <div class="w-full h-[250px] md:h-[400px] relative overflow-hidden">
      <img
        src="{{ article.image | image_url: width: 1920 }}"
        alt="{{ article.image.alt | escape | default: article.title | escape }}"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="800"
      >
    </div>
  {%- else -%}
    <div class="w-full h-[250px] md:h-[400px] bg-stone-200"></div>
  {%- endif -%}

</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "ホーム", "item": {{ shop.url | json }}},
    {"@type": "ListItem", "position": 2, "name": "成分ガイド", "item": {{ shop.url | append: blog.url | json }}},
    {"@type": "ListItem", "position": 3, "name": {{ article.title | json }}, "item": {{ shop.url | append: article.url | json }}}
  ]
}
</script>

{%- comment %} ── ブロックレンダリング ───────────────────────────── {%- endcomment -%}
{%- for block in section.blocks -%}

  {%- if block.type == 'article_content' -%}
    <div class="w-full flex flex-col items-center px-4 md:px-10 py-10" {{ block.shopify_attributes }}>
      <div class="w-full max-w-3xl flex flex-col gap-10">
        {%- if block.settings.heading != blank -%}
          <h2 class="text-3xl font-semibold leading-tight text-stone-900">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if article.content != blank -%}
          <div class="text-base leading-relaxed text-stone-900 space-y-4 rte">{{ article.content }}</div>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'text_section' -%}
    <div class="w-full flex flex-col items-center px-4 md:px-10 py-10" {{ block.shopify_attributes }}>
      <div class="w-full max-w-3xl flex flex-col gap-10">
        {%- if block.settings.heading != blank -%}
          <h2 class="text-3xl font-semibold leading-tight text-stone-900">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if block.settings.content != blank -%}
          <div class="text-base leading-relaxed text-stone-900 space-y-4">{{ block.settings.content }}</div>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'benefits_group' -%}
    <div class="w-full flex flex-col items-center px-4 md:px-10 py-10" {{ block.shopify_attributes }}>
      <div class="w-full max-w-3xl flex flex-col gap-10">
        {%- if block.settings.heading != blank -%}
          <h2 class="text-3xl font-semibold leading-tight text-stone-900">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if roles != blank -%}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {%- for role in roles -%}
              {%- if role.title != blank -%}
                <div class="bg-stone-100 p-6 flex flex-col gap-4">
                  {%- if role.icon != blank -%}
                    <div class="pb-2">
                      {%- render 'icon', icon: role.icon, class: 'w-12 h-12', stroke_width: 1 -%}
                    </div>
                  {%- endif -%}
                  <h3 class="text-2xl font-medium text-stone-900">{{ role.title }}</h3>
                  {%- if role.description != blank -%}
                    <p class="text-sm leading-relaxed text-stone-900">{{ role.description }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'disclaimer' -%}
    <div class="w-full flex flex-col items-center px-4 md:px-10 py-10" {{ block.shopify_attributes }}>
      <div class="w-full max-w-3xl">
        <div class="bg-stone-100 p-4 flex gap-2 items-start">
          <div class="shrink-0 pt-1">
            {%- render 'icon', icon: 'info', class: 'w-4 h-4 text-stone-900' -%}
          </div>
          <div class="flex-1 text-sm leading-relaxed text-stone-900">{{ block.settings.text }}</div>
        </div>
      </div>
    </div>

  {%- elsif block.type == 'compatible_ingredients' -%}
    <div class="w-full flex flex-col items-center px-4 md:px-10 py-10" {{ block.shopify_attributes }}>
      <div class="w-full max-w-3xl flex flex-col gap-10">
        {%- if block.settings.heading != blank -%}
          <h2 class="text-3xl font-semibold leading-tight text-stone-900">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if compatible_ingredients != blank -%}
          <div class="flex flex-col divide-y divide-stone-200">
            {%- for item in compatible_ingredients -%}
              {%- if item.name != blank -%}
                <div class="flex flex-col gap-2 py-5">
                  <p class="text-base font-semibold text-stone-900">{{ item.name }}</p>
                  {%- if item.reason != blank -%}
                    <p class="text-sm leading-relaxed text-stone-600">{{ item.reason }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'caution_combinations' -%}
    <div class="w-full flex flex-col items-center px-4 md:px-10 py-10" {{ block.shopify_attributes }}>
      <div class="w-full max-w-3xl flex flex-col gap-10">
        {%- if block.settings.heading != blank -%}
          <h2 class="text-3xl font-semibold leading-tight text-stone-900">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if caution_combinations != blank -%}
          <div class="flex flex-col divide-y divide-stone-200">
            {%- for item in caution_combinations -%}
              {%- if item.name != blank -%}
                <div class="flex flex-col gap-2 py-5">
                  <p class="text-base font-semibold">{{ item.name }}</p>
                  {%- if item.reason != blank -%}
                    <p class="text-sm leading-relaxed text-stone-600">{{ item.reason }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'pregnancy_note' -%}
    <div class="w-full flex flex-col items-center px-4 md:px-10 py-10" {{ block.shopify_attributes }}>
      <div class="w-full max-w-3xl flex flex-col gap-10">
        {%- if block.settings.heading != blank -%}
          <h2 class="text-3xl font-semibold leading-tight text-stone-900">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if pregnancy_note != blank -%}
          <p class="text-base leading-relaxed text-stone-900">{{ pregnancy_note }}</p>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'usage_tips' -%}
    <div class="w-full flex flex-col items-center px-4 md:px-10 py-10" {{ block.shopify_attributes }}>
      <div class="w-full max-w-3xl flex flex-col gap-10">
        {%- if block.settings.heading != blank -%}
          <h2 class="text-3xl font-semibold leading-tight text-stone-900">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if usage_tips != blank -%}
          <ol class="flex flex-col gap-6 list-none">
            {%- for tip in usage_tips -%}
              {%- if tip.title != blank -%}
                <li class="flex gap-4">
                  <span class="text-sm font-semibold text-stone-400 shrink-0 pt-0.5 min-w-[1.5rem] tabular-nums">{{ forloop.index }}.</span>
                  <div class="flex flex-col gap-1">
                    <p class="text-base font-semibold text-stone-900">{{ tip.title }}</p>
                    {%- if tip.description != blank -%}
                      <p class="text-sm leading-relaxed text-stone-600">{{ tip.description }}</p>
                    {%- endif -%}
                  </div>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ol>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'roles' -%}
    <div class="w-full flex flex-col items-center px-4 md:px-10 py-10" {{ block.shopify_attributes }}>
      <div class="w-full max-w-3xl flex flex-col gap-10">
        {%- if block.settings.heading != blank -%}
          <h2 class="text-3xl font-semibold leading-tight text-stone-900">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if roles != blank -%}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {%- for role in roles -%}
              {%- if role.title != blank -%}
                <div class="bg-stone-100 p-6 flex flex-col gap-4">
                  {%- if role.icon != blank -%}
                    <div class="pb-2">
                      {%- render 'icon', icon: role.icon, class: 'w-12 h-12', stroke_width: 1 -%}
                    </div>
                  {%- endif -%}
                  <p class="text-base font-semibold text-stone-900">{{ role.title }}</p>
                  {%- if role.description != blank -%}
                    <p class="text-sm leading-relaxed text-stone-600">{{ role.description }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'references' -%}
    <div class="w-full bg-stone-100 flex flex-col items-center px-4 md:px-10 py-10 md:py-[60px]" {{ block.shopify_attributes }}>
      <div class="w-full max-w-3xl flex flex-col gap-5">
        {%- if block.settings.heading != blank -%}
          <p class="text-base font-medium text-stone-900">{{ block.settings.heading }}</p>
        {%- endif -%}
        {%- if reference_entries != blank -%}
          <ol class="flex flex-col gap-2 list-none">
            {%- for entry in reference_entries -%}
              <li class="flex gap-3">
                <span class="text-sm text-stone-400 shrink-0 pt-0.5 min-w-[1.5rem] tabular-nums">{{ forloop.index }}.</span>
                <div class="flex flex-col gap-1 min-w-0">
                  <p class="text-sm font-medium text-stone-900">{{ entry.title }}</p>
                  {%- liquid
                    assign meta_parts = ''
                    if entry.authors != blank
                      assign meta_parts = entry.authors
                    endif
                    if entry.journal != blank
                      if meta_parts != blank
                        assign meta_parts = meta_parts | append: ' / ' | append: entry.journal
                      else
                        assign meta_parts = entry.journal
                      endif
                    endif
                    if entry.details != blank
                      if meta_parts != blank
                        assign meta_parts = meta_parts | append: ', ' | append: entry.details
                      else
                        assign meta_parts = entry.details
                      endif
                    endif
                  -%}
                  {%- if meta_parts != blank -%}
                    <p class="text-sm text-stone-500">{{ meta_parts }}</p>
                  {%- endif -%}
                </div>
              </li>
            {%- endfor -%}
          </ol>
        {%- endif -%}
      </div>
    </div>

  {%- elsif block.type == 'product_grid' -%}
    <section class="w-full bg-stone-50 flex flex-col gap-10 items-center overflow-hidden px-4 md:px-10 py-10 md:py-[60px]" {{ block.shopify_attributes }}>
      <div class="w-full max-w-screen-xl flex flex-col gap-2 items-center text-center">
        {%- if block.settings.heading != blank -%}
          <h2 class="text-4xl font-semibold tracking-wider text-stone-900">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if block.settings.subheading != blank -%}
          <p class="text-lg text-stone-900/70">{{ block.settings.subheading }}</p>
        {%- endif -%}
      </div>
      {%- if ingredient_products != blank -%}
        <div class="w-full max-w-screen-xl grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-6 md:gap-6">
          {%- for product in ingredient_products -%}
            {%- render 'card-product-4col', product: product -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </section>

  {%- endif -%}
{%- endfor -%}

{%- schema %}
