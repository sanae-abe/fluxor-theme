{%- comment %}
  成分ガイド記事 (main-ingredient-article.liquid)

  対応メタフィールド (名前空間: custom):
    category_tags       {list.single_line_text_field}
    inci_name           {single_line_text_field}
    product_reference   {list.product_reference}
{%- endcomment %}

{%- assign category_tags = article.metafields.custom.category_tags.value -%}
{%- assign name_en = article.metafields.custom.inci_name -%}

{%- comment %} ============================================================
  Header — ナビゲーション + タイトル + 記事画像
  ============================================================ {%- endcomment -%}
<div class="w-full flex flex-col items-center px-4 md:px-10">

  {%- comment %} 戻るリンク {%- endcomment -%}
  <div class="w-full border-b border-stone-400 flex items-center pb-5 pt-10">
    <a
      href="{{ blog.url }}"
      class="link-back inline-flex items-center gap-1 text-sm text-stone-500"
    >
      {%- render 'icon', icon: 'arrow-left', class: 'link-back__icon w-5 h-5 flex-shrink-0', stroke_width: 1.5 -%}
      <span>成分ガイドに戻る</span>
    </a>
  </div>

  {%- comment %} タイトルエリア {%- endcomment -%}
  <div class="w-full max-w-screen-xl flex flex-col gap-10 py-8 pb-10">
    <div class="flex flex-col gap-4">
      {%- if name_en != blank -%}
        <h1 class="text-4xl md:text-5xl font-semibold tracking-wider text-stone-900 leading-tight">
          {{ name_en }}
        </h1>
      {%- endif -%}
      <p class="text-lg font-medium text-stone-900">{{ article.title }}</p>
    </div>
    <div class="flex items-center justify-between w-full gap-4 flex-wrap">
      <div class="flex gap-3 items-center flex-wrap">
        {%- for tag in category_tags limit: 4 -%}
          <span class="inline-flex items-center justify-center px-2 py-1 rounded-full border border-stone-900/40 text-xs font-medium tracking-wider uppercase text-stone-900">{{ tag }}</span>
        {%- endfor -%}
      </div>
      <p class="text-sm font-medium text-stone-900 shrink-0">UPDATE: {{ article.updated_at | date: "%Y/%m/%d" }}</p>
    </div>
  </div>

  {%- comment %} 記事アイキャッチ画像 {%- endcomment -%}
  {%- if article.image -%}
    <div class="w-full h-[250px] md:h-[400px] relative overflow-hidden">
      <img
        src="{{ article.image | image_url: width: 1920 }}"
        alt="{{ article.image.alt | escape | default: article.title | escape }}"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="800"
      >
    </div>
  {%- else -%}
    <div class="w-full h-[250px] md:h-[400px] bg-stone-200"></div>
  {%- endif -%}

</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "ホーム", "item": {{ shop.url | json }}},
    {"@type": "ListItem", "position": 2, "name": "成分ガイド", "item": {{ shop.url | append: blog.url | json }}},
    {"@type": "ListItem", "position": 3, "name": {{ article.title | default: article.title | json }}, "item": {{ shop.url | append: article.url | json }}}
  ]
}
</script>

{%- comment %} ============================================================
  ブロックレンダリング
  ============================================================ {%- endcomment -%}
<div class="w-full flex flex-col items-center px-4 md:px-10 py-10 md:py-20 gap-10 md:gap-20">
  {%- for block in section.blocks -%}

    {%- comment %} テキストセクション {%- endcomment -%}
    {%- if block.type == 'text_section' -%}
      <div
        class="w-full max-w-3xl flex flex-col gap-10"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.heading != blank -%}
          <h2 class="text-3xl font-semibold leading-tight text-stone-900">
            {{ block.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if block.settings.content != blank -%}
          <div class="text-base leading-relaxed text-stone-900 space-y-4">{{ block.settings.content }}</div>
        {%- endif -%}
      </div>

    {%- comment %} ベネフィットカードグループ {%- endcomment -%}
    {%- elsif block.type == 'benefits_group' -%}
      <div
        class="w-full max-w-3xl flex flex-col gap-10"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.heading != blank -%}
          <h2 class="text-3xl font-semibold leading-tight text-stone-900">
            {{ block.settings.heading }}
          </h2>
        {%- endif -%}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {%- for n in (1..4) -%}
            {%- liquid
              assign icon_key = 'card' | append: n | append: '_icon'
              assign title_key = 'card' | append: n | append: '_title'
              assign desc_key = 'card' | append: n | append: '_description'
              assign card_icon = block.settings[icon_key]
              assign card_title = block.settings[title_key]
              assign card_desc = block.settings[desc_key]
            -%}
            {%- if card_title != blank -%}
              <div class="bg-stone-100 p-6 flex flex-col gap-4">
                <div class="pb-2">
                  {%- render 'icon', icon: card_icon, class: 'w-12 h-12' stroke_width: 1 -%}
                </div>
                <h3 class="text-2xl font-medium text-stone-900">{{ card_title }}</h3>
                {%- if card_desc != blank -%}
                  <p class="text-sm leading-relaxed text-stone-900">{{ card_desc }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

    {%- comment %} 免責事項ノート {%- endcomment -%}
    {%- elsif block.type == 'disclaimer' -%}
      <div
        class="w-full max-w-3xl"
        {{ block.shopify_attributes }}
      >
        <div class="bg-stone-100 p-4 flex gap-2 items-start">
          <div class="shrink-0 pt-1">
            {%- render 'icon', icon: 'info', class: 'w-4 h-4 text-stone-900' -%}
          </div>
          <div class="flex-1 text-sm leading-relaxed text-stone-900">{{ block.settings.text }}</div>
        </div>
      </div>

    {%- endif -%}
  {%- endfor -%}
</div>

{%- comment %} ============================================================
  参考文献
  ============================================================ {%- endcomment -%}
{%- assign ref_blocks = section.blocks | where: 'type', 'reference_entry' -%}
{%- if ref_blocks.size > 0 -%}
  <div class="w-full bg-stone-100 flex flex-col items-center px-4 md:px-10 py-10 md:py-[60px]">
    <div class="w-full max-w-3xl flex flex-col gap-5">
      {%- if section.settings.references_heading != blank -%}
        <p class="text-base font-medium text-stone-900">{{ section.settings.references_heading }}</p>
      {%- endif -%}
      <ol class="flex flex-col gap-2 list-none">
        {%- for block in ref_blocks -%}
          <li class="flex gap-3" {{ block.shopify_attributes }}>
            <span class="text-sm text-stone-400 shrink-0 pt-0.5 min-w-[1.5rem] tabular-nums">{{ forloop.index }}.</span>
            <div class="flex flex-col gap-1 min-w-0">
              {%- if block.settings.url != blank -%}
                <a
                  href="{{ block.settings.url }}"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-medium text-stone-900 underline underline-offset-2 break-words"
                >{{ block.settings.title }}</a>
              {%- else -%}
                <p class="text-sm font-medium text-stone-900">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- liquid
                assign meta_parts = ''
                if block.settings.author != blank
                  assign meta_parts = block.settings.author
                endif
                if block.settings.journal != blank
                  if meta_parts != blank
                    assign meta_parts = meta_parts | append: ' / ' | append: block.settings.journal
                  else
                    assign meta_parts = block.settings.journal
                  endif
                endif
                if block.settings.year != blank
                  if meta_parts != blank
                    assign meta_parts = meta_parts | append: ', ' | append: block.settings.year
                  else
                    assign meta_parts = block.settings.year
                  endif
                endif
              -%}
              {%- if meta_parts != blank -%}
                <p class="text-sm text-stone-500">{{ meta_parts }}</p>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ol>
    </div>
  </div>
{%- endif -%}

{%- comment %} ============================================================
  この成分を配合した製品
  ============================================================ {%- endcomment -%}
{%- assign ingredient_products = article.metafields.custom.product_reference.value -%}
{%- if ingredient_products != blank -%}
  <section class="w-full bg-stone-50 flex flex-col gap-10 items-center overflow-hidden px-4 md:px-10 py-10 md:py-[60px]">
    <div class="w-full max-w-screen-xl flex flex-col gap-2 items-center text-center">
      {%- if section.settings.products_heading != blank -%}
        <h2 class="text-4xl font-semibold tracking-wider text-stone-900">
          {{ section.settings.products_heading }}
        </h2>
      {%- endif -%}
      {%- if section.settings.products_subheading != blank -%}
        <p class="text-lg text-stone-900/70">{{ section.settings.products_subheading }}</p>
      {%- endif -%}
    </div>

    <div class="w-full max-w-screen-xl grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-6 md:gap-6">
      {%- for product in ingredient_products -%}
        {%- render 'card-product-4col', product: product -%}
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

