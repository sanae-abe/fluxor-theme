{%- comment %}
  商品詳細ページセクション (main-product.liquid)
  使用: templates/product.json に追加して使用

  対応メタフィールド (名前空間: custom):
    title_notes         {list.single_line_text_field}    タイトル注釈リスト（例: 透明感：うるおいを与え、キメを整えることによる）
    volume              {single_line_text_field}         内容量テキスト（例: 30ml（約1〜2ヶ月分））
    product_benefits    {list.single_line_text_field}    効能・効果リスト
    key_ingredients     {list.metaobject_reference}      注目成分リスト（key_ingredient: ingredient, ingredient.article, amount）
    certifications      {list.metaobject_reference}      商品ラベル（クルエルティフリー、ヴィーガン等）(certifications: name, icon, description)
    skin_type           {list.metaobject_reference}      おすすめの肌質 (suitable-for-skin-type; shopify--suitable-for-skin-type.label)
    ph_level            {single_line_text_field}         pHレベル
    origin              {single_line_text_field}         原産国
    texture             {single_line_text_field}         テクスチャー
    all_ingredients     {multi_line_text_field}          全成分テキスト
    all_ingredients_ja  {multi_line_text_field}          全成分テキスト（日本語）
    usage_timing        {multi_line_text_field}          使用タイミング
    usage_method        {multi_line_text_field}          使用方法テキスト
    how_to_store        {multi_line_text_field}          保管方法テキスト
    precautions         {multi_line_text_field}          注意事項テキスト
{%- endcomment -%}

{%- liquid
  assign variant = product.selected_or_first_available_variant
  assign on_sale = false
  if variant.compare_at_price > variant.price
    assign on_sale  = true
    assign discount = variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price
  endif

  assign rating_value = product.metafields.judgeme.avg_rating
  assign rating_count = product.metafields.judgeme.review_count

  assign title_notes        = product.metafields.custom.title_notes.value
  assign volume             = product.metafields.custom.volume
  assign product_benefits   = product.metafields.custom.product_benefits.value
  assign key_ingredients    = product.metafields.custom.key_ingredients.value
  assign certifications     = product.metafields.custom.certifications.value
  assign skin_types         = product.metafields.shopify.suitable-for-skin-type.value
  assign ph_level           = product.metafields.custom.ph_level
  assign origin             = product.metafields.custom.origin
  assign texture            = product.metafields.custom.texture
  assign all_ingredients    = product.metafields.custom.all_ingredients
  assign all_ingredients_ja = product.metafields.custom.all_ingredients_ja | default: all_ingredients
  assign usage_timing       = product.metafields.custom.usage_timing
  assign usage_method       = product.metafields.custom.usage_method
  assign how_to_store       = product.metafields.custom.how_to_store
  assign precautions        = product.metafields.custom.precautions
  assign product_name_en    = product.metafields.custom.product_name_en

  assign sale_eligible = false
  assign sale_discount = 0

  if settings.sale_enabled
    assign _excluded = false
    if settings.sale_exclude_handles != blank
      assign _exclude_handle_list = settings.sale_exclude_handles | split: ','
      for _handle in _exclude_handle_list
        assign _handle_normalized = _handle | strip | downcase
        if _handle_normalized == product.handle
          assign _excluded = true
          break
        endif
      endfor
    endif

    unless _excluded or settings.sale_exclude_tags == blank
      assign _exclude_tag_list = settings.sale_exclude_tags | split: ','
      for _exclude_tag in _exclude_tag_list
        assign _exclude_tag_normalized = _exclude_tag | strip | downcase
        for _product_tag in product.tags
          assign _product_tag_normalized = _product_tag | downcase
          if _product_tag_normalized == _exclude_tag_normalized
            assign _excluded = true
            break
          endif
        endfor
        if _excluded
          break
        endif
      endfor
    endunless

    unless _excluded
      case settings.sale_target
      when 'all'
        assign sale_eligible = true
      when 'tag'
        if settings.sale_target_tags != blank
          assign _target_tag_list = settings.sale_target_tags | split: ','
          for _target_tag in _target_tag_list
            assign _target_tag_normalized = _target_tag | strip | downcase
            for _product_tag in product.tags
              assign _product_tag_normalized = _product_tag | downcase
              if _product_tag_normalized == _target_tag_normalized
                assign sale_eligible = true
                break
              endif
            endfor
            if sale_eligible
              break
            endif
          endfor
        endif
      when 'collection'
        if settings.sale_target_collections != blank
          assign _target_col_list = settings.sale_target_collections | split: ','
          for _target_col_handle in _target_col_list
            assign _target_col_normalized = _target_col_handle | strip | downcase
            for _product_col in product.collections
              if _product_col.handle == _target_col_normalized
                assign sale_eligible = true
                break
              endif
            endfor
            if sale_eligible
              break
            endif
          endfor
        endif
      endcase

      if sale_eligible
        assign sale_discount = settings.sale_discount_percent | plus: 0
      endif
    endunless
  endif
-%}

{%- comment %} ※ 上付き文字変換用共通変数（※1〜※5 と ※ を <sup> タグに置換） {%- endcomment -%}
{%- assign _sup_open = '<sup class="text-xs font-normal text-stone-400 align-super">' -%}
{%- assign _sup1 = _sup_open | append: '※1</sup>' -%}
{%- assign _sup2 = _sup_open | append: '※2</sup>' -%}
{%- assign _sup3 = _sup_open | append: '※3</sup>' -%}
{%- assign _sup4 = _sup_open | append: '※4</sup>' -%}
{%- assign _sup5 = _sup_open | append: '※5</sup>' -%}
{%- assign _sup  = _sup_open | append: '※</sup>' -%}

{%- comment %} 価格表示（メイン商品情報とフローティングバーで共有） {%- endcomment -%}
{%- capture price_html -%}
  {%- if on_sale -%}
    <span class="text-3xl font-semibold text-stone-900 leading-none">{{ variant.price | money }}</span>
    <s class="text-base text-stone-500 leading-tight">{{ variant.compare_at_price | money }}</s>
  {%- elsif sale_eligible -%}
    <span class="text-3xl font-semibold text-stone-900 leading-none"
      x-text="(saleEligible && $store.sale.isActive()) ? $store.sale.formatMoney(salePrice) : $store.sale.formatMoney(selectedVariant.price / 100)"
    >{{ variant.price | money }}</span>
    <s class="text-base text-stone-500 leading-tight"
      x-show="saleEligible && $store.sale.isActive()"
      x-text="$store.sale.formatMoney(selectedVariant.price / 100)"
      x-cloak
    >{{ variant.price | money }}</s>
  {%- else -%}
    <span class="text-3xl font-semibold text-stone-900 leading-none">{{ variant.price | money }}</span>
  {%- endif -%}
{%- endcapture -%}

{%- comment %} 割引バッジ（メイン商品情報とフローティングバーで共有） {%- endcomment -%}
{%- capture discount_badge_html -%}
  {%- if on_sale -%}
    {%- assign discount_label = discount | append: '% OFF' -%}
    {%- render 'badge', label: discount_label, variant: 'premium', size: 'sm' -%}
  {%- elsif sale_eligible -%}
    {%- assign _sched_discount_label = sale_discount | append: '% OFF' -%}
    <template x-if="saleEligible && $store.sale.isActive()">
      <div>{%- render 'badge', label: _sched_discount_label, variant: 'premium', size: 'sm' -%}</div>
    </template>
  {%- endif -%}
{%- endcapture -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "ホーム", "item": {{ shop.url | json }}}
    {%- if collection != blank -%}
    ,{"@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ collection.url | prepend: shop.url | json }}}
    ,{"@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": {{ product.url | prepend: shop.url | json }}}
    {%- else -%}
    ,{"@type": "ListItem", "position": 2, "name": {{ product.title | json }}, "item": {{ product.url | prepend: shop.url | json }}}
    {%- endif -%}
  ]
}
</script>

<div x-data="productPageData()">

{%- comment %}====================================================
  商品情報セクション
===================================================={%- endcomment -%}
<section
  id="product-info"
  class="bg-stone-50 px-4 md:px-10 py-10 md:py-[60px]"
>
  <div class="max-w-screen-xl mx-auto flex flex-col lg:flex-row gap-6 md:gap-16 items-start">

    {%- comment %} 左カラム: 画像ギャラリー {%- endcomment -%}
    <div class="w-full lg:flex-1 flex flex-col gap-4">

      <div class="aspect-square overflow-hidden bg-stone-100 [transform:translateZ(0)]">
        {%- if product.featured_image -%}
          <img
            src="{{ product.featured_image | image_url: width: 800 }}"
            :src="activeImage"
            alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            class="w-full h-full object-cover"
            width="800"
            height="800"
          >
        {%- else -%}
          <div class="w-full h-full flex items-center justify-center text-stone-300">
            {%- render 'icon', icon: 'image', class: 'w-16 h-16' -%}
          </div>
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        {%- comment %} サムネイル横カルーセル（4枚表示、以降は左右ボタンで切り替え） {%- endcomment -%}
        <div
          class="relative"
          x-data="{ thumbOffset: 0, maxOffset: Math.max(0, {{ product.images.size }} - 4) }"
        >
          <button
            type="button"
            class="absolute left-0 top-0 z-10 h-full w-6 flex items-center justify-center bg-stone-50/80 transition-opacity focus-visible:outline-none"
            :class="thumbOffset === 0 ? 'opacity-0 pointer-events-none' : 'opacity-100 text-stone-500'"
            @click="thumbOffset = Math.max(0, thumbOffset - 1); $refs.thumbTrack.scrollTo({ left: thumbOffset * (($refs.thumbTrack.querySelector('button')?.offsetWidth ?? 0) + 12), behavior: 'smooth' })"
            aria-label="前へ"
          >
            {%- render 'icon', icon: 'chevron-left', class: 'w-5 h-5' -%}
          </button>

          <div class="overflow-hidden" x-ref="thumbTrack">
            <div class="flex gap-3">
              {%- for image in product.images limit: 12 -%}
                {%- assign thumb_url = image | image_url: width: 800 -%}
                <button
                  type="button"
                  class="w-[calc(25%-9px)] shrink-0 aspect-square overflow-hidden bg-stone-100 border-2 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-900 focus-visible:ring-offset-1 [transform:translateZ(0)]"
                  :class="activeImage === '{{ thumb_url }}' ? 'border-stone-900' : 'border-transparent'"
                  @click="activeImage = '{{ thumb_url }}'"
                  aria-label="{{ image.alt | escape | default: product.title | escape }}"
                >
                  <img
                    src="{{ image | image_url: width: 300 }}"
                    alt="{{ image.alt | escape | default: product.title | escape }}"
                    class="w-full h-full object-cover"
                    loading="lazy"
                    width="300"
                    height="300"
                  >
                </button>
              {%- endfor -%}
            </div>
          </div>

          <button
            type="button"
            class="absolute right-0 top-0 z-10 h-full w-6 flex items-center justify-center bg-stone-50/80 transition-opacity focus-visible:outline-none"
            :class="thumbOffset >= maxOffset ? 'opacity-0 pointer-events-none' : 'opacity-100 text-stone-500'"
            @click="thumbOffset = Math.min(maxOffset, thumbOffset + 1); $refs.thumbTrack.scrollTo({ left: thumbOffset * (($refs.thumbTrack.querySelector('button')?.offsetWidth ?? 0) + 12), behavior: 'smooth' })"
            aria-label="次へ"
          >
            {%- render 'icon', icon: 'chevron-right', class: 'w-5 h-5' -%}
          </button>
        </div>
      {%- endif -%}
    </div>

    {%- comment %} 右カラム: 商品情報 {%- endcomment -%}
    <div class="w-full lg:flex-1 flex flex-col gap-6 lg:sticky lg:top-20 min-w-0">

      <div class="flex flex-col gap-3">
        {%- if product.vendor != blank -%}
          <p class="text-sm text-stone-500 leading-tight">{{ product.vendor }}</p>
        {%- endif -%}

        {%- assign display_title = product.title
          | replace: '※1', _sup1
          | replace: '※2', _sup2
          | replace: '※3', _sup3
          | replace: '※4', _sup4
          | replace: '※5', _sup5
          | replace: '※',  _sup
        -%}
        <div class="flex flex-wrap items-start gap-2">
          <h1 class="text-2xl md:text-3xl font-medium leading-tight text-stone-900 palt tracking-wider">{{ display_title }}
          {%- if product.tags contains 'new' or product.tags contains 'NEW' or product.tags contains 'New' -%}
            {%- render 'badge', label: 'NEW', variant: 'accent', size: 'sm' -%}
          {%- endif -%}
          {%- if title_notes != blank -%}
            <span class="inline-flex gap-1 align-middle">
              {%- if title_notes.size == 1 -%}
                <span class="text-xs text-stone-400 font-normal tracking-normal">※{{ title_notes.first }}</span>
              {%- else -%}
                {%- for note in title_notes -%}
                  <span class="text-xs text-stone-400 font-normal tracking-normal">※{{ forloop.index }}{{ note }}</span>
                {%- endfor -%}
              {%- endif -%}
            </span>
          {%- endif -%}</h1>
        </div>

        {%- if product_name_en != blank -%}
          <p class="text-stone-400 text-sm leading-tight">{{ product_name_en }}</p>
        {%- endif -%}

        {%- if volume != blank -%}
          <p class="text-stone-900 leading-relaxed">内容量：{{ volume }}</p>
        {%- endif -%}

        <div style='{{ jm_style }}' class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}' data-auto-install='false'>
          {{ product.metafields.judgeme.badge }}
        </div>

        {%- if rating_value != blank -%}
          <div class="flex items-center gap-2">
            <div class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-stone-900" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M8 1.5 9.796 5.14l4.018.583-2.907 2.833.686 4L8 10.666l-3.593 1.89.686-4L2.186 5.723l4.018-.583z"/>
              </svg>
              <span class="text-sm font-medium text-stone-900 leading-tight">{{ rating_value | round: 1 }}</span>
            </div>
            {%- if rating_count != blank -%}
              <span class="text-sm text-stone-500 leading-tight">（{{ rating_count }}件のレビュー）</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <div class="flex items-end gap-2 flex-wrap">
        {{ price_html }}
        <span class="text-sm text-stone-900 leading-tight">(税込・送料込)</span>
        {{ discount_badge_html }}
      </div>

      {%- if product_benefits != blank -%}
        <div class="flex flex-col gap-2">
          {%- for product_benefit in product_benefits -%}
            {%- assign benefit_parts = product_benefit | split: ' ※' -%}
            {%- assign benefit_main = benefit_parts[0]
              | replace: '※1', _sup1
              | replace: '※2', _sup2
              | replace: '※3', _sup3
              | replace: '※4', _sup4
              | replace: '※5', _sup5
              | replace: '※', _sup
            -%}
            <div class="flex items-start gap-2">
              {%- render 'icon', icon: 'check', width: 16, height: 16, stroke: '#0f766e', class: 'shrink-0 mt-1' -%}
              <p class="text-stone-900 leading-relaxed">
                {{- benefit_main -}}
                {%- for i in (1..5) -%}
                  {%- if benefit_parts[i] != blank -%}
                    <span class="text-xs text-stone-400"> ※{{ benefit_parts[i] }}</span>
                  {%- endif -%}
                {%- endfor -%}
              </p>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment %} 注目の成分カルーセル {%- endcomment -%}
      {%- if key_ingredients != blank -%}
        <hr class="border-stone-200">
        {%- comment %} description を持つ成分のインデックスをカンマ区切りで収集（tooltip 表示判定に使用） {%- endcomment -%}
        {%- assign _ingredient_desc_indices = '' -%}
        {%- for _ki in key_ingredients -%}
          {%- if _ki.description != blank -%}
            {%- if _ingredient_desc_indices != '' -%}{%- assign _ingredient_desc_indices = _ingredient_desc_indices | append: ',' -%}{%- endif -%}
            {%- assign _ingredient_desc_indices = _ingredient_desc_indices | append: forloop.index0 -%}
          {%- endif -%}
        {%- endfor -%}
        <div
          class="min-w-0 relative"
          x-data="ingredientCarousel([{{ _ingredient_desc_indices }}])"
          x-init="$nextTick(() => updateNav())"
        >

          <div class="flex items-center justify-between gap-1 pb-3">
            <div class="flex items-center gap-1">
              <span class="text-sm font-medium text-stone-900 leading-tight palt tracking-wide">注目の成分</span>
            </div>
            <div class="text-xs text-stone-400 text-right">※すべて整肌・保湿成分として</div>
          </div>

          <div class="relative overflow-x-hidden min-w-0">
          <div x-ref="carouselRow">

            <button
              type="button"
              class="absolute left-0 top-0 z-10 w-6 h-full bg-stone-50/80 flex items-center justify-center transition-opacity focus-visible:outline-none"
              :class="atStart ? 'opacity-0 pointer-events-none' : 'opacity-100 text-stone-500 hover:text-stone-900'"
              @click="$refs.track.scrollLeft -= cardW; $nextTick(() => updateNav())"
              aria-label="前へ"
            >
              {%- render 'icon', icon: 'chevron-left', class: 'w-5 h-5' -%}
            </button>

            <div
              x-ref="track"
              class="ingredient-track flex gap-2 overflow-x-auto scroll-smooth"
              @scroll="updateNav()"
            >
              {%- for key_ingredient in key_ingredients -%}
                {%- assign amount  = key_ingredient.amount -%}
                {%- assign ing_idx = forloop.index0 -%}
                <div
                  class="shrink-0 w-[190px] cursor-default select-none"
                  @mouseenter="active = {{ ing_idx }}"
                  @mouseleave="active = null"
                  @click.stop="active = active === {{ ing_idx }} ? null : {{ ing_idx }}"
                >
                  <div
                    class="bg-white rounded-lg border p-2 flex items-center gap-2 transition-colors duration-150 h-[64px]"
                    :class="active === {{ ing_idx }} ? 'border-stone-500' : 'border-stone-200'"
                  >
                    {%- if key_ingredient.thumbnail != blank -%}
                      <img
                        src="{{ key_ingredient.thumbnail | image_url: width: 96, height: 96, crop: 'center' }}"
                        alt="{{ key_ingredient.ingredient }}"
                        class="w-12 h-12 rounded-full object-cover shrink-0"
                        width="48" height="48" loading="lazy"
                      >
                    {%- else -%}
                      <div class="w-12 h-12 rounded-full bg-stone-100 border border-stone-200 shrink-0 flex items-center justify-center">
                        {%- render 'icon', icon: 'flask-conical', class: 'w-5 h-5 text-stone-300' -%}
                      </div>
                    {%- endif -%}

                    <div class="text-sm text-stone-900 leading-snug palt min-w-0">
                      <p class="line-clamp-2 break-words">{{ key_ingredient.ingredient }}
                      {%- if amount != blank -%}({{ amount }}){%- endif -%}
                      </p>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>

            <button
              type="button"
              class="absolute top-0 right-0 z-10 w-6 h-full bg-stone-50/80 flex items-center justify-center transition-opacity focus-visible:outline-none"
              :class="atEnd ? 'opacity-0 pointer-events-none' : 'opacity-100 text-stone-500 hover:text-stone-900'"
              @click="$refs.track.scrollLeft += cardW; $nextTick(() => updateNav())"
              aria-label="次へ"
            >
              {%- render 'icon', icon: 'chevron-right', class: 'w-5 h-5' -%}
            </button>
          </div>
          </div>

          {%- if _ingredient_desc_indices != '' -%}
            <div
              class="absolute z-20 w-80"
              x-show="descIdx.includes(active)"
              x-cloak
              :style="{ left: tooltipLeft() + 'px', top: ($refs.carouselRow ? $refs.carouselRow.offsetTop + $refs.carouselRow.offsetHeight + 12 : 0) + 'px' }"
              x-transition:enter="transition ease-out duration-200"
              x-transition:enter-start="opacity-0 translate-y-1"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-transition:leave="transition ease-in duration-100"
              x-transition:leave-start="opacity-100"
              x-transition:leave-end="opacity-0"
            >
              <div class="absolute -top-[7px] left-[calc(50%-7px)] w-3 h-3 bg-white border-l border-t border-stone-200 rotate-45"></div>
              <div class="bg-white border border-stone-200 rounded-lg shadow-sm p-3 text-sm text-stone-700 leading-relaxed">
                {%- for key_ingredient in key_ingredients -%}
                  {%- if key_ingredient.description != blank -%}
                    <div x-show="active === {{ forloop.index0 }}">
                      {{ key_ingredient.description | newline_to_br }}
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

        </div>
      {%- endif -%}

      {%- if certifications != blank -%}
        <hr class="border-stone-200">
        <div class="flex flex-wrap gap-2">
          {%- for certification in certifications -%}
            <span class="bg-white border border-stone-200 px-1.5 py-[6px] text-xs text-stone-900 leading-tight">{{ certification.name }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- unless product.has_only_default_variant -%}
        <div class="flex flex-col gap-4">
          {%- for option in product.options_with_values -%}
            <div class="flex flex-col gap-1">
              <p class="text-xs font-medium text-stone-900 uppercase tracking-wider">{{ option.name }}</p>
              <div class="flex flex-wrap gap-2">
                {%- for value in option.values -%}
                  <label class="cursor-pointer">
                    <input
                      type="radio"
                      name="option-{{ forloop.parentloop.index }}"
                      value="{{ value }}"
                      class="sr-only peer"
                      {% if option.selected_value == value %}checked{% endif %}
                      @change="selectedOptions[{{ forloop.parentloop.index0 }}] = $event.target.value"
                    >
                    <span class="inline-flex items-center justify-center border border-stone-200 px-4 h-10 text-sm text-stone-900 peer-checked:border-stone-900 peer-checked:bg-stone-900 peer-checked:text-white transition-colors cursor-pointer">
                      {{ value }}
                    </span>
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      {%- if skin_types != blank or ph_level != blank or origin != blank or texture != blank -%}
        <div class="flex flex-wrap gap-x-8 gap-y-2">
          {%- if skin_types != blank -%}
            <p class="text-sm text-stone-900 leading-relaxed">
              <span class="font-medium">おすすめの肌質：</span>{%- for skin_type in skin_types -%}{{ skin_type.label }}{%- unless forloop.last -%}、{%- endunless -%}{%- endfor -%}
            </p>
          {%- endif -%}
          {%- if ph_level != blank -%}
            <p class="text-sm text-stone-900 leading-relaxed">
              <span class="font-medium">pHレベル：</span>{{ ph_level }}
            </p>
          {%- endif -%}
          {%- if origin != blank -%}
            <p class="text-sm text-stone-900 leading-relaxed">
              <span class="font-medium">原産国：</span>{{ origin }}
            </p>
          {%- endif -%}
          {%- if texture != blank -%}
            <p class="text-sm text-stone-900 leading-relaxed">
              <span class="font-medium">テクスチャー：</span>{{ texture }}
            </p>
          {%- endif -%}
        </div>
      {%- endif -%}

      <hr class="border-stone-200">

      <div class="flex flex-col gap-4">
        {%- render 'product-qty-add' -%}
        <p class="flex gap-2 text-sm justify-end">{%- render 'icon', icon: 'van', class: 'w-5 h-5 flex-shrink-0 stroke-1.5' -%}国際配送のため、通常ご注文から約14〜21営業日でお届けいたします。</p>
      </div>
    </div>
  </div>
</section>

{%- comment %}====================================================
  関連商品セクション
===================================================={%- endcomment -%}
{%- assign related_col = collections[section.settings.related_collection] -%}
{%- if related_col != blank -%}
  <section class="bg-stone-50 px-4 md:px-10 py-10 md:py-[60px]">
    <div class="max-w-screen-xl mx-auto flex flex-col gap-6 md:gap-10">

      {%- render 'section-header', heading: section.settings.related_heading -%}

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-6 md:gap-x-10 md:gap-y-6">
        {%- assign shown = 0 -%}
        {%- for p in related_col.products -%}
          {%- unless p.id == product.id -%}
            {%- render 'card-product-4col', product: p -%}
            {%- assign shown = shown | plus: 1 -%}
          {%- endunless -%}
          {%- if shown >= section.settings.related_products_count -%}{%- break -%}{%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </section>
{%- endif -%}

{%- comment %}====================================================
  フローティングカートバー（スクロール追従）
===================================================={%- endcomment -%}
<div
  id="floating-cart-bar"
  class="fixed bottom-0 left-0 right-0 z-50 bg-stone-50 border-t border-stone-200 px-10 py-4"
  role="complementary"
  aria-label="クイックカート"
  aria-hidden="true"
>
  <div class="max-w-screen-xl mx-auto flex items-center justify-between gap-4">

    <div class="flex items-center gap-4 min-w-0">
      <div class="w-[67px] h-[67px] shrink-0 overflow-hidden bg-stone-100">
        {%- if product.featured_image -%}
          <img
            src="{{ product.featured_image | image_url: width: 200 }}"
            alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            class="w-full h-full object-cover"
            width="67"
            height="67"
            loading="lazy"
          >
        {%- endif -%}
      </div>
      <div class="flex flex-col gap-2 min-w-0">
        {%- if product.vendor != blank -%}
          <p class="text-sm text-stone-500 leading-none">{{ product.vendor }}</p>
        {%- endif -%}
        <p class="text-base font-medium text-stone-900 leading-tight truncate">{{ product.title }}</p>
      </div>
    </div>

    <div class="flex items-center gap-4 shrink-0">
      <div class="flex items-end gap-2 whitespace-nowrap">
        {{ price_html }}
      </div>

      {%- render 'product-qty-add', compact: true -%}
    </div>

  </div>
</div>

</div>{%- comment %} x-data wrapper close {%- endcomment -%}

<script>
  function ingredientCarousel(descIdx) {
    return {
      active: null,
      atStart: true,
      atEnd: false,
      cardW: 198,
      descIdx,
      updateNav() {
        const t = this.$refs.track;
        this.atStart = t.scrollLeft <= 0;
        this.atEnd   = t.scrollLeft >= t.scrollWidth - t.clientWidth - 1;
      },
      tooltipLeft() {
        if (this.active === null || !this.$refs.track) return 0;
        const cardLeft = this.active * this.cardW - this.$refs.track.scrollLeft;
        return Math.min(Math.max(cardLeft, 0), this.$refs.track.offsetWidth - 288);
      }
    };
  }

  function productPageData() {
    return {
      variants: {{ product.variants | json }},
      selectedOptions: {{ variant.options | json }},
      activeImage: "{{ product.featured_image | image_url: width: 800 }}",
      qty: 1,
      adding: false,
      get selectedVariant() {
        return this.variants.find(v =>
          v.options.every((opt, i) => opt === this.selectedOptions[i])
        ) || this.variants[0];
      },
      saleEligible: {{ sale_eligible | json }},
      saleDiscount: {{ sale_discount | default: 0 }},
      get salePrice() {
        return Math.floor(this.selectedVariant.price / 100 * (100 - this.saleDiscount) / 100);
      },
      get variantAvailable() { return this.selectedVariant.available; },
      async addToCart() {
        if (this.adding || !this.variantAvailable) return;
        this.adding = true;
        await this.$store.cart.add(this.selectedVariant.id, this.qty);
        this.adding = false;
      }
    };
  }

  document.addEventListener('DOMContentLoaded', function () {
    const bar = document.getElementById('floating-cart-bar');
    const productSection = document.getElementById('product-info');
    const footer = document.getElementById('site-footer');
    if (!bar || !productSection) return;

    let productPassed = false;
    let footerVisible = false;

    function updateVisibility() {
      const visible = productPassed && !footerVisible;
      bar.classList.toggle('is-visible', visible);
      bar.setAttribute('aria-hidden', String(!visible));
    }

    new IntersectionObserver(
      ([entry]) => {
        productPassed = !entry.isIntersecting;
        updateVisibility();
      },
      { threshold: 0 }
    ).observe(productSection);

    if (footer) {
      new IntersectionObserver(
        ([entry]) => {
          footerVisible = entry.isIntersecting;
          updateVisibility();
        },
        { threshold: 0 }
      ).observe(footer);
    }
  });

</script>

{%- schema %}
{
  "name": "商品詳細",
  "settings": [
    {
      "type": "header",
      "content": "関連商品（コレクション指定）"
    },
    {
      "type": "text",
      "id": "related_heading",
      "label": "見出し",
      "default": "あわせてお試しください"
    },
    {
      "type": "collection",
      "id": "related_collection",
      "label": "関連商品コレクション"
    },
    {
      "type": "range",
      "id": "related_products_count",
      "label": "表示件数",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ]
}
{%- endschema -%}
