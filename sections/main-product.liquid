{%- comment %}======================================================
  フローティングカートバー（スクロール追従）
======================================================{%- endcomment %}
<div
  id="floating-cart-bar"
  class="fixed bottom-0 left-0 right-0 z-50 bg-stone-50 border-t border-stone-200 px-10 py-4"
  role="complementary"
  aria-label="クイックカート"
  aria-hidden="true"
>
  <div class="max-w-screen-xl mx-auto flex items-center justify-between gap-4">

    <div class="flex items-center gap-4 min-w-0">
      <div class="w-[67px] h-[67px] shrink-0 overflow-hidden bg-stone-100">
        {%- if product.featured_image -%}
          <img
            src="{{ product.featured_image | image_url: width: 200 }}"
            alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            class="w-full h-full object-cover"
            width="67"
            height="67"
            loading="lazy"
          >
        {%- endif -%}
      </div>
      <div class="flex flex-col gap-2 min-w-0">
        {%- if product.vendor != blank -%}
          <p class="text-sm text-stone-500 leading-none">{{ product.vendor }}</p>
        {%- endif -%}
        <p class="text-base font-medium text-stone-900 leading-tight truncate">{{ product.title }}</p>
      </div>
    </div>

    <div class="flex items-center gap-4 shrink-0">
      <div class="flex items-end gap-2 whitespace-nowrap">
        <span class="text-3xl font-medium text-stone-900 leading-none">{{ variant.price | money }}</span>
        {%- if on_sale -%}
          <s class="text-base text-stone-500 leading-tight">{{ variant.compare_at_price | money }}</s>
        {%- endif -%}
      </div>

      <div class="flex items-center border border-stone-200 w-[144px]">
        <button
          type="button"
          class="flex items-center justify-center w-12 h-12 text-stone-900 transition-opacity hover:opacity-60 focus-visible:outline-none"
          @click="qty = Math.max(1, qty - 1)"
          aria-label="数量を減らす"
        >
          {%- render 'icon', icon: 'minus', class: 'w-5 h-5' -%}
        </button>
        <div
          class="flex items-center justify-center flex-1 h-12 text-base text-stone-900 select-none"
          x-text="qty"
          aria-live="polite"
          aria-label="数量"
        >1</div>
        <button
          type="button"
          class="flex items-center justify-center w-12 h-12 text-stone-900 transition-opacity hover:opacity-60 focus-visible:outline-none"
          @click="qty++"
          aria-label="数量を増やす"
        >
          {%- render 'icon', icon: 'plus', class: 'w-5 h-5' -%}
        </button>
      </div>

      <button
        type="button"
        class="btn-add-to-cart bg-stone-950 border-2 border-stone-950 text-white flex items-center justify-center min-h-[48px] min-w-[144px] px-4 py-2 whitespace-nowrap focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-900 focus-visible:ring-offset-2"
        :class="(adding || !variantAvailable) ? 'opacity-70 cursor-wait' : ''"
        @click="addToCart()"
        :disabled="adding || !variantAvailable"
      >
        <span class="text-base font-medium leading-tight" x-show="!adding" x-text="variantAvailable ? 'カートに追加' : '売り切れ'">カートに追加</span>
        <span class="text-base font-medium leading-tight" x-show="adding" x-cloak>追加中…</span>
      </button>
    </div>

  </div>
</div>

</div>{{- '' -}}{%- comment -%}x-data wrapper close{%- endcomment -%}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const bar = document.getElementById('floating-cart-bar');
    const productSection = document.getElementById('product-info');
    const footer = document.getElementById('site-footer');
    if (!bar || !productSection) return;

    let productPassed = false;
    let footerVisible = false;

    function updateVisibility() {
      const visible = productPassed && !footerVisible;
      bar.classList.toggle('is-visible', visible);
      bar.setAttribute('aria-hidden', String(!visible));
    }

    new IntersectionObserver(
      ([entry]) => {
        productPassed = !entry.isIntersecting;
        updateVisibility();
      },
      { threshold: 0 }
    ).observe(productSection);

    if (footer) {
      new IntersectionObserver(
        ([entry]) => {
          footerVisible = entry.isIntersecting;
          updateVisibility();
        },
        { threshold: 0 }
      ).observe(footer);
    }
  });
</script>

{% schema %}
{
  "name": "商品詳細",
  "settings": [
    {
      "type": "header",
      "content": "個人輸入代行に関する注意事項"
    },
    {
      "type": "checkbox",
      "id": "show_import_notice",
      "label": "注意事項を表示する",
      "default": true
    },
    {
      "type": "textarea",
      "id": "import_notice_declaration",
      "label": "①本サービスについて（個人輸入代行の宣言）",
      "default": "当店「Fluxor」で提供しているサービスは、お客様ご自身が海外の事業者から商品を直接購入するための「個人輸入代行」となります。当店は商品の販売者ではなく、購入の手続きと発送手配を代行するサービスを提供しております。"
    },
    {
      "type": "textarea",
      "id": "import_notice_liability",
      "label": "②免責事項（薬機法・自己責任）",
      "default": "海外コスメは日本の薬機法に基づく承認を受けた商品ではございません。ご使用についてはお客様の完全な自己責任となります。万が一、肌に合わない場合やトラブルが発生した場合、当店では一切の責任（製造物責任等）を負いかねます。事前に成分等をご確認の上、ご自身の判断でご使用ください。"
    },
    {
      "type": "textarea",
      "id": "import_notice_resale",
      "label": "②転売禁止",
      "default": "個人輸入された商品は、輸入したご本人のみが使用することを前提としています。第三者への譲渡・転売（メルカリ等での販売を含む）は日本の法律により固く禁じられています。"
    },
    {
      "type": "textarea",
      "id": "import_notice_customs",
      "label": "③関税・輸入数量制限",
      "default": "化粧品の個人輸入には数量制限がございます（標準サイズで1品目につき24個まで）。制限を超えるご注文があった場合、分割発送のご相談をさせていただく場合がございます。また、ご購入金額（商品代金）が日本円で約16,666円を超える場合、日本の税関で関税・消費税等が発生する場合がございます。その際に発生した税金等につきましては、お客様（輸入者様）のご負担となりますので予めご了承ください。"
    },
    {
      "type": "textarea",
      "id": "import_notice_returns",
      "label": "④キャンセル・返品・交換",
      "default": "個人輸入代行というサービスの性質上、海外事業者への発注が完了した後のキャンセル、返品、交換は原則としてお受けできません。ただし、商品到着時に明らかな破損・液漏れ、またはご注文と異なる商品が届いた場合に限り、到着後3日以内にご連絡いただければ、海外事業者への返金・再送の交渉をサポートいたします。"
    },
    {
      "type": "header",
      "content": "配送・返品タブ"
    },
    {
      "type": "header",
      "content": "関連商品"
    },
    {
      "type": "text",
      "id": "related_heading",
      "label": "見出し",
      "default": "あわせてお試しください"
    },
    {
      "type": "collection",
      "id": "related_collection",
      "label": "関連商品コレクション"
    },
    {
      "type": "range",
      "id": "related_products_count",
      "label": "表示件数",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ]
}
{% endschema %}
