{% comment %}
  商品詳細ページセクション (main-product.liquid)
  使用: templates/product.json に追加して使用

  対応メタフィールド (名前空間: custom):
    volume              {single_line_text_field}         内容量テキスト（例: 30ml（約1〜2ヶ月分））
    benefits            {list.metaobject_reference}      効能・効果リスト (product_benefits: number, description, category)
    key_ingredients     {list.metaobject_reference}      注目成分リスト（key_ingredient: ingredient.name_ja, ingredient.article, amount）
    certifications      {list.metaobject_reference}      製品ラベル（クルエルティフリー、ヴィーガン等）(certifications: name, icon, description)
    skin_type           {list.metaobject_reference}      おすすめの肌質 (suitable-for-skin-type; shopify--suitable-for-skin-type.label)
    ph_level            {single_line_text_field}         pHレベル
    origin              {single_line_text_field}         原産国
    texture             {single_line_text_field}         テクスチャー
    all_ingredients     {multi_line_text_field}          全成分テキスト
    all_ingredients_ja  {multi_line_text_field}          全成分テキスト（日本語）
    usage_timing        {multi_line_text_field}          使用タイミング
    usage_method        {richtext}                       使用方法テキスト
    how_to_store        {richtext}                       保管方法テキスト
{% endcomment %}

{%- liquid
  assign variant      = product.selected_or_first_available_variant
  assign on_sale      = false
  if variant.compare_at_price > variant.price
    assign on_sale  = true
    assign discount = variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price
  endif

  assign rating_value = product.metafields.judgeme.avg_rating
  assign rating_count = product.metafields.judgeme.review_count

  assign volume             = product.metafields.custom.volume
  assign product_benefits   = product.metafields.custom.product_benefits.value
  assign key_ingredients    = product.metafields.custom.key_ingredients.value
  assign certifications     = product.metafields.custom.certifications.value
  assign skin_types         = product.metafields.shopify.suitable-for-skin-type.value
  assign ph_level           = product.metafields.custom.ph_level
  assign origin             = product.metafields.custom.origin
  assign texture            = product.metafields.custom.texture
  assign all_ingredients    = product.metafields.custom.all_ingredients
  assign all_ingredients_ja = product.metafields.custom.all_ingredients_ja | default: all_ingredients
  assign usage_timing       = product.metafields.custom.usage_timing
  assign usage_method       = product.metafields.custom.usage_method
  assign how_to_store       = product.metafields.custom.how_to_store
-%}

{%- comment %}======================================================
  商品情報セクション
======================================================{%- endcomment %}
<style>
  .btn-add-to-cart {
    transition: background-color 0.15s ease, color 0.15s ease, opacity 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (any-hover: hover) {
    .btn-add-to-cart:not(:disabled):hover {
      background-color: #ffffff;
      color: #0c0a09;
    }
  }
</style>

<script>
  function productPageData() {
    return {
      variants: {{ product.variants | json }},
      selectedOptions: {{ variant.options | json }},
      activeImage: "{{ product.featured_image | image_url: width: 800 }}",
      qty: 1,
      adding: false,
      get selectedVariant() {
        return this.variants.find(v =>
          v.options.every((opt, i) => opt === this.selectedOptions[i])
        ) || this.variants[0];
      },
      get variantAvailable() { return this.selectedVariant.available; },
      async addToCart() {
        if (this.adding || !this.variantAvailable) return;
        this.adding = true;
        await $store.cart.add(this.selectedVariant.id, this.qty);
        this.adding = false;
      }
    };
  }
</script>

<section
  class="bg-stone-50 px-10 py-[60px]"
  x-data="productPageData()"
>
  <div class="max-w-screen-xl mx-auto flex flex-col lg:flex-row gap-10 items-start">

    {%- comment %}--- 左カラム: 画像ギャラリー ---{%- endcomment %}
    <div class="w-full lg:flex-1 flex flex-col gap-4">

      {%- comment %} メイン画像 {%- endcomment %}
      <div class="aspect-square overflow-hidden bg-stone-100 [transform:translateZ(0)]">
        {%- if product.featured_image -%}
          <img
            src="{{ product.featured_image | image_url: width: 800 }}"
            :src="activeImage"
            alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            class="w-full h-full object-cover"
            width="800"
            height="800"
          >
        {%- else -%}
          <div class="w-full h-full flex items-center justify-center text-stone-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
        {%- endif -%}
      </div>

      {%- comment %} サムネイル {%- endcomment %}
      {%- if product.images.size > 1 -%}
        <div class="grid grid-cols-4 gap-3">
          {%- for image in product.images limit: 4 -%}
            {%- assign thumb_url = image | image_url: width: 800 -%}
            <button
              type="button"
              class="aspect-square overflow-hidden bg-stone-100 border-2 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-900 focus-visible:ring-offset-1 [transform:translateZ(0)]"
              :class="activeImage === '{{ thumb_url }}' ? 'border-stone-900' : 'border-transparent'"
              @click="activeImage = '{{ thumb_url }}'"
              aria-label="{{ image.alt | escape | default: product.title | escape }}"
            >
              <img
                src="{{ image | image_url: width: 300 }}"
                alt="{{ image.alt | escape | default: product.title | escape }}"
                class="w-full h-full object-cover"
                loading="lazy"
                width="300"
                height="300"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment %}--- 右カラム: 商品情報 ---{%- endcomment %}
    <div class="w-full lg:flex-1 flex flex-col gap-6 lg:sticky lg:top-20">

      {%- comment %} ブランド・タイトル・容量・評価 {%- endcomment %}
      <div class="flex flex-col gap-4">
        {%- if product.vendor != blank -%}
          <p class="text-sm text-stone-900 opacity-50 leading-tight">{{ product.vendor }}</p>
        {%- endif -%}

        <div class="flex flex-wrap items-start gap-2">
          <h1 class="text-3xl font-medium leading-tight text-stone-900 palt tracking-wider">{{ product.title }}
          {%- if product.tags contains 'new' or product.tags contains 'NEW' or product.tags contains 'New' -%}
            {%- render 'badge', label: 'NEW', variant: 'accent', size: 'sm' -%}
          {%- endif -%}</h1>
        </div>

        {%- if volume != blank -%}
          <p class="text-sm text-stone-900 leading-relaxed">内容量：{{ volume }}</p>
        {%- endif -%}

        {%- if rating_value != blank -%}
          <div class="flex items-center gap-2">
            <div class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-amber-700" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M8 1.5 9.796 5.14l4.018.583-2.907 2.833.686 4L8 10.666l-3.593 1.89.686-4L2.186 5.723l4.018-.583z"/>
              </svg>
              <span class="text-sm font-medium text-stone-900 leading-tight">{{ rating_value | round: 1 }}</span>
            </div>
            {%- if rating_count != blank -%}
              <span class="text-sm text-stone-900 opacity-40 leading-tight">（{{ rating_count }}件のレビュー）</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment %} 価格 {%- endcomment %}
      <div class="flex items-end gap-2 flex-wrap">
        <span class="text-3xl font-semibold text-stone-900 leading-tight">{{ variant.price | money }}</span>
        {%- if on_sale -%}
          <s class="text-base text-stone-900 opacity-50 leading-tight">{{ variant.compare_at_price | money }}</s>
        {%- endif -%}
        <span class="text-sm text-stone-900 leading-tight">(税込・送料込)</span>
        {%- if on_sale -%}
          {%- assign discount_label = discount | append: '% OFF' -%}
          {%- render 'badge', label: discount_label, variant: 'premium', size: 'sm' -%}
        {%- endif -%}
      </div>

      {%- comment %} 効能・効果 {%- endcomment %}
      {%- if product_benefits != blank -%}
        <div class="flex flex-col gap-2">
          {%- for product_benefit in product_benefits -%}
            <div class="flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 8.55556L6.8 13L14 3" stroke="#0B4F4A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <p class="text-sm text-stone-900 leading-relaxed">{{ product_benefit.benefit }}</p>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment %} 注目の成分 {%- endcomment %}
      {%- if key_ingredients != blank -%}
        <div class="bg-stone-100 rounded-2xl p-4 flex flex-col gap-2.5">
          <div class="flex items-center gap-1">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M2.42397 6.97718C2.28957 7.11145 2.18294 7.27089 2.11019 7.44639C2.03744 7.6219 2 7.81002 2 8C2 8.18998 2.03744 8.3781 2.11019 8.55361C2.18294 8.72911 2.28957 8.88855 2.42397 9.02282L6.97718 13.576C7.11145 13.7104 7.27089 13.8171 7.44639 13.8898C7.6219 13.9626 7.81002 14 8 14C8.18998 14 8.3781 13.9626 8.55361 13.8898C8.72911 13.8171 8.88855 13.7104 9.02282 13.576L13.576 9.02282C13.7104 8.88855 13.8171 8.72911 13.8898 8.55361C13.9626 8.3781 14 8.18998 14 8C14 7.81002 13.9626 7.6219 13.8898 7.44639C13.8171 7.27089 13.7104 7.11145 13.576 6.97718L9.02282 2.42397C8.88855 2.28957 8.72911 2.18294 8.55361 2.11019C8.3781 2.03744 8.18998 2 8 2C7.81002 2 7.6219 2.03744 7.44639 2.11019C7.27089 2.18294 7.11145 2.28957 6.97718 2.42397L2.42397 6.97718Z" stroke="#1C1917" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="text-sm font-medium text-stone-900 leading-tight">注目の成分</span>
          </div>
          <ul class="flex flex-col gap-1 text-sm text-stone-900 leading-relaxed">
            {%- for key_ingredient in key_ingredients -%}
              {%- assign ingredient = key_ingredient.ingredient.value -%}
              {%- assign article = ingredient.article.value -%}
              <li class="list-disc ml-5">
                {%- if article != blank -%}
                  <a href="{{ article.url }}" class="underline hover:opacity-70 transition-opacity">{{ ingredient.name_ja }}</a>
                {%- else -%}
                  {{ ingredient.name_ja }}
                {%- endif -%}
                {%- if key_ingredient.amount != blank -%}
                  &nbsp;({{ key_ingredient.amount }})
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      {%- comment %} ラベル {%- endcomment %}
      {%- if certifications != blank -%}
        <div class="flex flex-wrap gap-2">
          {%- for certification in certifications -%}
            <span class="bg-white border border-stone-200 px-1.5 py-[6px] text-xs text-stone-900 leading-tight">{{ certification.name }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment %} バリアント選択 {%- endcomment %}
      {%- unless product.has_only_default_variant -%}
        <div class="flex flex-col gap-4">
          {%- for option in product.options_with_values -%}
            <div class="flex flex-col gap-2">
              <p class="text-xs font-medium text-stone-900 uppercase tracking-wider">{{ option.name }}</p>
              <div class="flex flex-wrap gap-2">
                {%- for value in option.values -%}
                  <label class="cursor-pointer">
                    <input
                      type="radio"
                      name="option-{{ forloop.parentloop.index }}"
                      value="{{ value }}"
                      class="sr-only peer"
                      {% if option.selected_value == value %}checked{% endif %}
                      @change="selectedOptions[{{ forloop.parentloop.index0 }}] = $event.target.value"
                    >
                    <span class="inline-flex items-center justify-center border border-stone-200 px-4 h-10 text-sm text-stone-900 peer-checked:border-stone-900 peer-checked:bg-stone-900 peer-checked:text-white transition-colors cursor-pointer">
                      {{ value }}
                    </span>
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      {%- comment %} 数量カウンター + カートに追加 {%- endcomment %}
      <div class="flex items-center gap-4">
        <div class="flex items-center border border-stone-200 flex-shrink-0">
          <button
            type="button"
            class="flex items-center justify-center w-12 h-12 text-stone-900 transition-opacity hover:opacity-60 focus-visible:outline-none"
            @click="qty = Math.max(1, qty - 1)"
            aria-label="数量を減らす"
          >
            {%- render 'icon', icon: 'minus', class: 'w-5 h-5' -%}
          </button>
          <div
            class="flex items-center justify-center w-12 h-12 text-base text-stone-900 select-none"
            x-text="qty"
            aria-live="polite"
            aria-label="数量"
          >1</div>
          <button
            type="button"
            class="flex items-center justify-center w-12 h-12 text-stone-900 transition-opacity hover:opacity-60 focus-visible:outline-none"
            @click="qty++"
            aria-label="数量を増やす"
          >
            {%- render 'icon', icon: 'plus', class: 'w-5 h-5' -%}
          </button>
        </div>

        <button
          type="button"
          class="btn-add-to-cart flex-1 bg-stone-950 border-2 border-stone-950 text-white flex items-center justify-center min-h-[48px] px-4 py-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-900 focus-visible:ring-offset-2"
          :class="(adding || !variantAvailable) ? 'opacity-70 cursor-wait' : ''"
          @click="addToCart()"
          :disabled="adding || !variantAvailable"
        >
          <span class="text-base font-bold leading-tight" x-show="!adding" x-text="variantAvailable ? 'カートに追加' : '売り切れ'">カートに追加</span>
          <span class="text-base font-bold leading-tight" x-show="adding" x-cloak>追加中…</span>
        </button>
      </div>

      {%- comment %} 区切り線 {%- endcomment %}
      <hr class="border-stone-200">

      {%- comment %} 商品メタ情報 {%- endcomment %}
      {%- if skin_types != blank or ph_level != blank or origin != blank or texture != blank or usage_timing != blank -%}
        <div class="flex flex-wrap gap-x-8 gap-y-2">
          {%- if skin_types != blank -%}
            <p class="text-sm text-stone-900 leading-relaxed">
              <span class="font-medium">おすすめの肌質：</span>{%- for skin_type in skin_types -%}{{ skin_type.label }}{%- unless forloop.last -%}、{%- endunless -%}{%- endfor -%}
            </p>
          {%- endif -%}
          {%- if ph_level != blank -%}
            <p class="text-sm text-stone-900 leading-relaxed">
              <span class="font-medium">pHレベル：</span>{{ ph_level }}
            </p>
          {%- endif -%}
          {%- if origin != blank -%}
            <p class="text-sm text-stone-900 leading-relaxed">
              <span class="font-medium">原産国：</span>{{ origin }}
            </p>
          {%- endif -%}
          {%- if texture != blank -%}
            <p class="text-sm text-stone-900 leading-relaxed">
              <span class="font-medium">テクスチャー：</span>{{ texture }}
            </p>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{%- comment %}======================================================
  タブセクション
======================================================{%- endcomment %}
<section
  class="bg-stone-100 px-10 py-[60px]"
  x-data="{ activeTab: 0 }"
>
  <div class="max-w-screen-xl mx-auto">

    {%- comment %} タブバー {%- endcomment %}
    <div class="flex h-[48px]" role="tablist">
      {%- assign tab_names = '全成分,ご使用方法,使用タイミング,保管方法' | split: ',' -%}
      {%- for tab_name in tab_names -%}
        {%- assign tab_i = forloop.index0 -%}
        <button
          type="button"
          role="tab"
          class="flex items-center justify-center px-10 h-full text-base font-medium leading-tight transition-colors whitespace-nowrap focus-visible:outline-none"
          :class="{{ tab_i }} === activeTab ? 'border-b-2 border-stone-900 text-stone-900 py-4' : 'py-2 text-stone-500 hover:text-stone-900'"
          @click="activeTab = {{ tab_i }}"
          :aria-selected="{{ tab_i }} === activeTab"
        >{{ tab_name }}</button>
      {%- endfor -%}
    </div>

    {%- comment %} タブコンテンツ {%- endcomment %}
    <div class="py-10">

      <div x-show="activeTab === 0" role="tabpanel">
        {%- if all_ingredients_ja != blank -%}
          <p class="text-base text-stone-900 leading-relaxed">{{ all_ingredients_ja | newline_to_br }}</p>
        {%- elsif all_ingredients != blank -%}
          <p class="text-base text-stone-900 leading-relaxed">{{ all_ingredients | newline_to_br }}</p>
        {%- else -%}
          <p class="text-stone-400 text-sm">成分情報は現在準備中です。</p>
        {%- endif -%}
      </div>

      <div x-show="activeTab === 1" x-cloak role="tabpanel">
        {%- if usage_method != blank -%}
          <div class="text-base text-stone-900 leading-relaxed">{{ usage_method }}</div>
        {%- else -%}
          <p class="text-stone-400 text-sm">使用方法は現在準備中です。</p>
        {%- endif -%}
      </div>

      <div x-show="activeTab === 2" x-cloak role="tabpanel">
        {%- if usage_timing != blank -%}
          <div class="text-base text-stone-900 leading-relaxed">{{ usage_timing }}</div>
        {%- else -%}
          <p class="text-stone-400 text-sm">使用タイミングは現在準備中です。</p>
        {%- endif -%}
      </div>

      <div x-show="activeTab === 3" x-cloak role="tabpanel">
        {%- if how_to_store != blank -%}
          <div class="text-base text-stone-900 leading-relaxed">{{ how_to_store }}</div>
        {%- else -%}
          <p class="text-stone-400 text-sm">保管方法は現在準備中です。</p>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>



{%- comment %}======================================================
  個人輸入代行に関する注意事項
======================================================{%- endcomment %}
{%- if section.settings.show_import_notice -%}
<section class="bg-stone-50 px-10 py-[60px]">
  <div class="max-w-screen-xl mx-auto flex flex-col gap-8">
    <div class="flex flex-col gap-4 p-4 bg-amber-50 border border-amber-200 text-sm leading-relaxed">
      <p class="font-semibold text-stone-900">&#9888; 個人輸入代行に関する重要なご注意</p>

      {%- if section.settings.import_notice_declaration != blank -%}
        <div class="flex flex-col gap-1">
          <p class="font-medium text-stone-900">&#9670; 本サービスについて</p>
          <p class="text-stone-700">{{ section.settings.import_notice_declaration }}</p>
        </div>
      {%- endif -%}

      {%- if section.settings.import_notice_liability != blank or section.settings.import_notice_resale != blank -%}
        <div class="flex flex-col gap-1">
          <p class="font-medium text-stone-900">&#9670; ご使用上の注意と免責事項</p>
          {%- if section.settings.import_notice_liability != blank -%}
            <p class="text-stone-700">{{ section.settings.import_notice_liability }}</p>
          {%- endif -%}
          {%- if section.settings.import_notice_resale != blank -%}
            <p class="text-stone-700">{{ section.settings.import_notice_resale }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.import_notice_customs != blank -%}
        <div class="flex flex-col gap-1">
          <p class="font-medium text-stone-900">&#9670; 関税および輸入制限について</p>
          <p class="text-stone-700">{{ section.settings.import_notice_customs }}</p>
        </div>
      {%- endif -%}

      {%- if section.settings.import_notice_returns != blank -%}
        <div class="flex flex-col gap-1">
          <p class="font-medium text-stone-900">&#9670; キャンセル・返品・交換について</p>
          <p class="text-stone-700">{{ section.settings.import_notice_returns }}</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

{%- comment %}======================================================
  関連商品セクション
======================================================{%- endcomment %}
{%- assign related_col = collections[section.settings.related_collection] -%}
{%- if related_col != blank -%}
  <section class="bg-stone-50 px-10 py-[60px]">
    <div class="max-w-screen-xl mx-auto flex flex-col gap-10">

      {%- render 'section-header', heading: section.settings.related_heading -%}

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {%- assign shown = 0 -%}
        {%- for p in related_col.products -%}
          {%- unless p.id == product.id -%}
            {%- render 'card-product-4col', product: p -%}
            {%- assign shown = shown | plus: 1 -%}
          {%- endunless -%}
          {%- if shown >= section.settings.related_products_count -%}{%- break -%}{%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "商品詳細",
  "settings": [
    {
      "type": "header",
      "content": "個人輸入代行に関する注意事項"
    },
    {
      "type": "checkbox",
      "id": "show_import_notice",
      "label": "注意事項を表示する",
      "default": true
    },
    {
      "type": "textarea",
      "id": "import_notice_declaration",
      "label": "①本サービスについて（個人輸入代行の宣言）",
      "default": "当店「Fluxor」で提供しているサービスは、お客様ご自身が海外の事業者から商品を直接購入するための「個人輸入代行」となります。当店は商品の販売者ではなく、購入の手続きと発送手配を代行するサービスを提供しております。"
    },
    {
      "type": "textarea",
      "id": "import_notice_liability",
      "label": "②免責事項（薬機法・自己責任）",
