{%- comment %}
  sections/product-accordion.liquid

  商品詳細アコーディオン
  使用: templates/product.json に追加して使用
  項目はテーマエディタのブロックで追加・削除・並び替え可能
{%- endcomment -%}

<section
  class="px-4 md:px-10 py-10 md:py-[60px] bg-stone-100"
  x-data="{ openItem: 0 }"
>
  <div class="max-w-3xl mx-auto flex flex-col gap-6">

    {%- for block in section.blocks -%}
      {%- assign mf_key = block.settings.metafield_key -%}

      {%- capture _acc_body -%}
        {%- if mf_key == 'custom' -%}
          {%- if block.settings.content != blank -%}
            <div class="text-sm text-stone-900 leading-relaxed">{{ block.settings.content }}</div>
          {%- else -%}
            <p class="text-sm text-stone-400">テキストを入力してください。</p>
          {%- endif -%}

        {%- elsif mf_key == 'all_ingredients_ja' -%}
          {%- assign mf_ja = product.metafields.custom.all_ingredients_ja -%}
          {%- assign mf_en = product.metafields.custom.all_ingredients -%}
          {%- assign _primary = mf_ja | default: mf_en -%}
          {%- if _primary != blank -%}
            <p class="text-sm text-stone-900 leading-relaxed">{{ _primary | newline_to_br }}</p>
            {%- if mf_ja != blank and mf_en != blank -%}
              <p class="text-xs text-stone-400 leading-relaxed mt-4">{{ mf_en | newline_to_br }}</p>
            {%- endif -%}
          {%- else -%}
            <p class="text-sm text-stone-400">成分情報は現在準備中です。</p>
          {%- endif -%}

        {%- else -%}
          {%- assign mf_val = product.metafields.custom[mf_key] -%}
          {%- if mf_val != blank -%}
            <div class="text-sm text-stone-900 leading-relaxed">{{ mf_val | newline_to_br }}</div>
          {%- else -%}
            <p class="text-sm text-stone-400">{{ block.settings.title }}は現在準備中です。</p>
          {%- endif -%}
        {%- endif -%}
      {%- endcapture -%}

      {%- render 'accordion-item',
        title: block.settings.title,
        body: _acc_body,
        index: forloop.index0,
        shopify_attributes: block.shopify_attributes
      -%}
    {%- endfor -%}

  </div>
</section>

{%- schema %}
{
  "name": "商品アコーディオン",
  "enabled_on": {
    "templates": ["product"]
  },
  "max_blocks": 10,
  "blocks": [
    {
      "type": "accordion_item",
      "name": "アコーディオン項目",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "見出し",
          "default": "項目名"
        },
        {
          "type": "select",
          "id": "metafield_key",
          "label": "表示内容",
          "default": "usage_method",
          "options": [
            { "value": "all_ingredients_ja", "label": "全成分（メタフィールド）" },
            { "value": "usage_timing",       "label": "使用タイミング（メタフィールド）" },
            { "value": "usage_method",       "label": "使用方法（メタフィールド）" },
            { "value": "how_to_store",       "label": "保管方法（メタフィールド）" },
            { "value": "precautions",        "label": "注意事項（メタフィールド）" },
            { "value": "custom",             "label": "カスタムテキスト" }
          ]
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "カスタムテキスト",
          "info": "「表示内容」で「カスタムテキスト」を選択した場合に表示されます"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "商品アコーディオン",
      "blocks": [
        { "type": "accordion_item", "settings": { "title": "全成分",       "metafield_key": "all_ingredients_ja" } },
        { "type": "accordion_item", "settings": { "title": "使用タイミング", "metafield_key": "usage_timing" } },
        { "type": "accordion_item", "settings": { "title": "使用方法",     "metafield_key": "usage_method" } },
        { "type": "accordion_item", "settings": { "title": "保管方法",     "metafield_key": "how_to_store" } },
        { "type": "accordion_item", "settings": { "title": "注意事項",     "metafield_key": "precautions" } }
      ]
    }
  ]
}
{%- endschema -%}
