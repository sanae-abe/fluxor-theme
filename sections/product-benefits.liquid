{%- comment %}
  商品ベネフィットセクション (product-benefits.liquid)
  使用: templates/product.json に追加して使用

  データソース: product.metafields.custom.product_benefits (list.single_line_text_field)
  注釈処理: main-product.liquid と同一の ※ 分離パターンを使用
{%- endcomment -%}

{%- assign benefits = product.metafields.custom.product_benefits.value -%}
{%- if benefits != blank and benefits.size > 0 -%}

{%- liquid
  assign s = section.settings
  assign icon_style = s.icon_style | default: 'check'

  case benefits.size
    when 1
      assign grid_cols = 'md:max-w-md md:mx-auto'
    when 2
      assign grid_cols = 'md:grid-cols-2 md:max-w-2xl md:mx-auto'
    when 4
      assign grid_cols = 'md:grid-cols-2 lg:grid-cols-4'
    else
      assign grid_cols = 'md:grid-cols-3'
  endcase
-%}

{%- comment %} ※ 上付き文字変換用変数（render スコープ分離のため再定義） {%- endcomment -%}
{%- assign _sup_open = '<sup class="text-xs font-normal text-stone-400 align-super">' -%}
{%- assign _sup1 = _sup_open | append: '※1</sup>' -%}
{%- assign _sup2 = _sup_open | append: '※2</sup>' -%}
{%- assign _sup3 = _sup_open | append: '※3</sup>' -%}
{%- assign _sup4 = _sup_open | append: '※4</sup>' -%}
{%- assign _sup5 = _sup_open | append: '※5</sup>' -%}
{%- assign _sup  = _sup_open | append: '※</sup>' -%}

<section
  id="product-benefits"
  class="px-4 md:px-10 py-10 md:py-[60px] bg-stone-50"
>
  <div class="max-w-screen-xl mx-auto flex flex-col gap-8 md:gap-12">

    {%- render 'section-header',
      heading: s.heading,
      subheading: s.subheading,
      align: 'center'
    -%}

    <div class="benefit-grid grid grid-cols-1 {{ grid_cols }} gap-6 md:gap-8">
      {%- for benefit in benefits -%}
        {%- assign benefit_parts = benefit | split: ' ※' -%}
        {%- assign benefit_main = benefit_parts[0]
          | replace: '※1', _sup1
          | replace: '※2', _sup2
          | replace: '※3', _sup3
          | replace: '※4', _sup4
          | replace: '※5', _sup5
          | replace: '※', _sup
        -%}

        <div class="benefit-card flex flex-col items-center text-center gap-4 p-6 md:p-8">

          {%- case icon_style -%}
            {%- when 'check' -%}
              <div class="w-10 h-10 flex items-center justify-center rounded-full bg-stone-200/60">
                {%- render 'icon', icon: 'check', class: 'w-5 h-5 text-stone-700', stroke_width: 2 -%}
              </div>
            {%- when 'sparkle' -%}
              <div class="w-10 h-10 flex items-center justify-center">
                {%- render 'icon', icon: 'sparkle', class: 'w-6 h-6 text-stone-400', stroke_width: 1.5 -%}
              </div>
            {%- when 'number' -%}
              <span class="text-3xl font-light text-stone-300 leading-none tabular-nums tracking-tight">
                {{- forloop.index | prepend: '00' | slice: -2, 2 -}}
              </span>
            {%- when 'none' -%}
              {%- comment %} アイコンなし {%- endcomment -%}
          {%- endcase -%}

          <p class="text-base md:text-lg font-medium text-stone-900 leading-relaxed palt tracking-wide">
            {{- benefit_main -}}
          </p>

          {%- for i in (1..5) -%}
            {%- if benefit_parts[i] != blank -%}
              <p class="text-xs text-stone-400 leading-relaxed">※{{ benefit_parts[i] }}</p>
            {%- endif -%}
          {%- endfor -%}

        </div>
      {%- endfor -%}
    </div>

    {%- if s.disclaimer != blank -%}
      <p class="text-xs text-stone-400 text-center leading-relaxed">{{ s.disclaimer }}</p>
    {%- endif -%}

  </div>
</section>

<script>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var grid = document.querySelector('#product-benefits .benefit-grid');
    if (!grid) return;
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          grid.classList.add('is-visible');
          observer.disconnect();
        }
      });
    }, { threshold: 0.15 });
    observer.observe(grid);
  })();
</script>

{%- endif -%}

{% schema %}
{
  "name": "商品ベネフィット",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "期待できること"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "サブ見出し"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "アイコンスタイル",
      "options": [
        { "value": "check",   "label": "チェックマーク" },
        { "value": "sparkle", "label": "キラキラ" },
        { "value": "number",  "label": "番号（01, 02, 03）" },
        { "value": "none",    "label": "なし（テキストのみ）" }
      ],
      "default": "check"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "注意書き（薬機法対応）",
      "info": "セクション下部に小さく表示されます",
      "default": "※効能効果は化粧品の範囲内での表現です"
    }
  ],
  "presets": [
    {
      "name": "商品ベネフィット"
    }
  ]
}
{% endschema %}
