{%- comment %}
  商品ベネフィットセクション (product-benefits.liquid)
  使用: templates/product.json に追加して使用

  データソース（優先順）:
    1. product.metafields.custom.benefit_items (list.metaobject_reference → product_benefit_item)
       フィールド: title（タイトル）, description（説明文）
    2. product.metafields.custom.product_benefits (list.single_line_text_field) — レガシーフォールバック

  画像: custom.benefits_image → product.featured_image
  見出し: custom.benefits_heading → スキーマ設定
  注釈: custom.benefits_disclaimer → スキーマ設定
{%- endcomment -%}

{%- liquid
  assign benefit_items = product.metafields.custom.benefit_items.value
  assign benefits = product.metafields.custom.product_benefits.value
  assign use_metaobject = false

  if benefit_items != blank and benefit_items.size > 0
    assign use_metaobject = true
  endif
-%}
{%- if use_metaobject or benefits != blank and benefits.size > 0 -%}

{%- liquid
  assign s = section.settings
  assign icon_style = s.icon_style | default: 'check'
-%}

{%- comment %} ※ 上付き文字変換用変数（render スコープ分離のため再定義） {%- endcomment -%}
{%- assign _sup_open = '<sup class="text-xs font-normal text-stone-400 align-super">' -%}
{%- assign _sup1 = _sup_open | append: '※1</sup>' -%}
{%- assign _sup2 = _sup_open | append: '※2</sup>' -%}
{%- assign _sup3 = _sup_open | append: '※3</sup>' -%}
{%- assign _sup4 = _sup_open | append: '※4</sup>' -%}
{%- assign _sup5 = _sup_open | append: '※5</sup>' -%}
{%- assign _sup  = _sup_open | append: '※</sup>' -%}

<section
  id="product-benefits"
  class="px-4 md:px-10 py-10 md:py-[60px] bg-stone-50"
>
  <div class="max-w-screen-xl mx-auto flex flex-col gap-8 md:gap-12">

    <div class="benefit-grid grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12 items-center">

      {%- comment %} 左カラム: 見出し + ベネフィットリスト {%- endcomment -%}
      <div class="benefit-card flex flex-col gap-6 md:gap-8">

        {%- liquid
          assign _benefits_heading = product.metafields.custom.benefits_heading
          if _benefits_heading == blank
            assign _benefits_heading = s.heading | replace: '{product}', product.title
          endif
        -%}
        {%- assign _benefits_heading = _benefits_heading
          | replace: '※1', '__S1__'
          | replace: '※2', '__S2__'
          | replace: '※3', '__S3__'
          | replace: '※4', '__S4__'
          | replace: '※5', '__S5__'
          | replace: '※', _sup
          | replace: '__S1__', _sup1
          | replace: '__S2__', _sup2
          | replace: '__S3__', _sup3
          | replace: '__S4__', _sup4
          | replace: '__S5__', _sup5
        -%}
        {%- render 'section-header',
          heading: _benefits_heading,
          subheading: s.subheading,
          align: 'left'
        -%}

        {%- if use_metaobject -%}
          {%- comment %} リッチ表示（メタオブジェクト: タイトル + 説明文） {%- endcomment -%}
          <div class="flex flex-col gap-6">
            {%- for item in benefit_items -%}
              {%- assign _item_title = item.title
                | replace: '※1', '__S1__'
                | replace: '※2', '__S2__'
                | replace: '※3', '__S3__'
                | replace: '※4', '__S4__'
                | replace: '※5', '__S5__'
                | replace: '※', _sup
                | replace: '__S1__', _sup1
                | replace: '__S2__', _sup2
                | replace: '__S3__', _sup3
                | replace: '__S4__', _sup4
                | replace: '__S5__', _sup5
              -%}

              <div class="flex items-start gap-3">
                {%- case icon_style -%}
                  {%- when 'check' -%}
                    <div class="w-8 h-8 flex items-center justify-center rounded-full bg-stone-200/60 shrink-0 mt-0.5">
                      {%- render 'icon', icon: 'check', class: 'w-4 h-4 text-stone-700', stroke_width: 2 -%}
                    </div>
                  {%- when 'sparkle' -%}
                    <div class="w-8 h-8 flex items-center justify-center shrink-0 mt-0.5">
                      {%- render 'icon', icon: 'sparkle', class: 'w-5 h-5 text-stone-400', stroke_width: 1.5 -%}
                    </div>
                  {%- when 'number' -%}
                    <span class="text-2xl font-light text-stone-300 leading-none tabular-nums tracking-tight shrink-0 w-8 text-center mt-0.5">
                      {{- forloop.index | prepend: '00' | slice: -2, 2 -}}
                    </span>
                  {%- when 'none' -%}
                    {%- comment %} アイコンなし {%- endcomment -%}
                {%- endcase -%}

                <div class="flex flex-col gap-1">
                  <p class="text-base md:text-lg font-medium text-stone-900 leading-relaxed palt tracking-wide">
                    {{- _item_title -}}
                  </p>
                  {%- if item.description != blank -%}
                    <p class="text-sm text-stone-500 leading-relaxed">
                      {{- item.description | newline_to_br -}}
                    </p>
                  {%- endif -%}
                </div>
              </div>

            {%- endfor -%}
          </div>

        {%- else -%}
          {%- comment %} シンプル表示（レガシー: テキストリスト） {%- endcomment -%}
          <div class="flex flex-col gap-5">
            {%- for benefit in benefits -%}
              {%- assign benefit_parts = benefit | split: ' ※' -%}
              {%- assign benefit_main = benefit_parts[0]
                | replace: '※1', '__S1__'
                | replace: '※2', '__S2__'
                | replace: '※3', '__S3__'
                | replace: '※4', '__S4__'
                | replace: '※5', '__S5__'
                | replace: '※', _sup
                | replace: '__S1__', _sup1
                | replace: '__S2__', _sup2
                | replace: '__S3__', _sup3
                | replace: '__S4__', _sup4
                | replace: '__S5__', _sup5
              -%}

              <div class="flex items-start gap-3">
                {%- case icon_style -%}
                  {%- when 'check' -%}
                    <div class="w-8 h-8 flex items-center justify-center rounded-full bg-stone-200/60 shrink-0 mt-0.5">
                      {%- render 'icon', icon: 'check', class: 'w-4 h-4 text-stone-700', stroke_width: 2 -%}
                    </div>
                  {%- when 'sparkle' -%}
                    <div class="w-8 h-8 flex items-center justify-center shrink-0 mt-0.5">
                      {%- render 'icon', icon: 'sparkle', class: 'w-5 h-5 text-stone-400', stroke_width: 1.5 -%}
                    </div>
                  {%- when 'number' -%}
                    <span class="text-2xl font-light text-stone-300 leading-none tabular-nums tracking-tight shrink-0 w-8 text-center mt-0.5">
                      {{- forloop.index | prepend: '00' | slice: -2, 2 -}}
                    </span>
                  {%- when 'none' -%}
                    {%- comment %} アイコンなし {%- endcomment -%}
                {%- endcase -%}

                <div class="flex flex-col gap-1">
                  <p class="text-base md:text-lg font-medium text-stone-900 leading-relaxed palt tracking-wide">
                    {{- benefit_main -}}
                  </p>
                  {%- for i in (1..5) -%}
                    {%- if benefit_parts[i] != blank -%}
                      <p class="text-xs text-stone-400 leading-relaxed">※{{ benefit_parts[i] }}</p>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>

            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- assign _benefits_disclaimer = product.metafields.custom.benefits_disclaimer | default: s.disclaimer -%}
        {%- if _benefits_disclaimer != blank -%}
          <p class="text-xs text-stone-400 leading-relaxed">{{ _benefits_disclaimer | newline_to_br }}</p>
        {%- endif -%}

      </div>

      {%- comment %} 右カラム: 商品画像（メタフィールド優先 → featured_image フォールバック） {%- endcomment -%}
      {%- liquid
        assign _benefits_img = product.metafields.custom.benefits_image.value
        unless _benefits_img != blank
          assign _benefits_img = product.featured_image
        endunless
      -%}
      {%- if _benefits_img -%}
        <div class="benefit-card overflow-hidden rounded-lg">
          <img
            src="{{ _benefits_img | image_url: width: 900 }}"
            srcset="{{ _benefits_img | image_url: width: 600 }} 600w, {{ _benefits_img | image_url: width: 900 }} 900w, {{ _benefits_img | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 1023px) calc(100vw - 2rem), 45vw"
            alt="{{ _benefits_img.alt | default: product.title }}"
            width="{{ _benefits_img.width }}"
            height="{{ _benefits_img.height }}"
            loading="lazy"
            class="w-full h-auto"
          >
        </div>
      {%- endif -%}

    </div>

  </div>
</section>

<script>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var grid = document.querySelector('#product-benefits .benefit-grid');
    if (!grid) return;
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          grid.classList.add('is-visible');
          observer.disconnect();
        }
      });
    }, { threshold: 0.15 });
    observer.observe(grid);
  })();
</script>

{%- endif -%}

{% schema %}
{
  "name": "商品ベネフィット",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "このプロダクトにできること",
      "info": "{product} は商品名に自動置換されます"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "サブ見出し"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "アイコンスタイル",
      "options": [
        { "value": "check",   "label": "チェックマーク" },
        { "value": "sparkle", "label": "キラキラ" },
        { "value": "number",  "label": "番号（01, 02, 03）" },
        { "value": "none",    "label": "なし（テキストのみ）" }
      ],
      "default": "check"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "注意書き（薬機法対応）",
      "info": "セクション下部に小さく表示されます",
      "default": "※効能効果は化粧品の範囲内での表現です"
    }
  ],
  "presets": [
    {
      "name": "商品ベネフィット"
    }
  ]
}
{% endschema %}
