{{ 'product-grid-fluxor.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign products_count = section.settings.products_to_show

  if section.settings.auto_mode == 'new_arrivals'
    assign products = collections.all.products | sort: 'created_at' | reverse
    assign collection = collections.all
    assign view_all_url = '/collections/all?sort_by=created-desc'
  elsif section.settings.auto_mode == 'best_sellers'
    assign products = collections.all.products | sort: 'best-selling'
    assign collection = collections.all
    assign view_all_url = '/collections/all?sort_by=best-selling'
  elsif section.settings.collection != blank
    assign collection = collections[section.settings.collection]
    assign products = collection.products
    assign view_all_url = collection.url
  else
    assign collection = null
    assign products = null
    assign view_all_url = ''
  endif
-%}

<div class="product-grid-fluxor color-{{ section.settings.color_scheme }} gradient">
  <div class="product-grid-fluxor__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="product-grid-fluxor__heading">
        {{- section.settings.heading | escape -}}
      </h2>
    {%- endif -%}

    {%- if section.settings.show_view_all and view_all_url != blank -%}
      <a href="{{ view_all_url }}" class="product-grid-fluxor__view-all">
        すべて見る
        <span class="svg-wrapper" aria-hidden="true">
          {{- 'icon-arrow-fluxor.svg' | inline_asset_content -}}
        </span>
      </a>
    {%- endif -%}
  </div>

  {%- if products != blank and products.size > 0 -%}
    <div class="product-grid-fluxor__grid">
      {%- for product in products limit: products_count -%}
        {%- render 'card-product-fluxor',
          card_product: product,
          lazy_load: true,
          show_vendor: true
        -%}
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="product-grid-fluxor__empty">
      {%- if section.settings.auto_mode != 'none' -%}
        商品が見つかりませんでした。
      {%- else -%}
        テーマカスタマイザーでコレクションを選択するか、自動取得モードを設定してください。
      {%- endif -%}
    </p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Product Grid - Fluxor",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "New Arrivals"
    },
    {
      "type": "select",
      "id": "auto_mode",
      "label": "商品取得方法",
      "options": [
        {
          "value": "none",
          "label": "手動（コレクション選択）"
        },
        {
          "value": "new_arrivals",
          "label": "新着商品（自動）"
        },
        {
          "value": "best_sellers",
          "label": "ベストセラー（自動）"
        }
      ],
      "default": "none",
      "info": "自動取得を選択すると、コレクション設定は無視されます"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "コレクション",
      "info": "商品取得方法が「手動」の場合のみ有効"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "表示件数",
      "min": 2,
      "max": 12,
      "step": 2,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "「すべて見る」リンクを表示",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product Grid - Fluxor"
    }
  ]
}
{% endschema %}
