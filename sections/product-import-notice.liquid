{%- comment %}
  sections/product-import-notice.liquid

  個人輸入代行に関する重要なご注意
  使用: templates/product.json に追加して使用
{%- endcomment %}

{%- if section.settings.show_import_notice -%}

<section class="px-4 md:px-10 py-10 md:py-[60px] bg-stone-100">
  <div class="max-w-4xl mx-auto">
    <div class="flex flex-col gap-5">

      <div class="flex items-center gap-1">
        {%- render 'icon', icon: 'triangle-alert', class: 'w-5 h-5 shrink-0', stroke: '#1c1917', stroke_width: '2' -%}
        <p class="font-medium text-stone-900 text-base">個人輸入代行に関する重要なご注意</p>
      </div>

      {%- if section.settings.import_notice_declaration != blank -%}
        <div class="flex flex-col gap-1">
          <p class="font-medium text-stone-900 text-sm">本サービスについて</p>
          <p class="text-stone-900 text-sm leading-relaxed">{{ section.settings.import_notice_declaration }}</p>
        </div>
      {%- endif -%}

      {%- if section.settings.import_notice_liability != blank or section.settings.import_notice_resale != blank -%}
        <div class="flex flex-col gap-1">
          <p class="font-medium text-stone-900 text-sm">ご使用上の注意と免責事項</p>
          {%- if section.settings.import_notice_liability != blank -%}
            <p class="text-stone-900 text-sm leading-relaxed">{{ section.settings.import_notice_liability }}</p>
          {%- endif -%}
          {%- if section.settings.import_notice_resale != blank -%}
            <p class="text-stone-900 text-sm leading-relaxed">{{ section.settings.import_notice_resale }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.import_notice_customs != blank -%}
        <div class="flex flex-col gap-1">
          <p class="font-medium text-stone-900 text-sm">関税および輸入制限について</p>
          <p class="text-stone-900 text-sm leading-relaxed">{{ section.settings.import_notice_customs }}</p>
        </div>
      {%- endif -%}

      {%- if section.settings.import_notice_returns != blank -%}
        <div class="flex flex-col gap-1">
          <p class="font-medium text-stone-900 text-sm">キャンセル・返品・交換について</p>
          <p class="text-stone-900 text-sm leading-relaxed">{{ section.settings.import_notice_returns }}</p>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{%- endif -%}

{% schema %}
{
  "name": "個人輸入代行注意事項",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_import_notice",
      "label": "注意事項を表示する",
      "default": true
    },
    {
      "type": "textarea",
      "id": "import_notice_declaration",
      "label": "①本サービスについて（個人輸入代行の宣言）",
      "default": "当店「Fluxor」で提供しているサービスは、お客様ご自身が海外の事業者から商品を直接購入するための「個人輸入代行」となります。当店は商品の販売者ではなく、購入の手続きと発送手配を代行するサービスを提供しております。"
    },
    {
      "type": "textarea",
      "id": "import_notice_liability",
      "label": "②免責事項（薬機法・自己責任）",
      "default": "海外コスメは日本の薬機法に基づく承認を受けた商品ではございません。ご使用についてはお客様の完全な自己責任となります。万が一、肌に合わない場合やトラブルが発生した場合、当店では一切の責任（製造物責任等）を負いかねます。事前に成分等をご確認の上、ご自身の判断でご使用ください。"
    },
    {
      "type": "textarea",
      "id": "import_notice_resale",
      "label": "②転売禁止",
      "default": "個人輸入された商品は、輸入したご本人のみが使用することを前提としています。第三者への譲渡・転売（メルカリ等での販売を含む）は日本の法律により固く禁じられています。"
    },
    {
      "type": "textarea",
      "id": "import_notice_customs",
      "label": "③関税・輸入数量制限",
      "default": "化粧品の個人輸入には数量制限がございます（標準サイズで1品目につき24個まで）。制限を超えるご注文があった場合、分割発送のご相談をさせていただく場合がございます。また、ご購入金額（商品代金）が日本円で約16,666円を超える場合、日本の税関で関税・消費税等が発生する場合がございます。その際に発生した税金等につきましては、お客様（輸入者様）のご負担となりますので予めご了承ください。"
    },
    {
      "type": "textarea",
      "id": "import_notice_returns",
      "label": "④キャンセル・返品・交換",
      "default": "個人輸入代行というサービスの性質上、海外事業者への発注が完了した後のキャンセル、返品、交換は原則としてお受けできません。ただし、商品到着時に明らかな破損・液漏れ、またはご注文と異なる商品が届いた場合に限り、到着後3日以内にご連絡いただければ、海外事業者への返金・再送の交渉をサポートいたします。"
    }
  ],
  "presets": [
    {
      "name": "個人輸入代行注意事項"
    }
  ]
}
{% endschema %}
