{%- comment %}
  sections/product-import-notice.liquid

  個人輸入代行に関する重要なご注意
  使用: templates/product.json に追加して使用
{%- endcomment -%}

{%- if section.settings.show_import_notice -%}

<section class="px-4 md:px-10 py-10 md:py-[60px] bg-stone-100">
  <div class="max-w-3xl mx-auto">
    <div class="flex flex-col gap-5">

      <div class="flex items-center gap-1">
        {%- render 'icon', icon: 'triangle-alert', class: 'w-5 h-5 shrink-0', stroke: '#1c1917', stroke_width: '2' -%}
        <p class="font-medium text-stone-900 text-base">個人輸入代行に関する重要なご注意</p>
      </div>

      {%- if settings.import_notice_declaration != blank -%}
        <div class="flex flex-col gap-1">
          <p class="font-medium text-stone-900 text-sm">本サービスについて</p>
          <p class="text-stone-900 text-sm leading-relaxed">{{ settings.import_notice_declaration }}</p>
        </div>
      {%- endif -%}

      {%- if settings.import_notice_liability != blank or settings.import_notice_resale != blank -%}
        <div class="flex flex-col gap-1">
          <p class="font-medium text-stone-900 text-sm">ご使用上の注意と免責事項</p>
          {%- if settings.import_notice_liability != blank -%}
            <p class="text-stone-900 text-sm leading-relaxed">{{ settings.import_notice_liability }}</p>
          {%- endif -%}
          {%- if settings.import_notice_resale != blank -%}
            <p class="text-stone-900 text-sm leading-relaxed">{{ settings.import_notice_resale }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if settings.import_notice_customs != blank -%}
        <div class="flex flex-col gap-1">
          <p class="font-medium text-stone-900 text-sm">関税および輸入制限について</p>
          <p class="text-stone-900 text-sm leading-relaxed">{{ settings.import_notice_customs }}</p>
        </div>
      {%- endif -%}

      {%- if settings.import_notice_returns != blank -%}
        <div class="flex flex-col gap-1">
          <p class="font-medium text-stone-900 text-sm">キャンセル・返品・交換について</p>
          <p class="text-stone-900 text-sm leading-relaxed">{{ settings.import_notice_returns }}</p>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{%- endif -%}

{%- schema %}
{
  "name": "個人輸入代行注意事項",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_import_notice",
      "label": "注意事項を表示する",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "個人輸入代行注意事項"
    }
  ]
}
{%- endschema -%}
