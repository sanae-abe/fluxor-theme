{%- comment %}
  Search & Discovery おすすめ商品ローダーセクション
  product-recommendations.liquid を Ajax で呼び出すラッパー。
  templates/product.json に追加して使用する。
  直接コンテンツを持たず、Ajax で product-recommendations.liquid の出力を挿入する。
{%- endcomment -%}

{%- if section.settings.enabled -%}
  <div
    id="product-recommendations-{{ section.id }}"
    data-product-id="{{ product.id }}"
    data-limit="{{ section.settings.count }}"
    data-section-id="product-recommendations"
  ></div>

  <script>
    (function () {
      const container = document.getElementById('product-recommendations-{{ section.id }}');
      if (!container) return;

      function loadRecommendations() {
        const params = new URLSearchParams({
          section_id: container.dataset.sectionId,
          product_id: container.dataset.productId,
          limit: container.dataset.limit || 4,
        });

        fetch('/recommendations/products?' + params)
          .then((r) => r.text())
          .then((html) => {
            const content = new DOMParser()
              .parseFromString(html, 'text/html')
              .querySelector('.shopify-section');
            if (content?.children.length) {
              [...content.children].forEach((el) => container.appendChild(el));
            }
          })
          .catch(() => {});
      }

      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadRecommendations, { timeout: 3000 });
      } else {
        setTimeout(loadRecommendations, 200);
      }
    })();
  </script>
{%- endif -%}

{%- schema %}
{
  "name": "あなたへのおすすめ",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "おすすめ商品を表示する",
      "default": true
    },
    {
      "type": "range",
      "id": "count",
      "label": "表示件数",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "あなたへのおすすめ"
    }
  ]
}
{%- endschema -%}
