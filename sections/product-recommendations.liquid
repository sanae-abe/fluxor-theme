{%- comment %}
  Search & Discovery おすすめ商品セクション
  /recommendations/products?section_id=product-recommendations&product_id=XXX&limit=N
  の Ajax リクエストで呼び出される専用セクション。
  直接テンプレートには配置しない。
{%- endcomment -%}

{%- if recommendations.performed? and recommendations.products_count > 0 -%}
  <section class="bg-stone-50 px-4 md:px-10 py-10 md:py-[60px]">
    <div class="max-w-screen-xl mx-auto flex flex-col gap-6 md:gap-10">

      {%- render 'section-header', heading: section.settings.heading -%}

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-6 md:gap-x-6 md:gap-y-6">
        {%- for recommendation in recommendations.products -%}
          {%- render 'card-product-4col', product: recommendation -%}
        {%- endfor -%}
      </div>

    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "おすすめ商品（S&D）",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "あなたへのおすすめ"
    }
  ]
}
{% endschema %}
