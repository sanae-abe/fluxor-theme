{%- comment %}
  おすすめルーティン＆セクション (product-routine-set.liquid)
  使用: templates/product.json に追加して使用

  データソース:
    product.metafields.custom.routine_products (list.product_reference) — ルーティン推奨商品
    product.metafields.custom.recommended_set  (product_reference)     — お得なセット商品
{%- endcomment -%}

{%- liquid
  assign routine_products = product.metafields.custom.routine_products.value
  assign recommended_set = product.metafields.custom.recommended_set.value
-%}
{%- if routine_products != blank or recommended_set != blank -%}

{%- assign s = section.settings -%}

<section
  id="product-routine-set"
  class="px-4 md:px-10 py-10 md:py-[60px] bg-stone-100"
>
  <div class="max-w-screen-xl mx-auto flex flex-col gap-8 md:gap-12">

    {%- render 'section-header',
      heading: s.heading,
      subheading: s.subheading,
      align: 'center'
    -%}

    {%- if routine_products != blank -%}
      <div class="routine-set-grid grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4 md:gap-6 items-start">
        {%- for rp in routine_products -%}
          <div class="routine-set-card flex flex-col items-center text-center gap-3">

            {%- comment %} ステップ番号 {%- endcomment -%}
            <span class="text-xs font-medium text-stone-400 uppercase tracking-widest">Step {{ forloop.index }}</span>

            {%- comment %} 商品画像 {%- endcomment -%}
            <a href="{{ rp.url }}" class="routine-set-card__link block w-full overflow-hidden rounded-lg bg-white border border-stone-200">
              {%- if rp.featured_image -%}
                <img
                  src="{{ rp.featured_image | image_url: width: 400, format: 'webp' }}"
                  alt="{{ rp.featured_image.alt | default: rp.title }}"
                  width="200" height="200"
                  loading="lazy"
                  class="w-full h-auto"
                >
              {%- endif -%}
            </a>

            {%- comment %} 商品名 {%- endcomment -%}
            <a href="{{ rp.url }}" class="text-sm font-medium text-stone-900 leading-snug palt tracking-wide line-clamp-2">
              {{- rp.title -}}
            </a>

            {%- comment %} 現在の商品にハイライト {%- endcomment -%}
            {%- if rp.id == product.id -%}
              <span class="text-xs text-stone-400">この商品</span>
            {%- endif -%}

          </div>

          {%- comment %} ステップ間の矢印（最後以外） {%- endcomment -%}
          {%- unless forloop.last -%}
            <div class="hidden md:flex items-center justify-center self-center pt-6">
              {%- render 'icon', icon: 'chevron-right', class: 'w-5 h-5 text-stone-300' -%}
            </div>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment %} セット商品 CTA {%- endcomment -%}
    {%- if recommended_set != blank -%}
      <div class="flex flex-col md:flex-row items-center gap-4 md:gap-6 bg-white rounded-lg border border-stone-200 p-5 md:p-6">
        {%- if recommended_set.featured_image -%}
          <a href="{{ recommended_set.url }}" class="w-20 h-20 shrink-0 overflow-hidden rounded-lg">
            <img
              src="{{ recommended_set.featured_image | image_url: width: 200, format: 'webp' }}"
              alt="{{ recommended_set.title }}"
              width="80" height="80"
              loading="lazy"
              class="w-full h-full object-cover"
            >
          </a>
        {%- endif -%}
        <div class="flex flex-col gap-1 flex-1 min-w-0 text-center md:text-left">
          <p class="text-xs font-medium text-stone-400 uppercase tracking-widest">{{ s.set_label }}</p>
          <p class="text-base font-medium text-stone-900 leading-snug palt tracking-wide">{{ recommended_set.title }}</p>
          {%- if recommended_set.price < recommended_set.compare_at_price -%}
            <p class="text-sm text-stone-500">
              <s>{{ recommended_set.compare_at_price | money }}</s>
              <span class="text-stone-900 font-medium ml-1">{{ recommended_set.price | money }}</span>
            </p>
          {%- else -%}
            <p class="text-sm text-stone-900">{{ recommended_set.price | money }}</p>
          {%- endif -%}
        </div>
        <a
          href="{{ recommended_set.url }}"
          class="routine-set-cta shrink-0 inline-flex items-center gap-2 bg-stone-900 text-white text-sm font-medium px-6 py-3 rounded-lg"
        >
          <span>{{ s.set_cta }}</span>
          {%- render 'icon', icon: 'arrow-right', class: 'routine-set-cta__icon w-4 h-4' -%}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<script>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var grid = document.querySelector('#product-routine-set .routine-set-grid');
    if (!grid) return;
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          grid.classList.add('is-visible');
          observer.disconnect();
        }
      });
    }, { threshold: 0.15 });
    observer.observe(grid);
  })();
</script>

{%- endif -%}

{% schema %}
{
  "name": "おすすめルーティン",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "おすすめルーティン"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "サブ見出し"
    },
    {
      "type": "text",
      "id": "set_label",
      "label": "セット商品ラベル",
      "default": "お得なセット"
    },
    {
      "type": "text",
      "id": "set_cta",
      "label": "セットCTAテキスト",
      "default": "セットで揃える"
    }
  ],
  "presets": [
    {
      "name": "おすすめルーティン"
    }
  ]
}
{% endschema %}
