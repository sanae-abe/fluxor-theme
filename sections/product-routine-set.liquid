{%- comment %}
  おすすめルーティン＆セクション (product-routine-set.liquid)
  使用: templates/product.json に追加して使用

  データソース:
    product.metafields.custom.routine_products (list.product_reference) — ルーティン推奨商品
    product.metafields.custom.recommended_set  (product_reference)     — お得なセット商品
{%- endcomment -%}

{%- liquid
  assign routine_products = product.metafields.custom.routine_products.value
  assign recommended_set = product.metafields.custom.recommended_set.value
-%}
{%- if routine_products != blank or recommended_set != blank -%}

{%- assign s = section.settings -%}

<section
  id="product-routine-set"
  class="px-4 md:px-10 py-10 md:py-[60px] bg-stone-100"
>
  <div class="max-w-screen-xl mx-auto flex flex-col gap-8 md:gap-12">

    {%- render 'section-header',
      heading: s.heading,
      subheading: s.subheading,
      align: 'center'
    -%}

    {%- if routine_products != blank -%}
      <div class="routine-set-grid flex flex-col md:flex-row md:justify-center items-center md:items-start gap-4 md:gap-4 max-w-4xl mx-auto">
        {%- for rp in routine_products -%}
          <div class="routine-set-card flex-1 min-w-0 max-w-[200px] flex flex-col items-center text-center gap-3">

            {%- comment %} ステップ番号 {%- endcomment -%}
            <span class="text-lg font-medium text-stone-900 uppercase tracking-widest">Step {{ forloop.index }}</span>

            {%- comment %} 商品画像 {%- endcomment -%}
            {%- if rp.id == product.id -%}
              <div class="block w-full overflow-hidden bg-white border-2 border-stone-900">
            {%- else -%}
              <a href="{{ rp.url }}" class="routine-set-card__link block w-full overflow-hidden bg-white border border-stone-200">
            {%- endif -%}
              {%- if rp.featured_image -%}
                <img
                  src="{{ rp.featured_image | image_url: width: 400, format: 'webp' }}"
                  alt="{{ rp.featured_image.alt | default: rp.title }}"
                  width="200" height="200"
                  loading="lazy"
                  class="w-full h-auto"
                >
              {%- endif -%}
            {%- if rp.id == product.id -%}
              </div>
            {%- else -%}
              </a>
            {%- endif -%}

            {%- comment %} 商品名 {%- endcomment -%}
            {%- if rp.id == product.id -%}
              <span class="text-base font-medium text-stone-900 leading-snug palt tracking-wide line-clamp-2">
                {{- rp.title -}}
              </span>
            {%- else -%}
              <a href="{{ rp.url }}" class="text-base font-medium text-stone-900 leading-snug palt tracking-wide line-clamp-2">
                {{- rp.title -}}
              </a>
            {%- endif -%}

          </div>

          {%- comment %} ステップ間の矢印（最後以外） {%- endcomment -%}
          {%- unless forloop.last -%}
            <div class="hidden md:flex items-center shrink-0 self-center">
              {%- render 'icon', icon: 'chevron-right', class: 'w-8 h-8 text-stone-00' -%}
            </div>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment %} セット商品 CTA {%- endcomment -%}
    {%- if recommended_set != blank -%}
      <div class="flex justify-center">
        {%- capture set_cta_label -%}お得なセット商品を見る{%- endcapture -%}
        {%- render 'button',
          label: set_cta_label,
          url: recommended_set.url,
          icon_right: 'arrow-right',
          class: 'w-full md:w-auto'
        -%}
      </div>
    {%- endif -%}

  </div>
</section>

<script>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var grid = document.querySelector('#product-routine-set .routine-set-grid');
    if (!grid) return;
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          grid.classList.add('is-visible');
          observer.disconnect();
        }
      });
    }, { threshold: 0.15 });
    observer.observe(grid);
  })();
</script>

{%- endif -%}

{% schema %}
{
  "name": "おすすめルーティン",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "おすすめルーティン"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "サブ見出し"
    },
    {
      "type": "text",
      "id": "set_label",
      "label": "セット商品ラベル",
      "default": "お得なセット"
    },
    {
      "type": "text",
      "id": "set_cta",
      "label": "セットCTAテキスト",
      "default": "セットで揃える"
    }
  ],
  "presets": [
    {
      "name": "おすすめルーティン"
    }
  ]
}
{% endschema %}
