{% comment %}
  セールアナウンスメントバナー
  - グローバルセール設定（settings.sale_*）が有効かつスケジュール内のときのみ表示
  - Alpine.js $store.sale.isActive() でスケジュール判定
  - カウントダウンタイマーを内包
{% endcomment %}

{%- if settings.sale_enabled and settings.sale_banner_show -%}
  <div
    x-data
    x-show="$store.sale.isActive()"
    x-cloak
    class="sale-announcement-bar bg-accent text-white py-2 px-4"
    role="banner"
    aria-label="セール情報"
  >
    <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-xs md:text-sm">
      {%- comment %} バナーテキスト {%- endcomment %}
      <span class="font-medium">
        {%- if section.settings.text != blank -%}
          {{ section.settings.text }}
        {%- else -%}
          {{ settings.sale_banner_text }}
        {%- endif -%}
      </span>

      {%- comment %} ディスカウント率 {%- endcomment %}
      <span class="opacity-90">{{ settings.sale_discount_percent }}% OFF</span>

      {%- comment %} カウントダウンタイマー {%- endcomment %}
      {%- render 'sale-countdown' -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "セールバナー",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "バナーテキスト（上書き）",
      "info": "空白の場合はグローバルセール設定のテキストを使用します"
    }
  ],
  "presets": [
    {
      "name": "セールバナー"
    }
  ]
}
{% endschema %}
