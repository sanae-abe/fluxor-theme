{%- comment %}
  sections/set-builder-page.liquid

  セットビルダー専用商品ページセクション
  使用: templates/product.set-builder.json

  価格: 管理画面の商品価格をそのまま使用（compare_at_price でセール表示対応）
  左カラム: 商品画像ギャラリー
  右カラム: タイトル・価格・固定商品・候補選択・カートボタン
{%- endcomment -%}

{%- liquid
  assign variant = product.selected_or_first_available_variant
  assign on_sale = false
  if variant.compare_at_price > variant.price
    assign on_sale = true
    assign discount = variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price
  endif

  assign fp = section.settings.fixed_product | default: product
  assign fp_variant = fp.selected_or_first_available_variant

  assign sale_eligible = false
  assign sale_discount = 0

  if settings.sale_enabled
    assign _excluded = false
    if settings.sale_exclude_handles != blank
      assign _exclude_handle_list = settings.sale_exclude_handles | split: ','
      for _handle in _exclude_handle_list
        assign _handle_normalized = _handle | strip | downcase
        if _handle_normalized == product.handle
          assign _excluded = true
          break
        endif
      endfor
    endif

    unless _excluded or settings.sale_exclude_tags == blank
      assign _exclude_tag_list = settings.sale_exclude_tags | split: ','
      for _exclude_tag in _exclude_tag_list
        assign _exclude_tag_normalized = _exclude_tag | strip | downcase
        for _product_tag in product.tags
          assign _product_tag_normalized = _product_tag | downcase
          if _product_tag_normalized == _exclude_tag_normalized
            assign _excluded = true
            break
          endif
        endfor
        if _excluded
          break
        endif
      endfor
    endunless

    unless _excluded
      case settings.sale_target
      when 'all'
        assign sale_eligible = true
      when 'tag'
        if settings.sale_target_tags != blank
          assign _target_tag_list = settings.sale_target_tags | split: ','
          for _target_tag in _target_tag_list
            assign _target_tag_normalized = _target_tag | strip | downcase
            for _product_tag in product.tags
              assign _product_tag_normalized = _product_tag | downcase
              if _product_tag_normalized == _target_tag_normalized
                assign sale_eligible = true
                break
              endif
            endfor
            if sale_eligible
              break
            endif
          endfor
        endif
      when 'collection'
        if settings.sale_target_collections != blank
          assign _target_col_list = settings.sale_target_collections | split: ','
          for _target_col_handle in _target_col_list
            assign _target_col_normalized = _target_col_handle | strip | downcase
            for _product_col in product.collections
              if _product_col.handle == _target_col_normalized
                assign sale_eligible = true
                break
              endif
            endfor
            if sale_eligible
              break
            endif
          endfor
        endif
      endcase

      if sale_eligible
        assign sale_discount = settings.sale_discount_percent | plus: 0
      endif
    endunless
  endif
-%}

{%- comment %} 候補商品 JSON 配列 {%- endcomment -%}
{%- assign json_parts = '' -%}
{%- for i in (1..8) -%}
  {%- assign key = 'product_' | append: i -%}
  {%- assign p = section.settings[key] -%}
  {%- if p != blank -%}
    {%- assign pv = p.selected_or_first_available_variant -%}
    {%- if json_parts != '' -%}{%- assign json_parts = json_parts | append: ',' -%}{%- endif -%}
    {%- capture entry -%}{"id":{{ p.id }},"title":{{ p.title | json }},"priceFormatted":{{ pv.price | money_without_trailing_zeros | json }},"variantId":{{ pv.id }},"image":{{ p.featured_image | image_url: width: 400, format: 'webp' | json }},"available":{{ pv.available }}}{%- endcapture -%}
    {%- assign json_parts = json_parts | append: entry -%}
  {%- endif -%}
{%- endfor -%}

<script type="application/json" id="bundle-page-data-{{ section.id }}">
{
  "fixedVariantId": {{ fp_variant.id | default: 0 }},
  "candidates": [{{ json_parts }}]
}
</script>

<script>
  function bundlePage(dataId) {
    const raw = JSON.parse(document.getElementById(dataId).textContent)
    return {
      fixedVariantId: raw.fixedVariantId,
      candidates: raw.candidates,
      selected: [],
      adding: false,
      added: false,
      saleEligible: {{ sale_eligible | json }},
      saleDiscount: {{ sale_discount | default: 0 }},
      get salePrice() {
        return Math.floor({{ variant.price }} / 100 * (100 - this.saleDiscount) / 100);
      },

      isSelected(product) {
        return this.selected.some(s => s.id === product.id)
      },

      toggleSelect(product) {
        if (!product.available) return
        if (this.isSelected(product)) {
          this.selected = this.selected.filter(s => s.id !== product.id)
        } else if (this.selected.length < 2) {
          this.selected = [...this.selected, product]
        }
      },

      async addBundle() {
        if (this.selected.length < 2 || this.adding || !this.fixedVariantId) return
        this.adding = true
        try {
          const items = [
            { id: this.fixedVariantId, quantity: 1 },
            ...this.selected.map(s => ({ id: s.variantId, quantity: 1 })),
          ]
          const res = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items }),
          })
          if (!res.ok) throw new Error('Cart add failed')
          await this.$store.cart.fetch()
          this.$store.cart.open = true
          this.added = true
          setTimeout(() => { this.added = false }, 3000)
        } catch (err) {
          console.error('[bundlePage.addBundle]', err)
        } finally {
          this.adding = false
        }
      },
    }
  }
</script>

<div x-data="bundlePage('bundle-page-data-{{ section.id }}')">
<section
  class="bg-stone-50 px-4 md:px-10 py-10 md:py-[60px]"
>
  <div class="max-w-screen-xl mx-auto flex flex-col lg:flex-row gap-6 md:gap-10 items-start">

    {%- comment %}--- 左カラム: 画像ギャラリー ---{%- endcomment -%}
    <div class="w-full lg:flex-1 flex flex-col gap-4">
      <div class="aspect-square overflow-hidden bg-stone-100 [transform:translateZ(0)]">
        {%- if product.featured_image -%}
          <img
            src="{{ product.featured_image | image_url: width: 800, format: 'webp' }}"
            alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            class="w-full h-full object-cover"
            width="800"
            height="800"
          >
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="grid grid-cols-4 gap-3">
          {%- for image in product.images limit: 8 -%}
            <div class="aspect-square overflow-hidden bg-stone-100 [transform:translateZ(0)]">
              <img
                src="{{ image | image_url: width: 300, format: 'webp' }}"
                alt="{{ image.alt | escape | default: product.title | escape }}"
                class="w-full h-full object-cover"
                loading="lazy"
                width="300"
                height="300"
              >
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment %}--- 右カラム: バンドル情報 ---{%- endcomment -%}
    <div class="w-full lg:flex-1 flex flex-col gap-5 lg:sticky lg:top-20 min-w-0">

      {%- comment %} タイトル {%- endcomment -%}
      <div class="flex flex-col gap-2">
        {%- if product.vendor != blank -%}
          <p class="text-sm text-stone-500 leading-tight">{{ product.vendor }}</p>
        {%- endif -%}
        <h1 class="text-2xl md:text-3xl font-medium leading-tight text-stone-900 palt tracking-wider">{{ product.title }}</h1>
        {%- if product.description != blank -%}
          <p class="text-sm text-stone-500 leading-relaxed">{{ product.description | strip_html | truncate: 120 }}</p>
        {%- endif -%}
      </div>

      {%- comment %} 価格（管理画面設定値） {%- endcomment -%}
      <div class="flex items-end gap-2 flex-wrap">
        {%- if on_sale -%}
          <span class="text-3xl font-semibold text-stone-900 leading-none">{{ variant.price | money }}</span>
          <s class="text-base text-stone-500 leading-tight">{{ variant.compare_at_price | money }}</s>
        {%- elsif sale_eligible -%}
          <span class="text-3xl font-semibold text-stone-900 leading-none"
            x-text="$store.sale.isActive() ? $store.sale.formatMoney(salePrice) : $store.sale.formatMoney({{ variant.price }} / 100)"
          >{{ variant.price | money }}</span>
          <s class="text-base text-stone-500 leading-tight"
            x-show="$store.sale.isActive()"
            x-text="$store.sale.formatMoney({{ variant.price }} / 100)"
            x-cloak
          >{{ variant.price | money }}</s>
        {%- else -%}
          <span class="text-3xl font-semibold text-stone-900 leading-none">{{ variant.price | money }}</span>
        {%- endif -%}
        <span class="text-sm text-stone-900 leading-tight">(税込・送料込)</span>
        {%- if on_sale -%}
          {%- assign discount_label = discount | append: '% OFF' -%}
          {%- render 'badge', label: discount_label, variant: 'premium', size: 'sm' -%}
        {%- elsif sale_eligible -%}
          {%- assign _sched_discount_label = sale_discount | append: '% OFF' -%}
          <template x-if="$store.sale.isActive()">
            <div>{%- render 'badge', label: _sched_discount_label, variant: 'premium', size: 'sm' -%}</div>
          </template>
        {%- endif -%}
      </div>

      <hr class="border-stone-200">

      {%- comment %} 固定商品 {%- endcomment -%}
      <div>
        <p class="text-xs font-medium text-stone-500 uppercase tracking-wider mb-2">固定商品</p>
        <div class="flex items-center gap-3 p-3 rounded-xl border border-stone-200 bg-white">
          {%- if fp.featured_image -%}
            <img
              src="{{ fp.featured_image | image_url: width: 96, format: 'webp' }}"
              alt="{{ fp.featured_image.alt | escape }}"
              width="64" height="64"
              class="w-16 h-16 object-cover rounded-lg flex-shrink-0"
              loading="lazy"
            >
          {%- endif -%}
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-stone-900 line-clamp-2">{{ fp.title | escape }}</p>
            <p class="text-sm text-stone-500 mt-0.5">{{ fp_variant.price | money_without_trailing_zeros }}</p>
          </div>
          <div class="bundle-fixed-check flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center">
            {%- render 'icon', icon: 'check', class: 'w-3.5 h-3.5 text-white', stroke_width: 3 -%}
          </div>
        </div>
      </div>

      {%- comment %} 候補商品選択 {%- endcomment -%}
      <div>
        <div class="flex items-center justify-between mb-3">
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wider">好きな2点を選んでください</p>
          <span class="text-xs font-semibold bundle-count" :class="selected.length === 2 ? 'is-complete' : ''">
            <span x-text="selected.length"></span>/2
          </span>
        </div>
        <div class="flex flex-col gap-2">
          <template x-for="product in candidates" :key="product.id">
            <button
              type="button"
              class="bundle-candidate relative flex items-center gap-3 p-3 rounded-xl border text-left w-full"
              :class="{
                'is-selected': isSelected(product),
                'is-disabled': !isSelected(product) && selected.length >= 2,
                'is-soldout': !product.available
              }"
              :disabled="!product.available || (!isSelected(product) && selected.length >= 2)"
              @click="toggleSelect(product)"
            >
              <img
                :src="product.image"
                :alt="product.title"
                width="64" height="64"
                class="w-16 h-16 object-cover rounded-lg flex-shrink-0"
              >
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-stone-900 line-clamp-2 leading-tight" x-text="product.title"></p>
                <p class="text-sm text-stone-500 mt-0.5" x-text="product.priceFormatted"></p>
              </div>
              <div class="bundle-check-dot flex-shrink-0 w-6 h-6 rounded-full border-2 flex items-center justify-center">
                {%- render 'icon', icon: 'check', class: 'w-3.5 h-3.5 text-white', x_class: "isSelected(product) ? '' : 'hidden'", stroke_width: 3 -%}
              </div>
              <div class="bundle-soldout-badge absolute inset-0 rounded-xl flex items-center justify-center" :class="product.available ? 'hidden' : ''">
                <span class="text-xs font-semibold tracking-wide">在庫なし</span>
              </div>
            </button>
          </template>
        </div>
      </div>

      {%- comment %} カートに追加ボタン {%- endcomment -%}
      <div class="flex flex-col gap-3">
        <button
          type="button"
          class="btn-add-to-cart w-full bg-stone-950 border-2 border-stone-950 text-white flex items-center justify-center min-h-[48px] px-4 py-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-900 focus-visible:ring-offset-2 palt transition-opacity duration-300"
          :class="(selected.length < 2 || adding) ? 'opacity-50 cursor-not-allowed' : ''"
          :disabled="selected.length < 2 || adding"
          @click="addBundle"
        >
          <span class="text-base font-bold leading-tight" :class="(adding || added) ? 'hidden' : ''">
            <span :class="selected.length < 2 ? '' : 'hidden'">あと<span x-text="2 - selected.length"></span>点選んでください</span>
            <span :class="selected.length === 2 ? '' : 'hidden'">3点セットをカートに追加</span>
          </span>
          <span class="text-base font-bold leading-tight" :class="adding ? '' : 'hidden'">追加中…</span>
          <span class="text-base font-bold leading-tight" :class="added ? '' : 'hidden'">✓ カートに追加しました</span>
        </button>

        <p class="flex gap-2 text-sm justify-end">
          {%- render 'icon', icon: 'van', class: 'w-5 h-5 flex-shrink-0 stroke-1.5' -%}
          国際配送のため、通常ご注文から約14〜21営業日でお届けいたします。
        </p>
      </div>

    </div>
  </div>
</section>
</div>

{%- schema %}
{
  "name": "バンドルページ",
  "settings": [
    {
      "type": "product",
      "id": "fixed_product",
      "label": "固定商品",
      "info": "空欄の場合、このページの商品が固定商品になります"
    },
    {
      "type": "header",
      "content": "候補商品（最大8商品）"
    },
    { "type": "product", "id": "product_1", "label": "候補商品 1" },
    { "type": "product", "id": "product_2", "label": "候補商品 2" },
    { "type": "product", "id": "product_3", "label": "候補商品 3" },
    { "type": "product", "id": "product_4", "label": "候補商品 4" },
    { "type": "product", "id": "product_5", "label": "候補商品 5" },
    { "type": "product", "id": "product_6", "label": "候補商品 6" },
    { "type": "product", "id": "product_7", "label": "候補商品 7" },
    { "type": "product", "id": "product_8", "label": "候補商品 8" }
  ],
  "presets": [
    {
      "name": "バンドルページ"
    }
  ]
}
{%- endschema -%}
