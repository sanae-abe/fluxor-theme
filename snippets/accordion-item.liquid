{%- comment %}
  Accordion アイテム

  Parameters:
    title              {String}  見出しテキスト
    body               {String}  本文 HTML（capture 済み）
    index              {Number}  Alpine openItem 識別用インデックス
    shopify_attributes {String}  テーマエディタ用属性（block.shopify_attributes）
{%- endcomment -%}
<div {{ shopify_attributes }} class="bg-stone-50">
  <button
    type="button"
    class="w-full flex items-center justify-between gap-4 py-6 px-6 text-left focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
    @click="openItem = openItem === {{ index }} ? null : {{ index }}"
    :aria-expanded="openItem === {{ index }}"
  >
    <span class="text-base font-medium text-stone-900 leading-tight">{{ title }}</span>
    {%- capture _chevron_class -%}openItem === {{ index }} ? 'rotate-180' : ''{%- endcapture -%}
    {%- render 'icon', icon: 'chevron-down', class: 'w-5 h-5 text-stone-900 shrink-0 transition-transform duration-200', x_class: _chevron_class, stroke_width: 2 -%}
  </button>
  <div
    class="grid"
    style="transition: grid-template-rows 0.3s ease;"
    :style="{ 'grid-template-rows': openItem === {{ index }} ? '1fr' : '0fr' }"
    role="region"
    :aria-hidden="openItem !== {{ index }}"
  >
    <div class="overflow-hidden">
      <div
        class="pb-6 px-6 transition duration-300"
        :class="openItem === {{ index }} ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-2'"
      >
        {{ body }}
      </div>
    </div>
  </div>
</div>
