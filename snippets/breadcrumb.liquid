{%- comment %}
  breadcrumb — パンくずリスト

  Parameters:
    item1_label {String} 1段階目ラベル（必須）
    item1_url   {String} 1段階目URL（省略時は現在ページ扱い）
    item2_label {String} 2段階目ラベル
    item2_url   {String} 2段階目URL
    item3_label {String} 3段階目ラベル（省略時はitem2が現在ページ）
    item3_url   {String} 3段階目URL
    item4_label {String} 4段階目ラベル（URLなし = 常に現在ページ）
    max_w       {String} max-width クラス（デフォルト: 'max-w-3xl'）

  ルール: URLあり = リンク、URLなし = 現在ページ（最後のアイテム）
  モバイル（md未満）: 親ページへの ← リンクのみ表示

  Usage:
    {%- assign _title = name_ja | default: article.title -%}
    {%- render 'breadcrumb',
      item1_label: 'Home',
      item1_url: routes.root_url,
      item2_label: 'Ingredients',
      item2_url: blog.url,
      item3_label: _title
    -%}
{%- endcomment -%}

{%- liquid
  assign _max_w = max_w | default: 'max-w-3xl'
  assign _sep   = '|||'

  if item4_label != blank
    assign _parent_label = item3_label
    assign _parent_url   = item3_url
  elsif item3_label != blank
    assign _parent_label = item2_label
    assign _parent_url   = item2_url
  elsif item2_label != blank
    assign _parent_label = item1_label
    assign _parent_url   = item1_url
  endif

  assign _labels = item1_label | append: _sep | append: item2_label | append: _sep | append: item3_label | append: _sep | append: item4_label | split: _sep
  assign _urls   = item1_url   | append: _sep | append: item2_url   | append: _sep | append: item3_url   | append: _sep | split: _sep
-%}

{%- comment %} モバイル: 親ページへ戻るリンク {%- endcomment -%}
{%- if _parent_url != blank -%}
  <a
    href="{{ _parent_url }}"
    class="breadcrumb-link md:hidden w-full {{ _max_w }} mx-auto flex items-center gap-1 text-sm"
  >
    {%- render 'icon', icon: 'arrow-left', class: 'w-3.5 h-3.5 flex-shrink-0', stroke_width: 2 -%}
    <span>{{ _parent_label }} に戻る</span>
  </a>
{%- endif -%}

{%- comment %} デスクトップ: フルパンくず {%- endcomment -%}
<nav
  class="hidden md:flex w-full {{ _max_w }} mx-auto items-center gap-2 text-sm flex-wrap"
  aria-label="パンくずリスト"
>
  {%- assign _is_first = true -%}
  {%- for _label in _labels -%}
    {%- if _label == blank -%}{%- continue -%}{%- endif -%}
    {%- assign _url = _urls[forloop.index0] -%}
    {%- unless _is_first -%}
      {%- render 'icon', icon: 'chevron-right', class: 'w-3.5 h-3.5 text-stone-300 flex-shrink-0', stroke_width: 2 -%}
    {%- endunless -%}
    {%- if _url != blank -%}
      <a href="{{ _url }}" class="breadcrumb-link">{{ _label }}</a>
    {%- else -%}
      <span class="text-stone-900" aria-current="page">{{ _label }}</span>
    {%- endif -%}
    {%- assign _is_first = false -%}
  {%- endfor -%}
</nav>
