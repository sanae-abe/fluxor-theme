{%- comment %}
  breadcrumb — パンくずリスト

  Parameters:
    item1_label {String} 1段階目ラベル（必須）
    item1_url   {String} 1段階目URL（省略時は現在ページ扱い）
    item2_label {String} 2段階目ラベル
    item2_url   {String} 2段階目URL
    item3_label {String} 3段階目ラベル（省略時はitem2が現在ページ）
    item3_url   {String} 3段階目URL
    item4_label {String} 4段階目ラベル（URLなし = 常に現在ページ）
    max_w       {String} max-width クラス（デフォルト: 'max-w-4xl'）

  ルール: URLあり = リンク、URLなし = 現在ページ（最後のアイテム）
  モバイル（md未満）: 親ページへの ← リンクのみ表示

  Usage:
    {%- assign _title = name_ja | default: article.title -%}
    {%- render 'breadcrumb',
      item1_label: 'ホーム',
      item1_url: routes.root_url,
      item2_label: '成分ガイド',
      item2_url: blog.url,
      item3_label: _title
    -%}
{%- endcomment %}

{%- comment %} 親ページを特定（モバイル用バックリンク） {%- endcomment %}
{%- liquid
  if item4_label != blank
    assign _parent_label = item3_label
    assign _parent_url   = item3_url
  elsif item3_label != blank
    assign _parent_label = item2_label
    assign _parent_url   = item2_url
  elsif item2_label != blank
    assign _parent_label = item1_label
    assign _parent_url   = item1_url
  endif
-%}

{%- comment %} モバイル: 親ページへ戻るリンク {%- endcomment %}
{%- if _parent_url != blank -%}
  <a
    href="{{ _parent_url }}"
    class="md:hidden w-full {{ max_w | default: 'max-w-4xl' }} mx-auto flex items-center gap-1 text-sm text-stone-500 hover:text-stone-900 transition-colors"
  >
    {%- render 'icon', icon: 'arrow-left', class: 'w-3.5 h-3.5 flex-shrink-0', stroke_width: 2 -%}
    <span>{{ _parent_label }} に戻る</span>
  </a>
{%- endif -%}

{%- comment %} デスクトップ: フルパンくず {%- endcomment %}
<nav
  class="hidden md:flex w-full {{ max_w | default: 'max-w-4xl' }} mx-auto items-center gap-2 text-sm flex-wrap"
  aria-label="パンくずリスト"
>
  {%- if item1_label != blank -%}

    {%- if item1_url != blank -%}
      <a href="{{ item1_url }}" class="text-stone-500 hover:text-stone-900 transition-colors">{{ item1_label }}</a>
    {%- else -%}
      <span class="text-stone-900" aria-current="page">{{ item1_label }}</span>
    {%- endif -%}

    {%- if item2_label != blank -%}
      {%- render 'icon', icon: 'chevron-right', class: 'w-3.5 h-3.5 text-stone-300 flex-shrink-0', stroke_width: 2 -%}
      {%- if item2_url != blank -%}
        <a href="{{ item2_url }}" class="text-stone-500 hover:text-stone-900 transition-colors">{{ item2_label }}</a>
      {%- else -%}
        <span class="text-stone-900" aria-current="page">{{ item2_label }}</span>
      {%- endif -%}

      {%- if item3_label != blank -%}
        {%- render 'icon', icon: 'chevron-right', class: 'w-3.5 h-3.5 text-stone-300 flex-shrink-0', stroke_width: 2 -%}
        {%- if item3_url != blank -%}
          <a href="{{ item3_url }}" class="text-stone-500 hover:text-stone-900 transition-colors">{{ item3_label }}</a>
        {%- else -%}
          <span class="text-stone-900" aria-current="page">{{ item3_label }}</span>
        {%- endif -%}

        {%- if item4_label != blank -%}
          {%- render 'icon', icon: 'chevron-right', class: 'w-3.5 h-3.5 text-stone-300 flex-shrink-0', stroke_width: 2 -%}
          <span class="text-stone-900" aria-current="page">{{ item4_label }}</span>
        {%- endif -%}

      {%- endif -%}
    {%- endif -%}

  {%- endif -%}
</nav>
