{% comment %}
  Button component — Figma node 3083:6379

  Accepts:
  - label:      {String}  ボタンテキスト（必須）
  - url:        {String}  URLを指定すると<a>、省略すると<button>
  - variant:    {String}  'solid' | 'outline'  （デフォルト: 'solid'）
  - color:      {String}  'dark' | 'light' | 'teal' | 'amber' | 'muted'  （デフォルト: 'dark'）
  - size:       {String}  'xl' | 'lg' | 'md' | 'sm' | 'xs'  （デフォルト: 'md'）
  - icon_left:  {String}  左側アイコン名（例: 'arrow-left'）
  - icon_right: {String}  右側アイコン名（例: 'arrow-right'）
  - type:       {String}  button の type 属性  （デフォルト: 'button'）
  - disabled:   {Boolean} 非活性状態
  - full_width: {Boolean} 横幅100%
  - attr:       {String}  追加 HTML 属性（Alpine.js @click など）
  - class:      {String}  追加 CSS クラス

  利用可能なアイコン:
  arrow-left, arrow-right, hash, search, user, star, cart,
  trending-up, flask-conical, notebook-pen, x, instagram, tiktok,
  minus, plus

  Usage:
  {% render 'button', label: 'Shop Now', url: collection.url, icon_right: 'arrow-right' %}
  {% render 'button', label: 'カートに追加', size: 'lg' %}
  {% render 'button', label: '詳しく見る', variant: 'outline', color: 'teal', icon_left: 'arrow-left', icon_right: 'arrow-right' %}
{% endcomment %}

<style>
  .btn-slide {
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  @media (any-hover: hover) {
    .btn-slide:not(:disabled):hover {
      background-color: var(--hover-bg);
      color: var(--hover-text);
    }
  }
</style>

{%- liquid
  assign btn_variant  = variant  | default: 'solid'
  assign btn_color    = color    | default: 'dark'
  assign btn_size     = size     | default: 'md'

  # ── サイズ ──────────────────────────────────────────────────────
  case btn_size
  when 'xl'
    assign size_cls = 'h-[72px] px-5 text-xl gap-2 border-2 font-medium'
    assign icon_cls = 'w-6 h-6'
  when 'lg'
    assign size_cls = 'h-[60px] px-[18px] text-lg gap-3 border-2 font-medium'
    assign icon_cls = 'w-5 h-5'
  when 'sm'
    assign size_cls = 'h-8 px-[14px] text-sm gap-1'
    assign icon_cls = 'w-4 h-4'
  when 'xs'
    assign size_cls = 'h-7 px-[6px] text-xs gap-1'
    assign icon_cls = 'w-[14px] h-[14px]'
  else
    assign size_cls = 'h-12 px-4 text-base gap-2 border-2 font-medium'
    assign icon_cls = 'w-[18px] h-[18px]'
  endcase

  # ── カラー × バリアント ─────────────────────────────────────────
  case btn_color
  when 'light'
    if btn_variant == 'outline'
      assign color_cls = 'bg-transparent text-stone-50 border-stone-50'
      assign hover_bg = '#fafaf9'
      assign hover_text = '#1c1917'
    else
      assign color_cls = 'bg-stone-50 text-stone-900 border-stone-50'
      assign hover_bg = '#e7e5e4'
      assign hover_text = '#1c1917'
    endif
  when 'teal'
    if btn_variant == 'outline'
      assign color_cls = 'bg-transparent text-teal-900 border-teal-900'
      assign hover_bg = '#134e4a'
      assign hover_text = '#fafaf9'
    else
      assign color_cls = 'bg-teal-900 text-stone-50 border-teal-900'
      assign hover_bg = '#115e59'
      assign hover_text = '#fafaf9'
    endif
  when 'amber'
    if btn_variant == 'outline'
      assign color_cls = 'bg-transparent text-amber-700 border-amber-700'
      assign hover_bg = '#b45309'
      assign hover_text = '#fafaf9'
    else
      assign color_cls = 'bg-amber-700 text-stone-50 border-amber-700'
      assign hover_bg = '#92400e'
      assign hover_text = '#fafaf9'
    endif
  when 'muted'
    if btn_variant == 'outline'
      assign color_cls = 'bg-transparent text-stone-400 border-stone-400'
      assign hover_bg = '#a8a29e'
      assign hover_text = '#fafaf9'
    else
      assign color_cls = 'bg-stone-400 text-stone-50 border-stone-400'
      assign hover_bg = '#78716c'
      assign hover_text = '#fafaf9'
    endif
  else
    # dark（デフォルト）
    if btn_variant == 'outline'
      assign color_cls = 'bg-transparent text-stone-900 border-stone-900'
      assign hover_bg = '#1c1917'
      assign hover_text = '#fafaf9'
    else
      assign color_cls = 'bg-stone-900 text-stone-50 border-stone-900'
      assign hover_bg = '#ffffff'
      assign hover_text = '#0c0a09'
    endif
  endcase

  assign width_cls   = ''
  if full_width
    assign width_cls = 'w-full'
  endif

  assign disabled_cls = ''
  if disabled
    assign disabled_cls = 'opacity-40 cursor-not-allowed pointer-events-none'
  endif

  assign base_cls = 'btn-slide inline-flex items-center justify-center border font-sans tracking-wide select-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 palt tracking-wider'
  assign icon_svg_cls = icon_cls | append: ' flex-shrink-0 stroke-2'
-%}

{%- capture btn_inner -%}
  {%- if icon_left != blank -%}
    {%- render 'icon', icon: icon_left, class: icon_svg_cls -%}
  {%- endif -%}

  <span>{{ label }}</span>

  {%- if icon_right != blank -%}
    {%- render 'icon', icon: icon_right, class: icon_svg_cls -%}
  {%- endif -%}
{%- endcapture -%}

{%- assign all_cls = base_cls | append: ' ' | append: size_cls | append: ' ' | append: color_cls | append: ' ' | append: width_cls | append: ' ' | append: disabled_cls | append: ' ' | append: class -%}

{%- if url and disabled == false -%}
  <a href="{{ url }}" class="{{ all_cls }}" style="--hover-bg: {{ hover_bg }}; --hover-text: {{ hover_text }};" {{ attr }}>
    {{ btn_inner }}
  </a>
{%- else -%}
  <button
    type="{{ type | default: 'button' }}"
    class="{{ all_cls }}"
    style="--hover-bg: {{ hover_bg }}; --hover-text: {{ hover_text }};"
    {% if disabled %}disabled aria-disabled="true"{% endif %}
    {{ attr }}
  >
    {{ btn_inner }}
  </button>
{%- endif -%}
