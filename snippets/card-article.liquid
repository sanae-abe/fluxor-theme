{% comment %}
  Renders an article card.

  Accepts:
  - article: {Object} Article object

  Usage:
  {% render 'card-article', article: article %}
{% endcomment %}

<article>
  <a href="{{ article.url }}" class="group block space-y-4">
    {%- if article.image -%}
      <div class="aspect-[4/3] overflow-hidden bg-stone-200">
        <img
          src="{{ article.image | image_url: width: 800 }}"
          alt="{{ article.image.alt | escape | default: article.title }}"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
          width="800"
          height="600"
        >
      </div>
    {%- else -%}
      <div class="aspect-[4/3] bg-stone-200"></div>
    {%- endif -%}

    <div class="space-y-2">
      {%- if article.tags.size > 0 -%}
        <p class="text-xs tracking-widest uppercase text-stone-400">{{ article.tags.first }}</p>
      {%- endif -%}
      <h3 class="text-base font-medium leading-snug group-hover:text-stone-500 transition-colors">{{ article.title }}</h3>
      {%- if article.excerpt != blank -%}
        <p class="text-sm text-stone-500 leading-relaxed line-clamp-2">{{ article.excerpt }}</p>
      {%- endif -%}
      <time class="text-xs text-stone-400" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
        {{ article.published_at | date: '%Y.%m.%d' }}
      </time>
    </div>
  </a>
</article>
