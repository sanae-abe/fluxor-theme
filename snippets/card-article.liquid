{%- comment %}
  Journal 記事カード
  Parameters:
    article: {Object} Article object
{%- endcomment -%}

{%- assign category_tags = article.metafields.custom.category_tags.value -%}

<article class="card-article">
  <a href="{{ article.url }}" class="flex flex-col gap-4">

    {%- comment %} 画像エリア（正方形 + カテゴリバッジオーバーレイ） {%- endcomment -%}
    <div class="relative overflow-hidden bg-white aspect-square">
      {%- if article.image -%}
        <img
          src="{{ article.image | image_url: width: 600, format: 'webp' }}"
          alt="{{ article.image.alt | escape | default: article.title | escape }}"
          class="card-article__img w-full h-full object-cover"
          loading="lazy"
          width="600"
          height="600"
        >
      {%- else -%}
        <div class="w-full h-full bg-muted flex items-center justify-center" aria-hidden="true">
          {%- render 'icon', icon: 'notebook-pen', class: 'w-12 h-12 text-text-subtle', stroke_width: 1 -%}
        </div>
      {%- endif -%}

      {%- if category_tags != blank -%}
        <div class="absolute top-4 left-4 flex flex-col items-start gap-2">
          {%- for tag in category_tags limit: 2 -%}
            {%- render 'badge', label: tag, variant: 'secondary', size: 'sm' -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment %} タイトル + 矢印アイコン {%- endcomment -%}
    <div class="flex items-start gap-4">
      <h3 class="flex-1 text-base font-medium leading-5 text-text">{{ article.title | escape }}</h3>
      {%- render 'icon', icon: 'arrow-right', class: 'card-article__icon w-6 h-6 text-text shrink-0 mt-0.5', stroke_width: 1.5 -%}
    </div>

  </a>
</article>
