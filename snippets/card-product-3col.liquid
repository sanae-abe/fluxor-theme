{% comment %}
  3カラムレイアウト用 製品カード（Best Sellers）
  Parameters:
    product {Object}  Shopify product オブジェクト（必須）
    rank    {Number}  ランク番号（省略時はバッジ非表示）
{% endcomment %}


{%- assign variant = product.selected_or_first_available_variant -%}
{%- assign on_sale = false -%}
{%- if variant.compare_at_price > variant.price -%}
  {%- assign on_sale = true -%}
{%- endif -%}


<article
  class="group bg-stone-50 overflow-hidden [transform:translateZ(0)]"
  x-data="{
    adding: false,
    async addToCart() {
      if (this.adding) return;
      this.adding = true;
      await $store.cart.add({{ variant.id }});
      this.adding = false;
    }
  }"
>

  {%- comment %} 画像エリア {%- endcomment %}
  <div
    class="relative w-full aspect-square cursor-pointer"
    @click="window.location.href='{{ product.url }}'"
  >

    {%- comment %} ランクバッジ {%- endcomment %}
    {%- if rank != blank -%}
      <div class="absolute top-2 md:top-4 left-2 md:left-4 z-10 w-12 h-12 rounded-full bg-amber-900 flex items-center justify-center gap-0.5">
        {%- render 'icon', icon: 'hash', class: 'w-3.5 h-3.5 text-white flex-shrink-0' -%}
        <span class="text-white font-medium text-base leading-tight">{{ rank }}</span>
      </div>
    {%- endif -%}

    {%- comment %} 1枚目 {%- endcomment %}
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
        class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 group-hover:opacity-0"
        loading="lazy"
        width="600"
        height="600"
      >
    {%- else -%}
      <div class="w-full h-full flex items-center justify-center text-stone-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
    {%- endif -%}

    {%- comment %} 2枚目（hover時） {%- endcomment %}
    {%- if product.images.size > 1 -%}
      <img
        src="{{ product.images[1] | image_url: width: 600 }}"
        alt="{{ product.images[1].alt | escape | default: product.title | escape }}"
        class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500 group-hover:opacity-100"
        loading="lazy"
        width="600"
        height="600"
      >
    {%- endif -%}

  </div>

  {%- comment %} 商品情報 + カートボタン {%- endcomment %}
  <div class="p-4">

    {%- comment %} 左：テキスト情報 {%- endcomment %}
    <a href="{{ product.url }}" class="flex flex-col gap-2 min-w-0">
      {%- comment %} ベンダー {%- endcomment %}
      {%- if product.vendor != blank -%}
        <p class="text-sm leading-tight text-stone-500 truncate">{{ product.vendor }}</p>
      {%- endif -%}
      {%- comment %} タイトル {%- endcomment %}
      {%- assign card_title = product.title | replace: '※1', '' | replace: '※2', '' | replace: '※3', '' | replace: '※4', '' | replace: '※5', '' | replace: '※', '' -%}
      <h3 class="text-xl font-medium leading-tight text-stone-900">{{ card_title }}</h3>
    </a>

    <div class="flex justify-between gap-3 mt-4">
      {%- comment %} 評価 {%- endcomment %}
      <div class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}' data-auto-install='false'>{{ product.metafields.judgeme.badge }}</div>
      {%- comment %} 価格 {%- endcomment %}
      <div class="flex items-center gap-2">
        {%- if on_sale -%}
          <s class="text-sm leading-tight text-stone-500">{{ variant.compare_at_price | money }}</s>
        {%- endif -%}
        <span class="text-xl font-semibold leading-tight text-stone-900">{{ variant.price | money }}</span>
      </div>
      {%- comment %} 右：カートに追加ボタン {%- endcomment %}
      {%- if product.available -%}
        <button
          type="button"
          class="btn-card-add flex-shrink-0 bg-stone-900 border-2 border-stone-900 text-white font-medium flex items-center justify-center min-h-[48px] min-w-[144px] px-4 py-2"
          :class="adding ? 'opacity-70 cursor-wait' : ''"
          @click.stop="addToCart()"
          :disabled="adding"
        >
          <span class="font-medium leading-tight" x-show="!adding">カートに追加</span>
          <span class="font-medium leading-tight" x-show="adding" x-cloak>追加中…</span>
        </button>
      {%- else -%}
        <span class="flex-shrink-0 border-2 border-stone-300 text-stone-400 flex items-center justify-center min-h-[48px] min-w-[144px] px-4 py-2 font-medium leading-tight">
          売り切れ
        </span>
      {%- endif -%}

    </div>
  </div>
</article>
