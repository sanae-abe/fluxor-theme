{% comment %}
  3カラムレイアウト用 製品カード（Best Sellers）
  Parameters:
    product {Object}  Shopify product オブジェクト（必須）
    rank    {Number}  ランク番号（省略時はバッジ非表示）
{% endcomment %}

<style>
  .btn-card-add {
    transition: background-color 0.15s ease, color 0.15s ease, opacity 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (any-hover: hover) {
    .btn-card-add:not(:disabled):hover {
      background-color: #ffffff;
      color: #0c0a09;
    }
  }
</style>

{%- assign variant = product.selected_or_first_available_variant -%}
{%- assign on_sale = false -%}
{%- if variant.compare_at_price > variant.price -%}
  {%- assign on_sale = true -%}
{%- endif -%}

{%- assign rating_value = product.metafields.reviews.rating.value -%}
{%- assign rating_count = product.metafields.reviews.rating_count.value -%}

<article
  class="group bg-stone-50 rounded-2xl overflow-hidden [transform:translateZ(0)]"
  x-data="{
    adding: false,
    async addToCart() {
      if (this.adding) return;
      this.adding = true;
      await $store.cart.add({{ variant.id }});
      this.adding = false;
    }
  }"
>

  <!-- 画像エリア -->
  <div
    class="relative w-full aspect-square cursor-pointer"
    @click="window.location.href='{{ product.url }}'"
  >

    <!-- ランクバッジ -->
    {%- if rank != blank -%}
      <div class="absolute top-4 left-4 z-10 w-12 h-12 rounded-full bg-amber-700 flex items-center justify-center gap-0.5">
        {%- render 'icon', icon: 'hash', class: 'w-3.5 h-3.5 text-white flex-shrink-0' -%}
        <span class="text-white font-medium text-base leading-tight">{{ rank }}</span>
      </div>
    {%- endif -%}

    <!-- 1枚目 -->
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
        class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 group-hover:opacity-0"
        loading="lazy"
        width="600"
        height="600"
      >
    {%- else -%}
      <div class="w-full h-full flex items-center justify-center text-stone-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
    {%- endif -%}

    <!-- 2枚目（hover時） -->
    {%- if product.images.size > 1 -%}
      <img
        src="{{ product.images[1] | image_url: width: 600 }}"
        alt="{{ product.images[1].alt | escape | default: product.title | escape }}"
        class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500 group-hover:opacity-100"
        loading="lazy"
        width="600"
        height="600"
      >
    {%- endif -%}

  </div>

  <!-- 商品情報 + カートボタン -->
  <div class="flex items-end justify-between p-4 gap-3">

    <!-- 左：テキスト情報 -->
    <a href="{{ product.url }}" class="flex flex-col gap-2 min-w-0">

      <!-- ベンダー -->
      {%- if product.vendor != blank -%}
        <p class="text-sm leading-tight text-stone-900 opacity-60 truncate">{{ product.vendor }}</p>
      {%- endif -%}

      <!-- タイトル -->
      <h3 class="text-xl font-medium leading-tight text-stone-900">{{ product.title }}</h3>

      <!-- 評価 -->
      {%- if rating_value != blank -%}
        <div class="flex items-center gap-2">
          <div class="flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-stone-900" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M8 1.5 9.796 5.14l4.018.583-2.907 2.833.686 4L8 10.666l-3.593 1.89.686-4L2.186 5.723l4.018-.583z"/>
            </svg>
            <span class="text-sm font-medium leading-5 text-stone-900">{{ rating_value | round: 1 }}</span>
          </div>
          {%- if rating_count != blank -%}
            <span class="text-sm leading-5 text-stone-900 opacity-40">({{ rating_count }}+ レビュー)</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      <!-- 価格 -->
      <div class="flex items-center gap-2">
        {%- if on_sale -%}
          <s class="text-base leading-tight text-stone-900 opacity-50">{{ variant.compare_at_price | money }}</s>
        {%- endif -%}
        <span class="text-xl font-semibold leading-tight text-stone-900">{{ variant.price | money }}</span>
      </div>

    </a>

    <!-- 右：カートに追加ボタン -->
    {%- if product.available -%}
      <button
        type="button"
        class="btn-card-add flex-shrink-0 bg-accent border-2 border-accent text-white flex items-center justify-center min-h-[48px] min-w-[144px] px-4 py-2"
        :class="adding ? 'opacity-70 cursor-wait' : ''"
        @click.stop="addToCart()"
        :disabled="adding"
      >
        <span class="text-sm font-medium leading-tight" x-show="!adding">カートに追加</span>
        <span class="text-sm font-medium leading-tight" x-show="adding" x-cloak>追加中…</span>
      </button>
    {%- else -%}
      <span class="flex-shrink-0 border-2 border-stone-300 text-stone-400 flex items-center justify-center min-h-[48px] min-w-[144px] px-4 py-2 text-sm font-medium leading-tight">
        売り切れ
      </span>
    {%- endif -%}

  </div>
</article>
