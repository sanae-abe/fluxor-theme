{% comment %}
  4カラムレイアウト用 製品カード（Featured Products）
  Parameters:
    product {Object} Shopify product オブジェクト（必須）
{% endcomment %}

<style>
  .btn-card-add {
    transition: background-color 0.15s ease, color 0.15s ease, opacity 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (any-hover: hover) {
    .btn-card-add:not(:disabled):hover {
      background-color: #ffffff;
      color: #0c0a09;
    }
  }
</style>

{%- assign variant = product.selected_or_first_available_variant -%}
{%- assign on_sale = false -%}
{%- if variant.compare_at_price > variant.price -%}
  {%- assign on_sale = true -%}
  {%- assign discount = variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price -%}
{%- endif -%}

{%- assign rating_value = product.metafields.reviews.rating.value -%}
{%- assign rating_count = product.metafields.reviews.rating_count.value -%}

<article
  class="group"
  x-data="{
    adding: false,
    async addToCart() {
      if (this.adding) return;
      this.adding = true;
      await $store.cart.add({{ variant.id }});
      this.adding = false;
    }
  }"
>

  <!-- 画像エリア（クリックで商品ページへ） -->
  <div
    class="relative w-full aspect-square rounded-2xl bg-stone-50 overflow-hidden [transform:translateZ(0)] cursor-pointer"
    @click="window.location.href='{{ product.url }}'"
  >
    <!-- 1枚目 -->
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
        class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 group-hover:opacity-0"
        loading="lazy"
        width="600"
        height="600"
      >
    {%- else -%}
      <div class="w-full h-full flex items-center justify-center text-stone-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
    {%- endif -%}

    <!-- 2枚目（hover時） -->
    {%- if product.images.size > 1 -%}
      <img
        src="{{ product.images[1] | image_url: width: 600 }}"
        alt="{{ product.images[1].alt | escape | default: product.title | escape }}"
        class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500 group-hover:opacity-100"
        loading="lazy"
        width="600"
        height="600"
      >
    {%- endif -%}

    <!-- バッジ -->
    <div class="absolute top-4 left-4 z-10">
      {%- if product.available == false -%}
        {% render 'badge', label: '売り切れ', variant: 'secondary' %}
      {%- elsif on_sale -%}
        {%- assign badge_label = discount | append: '% OFF' -%}
        {% render 'badge', label: badge_label, variant: 'premium' %}
      {%- endif -%}
    </div>

    <!-- カートに追加ボタン（hover時に表示） -->
    {%- if product.available -%}
      <div class="absolute inset-0 flex items-center justify-center z-10 pointer-events-none group-hover:pointer-events-auto opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        <button
          type="button"
          class="btn-card-add bg-stone-900 border-2 border-stone-900 text-white flex items-center justify-center min-h-[48px] min-w-[144px] px-4 py-2"
          :class="adding ? 'opacity-70 cursor-wait' : ''"
          @click.stop="addToCart()"
          :disabled="adding"
        >
          <span class="text-[15px] font-medium leading-[22.5px]" x-show="!adding">カートに追加</span>
          <span class="text-[15px] font-medium leading-[22.5px]" x-show="adding" x-cloak>追加中…</span>
        </button>
      </div>
    {%- endif -%}
  </div>

  <!-- 商品情報（クリックで商品ページへ） -->
  <a href="{{ product.url }}" class="flex flex-col gap-2 mt-4">

    <!-- ベンダー -->
    {%- if product.vendor != blank -%}
      <p class="text-sm leading-tight text-stone-900 opacity-60">{{ product.vendor }}</p>
    {%- endif -%}

    <!-- タイトル -->
    <h3 class="text-lg font-medium leading-tight text-stone-900">{{ product.title }}</h3>

    <!-- 評価 -->
    {%- if rating_value != blank -%}
      <div class="flex items-center gap-2">
        <div class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-stone-900" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M8 1.5 9.796 5.14l4.018.583-2.907 2.833.686 4L8 10.666l-3.593 1.89.686-4L2.186 5.723l4.018-.583z"/>
          </svg>
          <span class="text-sm font-medium leading-5 text-stone-900">{{ rating_value | round: 1 }}</span>
        </div>
        {%- if rating_count != blank -%}
          <span class="text-sm leading-5 text-stone-900 opacity-40">({{ rating_count }}+ レビュー)</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- 価格 -->
    <div class="flex items-center gap-2">
      {%- if on_sale -%}
        <s class="text-sm leading-tight text-stone-900 opacity-50">{{ variant.compare_at_price | money }}</s>
      {%- endif -%}
      <span class="text-lg font-semibold leading-tight text-stone-900">{{ variant.price | money }}</span>
    </div>

  </a>

</article>
