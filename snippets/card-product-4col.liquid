{%- comment %}
  4カラムレイアウト用 製品カード（Featured Products）
  Parameters:
    product {Object} Shopify product オブジェクト（必須）
{%- endcomment -%}

{%- comment %} Shopify ネイティブセール判定 {%- endcomment -%}
{%- assign variant = product.selected_or_first_available_variant -%}
{%- assign on_sale = false -%}
{%- if variant.compare_at_price > variant.price -%}
  {%- assign on_sale = true -%}
  {%- assign discount = variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price -%}
{%- endif -%}

{%- comment %} スケジュールセール対象判定（render スコープ分離のためインライン） {%- endcomment -%}
{%- liquid
  assign sale_eligible = false
  assign sale_discount = 0

  if settings.sale_enabled

    assign _excluded = false
    if settings.sale_exclude_handles != blank
      assign _exc_handles = settings.sale_exclude_handles | split: ','
      for _h in _exc_handles
        assign _h_clean = _h | strip | downcase
        if _h_clean == product.handle
          assign _excluded = true
          break
        endif
      endfor
    endif

    if _excluded == false and settings.sale_exclude_tags != blank
      assign _exc_tags = settings.sale_exclude_tags | split: ','
      for _etag in _exc_tags
        assign _etag_low = _etag | strip | downcase
        for _ptag in product.tags
          assign _ptag_low = _ptag | downcase
          if _ptag_low == _etag_low
            assign _excluded = true
            break
          endif
        endfor
        if _excluded
          break
        endif
      endfor
    endif

    unless _excluded
      if settings.sale_target == 'all'
        assign sale_eligible = true
      elsif settings.sale_target == 'tag' and settings.sale_target_tags != blank
        assign _tgt_tags = settings.sale_target_tags | split: ','
        for _ttag in _tgt_tags
          assign _ttag_low = _ttag | strip | downcase
          for _ptag in product.tags
            assign _ptag_low = _ptag | downcase
            if _ptag_low == _ttag_low
              assign sale_eligible = true
              break
            endif
          endfor
          if sale_eligible
            break
          endif
        endfor
      elsif settings.sale_target == 'collection' and settings.sale_target_collections != blank
        assign _tgt_cols = settings.sale_target_collections | split: ','
        for _col_h in _tgt_cols
          assign _col_low = _col_h | strip | downcase
          for _col in product.collections
            if _col.handle == _col_low
              assign sale_eligible = true
              break
            endif
          endfor
          if sale_eligible
            break
          endif
        endfor
      endif
      if sale_eligible
        assign sale_discount = settings.sale_discount_percent | plus: 0
      endif
    endunless

  endif
-%}

{%- comment %} スケジュールセールバッジの HTML をプリレンダリング {%- endcomment -%}
{%- if sale_eligible and on_sale == false -%}
  {%- capture _sched_badge_html -%}
    {%- assign _sched_badge_label = sale_discount | append: '% OFF' -%}
    {%- render 'badge', label: _sched_badge_label, variant: 'sale' -%}
  {%- endcapture -%}
{%- endif -%}


<article
  class="group"
  x-data="{
    adding: false,
    saleEligible: {{ sale_eligible | json }},
    saleDiscount: {{ sale_discount | default: 0 }},
    isSaleActive() { return this.saleEligible && this.$store.sale.isActive(); },
    async addToCart() {
      if (this.adding) return;
      this.adding = true;
      await $store.cart.add({{ variant.id }});
      this.adding = false;
    }
  }"
>

  {%- comment %} 画像エリア（クリックで商品ページへ） {%- endcomment -%}
  <div
    class="relative w-full aspect-square bg-stone-50 overflow-hidden [transform:translateZ(0)] cursor-pointer"
    @click="window.location.href='{{ product.url }}'"
  >
    {%- comment %} 1枚目 {%- endcomment -%}
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
        class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 group-hover:opacity-0"
        loading="lazy"
        width="600"
        height="600"
      >
    {%- else -%}
      <div class="w-full h-full flex items-center justify-center text-stone-300">
        {%- render 'icon', icon: 'image', class: 'w-12 h-12' -%}
      </div>
    {%- endif -%}

    {%- comment %} 2枚目（hover時） {%- endcomment -%}
    {%- if product.images.size > 1 -%}
      <img
        src="{{ product.images[1] | image_url: width: 600 }}"
        alt="{{ product.images[1].alt | escape | default: product.title | escape }}"
        class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500 group-hover:opacity-100"
        loading="lazy"
        width="600"
        height="600"
      >
    {%- endif -%}

    {%- comment %} バッジ {%- endcomment -%}
    <div class="absolute top-2 md:top-4 left-2 md:left-4 z-10">
      {%- if product.available == false -%}
        {%- render 'badge', label: '売り切れ', variant: 'secondary' -%}
      {%- elsif on_sale -%}
        {%- assign badge_label = discount | append: '% OFF' -%}
        {%- render 'badge', label: badge_label, variant: 'sale' -%}
      {%- elsif sale_eligible -%}
        <template x-if="isSaleActive()">
          <div>{{ _sched_badge_html }}</div>
        </template>
      {%- endif -%}
    </div>

    {%- if product.available -%}
      {%- comment %} カートに追加ボタン（モバイル: 画像右下アイコン） {%- endcomment -%}
      <button
        type="button"
        class="md:hidden absolute bottom-2 right-2 z-10 w-9 h-9 rounded-full bg-stone-900 shadow-md flex items-center justify-center text-white"
        :class="adding ? 'opacity-70 cursor-wait' : ''"
        @click.stop="addToCart()"
        :disabled="adding"
        aria-label="カートに追加"
      >
        {%- render 'icon', icon: 'cart', class: 'w-4 h-4', x_class: "adding ? 'hidden' : ''" -%}
        <svg :class="adding ? '' : 'hidden'" class="w-4 h-4 animate-spin hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
      </button>
      {%- comment %} カートに追加ボタン（デスクトップ: hover時に中央表示） {%- endcomment -%}
      <div class="absolute inset-0 hidden md:flex items-center justify-center z-10 pointer-events-none group-hover:pointer-events-auto opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        <button
          type="button"
          class="btn-card-add bg-stone-900 border-2 border-stone-900 text-white font-medium flex items-center justify-center min-h-[48px] min-w-[144px] px-4 py-2"
          :class="adding ? 'opacity-70 cursor-wait' : ''"
          @click.stop="addToCart()"
          :disabled="adding"
        >
          <span :class="adding ? 'hidden' : ''" class="text-[15px] font-medium leading-[22.5px]">カートに追加</span>
          <span :class="adding ? '' : 'hidden'" class="text-[15px] font-medium leading-[22.5px] hidden">追加中…</span>
        </button>
      </div>
    {%- endif -%}
  </div>

  {%- comment %} 商品情報（クリックで商品ページへ） {%- endcomment -%}
  <a href="{{ product.url }}" class="flex flex-col gap-1 md:gap-2 mt-2 md:mt-4">

    {%- if product.vendor != blank -%}
      <p class="text-sm leading-tight text-stone-500">{{ product.vendor }}</p>
    {%- endif -%}

    {%- assign card_title = product.title | replace: '※1', '' | replace: '※2', '' | replace: '※3', '' | replace: '※4', '' | replace: '※5', '' | replace: '※', '' -%}
    <h3 class="text-sm md:text-lg font-medium leading-tight text-stone-900">{{ card_title }}</h3>

    <div class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}' data-auto-install='false'>{{ product.metafields.judgeme.badge }}</div>

    {%- comment %} 価格 {%- endcomment -%}
    <div class="flex items-center gap-2">
      {%- if on_sale -%}
        <s class="text-sm leading-tight text-stone-500">{{ variant.compare_at_price | money }}</s>
        <span class="text-lg font-semibold leading-tight text-stone-900">{{ variant.price | money }}</span>
      {%- elsif sale_eligible -%}
        {%- assign _disc = 100 | minus: sale_discount -%}
        {%- assign _sale_price_cents = variant.price | times: _disc | divided_by: 100 -%}
        <s class="text-sm leading-tight text-stone-500 hidden"
          :class="{ 'hidden': !isSaleActive() }"
        >{{ variant.price | money }}</s>
        <span class="text-lg font-semibold leading-tight text-stone-900 hidden"
          :class="{ 'hidden': !isSaleActive() }"
        >{{ _sale_price_cents | money }}</span>
        <span class="text-lg font-semibold leading-tight text-stone-900"
          :class="{ 'hidden': isSaleActive() }"
        >{{ variant.price | money }}</span>
      {%- else -%}
        <span class="text-lg font-semibold leading-tight text-stone-900">{{ variant.price | money }}</span>
      {%- endif -%}
    </div>

  </a>

</article>
