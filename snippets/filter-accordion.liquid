{%- comment %}
  フィルターアコーディオン（排他開閉型）

  同一グループ内で1つのみ開く。開いたアコーディオンが window に
  カスタムイベントを発火し、他のアコーディオンが自身を閉じる。

  Parameters:
    title:     {String} 見出しテキスト
    content:   {String} コンテンツ HTML（capture 済み文字列）
    show_expr: {String} Alpine.js x-show 式（省略時は常に表示）
{%- endcomment -%}

{%- assign _aid = title | handleize -%}
{%- assign _open = open_default | default: false -%}

<div
  x-data="{ open: {{ _open | json }}, _aid: '{{ _aid }}' }"
  @filter-accordion-open.window="if ($event.detail.id !== _aid) open = false"
  {%- if show_expr != blank %} x-show="{{ show_expr }}"{% endif %}
  class="bg-white"
>
  <button
    type="button"
    @click="open = !open; if (open) $dispatch('filter-accordion-open', { id: _aid })"
    class="flex items-center justify-between w-full text-sm font-medium p-4"
    :aria-expanded="open"
  >
    <span class="text-stone-900">{{ title }}</span>
    {%- capture _fac -%}open ? 'rotate-180' : ''{%- endcapture -%}
    {%- render 'icon', icon: 'chevron-down', class: 'w-4 h-4 text-stone-900 shrink-0 transition-transform duration-200', x_class: _fac, stroke_width: 1.5 -%}
  </button>
  <div
    class="grid filter-accordion__body"
    :style="{ 'grid-template-rows': open ? '1fr' : '0fr' }"
    role="region"
    :aria-hidden="!open"
  >
    <div class="overflow-hidden">
      <div
        class="px-4 pb-4 flex flex-col gap-3 motion-safe:transition motion-safe:duration-300"
        :class="open ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-2'"
      >
        {{ content }}
      </div>
    </div>
  </div>
</div>
