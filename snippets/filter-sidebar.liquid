{%- comment %} 引数: filters, sort_by {%- endcomment -%}
<div class="space-y-6">
  {%- for filter in filters -%}
    {%- comment %} アクティブフィルターがあれば初期展開 {%- endcomment -%}
    {%- assign _has_active = false -%}
    {%- if filter.active_values.size > 0 -%}
      {%- assign _has_active = true -%}
    {%- elsif filter.type == 'price_range' -%}
      {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
        {%- assign _has_active = true -%}
      {%- endif -%}
    {%- endif -%}
    {%- if forloop.first or _has_active -%}
      {%- assign _open_default = true -%}
    {%- else -%}
      {%- assign _open_default = false -%}
    {%- endif -%}

    {%- capture _filter_content -%}
      {%- if filter.type == 'price_range' -%}
        {%- liquid
          assign _range_min = filter.range_min | money_without_currency | replace: ',', '' | split: '.' | first | plus: 0
          assign _range_max = filter.range_max | money_without_currency | replace: ',', '' | split: '.' | first | plus: 0
          if filter.min_value.value != blank
            assign _sel_min = filter.min_value.value | money_without_currency | replace: ',', '' | split: '.' | first | plus: 0
          else
            assign _sel_min = _range_min
          endif
          if filter.max_value.value != blank
            assign _sel_max = filter.max_value.value | money_without_currency | replace: ',', '' | split: '.' | first | plus: 0
          else
            assign _sel_max = _range_max
          endif
        -%}
        <form
          action="{{ collection.url }}"
          method="get"
          class="space-y-4"
          x-data="{
            rangeMin: {{ _range_min }},
            rangeMax: {{ _range_max }},
            low:  {{ _sel_min }},
            high: {{ _sel_max }},
            get pctLow()  { let d = this.rangeMax - this.rangeMin; return d ? (this.low  - this.rangeMin) / d * 100 : 0; },
            get pctHigh() { let d = this.rangeMax - this.rangeMin; return d ? (this.high - this.rangeMin) / d * 100 : 100; }
          }"
        >
          {%- comment %} 他のアクティブフィルターを保持 {%- endcomment -%}
          {%- for f in filters -%}
            {%- if f.type != 'price_range' -%}
              {%- for v in f.active_values -%}
                <input type="hidden" name="{{ v.param_name }}" value="{{ v.value }}">
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if sort_by != blank -%}
            <input type="hidden" name="sort_by" value="{{ sort_by }}">
          {%- endif -%}
          {%- comment %} フォーム送信用 hidden inputs（全範囲時は送信しない） {%- endcomment -%}
          <input type="hidden" name="{{ filter.min_value.param_name }}" :value="low"  :disabled="low  <= rangeMin">
          <input type="hidden" name="{{ filter.max_value.param_name }}" :value="high" :disabled="high >= rangeMax">

          {%- comment %} デュアルハンドル価格スライダー {%- endcomment -%}
          <div class="price-range-slider" role="group" aria-label="価格範囲">
            <div class="price-range-slider__track" aria-hidden="true">
              <div
                class="price-range-slider__fill"
                :style="`left: ${pctLow}%; right: ${100 - pctHigh}%`"
              ></div>
            </div>
            <input
              type="range"
              :min="rangeMin" :max="rangeMax" step="1"
              x-model.number="low"
              @input="if (low > high) low = high"
              class="price-range-slider__input"
              :class="{ 'price-range-slider__input--top': low >= rangeMax }"
              aria-label="最低価格"
            >
            <input
              type="range"
              :min="rangeMin" :max="rangeMax" step="1"
              x-model.number="high"
              @input="if (high < low) high = low"
              class="price-range-slider__input price-range-slider__input--top"
              :class="{ 'price-range-slider__input--top': high > rangeMin }"
              aria-label="最高価格"
            >
          </div>

          {%- comment %} 現在の価格範囲ラベル {%- endcomment -%}
          <div class="flex items-center justify-between text-xs text-stone-500 -mt-1">
            <span>¥<span x-text="low.toLocaleString('ja-JP')"></span></span>
            <span>¥<span x-text="high.toLocaleString('ja-JP')"></span></span>
          </div>
          {%- render 'button', label: '適用', type: 'submit', variant: 'outline', size: 'sm', full_width: true -%}
        </form>
      {%- else -%}
        <ul class="space-y-2">
          {%- for value in filter.values -%}
            {%- if value.active -%}
              {%- assign _url = value.url_to_remove -%}
            {%- else -%}
              {%- assign _url = value.url_to_add -%}
            {%- endif -%}
            <li>
              {%- render 'filter-checkbox',
                url: _url,
                active: value.active,
                label: value.label
              -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    {%- endcapture -%}

    {%- render 'filter-accordion',
      title: filter.label,
      content: _filter_content,
      open_default: _open_default
    -%}
  {%- endfor -%}
</div>
