{%- comment %} 引数: filters, sort_by {%- endcomment %}
<div class="space-y-6">
  {%- for filter in filters -%}
    <div x-data="{ open: true }">
      <button
        type="button"
        @click="open = !open"
        class="flex items-center justify-between w-full text-sm font-medium pb-2.5 border-b border-stone-200"
      >
        {{ filter.label }}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 transition-transform duration-200"
          :class="open ? '' : '-rotate-90'"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <div x-show="open" class="mt-3">
        {%- if filter.type == 'price_range' -%}
          <form action="{{ collection.url }}" method="get" class="space-y-3">
            {%- comment %} 他のアクティブフィルターを保持 {%- endcomment %}
            {%- for f in filters -%}
              {%- if f.type != 'price_range' -%}
                {%- for v in f.active_values -%}
                  <input type="hidden" name="{{ v.param_name }}" value="{{ v.value }}">
                {%- endfor -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if sort_by != blank -%}
              <input type="hidden" name="sort_by" value="{{ sort_by }}">
            {%- endif -%}
            <div class="flex items-center gap-1.5">
              <input
                type="number"
                name="{{ filter.min_value.param_name }}"
                {% if filter.min_value.value != blank %}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                placeholder="{{ filter.range_min | money_without_currency | replace: ',', '' }}"
                min="0"
                class="w-full border border-stone-200 rounded px-2.5 py-1.5 text-sm focus:outline-none focus:border-stone-400"
              >
              <span class="text-stone-400 text-xs flex-shrink-0">〜</span>
              <input
                type="number"
                name="{{ filter.max_value.param_name }}"
                {% if filter.max_value.value != blank %}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                min="0"
                class="w-full border border-stone-200 rounded px-2.5 py-1.5 text-sm focus:outline-none focus:border-stone-400"
              >
            </div>
            <button
              type="submit"
              class="w-full border border-stone-900 text-stone-900 text-xs py-2 hover:bg-stone-900 hover:text-white transition-colors"
            >
              適用
            </button>
          </form>
        {%- else -%}
          <ul class="space-y-2">
            {%- for value in filter.values -%}
              <li>
                <a
                  href="{%- if value.active -%}{{ value.url_to_remove }}{%- else -%}{{ value.url_to_add }}{%- endif -%}"
                  class="flex items-center gap-2.5 group"
                  {% if value.count == 0 and value.active == false %}tabindex="-1" aria-disabled="true"{% endif %}
                >
                  <span class="w-4 h-4 border rounded flex-shrink-0 flex items-center justify-center transition-colors
                    {%- if value.active %} bg-stone-900 border-stone-900
                    {%- elsif value.count == 0 %} border-stone-200
                    {%- else %} border-stone-300 group-hover:border-stone-900
                    {%- endif -%}"
                  >
                    {%- if value.active -%}
                      <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                    {%- endif -%}
                  </span>
                  <span class="text-sm leading-tight{%- if value.count == 0 and value.active == false %} text-stone-300{%- endif -%}">
                    {{ value.label }}
                  </span>
                  <span class="text-xs text-stone-400 ml-auto">{{ value.count }}</span>
                </a>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
</div>
