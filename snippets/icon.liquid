{% comment %}
  Icon snippet — Lucide アイコン集
  Parameters:
    icon  {String}  アイコン名（必須）
    class {String}  SVGに追加するCSSクラス

  利用可能なアイコン:
    arrow-left, arrow-right, hash, search, user, star, cart,
    trending-up, flask-conical, gem, notebook-pen, x, instagram, tiktok,
    minus, plus
{% endcomment %}

<svg
  xmlns="http://www.w3.org/2000/svg"
  class="{{ class }}"
  fill="none"
  viewBox="0 0 24 24"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {%- case icon -%}
    {%- when 'arrow-left' -%}
      <path d="m12 19-7-7 7-7"/>
      <path d="M19 12H5"/>
    {%- when 'arrow-right' -%}
      <path d="M5 12h14"/>
      <path d="m12 5 7 7-7 7"/>
    {%- when 'hash' -%}
      <line x1="4" x2="20" y1="9" y2="9"/>
      <line x1="4" x2="20" y1="15" y2="15"/>
      <line x1="10" x2="8" y1="3" y2="21"/>
      <line x1="16" x2="14" y1="3" y2="21"/>
    {%- when 'search' -%}
      <circle cx="11" cy="11" r="8"/>
      <path d="m21 21-4.3-4.3"/>
    {%- when 'user' -%}
      <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
      <circle cx="12" cy="7" r="4"/>
    {%- when 'star' -%}
      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
    {%- when 'cart' -%}
      <circle cx="8" cy="21" r="1"/>
      <circle cx="19" cy="21" r="1"/>
      <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
    {%- when 'trending-up' -%}
      <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
      <polyline points="16 7 22 7 22 13"/>
    {%- when 'flask-conical' -%}
      <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/>
      <path d="M8.5 2h7"/>
      <path d="M7 16h10"/>
    {%- when 'gem' -%}
      <path d="M6 3h12l4 6-10 13L2 9Z"/>
      <path d="M11 3 8 9l4 13 4-13-3-6"/>
      <path d="M2 9h20"/>
    {%- when 'notebook-pen' -%}
      <path d="M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7.4"/>
      <path d="M2 6h4"/>
      <path d="M2 10h4"/>
      <path d="M2 14h4"/>
      <path d="M2 18h4"/>
      <path d="M21.378 5.626a1 1 0 1 0-3.004-3.004l-5.01 5.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z"/>
    {%- when 'x' -%}
      <path d="M18 6 6 18"/>
      <path d="m6 6 12 12"/>
    {%- when 'instagram' -%}
      <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
      <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
    {%- when 'tiktok' -%}
      <path d="M21 7.917v4.034A9.948 9.948 0 0 1 16 10v4.5a6.5 6.5 0 1 1-5-6.327V12.5a2.5 2.5 0 1 0 2 2.45V2h3.917A5.006 5.006 0 0 0 21 7.917z"/>
    {%- when 'minus' -%}
      <path d="M5 12h14"/>
    {%- when 'plus' -%}
      <path d="M5 12h14"/>
      <path d="M12 5v14"/>
    {%- when 'van' -%}
      <path d="M13 6V11C13 11.2652 13.1054 11.5196 13.2929 11.7071C13.4804 11.8946 13.7348 12 14 12H20.102C20.2345 12 20.3657 12.0264 20.4879 12.0775C20.6101 12.1287 20.721 12.2036 20.814 12.298L21.712 13.208C21.8965 13.3951 22 13.6473 22 13.91V17C22 17.2652 21.8946 17.5196 21.7071 17.7071C21.5196 17.8946 21.2652 18 21 18H18M18 18C18 19.1046 17.1046 20 16 20C14.8954 20 14 19.1046 14 18M18 18C18 16.8954 17.1046 16 16 16C14.8954 16 14 16.8954 14 18M5 18H3C2.73478 18 2.48043 17.8946 2.29289 17.7071C2.10536 17.5196 2 17.2652 2 17V8C2 7.46957 2.21071 6.96086 2.58579 6.58579C2.96086 6.21071 3.46957 6 4 6H16C17.1 6 18.1 6.8 18.4 7.8L19.576 12M5 18C5 19.1046 5.89543 20 7 20C8.10457 20 9 19.1046 9 18M5 18C5 16.8954 5.89543 16 7 16C8.10457 16 9 16.8954 9 18M9 18H14"/>
  {%- endcase -%}
</svg>
