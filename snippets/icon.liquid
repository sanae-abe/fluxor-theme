{% comment %}
  Icon snippet — Lucide アイコン集
  Parameters:
    icon         {String}  アイコン名（必須）
    class        {String}  SVGに追加するCSSクラス
    x_class      {String}  Alpine.js :class バインディング（省略時: なし）
    stroke       {String}  stroke色（省略時: currentColor）
    stroke_width {Number}  stroke太さ（省略時: 1.5）
    width        {Number}  width属性px（省略時: CSS任せ）
    height       {Number}  height属性px（省略時: CSS任せ）

  利用可能なアイコン:
    arrow-left, arrow-right, hash, search, user, star, cart,
    trending-up, flask-conical, gem, notebook-pen, x, instagram, tiktok,
    minus, plus, info, check, chevron-down,
    layout-grid, droplet, sparkle, citrus, sun, leaf,
    waves, shield-check, arrow-big-up-dash, smile, rose
{% endcomment %}
{%- assign _stroke = stroke | default: 'currentColor' -%}
{%- assign _stroke_width = stroke_width | default: 1.5 -%}
<svg
  xmlns="http://www.w3.org/2000/svg"
  {%- if class != blank %} class="{{ class }}"{% endif %}
  {%- if x_class != blank %} :class="{{ x_class }}"{% endif %}
  fill="none"
  viewBox="0 0 24 24"
  stroke="{{ _stroke }}"
  stroke-width="{{ _stroke_width }}"
  stroke-linecap="round"
  stroke-linejoin="round"
  {%- if width %} width="{{ width }}"{% endif %}
  {%- if height %} height="{{ height }}"{% endif %}
  aria-hidden="true"
>
  {%- case icon -%}
    {%- when 'arrow-left' -%}
      <path d="m12 19-7-7 7-7"/>
      <path d="M19 12H5"/>
    {%- when 'arrow-right' -%}
      <path d="M5 12h14"/>
      <path d="m12 5 7 7-7 7"/>
    {%- when 'hash' -%}
      <line x1="4" x2="20" y1="9" y2="9"/>
      <line x1="4" x2="20" y1="15" y2="15"/>
      <line x1="10" x2="8" y1="3" y2="21"/>
      <line x1="16" x2="14" y1="3" y2="21"/>
    {%- when 'search' -%}
      <circle cx="11" cy="11" r="8"/>
      <path d="m21 21-4.3-4.3"/>
    {%- when 'user' -%}
      <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
      <circle cx="12" cy="7" r="4"/>
    {%- when 'star' -%}
      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
    {%- when 'cart' -%}
      <circle cx="8" cy="21" r="1"/>
      <circle cx="19" cy="21" r="1"/>
      <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
    {%- when 'trending-up' -%}
      <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
      <polyline points="16 7 22 7 22 13"/>
    {%- when 'flask-conical' -%}
      <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/>
      <path d="M8.5 2h7"/>
      <path d="M7 16h10"/>
    {%- when 'gem' -%}
      <path d="M6 3h12l4 6-10 13L2 9Z"/>
      <path d="M11 3 8 9l4 13 4-13-3-6"/>
      <path d="M2 9h20"/>
    {%- when 'notebook-pen' -%}
      <path d="M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7.4"/>
      <path d="M2 6h4"/>
      <path d="M2 10h4"/>
      <path d="M2 14h4"/>
      <path d="M2 18h4"/>
      <path d="M21.378 5.626a1 1 0 1 0-3.004-3.004l-5.01 5.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z"/>
    {%- when 'x' -%}
      <path d="M18 6 6 18"/>
      <path d="m6 6 12 12"/>
    {%- when 'instagram' -%}
      <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
      <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
    {%- when 'tiktok' -%}
      <path d="M21 7.917v4.034A9.948 9.948 0 0 1 16 10v4.5a6.5 6.5 0 1 1-5-6.327V12.5a2.5 2.5 0 1 0 2 2.45V2h3.917A5.006 5.006 0 0 0 21 7.917z"/>
    {%- when 'check' -%}
      <path d="M20 6 9 17 4 12"/>
    {%- when 'chevron-down' -%}
      <path d="M19 9l-7 7-7-7"/>
    {%- when 'minus' -%}
      <path d="M5 12h14"/>
    {%- when 'plus' -%}
      <path d="M5 12h14"/>
      <path d="M12 5v14"/>
    {%- when 'info' -%}
      <circle cx="12" cy="12" r="10"/>
      <path d="M12 16v-4"/>
      <path d="M12 8h.01"/>
    {%- when 'layout-grid' -%}
      <rect width="7" height="7" x="3" y="3" rx="1"/>
      <rect width="7" height="7" x="14" y="3" rx="1"/>
      <rect width="7" height="7" x="14" y="14" rx="1"/>
      <rect width="7" height="7" x="3" y="14" rx="1"/>
    {%- when 'droplet' -%}
