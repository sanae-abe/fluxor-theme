{% comment %}
  Icon snippet — Lucide アイコン集
  Parameters:
    icon         {String}  アイコン名（必須）
    class        {String}  SVGに追加するCSSクラス
    x_class      {String}  Alpine.js :class バインディング（省略時: なし）
    stroke       {String}  stroke色（省略時: currentColor）
    stroke_width {Number}  stroke太さ（省略時: 1.5）
    fill         {String}  fill色（省略時: none）
    width        {Number}  width属性px（省略時: CSS任せ）
    height       {Number}  height属性px（省略時: CSS任せ）

  利用可能なアイコン（アルファベット順）:
    arrow-big-up-dash, arrow-left, arrow-right,
    book-marked, cart, check, chevron-down, chevron-left, chevron-right,
    circle-chevron-left, circle-chevron-right, citrus,
    droplet, flask-conical, gem, hash, image, info, instagram,
    layers, layout-grid, leaf, list-filter,
    message-square, minus, notebook-pen, pipette, plus, refresh-cw, rose,
    search, shield, smile, sparkle, sparkles, star, sun,
    tiktok, trending-up, triangle-alert,
    user, van, waves, x, x-twitter, grid-triangle, peel-off
{% endcomment %}
{%- assign _stroke = stroke | default: 'currentColor' -%}
{%- assign _stroke_width = stroke_width | default: 1.5 -%}
{%- assign _fill = fill | default: 'none' -%}
<svg
  xmlns="http://www.w3.org/2000/svg"
  {%- if class != blank %} class="{{ class }}"{% endif %}
  {%- if x_class != blank %} :class="{{ x_class }}"{% endif %}
  fill="{{ _fill }}"
  viewBox="0 0 24 24"
  stroke="{{ _stroke }}"
  stroke-width="{{ _stroke_width }}"
  stroke-linecap="round"
  stroke-linejoin="round"
  {%- if width %} width="{{ width }}"{% endif %}
  {%- if height %} height="{{ height }}"{% endif %}
  aria-hidden="true"
>
  {%- case icon -%}
    {%- when 'book-marked' -%}
      <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
