{%- comment -%}
  「すべて見る」リンクコンポーネント
  Parameters:
    url   {String}  リンク先URL（必須）
    label {String}  リンクテキスト（省略時: "すべて見る"）
    class {String}  追加CSSクラス（省略可）
{%- endcomment -%}

{%- assign view_all_label = label | default: 'すべて見る' -%}

<a
  href="{{ url }}"
  class="link-view-all flex-shrink-0 flex items-center gap-2 text-base leading-tight text-stone-900 whitespace-nowrap {{ class }}"
>
  <span>{{ view_all_label }}</span>
  {%- render 'icon', icon: 'arrow-right', class: 'link-view-all__icon w-6 h-6 flex-shrink-0 stroke-2' -%}
</a>
