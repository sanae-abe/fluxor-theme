{%- comment %}
  モバイルフィルタードロワー（パネル + オーバーレイ）

  Parameters:
    open_expr  : {String} x-show に渡す Alpine 式（例: "filtersOpen"）
    close_expr : {String} 閉じる操作の Alpine 式（例: "filtersOpen = false"）
    content    : {String} ドロワー本体コンテンツ HTML（capture 済み文字列）
    clear_url  : {String} すべてクリアリンクの URL（省略時はクリアリンクを非表示）
{%- endcomment -%}
{%- comment %} ドロワーパネル {%- endcomment -%}
<div
  x-show="{{ open_expr }}"
  x-cloak
  x-trap="{{ open_expr }}"
  x-transition:enter="transition-transform duration-300 ease-out"
  x-transition:enter-start="-translate-x-full"
  x-transition:enter-end="translate-x-0"
  x-transition:leave="transition-transform duration-200 ease-in"
  x-transition:leave-start="translate-x-0"
  x-transition:leave-end="-translate-x-full"
  class="fixed inset-y-0 left-0 z-50 w-80 max-w-full bg-stone-50 shadow-2xl flex flex-col md:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="絞り込み"
  @keydown.escape.window="{{ close_expr }}"
>
  <div class="flex items-center justify-between px-6 py-5 border-b border-stone-200">
    <h2 class="text-sm tracking-widest uppercase">絞り込み</h2>
    <button
      type="button"
      @click="{{ close_expr }}"
      class="text-stone-500 hover:text-stone-900 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 rounded-sm"
      aria-label="閉じる"
    >
      {%- render 'icon', icon: 'x', class: 'w-5 h-5' -%}
    </button>
  </div>
  <div class="flex-1 overflow-y-auto p-5 space-y-6">
    {{ content }}
  </div>
  <div class="border-t border-stone-200 px-5 py-4 flex items-center gap-3 flex-shrink-0">
    {%- if clear_url != blank -%}
      <a
        href="{{ clear_url }}"
        class="flex-1 text-center text-sm text-stone-500 underline py-2"
        @click="{{ close_expr }}"
      >
        すべてクリア
      </a>
    {%- endif -%}
    <button
      type="button"
      @click="{{ close_expr }}"
      class="flex-1 bg-stone-900 text-stone-50 text-sm py-2.5 px-4 transition-opacity hover:opacity-80"
    >
      閉じる
    </button>
  </div>
</div>
{%- comment %} オーバーレイ {%- endcomment -%}
<div
  x-show="{{ open_expr }}"
  x-cloak
  x-transition:enter="transition-opacity duration-300"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition-opacity duration-200"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  class="fixed inset-0 z-40 bg-stone-950/40 backdrop-blur-sm md:hidden"
  @click="{{ close_expr }}"
  aria-hidden="true"
></div>
