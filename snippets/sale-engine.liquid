{% comment %}
  セールエンジン: 商品がスケジュールセールの対象かどうかをサーバーサイドで判定する。
  スケジュールの時間チェックはクライアントサイド（Alpine.js $store.sale.isActive()）で行う。

  Parameters:
    product {Object} Shopify product オブジェクト（必須）

  Output variables:
    sale_eligible {Boolean} - この商品がセール対象条件を満たすか（時間チェック除く）
    sale_discount {Number}  - ディスカウント率（整数 %）
{% endcomment %}

{%- liquid
  assign sale_eligible = false
  assign sale_discount = 0

  if settings.sale_enabled

    # ハンドルによる除外チェック
    assign _excluded = false
    if settings.sale_exclude_handles != blank
      assign _exclude_handle_list = settings.sale_exclude_handles | split: ','
      for _handle in _exclude_handle_list
        assign _handle_normalized = _handle | strip | downcase
        if _handle_normalized == product.handle
          assign _excluded = true
          break
        endif
      endfor
    endif

    # タグによる除外チェック
    unless _excluded or settings.sale_exclude_tags == blank
      assign _exclude_tag_list = settings.sale_exclude_tags | split: ','
      for _exclude_tag in _exclude_tag_list
        assign _exclude_tag_normalized = _exclude_tag | strip | downcase
        for _product_tag in product.tags
          assign _product_tag_normalized = _product_tag | downcase
          if _product_tag_normalized == _exclude_tag_normalized
            assign _excluded = true
            break
          endif
        endfor
        if _excluded
          break
        endif
      endfor
    endunless

    # 対象判定
    unless _excluded
      case settings.sale_target
      when 'all'
        assign sale_eligible = true

      when 'tag'
        if settings.sale_target_tags != blank
          assign _target_tag_list = settings.sale_target_tags | split: ','
          for _target_tag in _target_tag_list
            assign _target_tag_normalized = _target_tag | strip | downcase
            for _product_tag in product.tags
              assign _product_tag_normalized = _product_tag | downcase
              if _product_tag_normalized == _target_tag_normalized
                assign sale_eligible = true
                break
              endif
            endfor
            if sale_eligible
              break
            endif
          endfor
        endif

      when 'collection'
        if settings.sale_target_collections != blank
          assign _target_col_list = settings.sale_target_collections | split: ','
          for _target_col_handle in _target_col_list
            assign _target_col_normalized = _target_col_handle | strip | downcase
            for _product_col in product.collections
              if _product_col.handle == _target_col_normalized
                assign sale_eligible = true
                break
              endif
            endfor
            if sale_eligible
              break
            endif
          endfor
        endif
      endcase

      if sale_eligible
        assign sale_discount = settings.sale_discount_percent | plus: 0
      endif
    endunless

  endif
-%}
