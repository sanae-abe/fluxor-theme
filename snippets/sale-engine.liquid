{%- comment %}
  セールエンジン: 商品がスケジュールセールの対象かどうかをサーバーサイドで判定する。
  スケジュールの時間チェックはクライアントサイド（Alpine.js $store.sale.isActive()）で行う。

  Parameters:
    product {Object} Shopify product オブジェクト（必須）

  Output variables:
    sale_eligible {Boolean} - この商品がセール対象条件を満たすか（時間チェック除く）
    sale_discount {Number}  - ディスカウント率（整数 %）
{%- endcomment %}

{%- liquid
  assign sale_eligible = false
  assign sale_discount = 0

  if settings.sale_enabled

    # ハンドルによる除外チェック
    assign _excluded = false
    if settings.sale_exclude_handles != blank
      assign _exclude_handles = settings.sale_exclude_handles | split: ','
      for _h in _exclude_handles
        assign _h_norm = _h | strip | downcase
        if _h_norm == product.handle
          assign _excluded = true
          break
        endif
      endfor
    endif

    # タグによる除外チェック
    if _excluded == false and settings.sale_exclude_tags != blank
      assign _exclude_tags = settings.sale_exclude_tags | split: ','
      for _ex_tag in _exclude_tags
        assign _ex_tag_norm = _ex_tag | strip | downcase
        for _p_tag in product.tags
          assign _p_tag_norm = _p_tag | downcase
          if _p_tag_norm == _ex_tag_norm
            assign _excluded = true
            break
          endif
        endfor
        if _excluded
          break
        endif
      endfor
    endif

    # 対象判定
    if _excluded == false
      case settings.sale_target
      when 'all'
        assign sale_eligible = true

      when 'tag'
        if settings.sale_target_tags != blank
          assign _target_tags = settings.sale_target_tags | split: ','
          for _t_tag in _target_tags
            assign _t_tag_norm = _t_tag | strip | downcase
            for _p_tag in product.tags
              assign _p_tag_norm = _p_tag | downcase
              if _p_tag_norm == _t_tag_norm
                assign sale_eligible = true
                break
              endif
            endfor
            if sale_eligible
              break
            endif
          endfor
        endif

      when 'collection'
        if settings.sale_target_collections != blank
          assign _target_cols = settings.sale_target_collections | split: ','
          for _t_col in _target_cols
            assign _t_col_norm = _t_col | strip | downcase
            for _p_col in product.collections
              if _p_col.handle == _t_col_norm
                assign sale_eligible = true
                break
              endif
            endfor
            if sale_eligible
              break
            endif
          endfor
        endif
      endcase

      if sale_eligible
        assign sale_discount = settings.sale_discount_percent | plus: 0
      endif
    endif

  endif
-%}
