{% comment %}
  セクションヘッダー
  Parameters:
    heading    {String} 見出しテキスト（必須）
    subheading {String} サブ見出しテキスト（省略可）
    link_url   {String} 「すべて見る」リンクURL（省略可）
    link_label {String} 「すべて見る」リンクラベル（省略可）
    align      {String} 'left'（左寄せ＋リンク） or 'center'（中央寄せ、デフォルト）
{% endcomment %}

{%- if heading != blank or subheading != blank -%}
  {%- if align == 'left' -%}

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div class="flex flex-col gap-4">
        {%- if heading != blank -%}
          <h2 class="text-2xl md:text-4xl font-semibold leading-tight text-stone-900 palt tracking-wider">{{ heading }}</h2>
        {%- endif -%}
        {%- if subheading != blank -%}
          <p class="text-base leading-tight text-stone-500">{{ subheading }}</p>
        {%- endif -%}
      </div>
      {%- if link_label != blank and link_url != blank -%}
        {%- render 'link-view-all', url: link_url, label: link_label, class: 'hidden md:flex' -%}
      {%- endif -%}
    </div>

  {%- else -%}

    <div class="flex flex-col gap-4 md:items-center md:text-center">
      {%- if heading != blank -%}
        <h2 class="text-2xl md:text-4xl font-semibold leading-tight text-stone-900 palt tracking-wider">{{ heading }}</h2>
      {%- endif -%}
      {%- if subheading != blank -%}
        <p class="text-base leading-tight text-stone-500">{{ subheading }}</p>
      {%- endif -%}
    </div>

  {%- endif -%}
{%- endif -%}
